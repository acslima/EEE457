Notebook[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Import", " ", "the", " ", "required", " ", "packages"}], "*)"}], 
  "\n", 
  RowBox[{
   RowBox[{
   "Needs", "[", 
    "\"\<DifferentialEquations`InterpolatingFunctionAnatomy`\>\"", "]"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Define", " ", "the", " ", "vector", " ", "fitting", " ", "function"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"VectorFitting", "[", 
     RowBox[{"data_", ",", 
      RowBox[{"poles_", ":", "10"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "z", ",", "w", ",", "p", ",", "x", ",", "y", ",", "f", ",", "g", ",", 
        "rhs", ",", "coeffs"}], "}"}], ",", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"Get", " ", "the", " ", "data", " ", "points"}], "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"x", "=", 
        RowBox[{"Re", "[", "data", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"y", "=", 
        RowBox[{"Im", "[", "data", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Construct", " ", "the", " ", "Vandermonde", " ", "matrix"}], 
        "*)"}], 
       RowBox[{"z", "=", 
        RowBox[{"Exp", "[", 
         RowBox[{"I", " ", "x"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"w", "=", 
        RowBox[{"Flatten", "[", 
         RowBox[{"Outer", "[", 
          RowBox[{"Times", ",", "z", ",", 
           RowBox[{"Range", "[", "poles", "]"}]}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"p", "=", 
        RowBox[{"LeastSquares", "[", 
         RowBox[{
          RowBox[{"w", ".", 
           RowBox[{"ConjugateTranspose", "[", "w", "]"}]}], ",", 
          RowBox[{"w", ".", 
           RowBox[{"ConjugateTranspose", "[", "y", "]"}]}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Construct", " ", "the", " ", "vector", " ", "fitting", " ", 
         "function"}], "*)"}], 
       RowBox[{"f", "=", 
        RowBox[{"Sum", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"p", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "/", 
           RowBox[{"(", 
            RowBox[{"z", "-", 
             RowBox[{"Exp", "[", 
              RowBox[{"I", " ", 
               RowBox[{"x", "[", 
                RowBox[{"[", "i", "]"}], "]"}]}], "]"}]}], ")"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", 
            RowBox[{"Length", "[", "x", "]"}]}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Calculate", " ", "the", " ", "residues", " ", "and", " ", "poles"}], 
        "*)"}], "\[IndentingNewLine]", 
       RowBox[{"g", "=", 
        RowBox[{"Expand", "[", 
         RowBox[{"Denominator", "[", "f", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"rhs", "=", 
        RowBox[{"CoefficientList", "[", 
         RowBox[{"g", ",", "z"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"coeffs", "=", 
        RowBox[{"CoefficientList", "[", 
         RowBox[{
          RowBox[{"Numerator", "[", "f", "]"}], ",", "z"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"poles", "=", 
        RowBox[{"z", "/.", " ", 
         RowBox[{"Solve", "[", 
          RowBox[{
           RowBox[{"g", "==", "0"}], ",", "z"}], "]"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
         RowBox[{"Return", " ", "the", " ", "poles"}], ",", "residues", ",", 
         RowBox[{"and", " ", "the", " ", "fitted", " ", "function"}]}], 
        "*)"}], 
       RowBox[{"{", 
        RowBox[{"poles", ",", "rhs", ",", "coeffs", ",", "f"}], "}"}]}]}], 
     "]"}]}], "\[IndentingNewLine]"}]}]], "Input",
 CellChangeTimes->{{3.897799762126326*^9, 3.8977997621345882`*^9}, 
   3.89779982110188*^9, 3.897799861672204*^9, {3.897799930950001*^9, 
   3.897799964947201*^9}},ExpressionUUID->"ba8f936f-aed2-47f6-ae18-\
13fda1bd8150"],

