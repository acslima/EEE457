 "\[Bullet] The angles should be input using positive values (e.g., ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"-", "120"}], "\[Rule]", "240"}], TraditionalForm]], "InlineMath"],
 ")."
}], "ManipulateCaption",
