Cell[BoxData[
 TagBox[
  StyleBox[
   DynamicModuleBox[{$CellContext`case$$ = 
    "Poynting", $CellContext`cos\[Theta]$$ = 0.8, $CellContext`dia$$ = 
    100, $CellContext`gap$$ = 500, $CellContext`Iim$$ = 
    100, $CellContext`Vm$$ = 10000, Typeset`show$$ = True, 
    Typeset`bookmarkList$$ = {}, Typeset`bookmarkMode$$ = "Menu", 
    Typeset`animator$$, Typeset`animvar$$ = 1, Typeset`name$$ = 
    "\"untitled\"", Typeset`specs$$ = {{{
       Hold[$CellContext`case$$], "Poynting", "displayed field type"}, {
      "Efield" -> "electric field", "Mfield" -> "magnetic field", "Poynting" -> 
       "Poynting vector"}}, {{
       Hold[$CellContext`gap$$], 500, 
       Row[{"gap length ", 
         Style["g", Italic], " (mm)"}]}, 20, 1000, 20}, {{
       Hold[$CellContext`dia$$], 100, 
       Row[{"conductor diameter ", 
         Style["d", Italic], " (mm)"}]}, 10, 200, 10}, {{
       Hold[$CellContext`Vm$$], 10000, 
       Row[{"voltage peak ", 
         Style["\!\(\*SubscriptBox[\(V\), \(m\)]\)", Italic], " (V)"}]}, 1000,
       20000, 1000}, {{
       Hold[$CellContext`Iim$$], 100, 
       Row[{"current peak ", 
         Style["\!\(\*SubscriptBox[\(I\), \(m\)]\)", Italic], " (A)"}]}, 10, 
      200, 10}, {{
       Hold[$CellContext`cos\[Theta]$$], 0.8, "power factor cos \[Theta] "}, {
      1, 0.8, 0.5, 0.2}}}, Typeset`size$$ = {570., {172., 178.}}, 
    Typeset`update$$ = 0, Typeset`initDone$$, Typeset`skipInitDone$$ = 
    False, $CellContext`case$63529$$ = False, $CellContext`gap$63530$$ = 
    0, $CellContext`dia$63531$$ = 0, $CellContext`Vm$63532$$ = 
    0, $CellContext`Iim$63533$$ = 0, $CellContext`cos\[Theta]$63534$$ = 0}, 
    DynamicBox[Manipulate`ManipulateBoxes[
     1, StandardForm, 
      "Variables" :> {$CellContext`case$$ = 
        "Poynting", $CellContext`cos\[Theta]$$ = 0.8, $CellContext`dia$$ = 
        100, $CellContext`gap$$ = 500, $CellContext`Iim$$ = 
        100, $CellContext`Vm$$ = 10000}, "ControllerVariables" :> {
        Hold[$CellContext`case$$, $CellContext`case$63529$$, False], 
        Hold[$CellContext`gap$$, $CellContext`gap$63530$$, 0], 
        Hold[$CellContext`dia$$, $CellContext`dia$63531$$, 0], 
        Hold[$CellContext`Vm$$, $CellContext`Vm$63532$$, 0], 
        Hold[$CellContext`Iim$$, $CellContext`Iim$63533$$, 0], 
        Hold[$CellContext`cos\[Theta]$$, $CellContext`cos\[Theta]$63534$$, 
         0]}, "OtherVariables" :> {
       Typeset`show$$, Typeset`bookmarkList$$, Typeset`bookmarkMode$$, 
        Typeset`animator$$, Typeset`animvar$$, Typeset`name$$, 
        Typeset`specs$$, Typeset`size$$, Typeset`update$$, Typeset`initDone$$,
         Typeset`skipInitDone$$}, "Body" :> Pane[
        Module[{$CellContext`len$ = 
          1.8, $CellContext`xyzrange$ = {{-1.2, 1.2}, {-0.8, 0.8}, {-0.8, 
           0.8}}, $CellContext`g$, $CellContext`d$, $CellContext`s$, \
$CellContext`h$, $CellContext`Fv$, $CellContext`Fmax$}, {$CellContext`g$, \
$CellContext`d$} = {$CellContext`gap$$, $CellContext`dia$$} 
           10^(-3); {$CellContext`s$, $CellContext`h$} = {$CellContext`g$ + \
$CellContext`d$, ($CellContext`g$ (2 $CellContext`d$ + $CellContext`g$))^
            Rational[1, 2]}; 
         Which[$CellContext`case$$ == "Efield", $CellContext`Fv$[
             Pattern[$CellContext`x$, 
              Blank[]], 
             Pattern[$CellContext`y$, 
              Blank[]], 
             Pattern[$CellContext`z$, 
              Blank[]]] = {
            0, ((2 $CellContext`h$) $CellContext`Vm$$) (($CellContext`h$^2 - 
               4 $CellContext`y$^2 + 
               4 $CellContext`z$^2)/((($CellContext`h$^2 - (
                 4 $CellContext`h$) $CellContext`y$ + 
                4 ($CellContext`y$^2 + $CellContext`z$^2)) ($CellContext`h$^2 + \
(4 $CellContext`h$) $CellContext`y$ + 
                4 ($CellContext`y$^2 + $CellContext`z$^2))) 
              Log[($CellContext`g$ + $CellContext`h$)/(-$CellContext`g$ + \
$CellContext`h$)])), -((((
                 16 $CellContext`h$) $CellContext`Vm$$) $CellContext`y$) \
($CellContext`z$/((($CellContext`h$^2 - (4 $CellContext`h$) $CellContext`y$ + 
                 
                 4 ($CellContext`y$^2 + $CellContext`z$^2)) \
($CellContext`h$^2 + (4 $CellContext`h$) $CellContext`y$ + 
                 4 ($CellContext`y$^2 + $CellContext`z$^2))) 
               Log[($CellContext`g$ + $CellContext`h$)/(-$CellContext`g$ + \
$CellContext`h$)])))}, $CellContext`case$$ == "Mfield", $CellContext`Fv$[
             Pattern[$CellContext`x$, 
              Blank[]], 
             Pattern[$CellContext`y$, 
              Blank[]], 
             Pattern[$CellContext`z$, 
              Blank[]]] = {
            0, (((16 $CellContext`Iim$$) $CellContext`s$) $CellContext`y$) \
($CellContext`z$/((
               Pi ($CellContext`s$^2 - (4 $CellContext`s$) $CellContext`y$ + 
                4 ($CellContext`y$^2 + $CellContext`z$^2))) \
($CellContext`s$^2 + (4 $CellContext`s$) $CellContext`y$ + 
               4 ($CellContext`y$^2 + $CellContext`z$^2)))), ((
               2 $CellContext`Iim$$) $CellContext`s$) (($CellContext`s$^2 - 
               4 $CellContext`y$^2 + 4 $CellContext`z$^2)/((
               Pi ($CellContext`s$^2 - (4 $CellContext`s$) $CellContext`y$ + 
                4 ($CellContext`y$^2 + $CellContext`z$^2))) \
($CellContext`s$^2 + (4 $CellContext`s$) $CellContext`y$ + 
               4 ($CellContext`y$^2 + $CellContext`z$^2))))}, \
$CellContext`case$$ == "Poynting", $CellContext`Fv$[
             Pattern[$CellContext`x$, 
              Blank[]], 
             Pattern[$CellContext`y$, 
              Blank[]], 
             Pattern[$CellContext`z$, 
              
              Blank[]]] = {((((((
                   2 $CellContext`cos\[Theta]$$) $CellContext`h$) \
$CellContext`Iim$$) $CellContext`s$) $CellContext`Vm$$) ($CellContext`h$^2 \
($CellContext`s$^2 - 4 $CellContext`y$^2 + 4 $CellContext`z$^2) + 
               4 ($CellContext`s$^2 (-$CellContext`y$^2 + $CellContext`z$^2) + 
                 4 ($CellContext`y$^2 + $CellContext`z$^2)^2)))/(((((
                 Pi ($CellContext`h$^2 - (4 $CellContext`h$) $CellContext`y$ + 
                  4 ($CellContext`y$^2 + $CellContext`z$^2))) \
($CellContext`h$^2 + (4 $CellContext`h$) $CellContext`y$ + 
                 4 ($CellContext`y$^2 + $CellContext`z$^2))) \
($CellContext`s$^2 - (4 $CellContext`s$) $CellContext`y$ + 
                4 ($CellContext`y$^2 + $CellContext`z$^2))) \
($CellContext`s$^2 + (4 $CellContext`s$) $CellContext`y$ + 
               4 ($CellContext`y$^2 + $CellContext`z$^2))) 
             Log[($CellContext`g$ + $CellContext`h$)/(-$CellContext`g$ + \
$CellContext`h$)]), 0, 0}]; $CellContext`Fmax$ = Norm[
            $CellContext`Fv$[0, $CellContext`g$/2, 0]]; Pane[
           Row[{
             Show[
              Graphics3D[{{Brown, 
                 
                 Cylinder[{{-($CellContext`len$/2), -($CellContext`s$/2), 
                    0}, {$CellContext`len$/2, -($CellContext`s$/2), 
                    0}}, $CellContext`d$/2], 
                 
                 Cylinder[{{-($CellContext`len$/2), $CellContext`s$/2, 
                    0}, {$CellContext`len$/2, $CellContext`s$/2, 
                    0}}, $CellContext`d$/2]}, {Black, 
                 Thickness[0.005], 
                 Arrowheads[0.03], 
                 Arrow[
                  
                  BSplineCurve[{{-($CellContext`len$/2), $CellContext`s$/
                    2, $CellContext`d$/2}, {-($CellContext`len$/2), 0, 
                    0.8 $CellContext`g$}, {-($CellContext`len$/
                    2), -($CellContext`s$/2), $CellContext`d$/2}}]]}, {Red, 
                 Arrow[
                  
                  Tube[{{-0.3 - $CellContext`len$/2, -($CellContext`s$/2), 
                    0}, {-($CellContext`len$/2), -($CellContext`s$/2), 0}}, 
                   0.02]], 
                 Arrow[
                  
                  Tube[{{-($CellContext`len$/2), $CellContext`s$/2, 
                    0}, {-0.3 - $CellContext`len$/2, $CellContext`s$/2, 0}}, 
                   0.02]], Blue, 
                 Arrowheads[{-0.03, 0.03}], 
                 
                 Arrow[{{$CellContext`len$/2, -($CellContext`g$/2), 
                    0}, {$CellContext`len$/2, $CellContext`g$/2, 0}}]}, {
                Black, 
                 Text[
                  Style[
                   Row[{
                    Subscript[
                    Style["V", Italic], 
                    Style["m", Italic]], " sin \[Omega] ", 
                    Style["t", Italic]}], 16], {-($CellContext`len$/2), 0, 
                   0.6 $CellContext`s$}, {1, 0}], 
                 Text[
                  Style[
                   Row[{
                    Subscript[
                    Style["I", Italic], 
                    Style["m", Italic]], " sin(\[Omega] ", 
                    Style["t", Italic], " - \[Phi])"}], 
                   16], {-0.4 - $CellContext`len$/
                   2, -($CellContext`g$/2), -0.15}], Blue, 
                 Text[
                  Style[
                   Row[{"  ", 
                    Style["g", Italic], " = \n", 
                    ToString[$CellContext`gap$$], " mm"}], 
                   16], {$CellContext`len$/2 + 0.1, 0, 0.2}], 
                 Text[
                  Style[
                   Row[{"diameter: \n", 
                    Style["d", Italic], " = ", 
                    ToString[$CellContext`dia$$], " mm"}], 
                   16], {$CellContext`len$/
                   2, -($CellContext`s$/2), -0.25}]}}], 
              
              ParametricPlot3D[{
               0, $CellContext`y, $CellContext`z}, {$CellContext`y, 
                Part[$CellContext`xyzrange$, 2, 1], 
                Part[$CellContext`xyzrange$, 2, 2]}, {$CellContext`z, 
                Part[$CellContext`xyzrange$, 3, 1], 
                Part[$CellContext`xyzrange$, 3, 2]}, Mesh -> {50, 50}, 
               MeshStyle -> None, ColorFunction -> 
               Function[{$CellContext`X$, $CellContext`Y$, $CellContext`Z$, \
$CellContext`y$, $CellContext`z$}, 
                 $CellContext`huef[Norm[
                    $CellContext`Fv$[
                    0, $CellContext`y$, \
$CellContext`z$]]/$CellContext`Fmax$]], ColorFunctionScaling -> False], 
              Graphics3D[{Black, 
                Thickness[0.003], 
                Arrowheads[0.015], 
                Table[
                 
                 Arrow[{{0, $CellContext`y, $CellContext`z} - 
                   If[$CellContext`case$$ == "Poynting", 0.5, 
                    0.1] ($CellContext`Fv$[
                    0, $CellContext`y, $CellContext`z]/$CellContext`Fmax$), {
                   0, $CellContext`y, $CellContext`z}}], {$CellContext`y, 
                  Part[$CellContext`xyzrange$, 2, 1] + (
                    Part[$CellContext`xyzrange$, 2, 2] - 
                    Part[$CellContext`xyzrange$, 2, 1])/32, 
                  Part[$CellContext`xyzrange$, 2, 2] - (
