                   Part[$CellContext`xyzrange$, 3, 1])/
                  32, (Part[$CellContext`xyzrange$, 3, 2] - 
                   Part[$CellContext`xyzrange$, 3, 1])/16}]}], 
              PlotRange -> $CellContext`xyzrange$, PlotLabel -> Style[
                
                Which[$CellContext`case$$ == "Efield", 
                 "electric field (peak value)", $CellContext`case$$ == 
                 "Mfield", "magnetic field (peak value)", $CellContext`case$$ == 
