                   Part[$CellContext`xyzrange$, 2, 1])/
                  32, (Part[$CellContext`xyzrange$, 2, 2] - 
                   Part[$CellContext`xyzrange$, 2, 1])/16}, {$CellContext`z, 
                  Part[$CellContext`xyzrange$, 3, 1] + (
                    Part[$CellContext`xyzrange$, 3, 2] - 
