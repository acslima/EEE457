Cell[CellGroupData[{

Cell["", "DetailsSection"],

Cell["Snapshot 1: an electric field distribution ", "DetailNotes",
 CellChangeTimes->{
  3.5502339875639153`*^9, {3.5556427225578117`*^9, 3.5556429800030584`*^9}, 
   3.5558111339375*^9, 3.556037008624332*^9, 3.556037660325678*^9, {
   3.5560505833220763`*^9, 3.5560505867762737`*^9}, 3.5563163076937685`*^9},
 CellID->132061358],

Cell["Snapshot 2: a magnetic field distributions ", "DetailNotes",
 CellChangeTimes->{{3.555643012713915*^9, 3.555643069372402*^9}, 
   3.5556431169766836`*^9, {3.5557069996804323`*^9, 3.5557070269492807`*^9}, 
   3.555811203328125*^9, {3.55605059317664*^9, 3.556050596375823*^9}, 
   3.556316327174883*^9},
 CellID->29778265],

Cell["\<\
Snapshot 3: a Poynting vector distribution\
\>", "DetailNotes",
 CellChangeTimes->{{3.55564309171284*^9, 3.555643148838336*^9}, {
   3.5557071316226625`*^9, 3.555707149085492*^9}, 3.555811226078125*^9, {
   3.556037158647021*^9, 3.556037159110067*^9}, 3.5563163435658207`*^9, {
   3.556318329063384*^9, 3.5563183290643845`*^9}, {3.557436499166382*^9, 
   3.557436511395323*^9}},
 CellID->120972801],

Cell[TextData[{
 "The electric field ",
 Cell[BoxData[
  FormBox[
   StyleBox["E",
    FontWeight->"Bold",
    FontSlant->"Plain"], TraditionalForm]], "InlineMath"],
 " of parallel cylinders is calculated assuming parallel line charges with \
separation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"h", "=", 
    SqrtBox[
     RowBox[{"g", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", " ", "d"}], "+", "g"}], ")"}]}]]}], TraditionalForm]], 
  "InlineMath"],
 ", where ",
 Cell[BoxData[
  FormBox["g", TraditionalForm]], "InlineMath"],
 " and ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]], "InlineMath"],
 " are the gap length and cylinder diameter. The magnetic field ",
 Cell[BoxData[
  FormBox[
   StyleBox["H",
    FontWeight->"Bold",
    FontSlant->"Plain"], TraditionalForm]], "InlineMath"],
 " is simulated by that of parallel line currents flowing along the cylinder \
axes (i.e. a uniform current density is assumed, ignoring the skin effect). \
The electric and magnetic vectors are in the plane of observation \
perpendicular to the cylinders. The average of the Poynting vector, given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox["1", "2"], " ", 
    RowBox[{
     StyleBox["E",
      FontWeight->"Bold",
      FontSlant->"Plain"], "\[Cross]", 
     StyleBox["H",
      FontWeight->"Bold",
      FontSlant->"Plain"]}], 
    StyleBox[" ",
     FontWeight->"Bold"], "cos", " ", "\[Phi]"}], TraditionalForm]], 
  "InlineMath"],
 ", is directed along the axial direction of conductors. "
}], "DetailNotes",
 CellChangeTimes->{{3.5556434327592216`*^9, 3.55564363306036*^9}, {
   3.555643669446023*^9, 3.5556437888404274`*^9}, {3.555707236739443*^9, 
   3.555707311751774*^9}, 3.5560371634314995`*^9, 3.5563163715764227`*^9, {
   3.557253722730498*^9, 3.557253728763101*^9}, {3.557436573621935*^9, 
   3.557436574317326*^9}, {3.557436605379229*^9, 3.557436646870287*^9}, {
   3.557448144715217*^9, 3.5574481531083717`*^9}, {3.557448191045684*^9, 
   3.557448327827236*^9}, {3.557448774892215*^9, 3.5574487864763947`*^9}, 
   3.5574488215189247`*^9},
 CellID->314565296],

Cell["\<\
The electric and magnetic field intensities (shown in colors for the peak \
values) are similarly distributed on the observation plane, but the \
directions are very nearly mutually perpendicular. The Poynting vector's \
intensity distribution in space decreases rapidly with the distance from the \
conductor.\
\>", "DetailNotes",
 CellChangeTimes->{{3.555643940578688*^9, 3.555643945773497*^9}, {
   3.555643979045554*^9, 3.5556441470046372`*^9}, {3.555644218008358*^9, 
   3.5556443124677196`*^9}, {3.555644389347453*^9, 3.5556444504423556`*^9}, {
   3.5556444875148163`*^9, 3.5556448259883885`*^9}, {3.55564486083885*^9, 
   3.555644995661478*^9}, {3.5556450620219927`*^9, 3.555645123603697*^9}, {
   3.5556451587901573`*^9, 3.5556451917994127`*^9}, {3.555707682480417*^9, 
   3.5557076853664217`*^9}, 3.556037175082664*^9, {3.5560507317575665`*^9, 
   3.5560508254599257`*^9}, 3.5560509642198625`*^9, {3.5563163939757037`*^9, 
   3.556316413860841*^9}, 3.556317153085122*^9, {3.5574366590637827`*^9, 
   3.557436672248815*^9}, {3.5574483482762403`*^9, 3.557448462566773*^9}, {
   3.557448846135003*^9, 3.5574488495266333`*^9}},
 CellID->181691910],

Cell["\<\
The power of the transmission line is actually carried in a thin region on \
the outside of the conductors, not within the lines themselves.\
\>", "DetailNotes",
 CellChangeTimes->{{3.555645243765701*^9, 3.555645319492628*^9}, {
   3.5556453503026824`*^9, 3.5556453938911576`*^9}, {3.555645474033695*^9, 
   3.5556454765952992`*^9}, 3.5556456074225287`*^9, {3.555645639995218*^9, 
   3.555646029371043*^9}, {3.5556460801107273`*^9, 3.555646164730261*^9}, {
   3.555646195218311*^9, 3.5556462053447275`*^9}, {3.5557077200608826`*^9, 
   3.5557077812837887`*^9}, 3.5557078398306913`*^9, {3.555707900585597*^9, 
   3.55570802375861*^9}, 3.5560376665345974`*^9, {3.5563164495168805`*^9, 
   3.556316457887359*^9}, 3.5563171613575954`*^9, {3.5563183246391315`*^9, 
   3.5563183246411314`*^9}, {3.5574366792807302`*^9, 3.557436753980321*^9}, {
   3.557448484975939*^9, 3.5574484960563498`*^9}, {3.557448588347889*^9, 
   3.55744866863894*^9}, {3.557448871103549*^9, 3.5574488860635443`*^9}},
 CellID->230708830],

Cell["Reference", "DetailNotes",
 CellChangeTimes->{3.5563164863599877`*^9, 3.55743654450599*^9},
 CellID->225510677],

