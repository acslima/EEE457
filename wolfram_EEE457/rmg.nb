Cell[CellGroupData[{

Cell["Utilizando a f\[OAcute]rmula", "Section",
 CellChangeTimes->{{3.414317917069609*^9, 3.414317922680679*^9}}],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["c", "1"], "=", 
    RowBox[{"2", "\[Pi]", " ", "\[Epsilon]", " ", 
     FractionBox["1", 
      RowBox[{"Log", "(", 
       RowBox[{
        FractionBox["DMG", "RMG"], 
        FractionBox["hmg", "HMG"]}], ")"}]]}]}], TraditionalForm]]],
 "\nDM G - dist\[AHat]ncia m\[EAcute]dia entre os condutores,\nRMG - raio m\
\[EAcute]dio geom\[EAcute]trico dos condutores de fase\n hmg  - \
dist\[AHat]ncia m\[EAcute]dia geom\[EAcute]trica entre condutores em rela\
\[CCedilla]\[ATilde]o \[AGrave]s imagens de mesma fase\n HMG - dos condutores \
em rela\[CCedilla]\[ATilde]o \[AGrave]s imagens de condutores de outras "
}], "Text",
 CellChangeTimes->{{3.414317956434049*^9, 3.414318073772775*^9}, {
  3.414318133926562*^9, 3.414318258996066*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"DMG", "=", 
   RadicalBox[
    RowBox[{"10", " ", "10", " ", "20"}], "3"]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rmg", "=", "rf"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"hmg", "=", 
   RadicalBox[
    RowBox[{"30", " ", "30", " ", "30"}], "3"]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"HMG", "=", 
   RadicalBox[
    RowBox[{
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{"10", "^", "2"}], "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"2", "*", "15"}], ")"}], "^", "2"}]}], "]"}], 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"2", "*", "10"}], ")"}], "^", "2"}], "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"2", "*", "15"}], ")"}], "^", "2"}]}], "]"}], 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{"10", "^", "2"}], "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"2", "*", "15"}], ")"}], "^", "2"}]}], "]"}]}], "3"]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.414319232077053*^9, 3.414319256253088*^9}, {
