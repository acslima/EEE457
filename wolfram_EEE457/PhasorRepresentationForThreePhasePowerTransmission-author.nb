    RowBox[{"{", 
     RowBox[{"f", ",", "x", ",", "pf", ",", "t"}], "}"}]}], ",", 
   RowBox[{"ControlPlacement", "\[Rule]", "Top"}], ",", 
   RowBox[{"Initialization", "\[RuleDelayed]", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"phasors", "[", 
