Cell[BoxData[
 RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"phasors", "[", 
    RowBox[{"f", ",", "x", ",", "pf", ",", "t"}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"f", ",", "60", ",", "\"\<frequency Hz\>\""}], "}"}], ",", "50",
      ",", "60", ",", 
     RowBox[{"Appearance", "\[Rule]", "\"\<Labeled\>\""}]}], "}"}], ",", " ", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"x", ",", "0", ",", "\"\<reactance\>\""}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "1"}], "\[Rule]", "\"\<inductive\>\""}], ",", 
       RowBox[{"1", "\[Rule]", "\"\<capacitive\>\""}]}], "}"}], ",", 
     "Setter"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"pf", ",", "1", ",", "\"\<power factor\>\""}], "}"}], ",", "0", 
     ",", "1", ",", 
     RowBox[{"Appearance", "\[Rule]", "\"\<Labeled\>\""}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "\"\<time\>\""}], "}"}], ",", "0", ",", 
     RowBox[{"2", "/", "f"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "\"\<animate\>\""}], "}"}], ",", "0", ",", 
     RowBox[{"2", "/", "f"}], ",", 
     SuperscriptBox["10", 
      RowBox[{"-", "5"}]], ",", "Trigger"}], "}"}], ",", 
