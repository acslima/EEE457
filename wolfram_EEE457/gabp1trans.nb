Cell[CellGroupData[{

Cell["Segunda Quest\[ATilde]o", "Section",
 CellChangeTimes->{{3.496404673005077*^9, 3.496404675883615*^9}}],

Cell["\<\
A partir da manipula\[CCedilla]\[OTilde]es do quadripolos \[EAcute] poss\
\[IAcute]vel obter as express\[OTilde]es para a express\[ATilde]o da matriz \
de admit\[AHat]ncia Q01 e do quadripolo Q03. Os quadripolos s\[ATilde]o \
mostradas abaixo \
\>", "Text",
 CellChangeTimes->{{3.496405297236599*^9, 3.496405298907751*^9}, {
  3.497001053686549*^9, 3.497001077628374*^9}, {3.497001112084525*^9, 
  3.4970011966203403`*^9}, {3.49700126320788*^9, 3.497001274484333*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"a", "=", " ", 
   RowBox[{"Cosh", "[", 
    RowBox[{"\[Gamma]", " ", "\[ScriptL]"}], "]"}]}], ";", " ", 
  RowBox[{"b", "=", 
   RowBox[{"Zc", " ", 
    RowBox[{"Sinh", "[", 
     RowBox[{"\[Gamma]", " ", "\[ScriptL]"}], "]"}]}]}], ";", " ", 
  RowBox[{"c", "=", 
   RowBox[{
    RowBox[{"1", "/", "Zc"}], " ", 
    RowBox[{"Sinh", "[", 
     RowBox[{"\[Gamma]", " ", "\[ScriptL]"}], "]"}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.496405303166339*^9, 3.4964053426283083`*^9}}],

Cell["\<\
Para a express\[ATilde]o de Q01 basta resolver a express\[ATilde]o do \
quadripolo em fun\[CCedilla]\[ATilde]o de i1 e i2\
\>", "Text",
 CellChangeTimes->{{3.49700127784256*^9, 3.4970013323560953`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"sol", "=", 
   RowBox[{
    RowBox[{"Solve", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"v1", ",", "i1"}], "}"}], "\[Equal]", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"a", ",", "b"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"c", ",", "a"}], "}"}]}], "}"}], ".", 
        RowBox[{"{", 
         RowBox[{"v2", ",", 
          RowBox[{"-", "i2"}]}], "}"}]}]}], ",", 
      RowBox[{"{", 
       RowBox[{"i1", ",", "i2"}], "}"}]}], "]"}], "//", "FullSimplify"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.496405360880631*^9, 3.496405418444619*^9}, {
  3.496405460606593*^9, 3.496405468836309*^9}, {3.496405507478179*^9, 
  3.496405512260149*^9}, {3.49700136890983*^9, 3.4970013812782707`*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Collect", "[", 
  RowBox[{
   RowBox[{"i1", "/.", "sol"}], ",", "v1"}], "]"}]], "Input",
 CellChangeTimes->{{3.4970013863568277`*^9, 3.4970014086772537`*^9}, {
  3.497001499208589*^9, 3.497001505221333*^9}}],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox[
    RowBox[{"v1", " ", 
     RowBox[{"Coth", "[", 
      RowBox[{"\[ScriptL]", " ", "\[Gamma]"}], "]"}]}], "Zc"], "-", 
   FractionBox[
    RowBox[{"v2", " ", 
     RowBox[{"Csch", "[", 
      RowBox[{"\[ScriptL]", " ", "\[Gamma]"}], "]"}]}], "Zc"]}], 
  "}"}]], "Output",
 CellChangeTimes->{{3.497001396442292*^9, 3.497001409654379*^9}, 
   3.497001506278204*^9}]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Collect", "[", 
  RowBox[{
   RowBox[{"i2", "/.", "sol"}], ",", "v1"}], "]"}]], "Input",
 CellChangeTimes->{{3.497001537221599*^9, 3.4970015373732452`*^9}}],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox[
    RowBox[{"v2", " ", 
     RowBox[{"Coth", "[", 
      RowBox[{"\[ScriptL]", " ", "\[Gamma]"}], "]"}]}], "Zc"], "-", 
   FractionBox[
    RowBox[{"v1", " ", 
     RowBox[{"Csch", "[", 
      RowBox[{"\[ScriptL]", " ", "\[Gamma]"}], "]"}]}], "Zc"]}], 
  "}"}]], "Output",
 CellChangeTimes->{3.4970015380588007`*^9}]
}, Open  ]],

Cell["\<\
Para a express\[ATilde]o de Q01 basta resolver a express\[ATilde]o do \
quadripolo em fun\[CCedilla]\[ATilde]o de v1 e i2\
\>", "Text",
 CellChangeTimes->{{3.49700127784256*^9, 3.497001349332333*^9}}],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"sol1", "=", 
  RowBox[{
   RowBox[{"Solve", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"v1", ",", "i1"}], "}"}], "\[Equal]", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"a", ",", "b"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"c", ",", "a"}], "}"}]}], "}"}], ".", 
       RowBox[{"{", 
        RowBox[{"v2", ",", "i2"}], "}"}]}]}], ",", 
     RowBox[{"{", 
      RowBox[{"v1", ",", "i2"}], "}"}]}], "]"}], "//", 
   "FullSimplify"}]}]], "Input",
 CellChangeTimes->{{3.496405360880631*^9, 3.496405418444619*^9}, {
  3.496405460606593*^9, 3.496405468836309*^9}, {3.496405507478179*^9, 
  3.496405512260149*^9}, {3.4964056101184072`*^9, 3.496405611268722*^9}, {
  3.496405643262505*^9, 3.4964056547408333`*^9}, {3.497001558543269*^9, 
  3.49700155944564*^9}}],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"v1", "\[Rule]", 
     RowBox[{
      RowBox[{"Sech", "[", 
       RowBox[{"\[ScriptL]", " ", "\[Gamma]"}], "]"}], " ", 
      RowBox[{"(", 
       RowBox[{"v2", "+", 
        RowBox[{"i1", " ", "Zc", " ", 
         RowBox[{"Sinh", "[", 
          RowBox[{"\[ScriptL]", " ", "\[Gamma]"}], "]"}]}]}], ")"}]}]}], ",", 
    
    RowBox[{"i2", "\[Rule]", 
     RowBox[{
      RowBox[{"i1", " ", 
       RowBox[{"Sech", "[", 
        RowBox[{"\[ScriptL]", " ", "\[Gamma]"}], "]"}]}], "-", 
      FractionBox[
       RowBox[{"v2", " ", 
        RowBox[{"Tanh", "[", 
         RowBox[{"\[ScriptL]", " ", "\[Gamma]"}], "]"}]}], "Zc"]}]}]}], "}"}],
   "}"}]], "Output",
 CellChangeTimes->{
  3.4964054310122128`*^9, 3.4964054700164833`*^9, 3.496405513511994*^9, {
   3.496405621048267*^9, 3.496405658052887*^9}, 3.496406412358193*^9, 
   3.497001561987906*^9, 3.497001598077059*^9}]
}, Open  ]]
}, Open  ]],

