Cell[CellGroupData[{

Cell["Primeira Quest\[ATilde]o", "Section",
 CellChangeTimes->{{3.4724757570466256`*^9, 3.4724757618920193`*^9}, {
  3.496404396971299*^9, 3.496404404562701*^9}}],

Cell[TextData[{
 "Para a an\[AAcute]lise vamos considerar primeiro uma linha sem perdas, \
visto que apenas valores absolutos s\[ATilde]o considerados no \
c\[AAcute]lculo da regula\[CCedilla]\[ATilde]o\n",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", "=", 
    RowBox[{
     FractionBox[
      SubscriptBox["V", "NL"], 
      SubscriptBox["V", "FL"]], "-", "1"}]}], TraditionalForm]]],
 " \nonde ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["V", "NL"], TraditionalForm]]],
 " representa o valor absoluto da tens\[ATilde]o a vazio, e ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["V", "FL"], TraditionalForm]]],
 "\[EAcute] o valor absoluto da tens\[ATilde]o em pelna carga. Para ambas \
configura\[CCedilla]\[OTilde]es de linha, a tens\[ATilde]o em vazio \[EAcute] \
dada por 1/A, sendo A o elemento do quadripolo.\n",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "=", 
    RowBox[{"1", "/", 
     RowBox[{"Cosh", "[", "\[Theta]", "]"}]}]}], TraditionalForm]]],
 " com  \[Theta]=\[ImaginaryJ]",
 Cell[BoxData[
  FormBox[
   FractionBox["\[Omega]", "c"], TraditionalForm]]],
 "\[ScriptL]\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Theta]", "0"], "=", 
    RowBox[{"5.76", "\[Degree]"}]}], TraditionalForm]]],
 " para linha curta e ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Theta]", "0"], "=", 
    RowBox[{"17.28", "\[Degree]"}]}], TraditionalForm]]],
 " para a linha longa. "
}], "Text",
 CellChangeTimes->{{3.496404419201538*^9, 3.496404588866844*^9}, {
  3.496404630203094*^9, 3.496404661746975*^9}, {3.496904859413642*^9, 
  3.4969050257320337`*^9}, {3.4969050979491043`*^9, 3.49690515907482*^9}, {
  3.4969052346732607`*^9, 3.4969055185880213`*^9}, {3.4969055921875677`*^9, 
  3.496905613960792*^9}, {3.4969057570032673`*^9, 3.496905758688888*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Theta]0", "=", 
   RowBox[{"2", " ", "\[Pi]", " ", 
    RowBox[{"60", " ", "/", 
     RowBox[{"(", 
      RowBox[{"3", " ", 
       RowBox[{"10", "^", "8"}]}], ")"}]}], "80000", " ", 
    RowBox[{"(", 
     RowBox[{"180", "/", "\[Pi]"}], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Theta]1", "=", 
   RowBox[{"2", " ", "\[Pi]", " ", 
    RowBox[{"60", " ", "/", 
     RowBox[{"(", 
      RowBox[{"3", " ", 
       RowBox[{"10", "^", "8"}]}], ")"}]}], "240000", 
    RowBox[{"(", 
     RowBox[{"180", "/", "\[Pi]"}], ")"}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.4968757094476223`*^9, 3.4968757239891653`*^9}, {
  3.496875811891152*^9, 3.496875833023731*^9}, {3.4969057723759108`*^9, 
  3.4969057969881163`*^9}, {3.496905894912592*^9, 3.4969059296205063`*^9}}],

Cell["\<\
 O gr\[AAcute]fico abaixo apresenta o Efeito Ferranti em fun\[CCedilla]\
\[ATilde]o do \[AHat]ngulo el\[EAcute]trico da LT. Nesse gr\[AAcute]fico \
\[EAcute] poss\[IAcute]vel notar que para linha curta os valores s\[ATilde]o \
muito pr\[OAcute]ximos a 1 \
\>", "Text",
 CellChangeTimes->{{3.496906752538012*^9, 3.496906757309565*^9}, {
   3.496906947689611*^9, 3.496906985746447*^9}, {3.4969070371968*^9, 
