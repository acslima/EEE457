Cell[TextData[{
 "Admitindo - se que tanto a linha curta como a linha longa possuem tens\
\[ATilde]o em plena carga semelhantes, algo como 0,95\[LessEqual] ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["V", "FL"], "\[LessEqual]", "1.05"}], TraditionalForm]]],
 " temos, para a linha curta. A figura abaixo mostra a regula\[CCedilla]\
\[ATilde]o de tens\[ATilde]o para uma linha curta, onde pode-se ver que a \
regula\[CCedilla]\[ATilde]o pode ser maior que uma linha longa dependendo \
qual a tens\[ATilde]o a plena carga que a linha estar\[AAcute] submetida. \
Desse resultado, pode-se notar que a regula\[CCedilla]\[ATilde]o de uma linha \
longa pode ser menor que a encontrada numa linha curta."
}], "Text",
 CellChangeTimes->{{3.496907136509001*^9, 3.49690725221005*^9}, 
   3.4969100147761097`*^9, {3.496914868596442*^9, 3.496914970461685*^9}}],

Cell[BoxData[""], "Input",
 CellChangeTimes->{{3.496907373194324*^9, 3.496907401193735*^9}, 
   3.496915059463505*^9}],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"A0", "=", 
   RowBox[{"1", "/", 
    RowBox[{"Cos", "[", 
     RowBox[{"\[Theta]0", " ", "Degree"}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"A1", "=", 
   RowBox[{"1", "/", 
    RowBox[{"Cos", "[", 
     RowBox[{"\[Theta]1", " ", "Degree"}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"100", " ", 
      RowBox[{"Abs", "[", 
       RowBox[{
        FractionBox[
         RowBox[{"(", 
          RowBox[{"Sec", "[", 
           RowBox[{"2", " ", "\[Pi]", " ", 
            RowBox[{"60.", "/", 
             RowBox[{"(", 
              RowBox[{"3", " ", 
