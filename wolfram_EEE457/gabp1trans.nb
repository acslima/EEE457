Cell[BoxData[{
 RowBox[{
  RowBox[{"Grelemp", "=", 
   RowBox[{"ListLogLogPlot", "[", 
    RowBox[{
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Transpose", "@", 
         RowBox[{"{", 
          RowBox[{"sk", ",", 
           RowBox[{"Abs", "[", 
            RowBox[{"yElementosp", "[", 
             RowBox[{"[", 
