      RowBox[{"xc", "[", 
       RowBox[{"[", "2", "]"}], "]"}]}], ",", " ", 
     RowBox[{
      RowBox[{"xc", "[", 
       RowBox[{"[", "3", "]"}], "]"}], "+", 
      RowBox[{"xc", "[", 
       RowBox[{"[", "4", "]"}], "]"}]}], ",", " ", 
     RowBox[{
      RowBox[{"xc", "[", 
       RowBox[{"[", "5", "]"}], "]"}], "+", 
      RowBox[{"xc", "[", 
       RowBox[{"[", "6", "]"}], "]"}]}]}], "}"}]}]}]], "Input",
