                    RowBox[{"[", "k", "]"}], "]"}]}], ")"}], "^", "2"}]}], 
                ")"}]}]}], ")"}]}], "+", 
           RowBox[{"\[ImaginaryI]", "*", 
            RowBox[{"(", 
