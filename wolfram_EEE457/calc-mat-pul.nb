Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "  ", 
   RowBox[{
   "ground", " ", "wires", " ", "are", " ", "not", " ", "explicitly", " ", 
    "considered", " ", "so", " ", "we", " ", "include", " ", "their", " ", 
    "effects", " ", "via", " ", "Kron", " ", 
    RowBox[{"Reduction", " ", "--"}], " ", "matrizes", " ", "devem", " ", 
    "estar", " ", "no", " ", "formato", " ", "de", " ", "impedancia"}], " ", 
   "*)"}], "        ", "\n", 
  RowBox[{
   RowBox[{"eliprc", " ", "=", " ", 
    RowBox[{"Compile", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"m", ",", "_Complex", ",", "2"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"nc", ",", "_Integer"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"np", ",", "_Integer"}], "}"}]}], "}"}], ",", "\n", 
      "\t            ", 
      RowBox[{"Take", "[", 
       RowBox[{
        RowBox[{"Inverse", "[", "m", "]"}], ",", " ", 
        RowBox[{"nc", " ", "-", " ", "np"}], ",", " ", 
        RowBox[{"nc", " ", "-", " ", "np"}]}], "]"}]}], "\n", 
     "\t            ", "]"}]}], ";"}]}]], "Input",
 CellChangeTimes->{3.838272594492523*^9},
 CellLabel->"In[50]:=",ExpressionUUID->"9c84e26c-c909-4fb0-85b3-e86e6b871657"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"case", "  ", "2"}], ":", " ", 
    RowBox[{
    "ground", " ", "wires", " ", "and", " ", "unbundled", " ", 
     "conductors"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"cZYlt", "[", 
      RowBox[{"omega_", ",", 
       RowBox[{
        RowBox[{"(", "x_", ")"}], "?", "VectorQ"}], ",", " ", 
       RowBox[{
        RowBox[{"(", "y_", ")"}], "?", "VectorQ"}], ",", " ", "sigmas_", ",", 
       " ", "rdc_", ",", "rf_", ",", "rint_", ",", " ", "npr_", ",", " ", 
       "rdcpr_", ",", " ", "rpr_"}], "]"}], ":=", "\n", "    ", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"mu", "=", 
          RowBox[{"4", "*", "Pi", "*", 
           RowBox[{"10", "^", 
            RowBox[{"-", "7"}]}]}]}], ",", " ", 
         RowBox[{"eps", "=", 
          RowBox[{"8.854", "*", 
           RowBox[{"10", "^", 
            RowBox[{"-", "12"}]}]}]}], ",", " ", 
         RowBox[{"nc", "=", 
          RowBox[{"Length", "[", "x", "]"}]}], ",", "  ", "nf", ",", " ", 
         "rhoc", ",", " ", "rhopr", ",", " ", "mp", ",", " ", "zin", ",", " ",
          "ze", ",", " ", "Z1", ",", " ", "Y1"}], "}"}], ",", "\n", "    \t", 
       "\n", "    ", 
       RowBox[{
        RowBox[{"nf", "=", " ", 
         RowBox[{"IntegerPart", "[", 
          RowBox[{"(", 
