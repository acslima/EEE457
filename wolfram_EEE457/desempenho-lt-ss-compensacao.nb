     RowBox[{"\[Gamma]", "=", " ", 
      RowBox[{"Sqrt", "[", " ", 
       RowBox[{"z", " ", "y"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Pn", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
