  3.966004811758502*^9}, {3.966005203201703*^9, 3.9660052093394527`*^9}, {
  3.966005289387164*^9, 3.9660053365695763`*^9}, {3.966005398799849*^9, 
  3.966005522667204*^9}, {3.966005580482029*^9, 3.966005602491531*^9}, {
  3.9660056578795443`*^9, 3.966005659017988*^9}, {3.966005778989566*^9, 
  3.966005800237133*^9}, {3.966073849883511*^9, 3.966073855032535*^9}},
