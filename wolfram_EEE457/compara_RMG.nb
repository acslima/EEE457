Cell[BoxData[
 RowBox[{
  RowBox[{"P", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"i", "\[NotEqual]", "j"}], ",", 
       RowBox[{"Log", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"\[Sqrt]", 
           RowBox[{"(", 
            RowBox[{
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{
                RowBox[{"xc", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], "-", 
                RowBox[{"xc", "[", 
                 RowBox[{"[", "j", "]"}], "]"}]}], ")"}], "2"], "+", 
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{
                RowBox[{"yc", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], "+", 
                RowBox[{"yc", "[", 
                 RowBox[{"[", "j", "]"}], "]"}]}], ")"}], "2"]}], ")"}]}], 
          ")"}], "/", 
         RowBox[{"(", 
          RowBox[{"\[Sqrt]", 
           RowBox[{"(", 
            RowBox[{
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{
                RowBox[{"xc", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], "-", 
                RowBox[{"xc", "[", 
                 RowBox[{"[", "j", "]"}], "]"}]}], ")"}], "2"], "+", 
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{
                RowBox[{"yc", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], "-", 
                RowBox[{"yc", "[", 
                 RowBox[{"[", "j", "]"}], "]"}]}], ")"}], "2"]}], ")"}]}], 
          ")"}]}], "]"}], ",", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"i", "\[LessEqual]", 
          RowBox[{"ncond", "-", "npr"}]}], ",", 
         RowBox[{"Log", "[", 
          RowBox[{"2", " ", 
           FractionBox[
            RowBox[{"yc", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "rf"]}], "]"}], ",", 
         RowBox[{"Log", " ", "[", 
          RowBox[{"2", 
           FractionBox[
            RowBox[{"yc", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "rpr"]}], "]"}]}], "]"}]}], 
      "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "ncond"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", "ncond"}], "}"}]}], "]"}]}], ";"}]], "Input",\

