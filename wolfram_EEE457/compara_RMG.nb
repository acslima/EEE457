                RowBox[{"xc", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], "-", 
                RowBox[{"xc", "[", 
                 RowBox[{"[", "j", "]"}], "]"}]}], ")"}], "2"], "+", 
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{
                RowBox[{"yc", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], "+", 
                RowBox[{"yc", "[", 
                 RowBox[{"[", "j", "]"}], "]"}]}], ")"}], "2"]}], ")"}]}], 
          ")"}], "/", 
         RowBox[{"(", 
          RowBox[{"\[Sqrt]", 
           RowBox[{"(", 
            RowBox[{
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{
                RowBox[{"xc", "[", 
                 RowBox[{"[", "i", "]"}], "]"}], "-", 
                RowBox[{"xc", "[", 
                 RowBox[{"[", "j", "]"}], "]"}]}], ")"}], "2"], "+", 
