                RowBox[{"yc", "[", 
                 RowBox[{"[", "j", "]"}], "]"}]}], ")"}], "2"]}], ")"}]}], 
          ")"}]}], "]"}], ",", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"i", "\[LessEqual]", 
          RowBox[{"ncond", "-", "npr"}]}], ",", 
         RowBox[{"Log", "[", 
          RowBox[{"2", " ", 
           FractionBox[
            RowBox[{"yc", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "rf"]}], "]"}], ",", 
