Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Pspr", "=", 
    RowBox[{"Inverse", "[", 
     RowBox[{"Take", "[", 
      RowBox[{"Pinv", ",", 
       RowBox[{"ncond", "-", "npr"}], ",", 
