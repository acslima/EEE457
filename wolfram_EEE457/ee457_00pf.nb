            \)\)]]], "Text"],

Cell["\<\
Vs Is=A Vr Is+B Ir(C Vr+A Ir)
Vs Is+VrIr=AVrIs+(BC+1)IrVr+BAIr^2
A^2-BC=1\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[{
    \(A = \(Vs\ Is + Vr\ Ir\)\/\(Vr\ Is + Vs\ Ir\)\), "\[IndentingNewLine]", 
    \(B = \(Vs^2 - Vr^2\)\/\(Vr\ Is + VsIr\)\)}], "Input"],

Cell[BoxData[
    \(\(Ir\ Vr + Is\ Vs\)\/\(Is\ Vr + Ir\ Vs\)\)], "Output"],

Cell[BoxData[
    \(\(\(-Vr\^2\) + Vs\^2\)\/\(Is\ Vr + VsIr\)\)], "Output"]
}, Open  ]],

