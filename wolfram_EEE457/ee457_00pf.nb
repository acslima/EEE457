Notebook[{
Cell["Gabarito Prova Final de Transmiss\[ATilde]o", "Title"],

Cell["Julho de 2004 ", "Subtitle"],

Cell[BoxData[
    \(\(Off[General::"\<spell\>", General::"\<spell1\>"];\)\)], "Input"],

Cell[CellGroupData[{

Cell["Primeira Quest\[ATilde]o", "Section"],

Cell["Dados do sistema", "Text",
  PageWidth->WindowWidth,
  CellDingbat->None],

Cell[CellGroupData[{

Cell[BoxData[{
    \(xa1 = \(-12.19\)/2; ya1 = 13.94\ ; xb1 = 12.19/2; yb1 = ya1; 
    xc1 = 0\ ;\), "\[IndentingNewLine]", 
    \(\(yc1 = 22.32;\)\), "\n", 
    \(\(xc = {xa1, xb1, xc1};\)\), "\n", 
    \(\(yc = {ya1, yb1, yc1};\)\), "\[IndentingNewLine]", 
    \(\(mostra = 
        Table[{Circle[{xc[\([i]\)], yc[\([i]\)]}, 0.5]}, {i, 1, 
            3}];\)\), "\n", 
    \(\(tduplo = 
        Show[Graphics[mostra], AspectRatio \[Rule] Automatic, 
          Axes \[Rule] False, Frame -> Automatic, 
          PlotRange \[Rule] {{\(-12\), 12}, {9.9, 25}}, 
          FrameTicks \[Rule] {{\(-10\), 0, 10}, {10, 15, 25}, False, False}, 
          FrameLabel \[Rule] {"\<dist\[AHat]ncia (m)\>", "\<dist\[AHat]ncia \
(m)\>"}];\)\)}], "Input"],

Cell[GraphicsData["PostScript", "\<\
