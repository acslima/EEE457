Notebook[{

Cell[CellGroupData[{
Cell["Compara\[CCedilla]\[ATilde]o de par\[AHat]metros de Linhas de Transmiss\
\[ATilde]o", "Title"],

Cell[CellGroupData[{

Cell["Op\[CCedilla]\[OTilde]es de programa", "Section",
  FontSize->12],

Cell[BoxData[{
    \(<< Graphics`Graphics`\), "\n", 
    \(\(Off[General::"\<spell\>", General::"\<spell1\>"];\)\), "\n", 
    \(\(SetOptions[{Graphics}, Axes \[Rule] False, Frame \[Rule] True, 
        ImageSize \[Rule] 450, 
        DefaultFont \[Rule] {"\<Helvetica\>", 14}];\)\)}], "Input",
  CellLabel->"In[1]:=",
  FontSize->12]
}, Closed]],

Cell[CellGroupData[{

Cell["Circuito Convencional 345kV", "Section",
  FontSize->12],

Cell[BoxData[
    StyleBox[\(xy1 = {{\(-7.229\), 10.5}, \ {\(-6.771\), \ 
              10.500}, \ {\(-0.229\), \ 10.500}, \ {0.229, \ 
              10.500}, \ {7.229, \ 10.500}, \n{6.771, \ 
              10.500}, \ {\(-5.000\), \ 20.500}, \ {5.000, \ 20.500}};\),
      FontSize->12]], "Input",
  CellLabel->"In[4]:=",
  FontSize->12],

Cell[BoxData[
    \(\(mostra1 = \({Circle[#,  .25]} &\) /@ xy1;\)\)], "Input",
  CellLabel->"In[5]:=",
  FontSize->12],

Cell[CellGroupData[{

Cell[BoxData[
    \(\(t1 = 
        Show[Graphics[mostra1], AspectRatio \[Rule] Automatic, 
          Axes \[Rule] False, Frame -> Automatic, 
          PlotRange \[Rule] {{\(-10.1\), 10.1}, {0, 25}}, 
          FrameLabel \[Rule] {"\<dist\[AHat]ncia (m)\>", "\<dist\[AHat]ncia \
(m)\>"}];\)\)], "Input",
  CellLabel->"In[6]:=",
  FontSize->12],

