Cell[CellGroupData[{

Cell["", "ManipulateCaptionSection"],

Cell[TextData[{
 "Wireless power transmission uses a pair of magnetically-coupled coils, each \
in series with a capacitor. The self-inductance and mutual inductance of \
circular coils can be estimated from the geometry. For two identical coils at \
axial distance ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]], "InlineMath"],
 ", the mutual inductance ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["L", "12"], TraditionalForm]], "InlineMath"],
 " is given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["L", "12"], "(", "d", ")"}], TraditionalForm]], "InlineMath"],
 ", while their individual self-inductances are the same: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["L", "1"], "=", 
    SubscriptBox["L", "2"]}], TraditionalForm]], "InlineMath"],
 ". Applying these in the equivalent circuit, it is possible to analyze the \
frequency characteristics of the system."
}], "ManipulateCaption",
 CellChangeTimes->{
  3.6253887037707925`*^9, {3.6253887413399415`*^9, 3.625388796227081*^9}, {
   3.6253888341792517`*^9, 3.625388850267172*^9}, 3.6253890077541795`*^9, {
   3.6253890593851323`*^9, 3.6253890754570518`*^9}, {3.6253891145622883`*^9, 
   3.625389146913139*^9}, {3.625389203472374*^9, 3.625389281439833*^9}, {
   3.625389330175621*^9, 3.6253895166292853`*^9}, {3.6253895888624167`*^9, 
   3.625389590813528*^9}, {3.6253897690927258`*^9, 3.6253898173144836`*^9}, {
   3.625389993434557*^9, 3.625390115970566*^9}, {3.625390306544466*^9, 
   3.62539039822571*^9}, {3.6253905324723883`*^9, 3.6253906339841948`*^9}, {
