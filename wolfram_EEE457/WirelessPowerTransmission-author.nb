   3.626972944646502*^9}, {3.626973072413823*^9, 3.626973132348845*^9}, {
   3.627047923003078*^9, 3.627047923282567*^9}},
 CellID->1879125043],

Cell[TextData[{
 "2. When ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["C", "1"], "=", " ", 
    SubscriptBox["C", "2"]}], TraditionalForm]], "InlineMath"],
 ", ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["f", 
    SubscriptBox["r", "12"]], TraditionalForm]], "InlineMath"],
 " can differ from ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["f", 
     SubscriptBox["r", "1"]], "=", 
    SubscriptBox["f", 
     SubscriptBox["r", "2"]]}], TraditionalForm]], "InlineMath"],
 " for small ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]], "InlineMath"],
 ", resulting in the two-peak profile (Snapshot 2)."
}], "DetailNotes",
 CellChangeTimes->{{3.6253940200776973`*^9, 3.625394210086031*^9}, {
   3.6253943254482336`*^9, 3.6253944052111735`*^9}, {3.625394436224028*^9, 
   3.625394668414836*^9}, {3.6253947180853233`*^9, 3.6253947839798393`*^9}, {
   3.6253948211703043`*^9, 3.6253949835821896`*^9}, {3.6253951583492966`*^9, 
   3.625395250233458*^9}, {3.6253952894519267`*^9, 3.625395335316007*^9}, {
   3.6253953913201056`*^9, 3.625395402193325*^9}, {3.6253954499450088`*^9, 
   3.625395675397605*^9}, {3.6253957116676683`*^9, 3.625395755800146*^9}, {
   3.6253957997454233`*^9, 3.625395814471849*^9}, {3.6253958475127068`*^9, 
   3.625395935184861*^9}, {3.6253960542836704`*^9, 3.6253960748601065`*^9}, {
   3.6255386361359777`*^9, 3.625538697862508*^9}, {3.6255388256708183`*^9, 
   3.6255389519710417`*^9}, {3.62553908376158*^9, 3.625539139895791*^9}, {
   3.6255392372953615`*^9, 3.6255392417676177`*^9}, 3.625719932110749*^9, {
   3.6258470347953377`*^9, 3.625847035294544*^9}, {3.626972873701851*^9, 
   3.626972944646502*^9}, {3.626973072413823*^9, 3.6269732307376432`*^9}, {
   3.627047935703443*^9, 3.627048004135676*^9}, {3.627051923371275*^9, 
   3.627051926242784*^9}},
 CellID->458641156],

Cell[TextData[{
 "3. When ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["C", "1"], "=", " ", 
    SubscriptBox["C", "2"]}], TraditionalForm]], "InlineMath"],
 " and ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]], "InlineMath"],
 " is large, all three resonance frequencies are similar, resulting in the \
one-peak profile, especially for larger output resistance ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "o"], TraditionalForm]], "InlineMath"],
 " (Snapshot 3)."
}], "DetailNotes",
 CellChangeTimes->{{3.6253940200776973`*^9, 3.625394210086031*^9}, {
