Cell[CellGroupData[{

Cell["", "DetailsSection"],

Cell[TextData[{
 "There are four candidates for resonance frequencies:\[LineSeparator]   ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["f", 
     SubscriptBox["r", "1"]], "=", 
    FractionBox["1", 
     RowBox[{"2", " ", "\[Pi]", " ", 
      SqrtBox[
       RowBox[{
        SubscriptBox["L", "1"], 
        SubscriptBox["C", "1"], " "}]]}]]}], TraditionalForm]], "InlineMath"],
 ",  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["f", 
     SubscriptBox["r", "2"]], "=", 
    FractionBox["1", 
     RowBox[{"2", " ", "\[Pi]", " ", 
      SqrtBox[
       RowBox[{
        SubscriptBox["L", "2"], 
        SubscriptBox["C", "2"], " "}]]}]]}], TraditionalForm]], "InlineMath"],
 ",  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["f", "rs"], "=", 
    FractionBox["1", 
     RowBox[{"2", " ", "\[Pi]", " ", 
      SqrtBox[
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           SubscriptBox["L", "1"], "+", 
           SubscriptBox["L", "2"]}], ")"}], " ", "[", 
         RowBox[{"1", "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"1", "/", 
             SubscriptBox["C", "1"]}], "+", 
            RowBox[{"1", "/", 
             SubscriptBox["C", "2"]}]}], ")"}]}], "]"}], " "}]]}]]}], 
   TraditionalForm]], "InlineMath"],
 ",  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["f", "rp"], "=", 
    FractionBox["1", 
     RowBox[{"2", " ", "\[Pi]", " ", 
      SqrtBox[
       RowBox[{
        RowBox[{"[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            SubscriptBox["L", "1"], "+", 
            SubscriptBox["L", "2"]}], ")"}], "/", "2"}], "]"}], " ", 
        RowBox[{"(", 
         RowBox[{
          SubscriptBox["C", "1"], "+", 
          SubscriptBox["C", "2"]}], ")"}], " "}]]}]]}], TraditionalForm]], 
  "InlineMath"],
 ".\[LineSeparator]These are indicated by vertical lines in the graphics. The \
displayed frequency range is set so as to include these frequencies. The \
following tendencies are noticed in the frequency characteristics."
}], "DetailNotes",
 CellChangeTimes->{{3.6253940200776973`*^9, 3.625394210086031*^9}, {
   3.6253943254482336`*^9, 3.6253944052111735`*^9}, {3.625394436224028*^9, 
   3.625394668414836*^9}, {3.6253947180853233`*^9, 3.6253947839798393`*^9}, {
   3.6253948211703043`*^9, 3.6253949835821896`*^9}, {3.6253951583492966`*^9, 
   3.625395250233458*^9}, {3.6253952894519267`*^9, 3.625395335316007*^9}, {
   3.6253953913201056`*^9, 3.625395402193325*^9}, {3.6253954499450088`*^9, 
   3.625395675397605*^9}, {3.6253957116676683`*^9, 3.625395755800146*^9}, {
   3.6253957997454233`*^9, 3.625395814471849*^9}, {3.6253958475127068`*^9, 
   3.625395935184861*^9}, {3.6253960542836704`*^9, 3.6253960748601065`*^9}, {
   3.6255386361359777`*^9, 3.625538697862508*^9}, {3.6255388256708183`*^9, 
   3.6255389519710417`*^9}, {3.62553908376158*^9, 3.625539139895791*^9}, {
   3.6255392372953615`*^9, 3.6255392417676177`*^9}, 3.625719932110749*^9, {
   3.6258470347953377`*^9, 3.625847035294544*^9}, {3.626972873701851*^9, 
   3.626972944646502*^9}, {3.626973072413823*^9, 3.626973090334264*^9}},
 CellID->383092171],

Cell[TextData[{
 "1. When ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["C", "1"], "\[NotEqual]", 
    SubscriptBox["C", "2"]}], TraditionalForm]], "InlineMath"],
 ", two peaks appear around the above resonance frequencies (Snapshot 1)."
}], "DetailNotes",
 CellChangeTimes->{{3.6253940200776973`*^9, 3.625394210086031*^9}, {
   3.6253943254482336`*^9, 3.6253944052111735`*^9}, {3.625394436224028*^9, 
