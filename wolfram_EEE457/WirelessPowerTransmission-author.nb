   3.625719899881092*^9, 3.6257199267755394`*^9}, {3.6258464322993813`*^9, 
   3.625846432985794*^9}, {3.626972458822947*^9, 3.6269725047396307`*^9}, {
   3.626972542730448*^9, 3.626972560784988*^9}, 3.6269726975663557`*^9, {
   3.626978634689837*^9, 3.626978688054739*^9}, {3.62697873568042*^9, 
   3.626978760229782*^9}, {3.626978790718206*^9, 3.626978798493292*^9}, 
   3.62697891732627*^9, {3.626978948971937*^9, 3.626978949755447*^9}},
 CellID->161053412],

Cell[TextData[{
 "Assuming a constant voltage source ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["V", "i"], "=", 
    RowBox[{"100", " ", 
     SubscriptBox[
      StyleBox["V",
       FontSlant->"Plain"], "rms"]}]}], TraditionalForm]], "InlineMath"],
 " with impedance ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["r", "i"], "=", 
    RowBox[{"10", " ", "\[CapitalOmega]"}]}], TraditionalForm]], "InlineMath"],
 ", the frequency characteristic of currents in two coils ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["I", "1"], ",", " ", 
    SubscriptBox["I", "2"], " "}], TraditionalForm]], "InlineMath"],
 " can be obtained by applying harmonic analysis. The coil distance ",
 Cell[BoxData[
  FormBox["d", TraditionalForm]], "InlineMath"],
 ", capacitances ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["C", "1"], TraditionalForm]], "InlineMath"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["C", "2"], TraditionalForm]], "InlineMath"],
 ", and output resistance ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["r", "o"], TraditionalForm]], "InlineMath"],
 " are variable parameters. The frequency characteristics of input and output \
powers determine ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["I", "1"], " "}], TraditionalForm]], "InlineMath"],
 "and ",
 Cell[BoxData[
  FormBox[
   RowBox[{" ", 
    SubscriptBox["I", "2"]}], TraditionalForm]], "InlineMath"],
 ". As you can see by changing the parameters, the frequency characteristics \
are sensitive to these parameters."
}], "ManipulateCaption",
 CellChangeTimes->{
  3.6253887037707925`*^9, {3.6253887413399415`*^9, 3.625388796227081*^9}, {
