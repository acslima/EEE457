 RowBox[{
  RowBox[{"z1", "=", " ", 
   RowBox[{"0.1020", " ", "+", " ", 
    RowBox[{"I", ".5094"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"y1", "=", 
   RowBox[{"I", " ", "3.2599", "  ", 
    RowBox[{"10", "^", 
     RowBox[{"-", "6"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Gamma]", " ", "=", " ", 
   RowBox[{"Sqrt", "[", 
    RowBox[{"z1", " ", "y1"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Zc", "=", " ", 
   RowBox[{"Sqrt", "[", 
    RowBox[{"z1", "/", "y1"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Vn", "=", " ", 
   RowBox[{"230", " ", 
    RowBox[{"10", "^", "3"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Pn", " ", "=", " ", 
