   3.9531885903733826`*^9, 3.9531886029264603`*^9}, {3.9531886434543095`*^9, 
   3.9531886482297497`*^9}},ExpressionUUID->"3076b87d-b644-49b2-a02f-\
bd2e9ddf1cdd"],

Cell["fun\[CCedilla]\[ATilde]o para o c\[AAcute]lculo das perdas", "Text",
 CellChangeTimes->{{3.921928424155348*^9, 
  3.921928431384848*^9}},ExpressionUUID->"0511a503-3265-4b86-8961-\
8b1a4cd5128b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"calcPerdas", "[", 
   RowBox[{"x_", ",", " ", "pr_", ",", " ", "vrff_", ",", " ", 
    RowBox[{"fp_", ":", "1"}], ",", " ", 
    RowBox[{"ang_", ":", "1"}]}], "]"}], ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"a", ",", "b", ",", "c", ",", "s", ",", "vr", ",", "ir"}], "}"}],
     ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"a", "=", " ", 
      RowBox[{"Cosh", "[", 
       RowBox[{"\[Gamma]", " ", "x"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"b", "=", " ", 
      RowBox[{"Zc", " ", 
       RowBox[{"Sinh", "[", 
        RowBox[{"\[Gamma]", " ", "x"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"c", "=", " ", 
      RowBox[{
       RowBox[{"1", "/", "Zc"}], " ", 
       RowBox[{"Sinh", "[", 
        RowBox[{"\[Gamma]", " ", "x"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"s", " ", "=", " ", 
      RowBox[{"pr", "/", "fp"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"ir", "=", 
      RowBox[{"s", " ", 
       RowBox[{
        RowBox[{"Conjugate", "[", 
         RowBox[{"Exp", "[", 
          RowBox[{"ang", " ", "I", " ", 
           RowBox[{"ArcCos", "[", "fp", "]"}]}], "]"}], "]"}], "/", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Sqrt", "[", "3", "]"}], " ", "vr"}], ")"}]}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"vr", "=", " ", 
      RowBox[{"vrff", "/", 
       RowBox[{"Sqrt", "[", "3", "]"}]}]}], ";", "\[IndentingNewLine]", " ", 
     RowBox[{"vs", "=", " ", 
      RowBox[{
       RowBox[{"a", " ", "vr"}], " ", "+", " ", 
       RowBox[{"b", " ", "ir"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"is", " ", "=", " ", 
      RowBox[{
       RowBox[{"c", " ", "vr"}], " ", "+", " ", 
       RowBox[{"a", " ", "ir"}]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Re", "[", 
      RowBox[{
       RowBox[{"vs", " ", 
        RowBox[{"Conjugate", "[", "is", "]"}]}], " ", "-", " ", 
       RowBox[{"vr", " ", 
        RowBox[{"Conjugate", "[", "ir", "]"}]}]}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.9219284336058292`*^9, 3.9219286714781303`*^9}, {
  3.9219287021241198`*^9, 3.9219288121999807`*^9}, {3.921928975135489*^9, 
  3.921928990768791*^9}, {3.9219308038894587`*^9, 3.9219308101805143`*^9}, {
  3.921930867322857*^9, 3.921930875588727*^9}},
 CellLabel->"In[11]:=",ExpressionUUID->"15326e9c-87f6-422f-ab98-3efa6890b3e2"],

