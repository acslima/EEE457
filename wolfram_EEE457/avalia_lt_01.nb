Cell[BoxData[{
 RowBox[{
  RowBox[{"z1", "=", " ", 
   RowBox[{"0.12201634999153511", "+", 
    RowBox[{"0.48345448483576975", "  ", "I"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"y1", "=", 
   RowBox[{"I", " ", "3.46770008354597", "  ", 
    RowBox[{"10", "^", 
     RowBox[{"-", "6"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Gamma]", " ", "=", " ", 
   RowBox[{"Sqrt", "[", 
    RowBox[{"z1", " ", "y1"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Zc", "=", " ", 
   RowBox[{"Sqrt", "[", 
    RowBox[{"z1", "/", "y1"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Vn", "=", " ", 
   RowBox[{"138", " ", 
    RowBox[{"10", "^", "3"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Pn", " ", "=", " ", 
   RowBox[{
    RowBox[{"Vn", "^", "2"}], "/", 
    RowBox[{"Re", "[", "Zc", "]"}]}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.921833679902631*^9, 3.921833846798513*^9}, {
   3.9218338799909067`*^9, 3.921833919373364*^9}, {3.921834282685533*^9, 
   3.9218343407757387`*^9}, 3.921928418736725*^9, {3.921928852675314*^9, 
