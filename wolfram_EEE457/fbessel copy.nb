Notebook[{
Cell[BoxData[{
    \(\(Off[General::"\<spell\>", 
        General::"\<spell1\>"];\)\), "\[IndentingNewLine]", 
    \(<< Graphics`Graphics`\), "\[IndentingNewLine]", 
    \(<< Graphics`Legend`\)}], "Input"],

Cell[BoxData[
    \(\(SetOptions[{Plot, ListPlot, \ LogLinearListPlot, LogLogPlot, 
          LogPlot}, Frame \[Rule] True, Axes \[Rule] False, 
        ImageSize \[Rule] 600, DefaultFont \[Rule] {"\<Helvetica\>", 14}, 
        PlotStyle \[Rule] {PointSize[0.015]}];\)\)], "Input"],

Cell[CellGroupData[{

Cell[BoxData[{
    \(Format[J[i_]] := J\_i\), "\[IndentingNewLine]", 
    \(Format[K[i_]] := K\_i\), "\[IndentingNewLine]", 
    \(Format[I[i_]] := I\_i\), "\[IndentingNewLine]", 
    \(Format[Y[i_]] := Y\_i\)}], "Input"],

Cell[BoxData[
    RowBox[{\(SetDelayed::"write"\), \(\(:\)\(\ \)\), "\<\"Tag \
\\!\\(Complex\\) in \\!\\(MakeBoxes[\\(\\(\\(\\(\[ImaginaryI][i_]\\)\\), \
FormatType_\\)\\)]\\) is Protected. \
\\!\\(\\*ButtonBox[\\\"More\[Ellipsis]\\\", ButtonStyle->\\\"RefGuideLinkText\
\\\", ButtonFrame->None, ButtonData:>\\\"General::write\\\"]\\)\"\>"}]], \
"Message"],

Cell[BoxData[
    RowBox[{\(SetDelayed::"write"\), \(\(:\)\(\ \)\), "\<\"Tag \
\\!\\(Complex\\) in \\!\\(StandardForm\\`\\(\[ImaginaryI][i_]\\)\\) is \
Protected. \\!\\(\\*ButtonBox[\\\"More\[Ellipsis]\\\", \
ButtonStyle->\\\"RefGuideLinkText\\\", ButtonFrame->None, \
ButtonData:>\\\"General::write\\\"]\\)\"\>"}]], "Message"],

Cell[BoxData[
    \($Failed\)], "Output"]
}, Open  ]],

Cell[BoxData[
    \(\(style = Table[Hue[x \((0.25)\)], {x, 1, 5}];\)\)], "Input"],

Cell[BoxData[{
    \(\(legendJ = Table[J[i], {i, 1, 5}];\)\), "\[IndentingNewLine]", 
    \(\(legendI = Table[I[i], {i, 1, 5}];\)\), "\[IndentingNewLine]", 
    \(\(legendK = Table[K[i], {i, 1, 5}];\)\), "\[IndentingNewLine]", 
    \(\(legendY = Table[Y[i], {i, 1, 5}];\)\)}], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
    \(\(f1 = 
        Plot[Evaluate[Table[BesselJ[n, x], {n, 1, 5}], {x, 0, 20}], 
          PlotRange \[Rule] All, PlotStyle \[Rule] style, 
          PlotLabel \[Rule] "\<Bessel J\>", PlotLegend \[Rule] legendJ, 
          LegendShadow \[Rule] None, LegendPosition \[Rule] {1, \(- .50\)}, 
          FrameLabel \[Rule] {"\<x\>", "\<Amplitude\>"}];\)\)], "Input"],

Cell[GraphicsData["PostScript", "\<\
