Cell["Para condutores cilindricos s\[OAcute]lidos", "Text",
 CellChangeTimes->{{3.8365045308218393`*^9, 
  3.836504541640485*^9}},ExpressionUUID->"37564632-8fd7-4ccf-8968-\
c7dd14f3fd5b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Zapp1", "[", 
   RowBox[{"Omega_", ",", " ", "Rhoc_", ",", " ", "rf_", ",", "  ", 
    RowBox[{"Mur_", ":", " ", "1"}], ",", " ", 
    RowBox[{"Mu_", ":", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"4.", "*", "Pi"}], ")"}], "/", 
      RowBox[{"10", "^", "7"}]}]}]}], "]"}], " ", ":=", " ", "\n", " ", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"Etac", " ", "=", " ", 
      RowBox[{"N", "[", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"I", "*", "Omega", "*", "Mur", "*", "Mu"}], ")"}], "/", 
         "Rhoc"}], "]"}], "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Etac", " ", 
      RowBox[{"Rhoc", "/", 
       RowBox[{"(", 
        RowBox[{"2", " ", "\[Pi]", " ", "rf"}], ")"}]}], 
      RowBox[{"Coth", "[", 
       RowBox[{"0.777", " ", "Etac", " ", "rf"}], "]"}]}], "+", 
     RowBox[{"0.356", " ", 
      RowBox[{"Rhoc", "/", 
       RowBox[{"(", 
        RowBox[{"2", " ", "\[Pi]", " ", "rf"}], ")"}]}]}]}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.836504310572135*^9, 3.8365045258678308`*^9}, {
  3.836504692294114*^9, 3.836504693419306*^9}},
 CellLabel->"In[76]:=",ExpressionUUID->"8d0e518b-6aa3-49a4-97a0-51e97f1fad35"],

Cell["Para condutores cilindricos tubulares", "Text",
 CellChangeTimes->{{3.8365045308218393`*^9, 3.836504541640485*^9}, {
  3.8365045789763412`*^9, 
  3.836504583345646*^9}},ExpressionUUID->"94982a1e-d00d-4cc8-9cc1-\
b596ff1bcee0"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Zapp2", "[", 
   RowBox[{
   "Omega_", ",", " ", "Rhoc_", ",", " ", "rf_", ",", " ", "ri_", ",", " ", 
    RowBox[{"Mur_", ":", " ", "1"}], ",", " ", 
    RowBox[{"Mu_", ":", " ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"4.", "*", "Pi"}], ")"}], "/", 
      RowBox[{"10", "^", "7"}]}]}]}], "]"}], " ", ":=", " ", "\n", " ", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"Etac", " ", "=", " ", 
      RowBox[{"N", "[", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"I", "*", "Omega", "*", "Mur", "*", "Mu"}], ")"}], "/", 
         "Rhoc"}], "]"}], "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Etac", " ", 
      RowBox[{"Rhoc", "/", 
       RowBox[{"(", 
        RowBox[{"2", " ", "\[Pi]", " ", "rf"}], ")"}]}], 
      RowBox[{"Coth", "[", 
       RowBox[{"Etac", " ", 
        RowBox[{"(", 
         RowBox[{"rf", "-", "ri"}], ")"}]}], "]"}]}], "+", " ", 
     RowBox[{"Rhoc", "/", 
      RowBox[{"(", 
       RowBox[{"2", " ", "\[Pi]", " ", "rf", 
        RowBox[{"(", 
         RowBox[{"rf", "+", "ri"}], ")"}]}], ")"}]}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.836504310572135*^9, 3.8365045258678308`*^9}, {
  3.8365045751550303`*^9, 3.836504636603692*^9}},
 CellLabel->"In[77]:=",ExpressionUUID->"b02c18b9-33e3-4d44-966f-12c21c74907f"]
}, Open  ]]
}, Open  ]],

