 RowBox[{
  RowBox[{"Zbja1", "=", 
   RowBox[{"Zapp1", "[", 
    RowBox[{
     RowBox[{"2", "\[Pi]", " ", "f"}], ",", " ", "\[Rho]", ",", "re"}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Zbja2", "=", 
    RowBox[{"Zapp2", "[", 
     RowBox[{
      RowBox[{"2", "\[Pi]", " ", "f"}], ",", " ", "\[Rho]", ",", "re", ",", 
