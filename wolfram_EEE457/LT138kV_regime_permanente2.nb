Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "impedancia", " ", "interna", " ", "de", " ", "condutores", " ", 
    "tubulares"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{"ZintTubo", "[", 
    RowBox[{
    "Omega_", ",", "Rhoc_", ",", " ", "rf_", ",", " ", "rint_", ",", " ", 
     RowBox[{"Mur_", ":", " ", "1"}], ",", " ", 
     RowBox[{"Mu_", ":", " ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"4.", "*", "Pi"}], ")"}], "/", 
       RowBox[{"10", "^", "7"}]}]}]}], "]"}], " ", ":=", " ", "\n", "       ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "r", "}"}], ",", "  ", 
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Etac", " ", "=", " ", 
          RowBox[{"N", "[", 
           RowBox[{"Sqrt", "[", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"I", "*", "Omega", "*", "Mur", "*", "Mu"}], ")"}], "/", 
             "Rhoc"}], "]"}], "]"}]}], ",", 
         RowBox[{"ri", "=", 
          RowBox[{"rint", "+", 
           RowBox[{"10", "^", 
            RowBox[{"-", "6"}]}]}]}]}], "}"}], ",", " ", "\n", "        ", 
       RowBox[{"With", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Den", " ", "=", " ", 
            RowBox[{
             RowBox[{
              RowBox[{"BesselK", "[", 
               RowBox[{"1", ",", 
                RowBox[{"Etac", "*", "ri"}]}], "]"}], "*", 
              RowBox[{"BesselI", "[", 
               RowBox[{"1", ",", 
                RowBox[{"Etac", "*", "rf"}]}], "]"}]}], "-", 
             RowBox[{
              RowBox[{"BesselK", "[", 
               RowBox[{"1", ",", 
                RowBox[{"Etac", "*", "rf"}]}], "]"}], "*", 
              RowBox[{"BesselI", "[", 
               RowBox[{"1", ",", 
                RowBox[{"Etac", "*", "ri"}]}], "]"}]}]}]}], ",", " ", "\n", 
           "             ", 
           RowBox[{"Num", " ", "=", "  ", 
            RowBox[{
             RowBox[{
              RowBox[{"BesselK", "[", 
               RowBox[{"1", ",", 
                RowBox[{"Etac", "*", "ri"}]}], "]"}], "*", 
              RowBox[{"BesselI", "[", 
               RowBox[{"0", ",", 
                RowBox[{"Etac", "*", "rf"}]}], "]"}]}], "+", 
             RowBox[{
              RowBox[{"BesselK", "[", 
               RowBox[{"0", ",", 
                RowBox[{"Etac", "*", "rf"}]}], "]"}], "*", 
              RowBox[{"BesselI", "[", 
               RowBox[{"1", ",", 
                RowBox[{"Etac", "*", "ri"}]}], "]"}]}]}]}]}], "}"}], ",", " ",
          "\n", "        ", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"Rhoc", "*", "Etac"}], ")"}], "*", "Num"}], ")"}], "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"2", "*", "Pi", "*", "rf"}], ")"}], "*", "Den"}], 
           ")"}]}]}], "]"}]}], "]"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.8081768992607718`*^9, 3.808176938092792*^9}},
 CellLabel->
  "In[311]:=",ExpressionUUID->"8d248919-7342-4b20-8af9-a7f340c14383"],

