  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"c", "=", 
   RowBox[{
    RowBox[{"f1", "[", 
     RowBox[{"[", 
      RowBox[{"10", ",", " ", "9"}], "]"}], "]"}], " ", 
    RowBox[{
     RowBox[{"10", "^", 
