Cell[BoxData[
 RowBox[{
  RowBox[{"a", "[", 
   RowBox[{"s_", ",", " ", "\[ScriptL]_"}], "]"}], ":=", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"z", "=", " ", 
       RowBox[{"r", " ", "+", " ", 
        RowBox[{"s", " ", "l"}]}]}], ",", 
      RowBox[{"y", "=", 
       RowBox[{"s", " ", "c"}]}]}], "}"}], ",", "\[IndentingNewLine]", " ", 
    RowBox[{"Cosh", "[", 
     RowBox[{
      RowBox[{"Sqrt", "[", 
       RowBox[{"z", " ", "y"}], "]"}], " ", "\[ScriptL]"}], "]"}]}], " ", 
   "]"}], " "}]], "Input",
 CellChangeTimes->{{3.921739705247139*^9, 3.921739706512598*^9}, {
