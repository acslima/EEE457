Cell[BoxData[
 RowBox[{
  RowBox[{"y1", "[", 
   RowBox[{"s_", ",", " ", "\[ScriptL]_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"z", "=", " ", 
       RowBox[{"r", " ", "+", " ", 
        RowBox[{"s", " ", "l"}]}]}], ",", 
      RowBox[{"y", "=", 
       RowBox[{"s", " ", "c"}]}], ",", " ", "yc", ",", " ", "\[Gamma]"}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\[Gamma]", "=", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"z", " ", "y"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"yc", " ", "=", " ", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"y", "/", "z"}], "]"}]}], ";", "\n", 
     RowBox[{"yc", " ", 
      RowBox[{"Coth", "[", 
       RowBox[{"\[Gamma]", " ", "\[ScriptL]"}], "]"}]}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
