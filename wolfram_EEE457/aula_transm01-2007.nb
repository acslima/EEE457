Cell[BoxData[{
    \(\(ncond = Length[xy2];\)\), "\[IndentingNewLine]", 
    \(\(xc = xy2[\([All, 1]\)];\)\), "\n", 
    \(\(yc = xy2[\([All, 2]\)];\)\), "\n", 
    \(\(nfases = 3;\)\), "\[IndentingNewLine]", 
    \(\(nfeixe = 4;\)\), "\n", 
    \(\(npr = 2;\)\), "\[IndentingNewLine]", 
    \(\(rpr = 3/4\ r;\)\)}], "Input"],

Cell[CellGroupData[{

Cell["C\[AAcute]lculo da Matriz de Coeficiente de Potencial", "Subsection"],

Cell[BoxData[
    \(\(Pcompleto = 
        Table[If[i \[NotEqual] j, 
            Log[\((\[Sqrt]\((\((xc[\([i]\)] - xc[\([j]\)])\)\^2 + \((yc[\([i]\
\)] + yc[\([j]\)])\)\^2)\))\)/\((\[Sqrt]\((\((xc[\([i]\)] - xc[\([j]\)])\)\^2 \
+ \((yc[\([i]\)] - yc[\([j]\)])\)\^2)\))\)], \[IndentingNewLine]If[
              i \[LessEqual] ncond - npr, Log[2\ yc[\([i]\)]\/r], 
              Log\ [2  yc[\([i]\)]\/rpr]]], {i, 1, ncond}, {j, 1, 
            ncond}];\)\)], "Input"],

Cell[BoxData[{
    \(Pspr = 
      Inverse[Take[Inverse[Pcompleto], ncond - npr, ncond - npr]]; \ \  (*\ 
      elimina\ cabo\ pr*) \[IndentingNewLine]aux02 = 
      Inverse[Pspr];\), "\[IndentingNewLine]", 
    \(\(Cfase = 
        Table[Sum[
            aux02[\([i, j]\)]\ , {i, nfeixe*m\  - \((nfeixe - 1)\), 
              nfeixe*m}, {j, nfeixe*n\  - \((nfeixe - 1)\), nfeixe*n}], {m, 
            1, nfases}, {n, 1, nfases}];\)\), "\[IndentingNewLine]", 
    \( (*\ elimina\ feixe\ *) \)}], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
    \(MatrixForm[Y = I\ \[Omega]\ 2.0\ \[Pi]\ \[Epsilon]\ Cfase]\)], "Input"],

Cell[BoxData[
    TagBox[
      RowBox[{"(", "\[NoBreak]", GridBox[{
            {\(1.6054484997666216`\ \[ImaginaryI]\ \[Epsilon]\ \[Omega]\), \(\
\(-0.3291697132897261`\)\ \[ImaginaryI]\ \[Epsilon]\ \[Omega]\), \
\(\(-0.09703316457609407`\)\ \[ImaginaryI]\ \[Epsilon]\ \[Omega]\)},
            {\(\(-0.3291697132897261`\)\ \[ImaginaryI]\ \[Epsilon]\ \
\[Omega]\), \(1.501649163137342`\ \[ImaginaryI]\ \[Epsilon]\ \[Omega]\), \
\(\(-0.32916971328972605`\)\ \[ImaginaryI]\ \[Epsilon]\ \[Omega]\)},
            {\(\(-0.09703316457609404`\)\ \[ImaginaryI]\ \[Epsilon]\ \[Omega]\
\), \(\(-0.3291697132897261`\)\ \[ImaginaryI]\ \[Epsilon]\ \[Omega]\), \
\(1.6054484997666232`\ \[ImaginaryI]\ \[Epsilon]\ \[Omega]\)}
            },
          RowSpacings->1,
          ColumnSpacings->1,
          ColumnAlignments->{Left}], "\[NoBreak]", ")"}],
      Function[ BoxForm`e$, 
        MatrixForm[ BoxForm`e$]]]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(Cfase\)], "Input"],

Cell[BoxData[
    \({{0.2555150646173254`, \(-0.05238898698620186`\), \
\(-0.015443307786134767`\)}, {\(-0.05238898698620186`\), 
        0.23899488710311595`, \(-0.052388986986201855`\)}, \
{\(-0.015443307786134761`\), \(-0.05238898698620187`\), 
        0.25551506461732565`}}\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(Cfaseprop = Tr[Cfase]/3\)], "Input"],

Cell[BoxData[
    \(0.25000833877925566`\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(Cfasemut = \((Cfase[\([1, 2]\)] + Cfase[\([1, 3]\)] + 
            Cfase[\([2, 3]\)])\)/3\)], "Input"],

Cell[BoxData[
    \(\(-0.040073760586179494`\)\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(Ctrans = 
      Table[If[i \[NotEqual] j, \ Cfasemut, Cfaseprop], {i, 3}, {j, 
          3}]\)], "Input"],

Cell[BoxData[
    \({{0.25000833877925566`, \(-0.040073760586179494`\), \
\(-0.040073760586179494`\)}, {\(-0.040073760586179494`\), 
        0.25000833877925566`, \(-0.040073760586179494`\)}, \
{\(-0.040073760586179494`\), \(-0.040073760586179494`\), 
        0.25000833877925566`}}\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

