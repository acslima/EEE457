Cell[CellGroupData[{

Cell["Par\[AHat]metros de Seq\[UDoubleDot]\[EHat]ncia para a LT  transposta", \
"Subsection"],

Cell[BoxData[{
    \(\(Potm = \(Pot[\([1, 2]\)] + Pot[\([1, 3]\)] + Pot[\([2, \
3]\)]\)\/3;\)\), "\[IndentingNewLine]", 
    \(\(Pots = Tr[Pot]/3;\)\), "\[IndentingNewLine]", 
    \(\(Capacm = \(1\/3\) \((Clinha[\([1, 2]\)] + Clinha[\([1, 3]\)] + 
              Clinha[\([2, 3]\)])\);\)\), "\[IndentingNewLine]", 
    \(\(Capacs = \(1\/3\) Tr[Clinha];\)\)}], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
    \(MatrixForm[
      PotTrans = 
        Table[If[i \[NotEqual] j, \ Potm, \ Pots], {i, 3}, {j, 
            3}]]\)], "Input"],

Cell[BoxData[
    TagBox[
      RowBox[{"(", "\[NoBreak]", GridBox[{
            {"7.600902459542081`", "0.9237551978496812`", 
              "0.9237551978496812`"},
            {"0.9237551978496812`", "7.600902459542081`", 
              "0.9237551978496812`"},
            {"0.9237551978496812`", "0.9237551978496812`", 
              "7.600902459542081`"}
            },
          RowSpacings->1,
          ColumnSpacings->1,
          ColumnAlignments->{Left}], "\[NoBreak]", ")"}],
      Function[ BoxForm`e$, 
        MatrixForm[ BoxForm`e$]]]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(MatrixForm[
      Llinha012Trans = Inverse[A] . PotTrans . A // Chop]\)], "Input"],

Cell[BoxData[
    TagBox[
      RowBox[{"(", "\[NoBreak]", GridBox[{
            {"9.448412855241443`", "0", "0"},
            {"0", "6.677147261692401`", "0"},
            {"0", "0", "6.677147261692399`"}
            },
          RowSpacings->1,
          ColumnSpacings->1,
          ColumnAlignments->{Left}], "\[NoBreak]", ")"}],
      Function[ BoxForm`e$, 
        MatrixForm[ BoxForm`e$]]]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(MatrixForm[
      Clinha012Trans = 
        Inverse[A] . 
            Table[If[i \[NotEqual] j, Capacm, \ Capacs], {i, 3}, {j, 3}]\  . 
            A // Chop]\)], "Input"],

Cell[BoxData[
    TagBox[
      RowBox[{"(", "\[NoBreak]", GridBox[{
            {"0.10595803099164766`", "0", "0"},
            {"0", "0.15031004655744712`", "0"},
            {"0", "0", "0.15031004655744712`"}
            },
          RowSpacings->1,
          ColumnSpacings->1,
          ColumnAlignments->{Left}], "\[NoBreak]", ")"}],
      Function[ BoxForm`e$, 
        MatrixForm[ BoxForm`e$]]]], "Output"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Elimina\[CCedilla]\[ATilde]o do Cabo p\[AAcute]ra-raios", "Subsection"],

Cell["\<\
Supomos, agora, que h\[AAcute] no circuito dois cabos \
p\[AAcute]ra-raios localizados 3 m acima dos condutores de fase e colocados a \
5 m do condutor central  em rela\[CCedilla]\[ATilde]o a disposi\[CCedilla]\
\[ATilde]o horizontal. Com isto temos:\
\>", "Text"],

Cell[BoxData[
    \(\(xy = {{\(-7\), 10}, {0, 10}, {7, 10}, {\(-5\), 13}, {5, 
            13}};\)\)], "Input"],

Cell[CellGroupData[{

Cell[BoxData[{
    \(\(mostra2 = \({Circle[#,  .25]} &\) /@ xy;\)\), "\[IndentingNewLine]", 
    \(\(t2 = 
        Show[Graphics[mostra2], AspectRatio \[Rule] Automatic, 
          Axes \[Rule] False, Frame -> Automatic, 
          PlotRange \[Rule] {{\(-10\), 10}, {\(- .10\), 25}}, 
          FrameLabel \[Rule] {"\<dist\[AHat]ncia (m)\>", "\<dist\[AHat]ncia \
(m)\>"}];\)\)}], "Input",
  FontSize->12],

