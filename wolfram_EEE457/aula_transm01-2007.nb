Cell[CellGroupData[{

Cell["Nova Matriz de Coeficientes de Potencial", "Subsubsection"],

Cell[BoxData[{
    \(\(xc = xy[\([All, 1]\)];\)\), "\n", 
    \(\(yc = xy[\([All, 2]\)];\)\), "\[IndentingNewLine]", 
    \(\(ncond = Length[xy];\)\), "\n", 
    \(\(nfases = 3;\)\), "\n", 
    \(\(npr = 2;\)\), "\[IndentingNewLine]", 
    \(\(rpr = 3/4\ r;\)\)}], "Input"],

Cell[BoxData[
    \(\(Pfull = 
        Table[If[
              i \[NotEqual] 
                j, \((\ \ \
Log[\((\[Sqrt]\((\((xc\_\(\(\[LeftDoubleBracket]\)\(i\)\(\[RightDoubleBracket]\
\)\) - xc\_\(\(\[LeftDoubleBracket]\)\(j\)\(\[RightDoubleBracket]\)\))\)\^2 + \
\((yc\_\(\(\[LeftDoubleBracket]\)\(i\)\(\[RightDoubleBracket]\)\) + yc\_\(\(\
\[LeftDoubleBracket]\)\(j\)\(\[RightDoubleBracket]\)\))\)\^2)\))\)/\((\[Sqrt]\
\((\((xc\_\(\(\[LeftDoubleBracket]\)\(i\)\(\[RightDoubleBracket]\)\) - xc\_\(\
\(\[LeftDoubleBracket]\)\(j\)\(\[RightDoubleBracket]\)\))\)\^2 + \((yc\_\(\(\
\[LeftDoubleBracket]\)\(i\)\(\[RightDoubleBracket]\)\) - yc\_\(\(\
\[LeftDoubleBracket]\)\(j\)\(\[RightDoubleBracket]\)\))\)\^2)\))\)])\), 
              If[i \[LessEqual] ncond - npr, \((\ 
                  Log[\(2\ \((yc\_\(\(\[LeftDoubleBracket]\)\(i\)\(\
\[RightDoubleBracket]\)\))\)\)\/r])\)\ , \((Log[\(2 \((\ \ yc\_\(\(\
\[LeftDoubleBracket]\)\(i\)\(\[RightDoubleBracket]\)\))\)\)\/rpr])\)\ ]], {i, 
              1, ncond}, {j, 1, ncond}] // N;\)\)], "Input"],

