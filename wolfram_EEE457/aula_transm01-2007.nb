Cell["\<\
Consideramos que as fases s\[ATilde]o alimentadas por \
tens\[OTilde]es sim\[EAcute]tricas e equilibradas cujo valor de  pico \
\[EAcute] de 200 kV para a tens\[ATilde]o e de 500 A para a corrente. A rede \
posui freq\[UDoubleDot]\[EHat]ncia de opera\[CCedilla]\[ATilde]o \[EAcute] de \
60 Hz.\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[{
    \(v[u_:  200, f_:  60] = 
      u\ {Cos[2\ \[Pi]\ f], \ Cos[2\ \[Pi]\ f\  - \ \(2\ \[Pi]\)\/3], \ 
          Cos[2\ \[Pi]\ f - \ \(4\ \[Pi]\)\/3]}\), "\[IndentingNewLine]", 
    \(i[io_:  500, f_:  60] = 
      io {\ Cos[2\ \[Pi]\ f], \ \ Cos[2\ \[Pi]\ f\  - \ \(2\ \[Pi]\)\/3], \ 
          Cos[2\ \[Pi]\ f - \ \(4\ \[Pi]\)\/3]}\)}], "Input"],

Cell[BoxData[
    \({u\ Cos[2\ f\ \[Pi]], u\ Cos[\(2\ \[Pi]\)\/3 - 2\ f\ \[Pi]], 
      u\ Cos[\(4\ \[Pi]\)\/3 - 2\ f\ \[Pi]]}\)], "Output"],

Cell[BoxData[
    \({io\ Cos[2\ f\ \[Pi]], io\ Cos[\(2\ \[Pi]\)\/3 - 2\ f\ \[Pi]], 
      io\ Cos[\(4\ \[Pi]\)\/3 - 2\ f\ \[Pi]]}\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Matriz de Coeficientes de Potencial", "Subsubsection"],

Cell[CellGroupData[{

Cell[BoxData[
    \(MatrixForm[
      Pot = Table[
            If[i \[NotEqual] \ j, \ 
              Log[\@\(\(\((xc[\([i]\)] - xc[\([j]\)])\)\^2 + \((yc[\([i]\)] + \
yc[\([j]\)])\)\^2\)\/\(\((xc[\([i]\)] - xc[\([j]\)])\)\^2 + \((yc[\([i]\)] - \
yc[\([j]\)])\)\^2\)\)], \ Log[\(yc[\([i]\)] + yc[\([j]\)]\)\/r]], {i, 3}, {j, 
              3}] // N]\)], "Input"],

Cell[BoxData[
    TagBox[
      RowBox[{"(", "\[NoBreak]", GridBox[{
            {"7.600902459542082`", "1.1076012948158138`", 
              "0.5560630039174161`"},
            {"1.1076012948158138`", "7.600902459542082`", 
              "1.1076012948158138`"},
            {"0.5560630039174161`", "1.1076012948158138`", 
              "7.600902459542082`"}
            },
          RowSpacings->1,
          ColumnSpacings->1,
          ColumnAlignments->{Left}], "\[NoBreak]", ")"}],
      Function[ BoxForm`e$, 
        MatrixForm[ BoxForm`e$]]]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(MatrixForm[Clinha = Inverse[Pot]]\)], "Input"],

Cell[BoxData[
    TagBox[
      RowBox[{"(", "\[NoBreak]", GridBox[{
            {
              "0.1347969347544021`", \(-0.018600536981737435`\), \
\(-0.007150941602324617`\)},
            {\(-0.018600536981737432`\), 
              "0.13698425459773772`", \(-0.018600536981737432`\)},
            {\(-0.007150941602324618`\), \(-0.018600536981737432`\), 
              "0.1347969347544021`"}
            },
          RowSpacings->1,
          ColumnSpacings->1,
          ColumnAlignments->{Left}], "\[NoBreak]", ")"}],
      Function[ BoxForm`e$, 
        MatrixForm[ BoxForm`e$]]]], "Output"]
}, Open  ]],

Cell[BoxData[
    \(\(a = Exp[\[ImaginaryJ]\ 120\ Degree];\)\)], "Input"],

Cell[BoxData[
    RowBox[{
      RowBox[{"A", "=", 
        RowBox[{"(", GridBox[{
              {"1", "1", "1"},
              {"1", \(a\^2\), "a"},
              {"1", "a", \(a\^2\)}
              }], ")"}]}], ";"}]], "Input"]
}, Open  ]],

