Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", "Properties", " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"\[Epsilon]", "=", 
     RowBox[{"8.85", " ", 
      RowBox[{"10", "^", 
       RowBox[{"-", "12"}]}]}]}], ";"}], "          ", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Permittivity", " ", "of", " ", "Free", " ", "Space"}], " ", "-",
      " ", 
     RowBox[{"F", "/", "m"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"c", "=", "300."}], ";"}], "                   ", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"Speed", " ", "of", " ", "Light"}], " ", "-", " ", 
     RowBox[{"m", "/", 
      StyleBox[
       RowBox[{
        StyleBox["m",
         FontFamily->"Symbol"], "s"}]]}]}], " ", "*)"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"Time", " ", "delay", " ", "of", " ", "ground", " ", "bounce"}], 
    " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"To", "[", 
      RowBox[{"\[Psi]_", ",", " ", "h_"}], "]"}], ":=", 
     RowBox[{"2", " ", "h", " ", 
      RowBox[{
       RowBox[{"Sin", "[", 
        RowBox[{"\[Psi]", " ", "Degree"}], "]"}], "/", "c"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Coupled", " ", "voltage", " ", "prior", " ", "to", " ", "arrival", " ", 
     "of", " ", "the", " ", "ground", " ", "bounce", " ", "term"}], " ", 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"VCearly", "[", 
      RowBox[{"t_", ",", " ", "\[Tau]1_"}], "]"}], ":=", 
     RowBox[{"c", " ", "\[Tau]1", " ", 
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{"Exp", "[", 
         RowBox[{
          RowBox[{"-", "t"}], "/", "\[Tau]1"}], "]"}]}], ")"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "Coupled", " ", "voltage", " ", "after", " ", "the", " ", "arrival", " ", 
     "of", " ", "the", " ", "ground", " ", "bounce", " ", "term"}], " ", 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"VClate", "[", 
      RowBox[{
      "t_", ",", " ", "\[Tau]1_", ",", " ", "p_", ",", " ", "\[Psi]_", ",", 
       " ", "\[Sigma]_", ",", " ", "h_"}], "]"}], ":=", 
     RowBox[{"c", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"\[Tau]1", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Exp", "[", 
            RowBox[{
             RowBox[{"To", "[", 
              RowBox[{"\[Psi]", ",", " ", "h"}], "]"}], "/", "\[Tau]1"}], 
            "]"}], "-", "1"}], ")"}], " ", 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", "t"}], "/", "\[Tau]1"}], "]"}]}], "-", 
        RowBox[{"2000.", " ", "I", " ", 
         RowBox[{"Sqrt", "[", 
          RowBox[{"\[Epsilon]", "/", "\[Sigma]"}], "]"}], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Sin", "[", 
            RowBox[{"\[Psi]", " ", "Degree"}], "]"}], "^", 
           RowBox[{"(", 
            RowBox[{"1", "-", 
             RowBox[{"2", " ", 
              RowBox[{"Boole", "[", 
               RowBox[{"p", "\[Equal]", "\"\<Vert\>\""}], "]"}]}]}], ")"}]}], 
          ")"}], " ", 
         RowBox[{"Sqrt", "[", "\[Tau]1", "]"}], 
         RowBox[{"Exp", "[", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{"(", 
             RowBox[{"t", "-", 
              RowBox[{"To", "[", 
               RowBox[{"\[Psi]", ",", " ", "h"}], "]"}]}], ")"}]}], "/", 
           "\[Tau]1"}], "]"}], 
         RowBox[{"Erf", "[", 
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"-", 
             RowBox[{"(", 
              RowBox[{"t", "-", 
               RowBox[{"To", "[", 
                RowBox[{"\[Psi]", ",", "h"}], " ", "]"}]}], ")"}]}], "/", 
            "\[Tau]1"}], "]"}], "]"}]}]}], ")"}]}]}], ";"}]}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{
