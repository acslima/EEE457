Cell[BoxData[{
    \(\(Pinv = 
        Inverse[Table[
            If[i \[NotEqual] j, 
              Log[\((\[Sqrt]\((\((xc[\([i]\)] - xc[\([j]\)])\)\^2 + \
\((yc[\([i]\)] + yc[\([j]\)])\)\^2)\))\)/\((\[Sqrt]\((\((xc[\([i]\)] - \
xc[\([j]\)])\)\^2 + \((yc[\([i]\)] - yc[\([j]\)])\)\^2)\))\)], \
