Notebook[{
Cell["Compara\[CCedilla]\[ATilde]o dos c\[AAcute]lculos de Par\[AHat]metros \
unit\[AAcute]rios de LTs", "Title"],

Cell["Prof. Antonio Carlos Siqueira de Lima", "Subtitle"],

Cell[CellGroupData[{

Cell["Op\[CCedilla]\[OTilde]es de programa", "Subsection"],

Cell[BoxData[{
    \(<< LinearAlgebra`MatrixManipulation`\), "\[IndentingNewLine]", 
    \(<< Graphics`Graphics`\)}], "Input"],

Cell[BoxData[
    \(\(Off[General::"\<spell\>", General::"\<spell1\>"];\)\)], "Input"],

Cell[BoxData[{
    \(\(plstyle1 = {AbsoluteThickness[2], 
          RGBColor[1, 0, 0]};\)\), "\[IndentingNewLine]", 
    \(\(plstyle2 = {AbsoluteThickness[2], 
          RGBColor[0, 0, 1]};\)\), "\[IndentingNewLine]", 
    \(\(plstyle3 = {AbsoluteThickness[2], PointSize[ .015], 
          RGBColor[0, 1, 0]};\)\)}], "Input"],

Cell[BoxData[{
    \(\(SetOptions[{ListPlot, \ LogLinearListPlot, LogLogListPlot}, 
        Axes \[Rule] False, Frame \[Rule] True, PlotJoined \[Rule] True, 
        ImageSize \[Rule] 450, DefaultFont \[Rule] {"\<Helvetica\>", 14}, 
        PlotStyle \[Rule] {AbsoluteThickness[2]}];\)\), "\n", 
    \(\(SetOptions[{Plot, \ LogLinearPlot, LogLogPlot}, Axes \[Rule] False, 
        Frame \[Rule] True, ImageSize \[Rule] 450, 
        DefaultFont \[Rule] {"\<Helvetica\>", 14}, 
        PlotStyle \[Rule] {AbsoluteThickness[2]}];\)\)}], "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Par\[AHat]metros do sistema", "Section"],

Cell[BoxData[{
    \(\(\[Omega] = 2\ \[Pi]\ 60.0;\)\), "\[IndentingNewLine]", 
    \(\(V = 420*10^3;\)\), "\n", 
    \(\(nfeixe = 4;\)\), "\n", 
    \(\(nfases = 3;\)\), "\n", 
    \(\(npr = 2;\)\)}], "Input"],

Cell[CellGroupData[{

Cell["Dados do condutor de fase", "Subsection"],

Cell[BoxData[{
    \(\(rf = 0.0108965;\)\), "\[IndentingNewLine]", 
    \(\(rint = 0.0040131;\)\), "\[IndentingNewLine]", 
    \(\(tempfase = 60;\)\), "\[IndentingNewLine]", 
    \(\(fencalum = 0.750223;\)\), "\[IndentingNewLine]", 
    \(\(\[Alpha]temp = 0.00454562;\)\), "\[IndentingNewLine]", 
    \(\(\[Rho]00 = 26.4573*10^\(-9\);\)\), "\[IndentingNewLine]", 
    \(\(\[Sigma]c = 
        fencalum/\((\[Rho]00 \((1 + \[Alpha]temp\ tempfase)\))\);\)\), "\
\[IndentingNewLine]", 
    \(\(\[Rho]c = 1/\[Sigma]c;\)\), "\[IndentingNewLine]", 
    \(\(\[Eta]c = \@\(\(I\ \[Omega]\ \[Mu]\)\/\[Rho]c\);\)\)}], "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Dados do cabo p\[AAcute]ra-raios", "Subsection"],

Cell[BoxData[{
    \(\(rpr = 0.004755;\)\), "\[IndentingNewLine]", 
    \(\(\[Rho]pr = 
        3.25397*\ 10^\(-3\)\ \[Pi]\ rpr\^2;\)\), "\[IndentingNewLine]", 
    \(\(\[Eta]pr = \@\(\(I\ \[Omega]\ \[Mu]\)\/\[Rho]pr\);\)\)}], "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Dados do meio externo, ar e solo ", "Subsection"],

Cell[BoxData[{
    \(\(\[Mu] = 4.0\ \[Pi]\ 10\^\(-7\);\)\), "\[IndentingNewLine]", 
    \(\(\[Epsilon] = 8.854*10^\(-12\);\)\), "\[IndentingNewLine]", 
    \(\(\[Rho]solo = 10000.0;\)\), "\[IndentingNewLine]", 
    \(\(p = \@\(\[Rho]solo\/\(\(I\)\(\ \)\(\[Omega]\)\(\ \)\(\[Mu]\)\(\ \
\)\)\);\)\)}], "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Configura\[CCedilla]\[ATilde]o do circuito", "Subsection"],

Cell[BoxData[
    \(\(\(\ \)\(xy2 = {{\(-8.25\), 13.5275}, \ {\(-8.25\), \ 
            13.5275 -  .50}, \ {\(-8. \) +  .25, 
            13.5275}, \ {\(-8. \) +  .25, 13.5275 -  .5}, \ {\(-0.25\), \ 
