Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "  ", 
   RowBox[{
   "ground", " ", "wires", " ", "are", " ", "not", " ", "explicitly", " ", 
    "considered", " ", "so", " ", "we", " ", "include", " ", "their", " ", 
