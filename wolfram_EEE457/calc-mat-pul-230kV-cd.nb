Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "impedancia", " ", "interna", " ", "de", " ", "condutores", " ", 
    "tubulares"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"ZintTubo", "[", 
     RowBox[{
     "Omega_", ",", " ", "Rhoc_", ",", " ", "rf_", ",", " ", "rint_", ",", 
      " ", 
      RowBox[{"Mur_", ":", " ", "1"}], ",", " ", 
      RowBox[{"Mu_", ":", " ", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"4.", "*", "Pi"}], ")"}], "/", 
        RowBox[{"10", "^", "7"}]}]}]}], "]"}], " ", ":=", " ", "\n", " ", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Etac", " ", "=", " ", 
         RowBox[{"N", "[", 
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"I", "*", "Omega", "*", "Mur", "*", "Mu"}], ")"}], "/", 
            "Rhoc"}], "]"}], "]"}]}], ",", " ", 
        RowBox[{"ri", " ", "=", " ", 
         RowBox[{"rint", " ", "+", " ", 
          RowBox[{"10", "^", 
           RowBox[{"-", "6"}]}]}]}]}], "}"}], ",", " ", "\n", "  ", 
      RowBox[{"With", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"Den", " ", "=", " ", "\n", "     ", 
           RowBox[{
            RowBox[{
             RowBox[{"BesselK", "[", 
              RowBox[{"1", ",", " ", 
               RowBox[{"Etac", "*", "ri"}]}], "]"}], "*", 
             RowBox[{"BesselI", "[", 
              RowBox[{"1", ",", " ", 
               RowBox[{"Etac", "*", "rf"}]}], "]"}]}], " ", "-", " ", "\n", 
            "      ", 
            RowBox[{
             RowBox[{"BesselK", "[", 
              RowBox[{"1", ",", " ", 
               RowBox[{"Etac", "*", "rf"}]}], "]"}], "*", 
             RowBox[{"BesselI", "[", 
              RowBox[{"1", ",", " ", 
               RowBox[{"Etac", "*", "ri"}]}], "]"}]}]}]}], ",", " ", "\n", 
          "    ", 
          RowBox[{"Num", " ", "=", " ", 
           RowBox[{
            RowBox[{
             RowBox[{"BesselK", "[", 
              RowBox[{"1", ",", " ", 
               RowBox[{"Etac", "*", "ri"}]}], "]"}], "*", 
             RowBox[{"BesselI", "[", 
              RowBox[{"0", ",", " ", 
               RowBox[{"Etac", "*", "rf"}]}], "]"}]}], " ", "+", " ", "\n", 
            "      ", 
            RowBox[{
             RowBox[{"BesselK", "[", 
              RowBox[{"0", ",", " ", 
               RowBox[{"Etac", "*", "rf"}]}], "]"}], "*", 
             RowBox[{"BesselI", "[", 
              RowBox[{"1", ",", " ", 
               RowBox[{"Etac", "*", "ri"}]}], "]"}]}]}]}]}], "}"}], ",", " ", 
        
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"Rhoc", "*", "Etac"}], ")"}], "*", "\n", "      ", 
           "Num"}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"2", "*", "Pi", "*", "rf"}], ")"}], "*", "Den"}], 
          ")"}]}]}], "]"}]}], "]"}]}], "\n", "      ", "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "impedancia", " ", "interna", " ", "de", " ", "condutor", " ", "sem", " ",
      "alma", " ", "de", " ", "aco"}], " ", "*)"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
    "impedancia", " ", "interna", " ", "de", " ", "condutores", " ", 
     "cilindricos"}], " ", "*)"}], " ", "\n", 
   RowBox[{"(*", 
    RowBox[{"Mur", "=", 
     RowBox[{"90", " ", "para", " ", "cables", " ", "de", " ", "aco"}]}], 
    "*)"}], "    ", "\n", 
   RowBox[{
    RowBox[{"Zin", "[", 
     RowBox[{"Omega_", ",", " ", "Rhopr_", ",", " ", "rpr_", ",", " ", 
      RowBox[{"Mur_", ":", "90"}], ",", " ", 
      RowBox[{"Mu_", ":", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"4", "*", "Pi"}], ")"}], "/", 
        RowBox[{"10", "^", "7"}]}]}]}], "]"}], " ", ":=", " ", "\n", "    ", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"Etapr", " ", "=", " ", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"I", "*", "Omega", "*", "Mu", "*", "Mur"}], ")"}], "/", 
          "Rhopr"}], "]"}]}], "}"}], ",", " ", "\n", "         ", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"Etapr", "*", "Rhopr"}], ")"}], "*", 
         RowBox[{"BesselI", "[", 
          RowBox[{"0", ",", " ", 
           RowBox[{"Etapr", "*", "rpr"}]}], "]"}]}], ")"}], "/", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"2", "*", "Pi", "*", "rpr"}], ")"}], "*", 
         RowBox[{"BesselI", "[", 
          RowBox[{"1", ",", 
           RowBox[{"Etapr", "*", "rpr"}]}], "]"}]}], ")"}]}]}], 
     "]"}]}]}]}]], "Input",
 CellLabel->"In[16]:=",ExpressionUUID->"030c26c4-e2c3-4a67-81e6-b6361a9d4cd3"],

