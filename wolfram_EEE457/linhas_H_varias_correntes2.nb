Notebook[{

Cell[CellGroupData[{
Cell["\<\
C\[AAcute]lculo de Linhas de Campo Magnetost\[AAcute]tico\
\>", "Title",
 CellChangeTimes->{{3.43410998141*^9, 3.43410999604*^9}}],

Cell["\<\
Antonio Carlos Siqueira de Lima
Outubro de 2008\
\>", "Subtitle",
 CellChangeTimes->{{3.434110006101*^9, 3.434110015523*^9}}],

Cell[TextData[{
 "Using the Biot\[Dash]Savart law, we obtain the well\[Hyphen]known magnetic \
field ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     StyleBox[
      OverscriptBox[
       StyleBox["B",
        FontWeight->"Bold"], 
       StyleBox["\[RightVector]",
        FontWeight->"Plain"]],
      FontWeight->"Bold"], "(", 
     OverscriptBox[
      StyleBox["x",
       FontWeight->"Bold"], "\[RightVector]"], ")"}], "\[Tilde]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "y"}], ",", "x", ",", "0"}], "}"}], "/", 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["x", "2"], "+", 
       SuperscriptBox["y", "2"]}], ")"}]}]}], TraditionalForm]]],
 "."
}], "Text",
 CellChangeTimes->{{3.434110595744*^9, 3.4341105969300003`*^9}, 
   3.434128861059*^9},
 CellTags->"Index[10, M[BInfiniteWire, GB]]"],

Cell["BInfiniteWire[{x_, y_}] =  {-y, x}/(x^2 + y^2);", "Input",
 CellChangeTimes->{3.4341120521289997`*^9}],

Cell["\<\
Using the last result, we define the components of the magnetic field.\
\>", "Text"],

Cell[CellGroupData[{

Cell["Duas correntes de mesmo sentido", "Section",
 CellChangeTimes->{{3.434123738387576*^9, 3.4341237454075766`*^9}}],

Cell[TextData[{
 "Instead of one infinite straight current, let us now deal with many of \
them. We choose 15 parallel currents at random positions and of random \
strengths. This system is translation\[Hyphen]invariant along the wires. So, \
we restrict ourselves to the plane ",
 Cell[BoxData[
  FormBox[
   RowBox[{"z", "=", "0"}], TraditionalForm]]],
 ". "
}], "Text"],

