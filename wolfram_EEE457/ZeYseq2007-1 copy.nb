Cell[CellGroupData[{

Cell["C\[AAcute]lculo da Admit\[AHat]ncia", "Subsubsection",
 Background->GrayLevel[1]],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Pinv", "=", 
   RowBox[{"Inverse", "[", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"i", "\[NotEqual]", "j"}], ",", 
        RowBox[{"Log", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"\[Sqrt]", 
            RowBox[{"(", 
             RowBox[{
              SuperscriptBox[
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"xc", "[", 
                  RowBox[{"[", "i", "]"}], "]"}], "-", 
                 RowBox[{"xc", "[", 
                  RowBox[{"[", "j", "]"}], "]"}]}], ")"}], "2"], "+", 
              SuperscriptBox[
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"yc", "[", 
                  RowBox[{"[", "i", "]"}], "]"}], "+", 
                 RowBox[{"yc", "[", 
                  RowBox[{"[", "j", "]"}], "]"}]}], ")"}], "2"]}], ")"}]}], 
           ")"}], "/", 
          RowBox[{"(", 
           RowBox[{"\[Sqrt]", 
            RowBox[{"(", 
             RowBox[{
              SuperscriptBox[
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"xc", "[", 
                  RowBox[{"[", "i", "]"}], "]"}], "-", 
                 RowBox[{"xc", "[", 
                  RowBox[{"[", "j", "]"}], "]"}]}], ")"}], "2"], "+", 
              SuperscriptBox[
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"yc", "[", 
                  RowBox[{"[", "i", "]"}], "]"}], "-", 
                 RowBox[{"yc", "[", 
                  RowBox[{"[", "j", "]"}], "]"}]}], ")"}], "2"]}], ")"}]}], 
           ")"}]}], "]"}], ",", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"i", "\[LessEqual]", 
           RowBox[{"ncond", "-", "npr"}]}], ",", 
          RowBox[{"Log", "[", 
           RowBox[{"2", " ", 
            FractionBox[
             RowBox[{"yc", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "rf"]}], "]"}], ",", 
          RowBox[{"Log", " ", "[", 
           RowBox[{"2", 
            FractionBox[
             RowBox[{"yc", "[", 
              RowBox[{"[", "i", "]"}], "]"}], "rpr"]}], "]"}]}], "]"}]}], 
       "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "ncond"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"j", ",", "1", ",", "ncond"}], "}"}]}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Pspr", "=", 
   RowBox[{"Inverse", "[", 
    RowBox[{"Take", "[", 
     RowBox[{"Pinv", ",", 
      RowBox[{"ncond", "-", "npr"}], ",", 
      RowBox[{"ncond", "-", "npr"}]}], "]"}], "]"}]}], ";", "  ", 
  RowBox[{"(*", " ", 
   RowBox[{"elimina", " ", "cabo", " ", "pr"}], "*)"}], "\[IndentingNewLine]",
   
  RowBox[{"aux02", "=", 
   RowBox[{"Inverse", "[", "Pspr", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Cfase", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{"aux02", "[", 
          RowBox[{"[", 
           RowBox[{"i", ",", "j"}], "]"}], "]"}], " ", ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", 
           RowBox[{
            RowBox[{"nfeixe", "*", "m"}], " ", "-", 
            RowBox[{"(", 
             RowBox[{"nfeixe", "-", "1"}], ")"}]}], ",", 
           RowBox[{"nfeixe", "*", "m"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", 
           RowBox[{
            RowBox[{"nfeixe", "*", "n"}], " ", "-", 
            RowBox[{"(", 
             RowBox[{"nfeixe", "-", "1"}], ")"}]}], ",", 
           RowBox[{"nfeixe", "*", "n"}]}], "}"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"m", ",", "1", ",", "nfases"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "1", ",", "nfases"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]"}], 
  RowBox[{"(*", " ", 
   RowBox[{"elimina", " ", "feixe"}], " ", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
