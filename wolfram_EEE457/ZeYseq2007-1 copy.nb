Cell[BoxData[{
 RowBox[{
  RowBox[{"rf", "=", "0.0108965"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rint", "=", "0.0040131"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"tempfase", "=", "60"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"fencalum", "=", "0.750223"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Alpha]temp", "=", "0.00454562"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Rho]00", "=", 
   RowBox[{"26.4573", "*", 
    RowBox[{"10", "^", 
     RowBox[{"-", "9"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Sigma]c", "=", 
   RowBox[{"fencalum", "/", 
    RowBox[{"(", 
     RowBox[{"\[Rho]00", 
      RowBox[{"(", 
       RowBox[{"1", "+", 
        RowBox[{"\[Alpha]temp", " ", "tempfase"}]}], ")"}]}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
