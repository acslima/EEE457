Cell["Para a LT Ideal", "Section"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Zfull02", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"i", "\[NotEqual]", "j"}], ",", 
         RowBox[{
          FractionBox[
           RowBox[{"\[ImaginaryI]", " ", "\[Omega]", " ", "\[Mu]"}], 
           RowBox[{"2", " ", "\[Pi]"}]], 
          RowBox[{"(", "  ", 
           RowBox[{"Log", "[", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"\[Sqrt]", 
               RowBox[{"(", 
                RowBox[{
                 SuperscriptBox[
                  RowBox[{"(", 
                   RowBox[{
                    SubscriptBox["xc", 
                    RowBox[{
                    "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}]], 
                    "-", 
                    SubscriptBox["xc", 
                    RowBox[{
                    "\[LeftDoubleBracket]", "j", "\[RightDoubleBracket]"}]]}],
                    ")"}], "2"], "+", 
                 SuperscriptBox[
                  RowBox[{"(", 
                   RowBox[{
                    SubscriptBox["yc", 
                    RowBox[{
                    "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}]], 
                    "+", 
                    SubscriptBox["yc", 
                    RowBox[{
                    "\[LeftDoubleBracket]", "j", "\[RightDoubleBracket]"}]]}],
                    ")"}], "2"]}], ")"}]}], ")"}], "/", 
             RowBox[{"(", 
              RowBox[{"\[Sqrt]", 
               RowBox[{"(", 
                RowBox[{
                 SuperscriptBox[
                  RowBox[{"(", 
                   RowBox[{
                    SubscriptBox["xc", 
                    RowBox[{
                    "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}]], 
                    "-", 
                    SubscriptBox["xc", 
                    RowBox[{
                    "\[LeftDoubleBracket]", "j", "\[RightDoubleBracket]"}]]}],
                    ")"}], "2"], "+", 
                 SuperscriptBox[
                  RowBox[{"(", 
                   RowBox[{
                    SubscriptBox["yc", 
                    RowBox[{
                    "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}]], 
                    "-", 
                    SubscriptBox["yc", 
                    RowBox[{
                    "\[LeftDoubleBracket]", "j", "\[RightDoubleBracket]"}]]}],
                    ")"}], "2"]}], ")"}]}], ")"}]}], "]"}], ")"}]}], ",", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"i", "\[LessEqual]", 
            RowBox[{"ncond", "-", "npr"}]}], ",", 
           RowBox[{
            FractionBox[
             RowBox[{"\[ImaginaryI]", " ", "\[Omega]", " ", "\[Mu]"}], 
             RowBox[{"2", " ", "\[Pi]"}]], 
            RowBox[{"(", " ", 
             RowBox[{"Log", "[", 
              FractionBox[
               RowBox[{"2", " ", 
                RowBox[{"(", 
                 SubscriptBox["yc", 
                  RowBox[{
                  "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}]], 
                 ")"}]}], "rf"], "]"}], ")"}]}], " ", ",", 
           RowBox[{
            FractionBox[
             RowBox[{"\[ImaginaryI]", " ", "\[Omega]", " ", "\[Mu]"}], 
             RowBox[{"2", " ", "\[Pi]"}]], 
            RowBox[{"(", 
             RowBox[{"Log", "[", 
              FractionBox[
               RowBox[{"2", 
                RowBox[{"(", " ", 
                 SubscriptBox["yc", 
                  RowBox[{
                  "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}]], 
                 ")"}]}], "rpr"], "]"}], ")"}]}]}], " ", "]"}]}], "]"}], ",", 
       
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "ncond"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "1", ",", "ncond"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Zspr", "=", 
     RowBox[{"Inverse", "[", 
      RowBox[{"Take", "[", 
       RowBox[{
        RowBox[{"Inverse", "[", "Zfull02", "]"}], ",", 
        RowBox[{"ncond", "-", "npr"}], ",", 
        RowBox[{"ncond", "-", "npr"}]}], "]"}], "]"}]}], ";", " ", 
    RowBox[{"(*", " ", 
     RowBox[{"elimina", " ", "cabo", " ", "pr"}], "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{"aux", "=", 
     RowBox[{"Inverse", "[", "Zspr", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"aux01", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{"aux", "[", 
          RowBox[{"[", 
           RowBox[{"i", ",", "j"}], "]"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", 
           RowBox[{
            RowBox[{"nfeixe", "*", "m"}], " ", "-", 
