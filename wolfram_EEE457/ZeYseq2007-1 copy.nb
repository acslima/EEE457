         RowBox[{"{", 
          RowBox[{"j", ",", 
           RowBox[{
            RowBox[{"nfeixe", "*", "n"}], " ", "-", 
            RowBox[{"(", 
             RowBox[{"nfeixe", "-", "1"}], ")"}]}], ",", 
           RowBox[{"nfeixe", "*", "n"}]}], "}"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"m", ",", "1", ",", "nfases"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "1", ",", "nfases"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ZTudoIdeal", "=", 
     RowBox[{"Inverse", "[", "aux01", "]"}]}], ";"}]}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"elimina", " ", "feixe"}], " ", "*)"}]}]], "Input"],

