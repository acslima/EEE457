Cell[CellGroupData[{

Cell["Solu\[CCedilla]\[ATilde]o \"Correta\"", "Section"],

Cell["\<\
Neste caso consideramos a imped\[AHat]ncia interna supondo o condutor s\
\[OAcute]lido. O efeito do solo \[EAcute] representado pelo m\[EAcute]todo do \
plano complexo.\
\>", "Text"],

Cell[CellGroupData[{

Cell["\<\
C\[AAcute]lculo da Imped\[AHat]ncia pelas fun\[CCedilla]\[OTilde]es de Bessel \
& Carson- solo convencional\
\>", "Subsubsection",
 Background->GrayLevel[1]],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Zfull", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"i", "\[NotEqual]", "j"}], ",", 
         RowBox[{
          FractionBox[
           RowBox[{"\[ImaginaryI]", " ", "\[Omega]", " ", "\[Mu]"}], 
           RowBox[{"2", " ", "\[Pi]"}]], 
          RowBox[{"(", "  ", 
           RowBox[{"Log", "[", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"\[Sqrt]", 
               RowBox[{"(", 
                RowBox[{
                 SuperscriptBox[
                  RowBox[{"(", 
                   RowBox[{
                    SubscriptBox["xc", 
                    RowBox[{
                    "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}]], 
                    "-", 
                    SubscriptBox["xc", 
                    RowBox[{
                    "\[LeftDoubleBracket]", "j", "\[RightDoubleBracket]"}]]}],
                    ")"}], "2"], "+", 
                 SuperscriptBox[
                  RowBox[{"(", 
                   RowBox[{
                    SubscriptBox["yc", 
                    RowBox[{
                    "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}]], 
                    "+", 
                    SubscriptBox["yc", 
                    RowBox[{
                    "\[LeftDoubleBracket]", "j", "\[RightDoubleBracket]"}]], 
                    "+", 
                    RowBox[{"2", " ", "p"}]}], ")"}], "2"]}], ")"}]}], ")"}], 
             "/", 
             RowBox[{"(", 
              RowBox[{"\[Sqrt]", 
               RowBox[{"(", 
                RowBox[{
                 SuperscriptBox[
                  RowBox[{"(", 
                   RowBox[{
                    SubscriptBox["xc", 
                    RowBox[{
                    "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}]], 
                    "-", 
                    SubscriptBox["xc", 
                    RowBox[{
                    "\[LeftDoubleBracket]", "j", "\[RightDoubleBracket]"}]]}],
                    ")"}], "2"], "+", 
                 SuperscriptBox[
                  RowBox[{"(", 
                   RowBox[{
                    SubscriptBox["yc", 
                    RowBox[{
                    "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}]], 
                    "-", 
                    SubscriptBox["yc", 
                    RowBox[{
                    "\[LeftDoubleBracket]", "j", "\[RightDoubleBracket]"}]]}],
                    ")"}], "2"]}], ")"}]}], ")"}]}], "]"}], ")"}]}], ",", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"i", "\[LessEqual]", 
            RowBox[{"ncond", "-", "npr"}]}], ",", 
           RowBox[{
            RowBox[{
             FractionBox[
              RowBox[{"\[Eta]c", " ", "\[Rho]c"}], 
              RowBox[{"2", " ", "\[Pi]", " ", "rf"}]], 
             FractionBox[
              RowBox[{"BesselI", "[", 
               RowBox[{"0", ",", 
                RowBox[{"\[Eta]c", " ", "rf"}]}], "]"}], 
              RowBox[{"BesselI", "[", 
               RowBox[{"1", ",", 
                RowBox[{"\[Eta]c", " ", "rf"}]}], "]"}]]}], "+", 
            RowBox[{
             FractionBox[
              RowBox[{"\[ImaginaryI]", " ", "\[Omega]", " ", "\[Mu]"}], 
              RowBox[{"2", " ", "\[Pi]"}]], 
             RowBox[{"(", " ", 
              RowBox[{"Log", "[", 
               FractionBox[
                RowBox[{"2", " ", 
                 RowBox[{"(", 
                  RowBox[{
                   SubscriptBox["yc", 
                    RowBox[{
                    "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}]], 
                   "+", " ", "p"}], ")"}]}], "rf"], "]"}], ")"}]}]}], " ", 
           ",", 
           RowBox[{
            RowBox[{
             FractionBox[
              RowBox[{"\[Eta]pr", " ", "\[Rho]pr"}], 
              RowBox[{"2", " ", "\[Pi]", " ", "rpr"}]], 
             FractionBox[
              RowBox[{"BesselI", "[", 
               RowBox[{"0", ",", 
                RowBox[{"\[Eta]pr", " ", "rpr"}]}], "]"}], 
              RowBox[{"BesselI", "[", 
               RowBox[{"1", ",", 
                RowBox[{"\[Eta]pr", " ", "rpr"}]}], "]"}]]}], "+", 
            RowBox[{
             FractionBox[
              RowBox[{"\[ImaginaryI]", " ", "\[Omega]", " ", "\[Mu]"}], 
              RowBox[{"2", " ", "\[Pi]"}]], 
             RowBox[{"(", 
              RowBox[{"Log", "[", 
               FractionBox[
                RowBox[{"2", 
                 RowBox[{"(", " ", 
                  RowBox[{"p", "+", " ", 
                   SubscriptBox["yc", 
                    RowBox[{
                    "\[LeftDoubleBracket]", "i", "\[RightDoubleBracket]"}]]}],
                   ")"}]}], "rpr"], "]"}], ")"}]}]}]}], " ", "]"}]}], "]"}], 
       ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "ncond"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "1", ",", "ncond"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Zspr", "=", 
     RowBox[{"Inverse", "[", 
      RowBox[{"Take", "[", 
       RowBox[{
        RowBox[{"Inverse", "[", "Zfull", "]"}], ",", 
        RowBox[{"ncond", "-", "npr"}], ",", 
        RowBox[{"ncond", "-", "npr"}]}], "]"}], "]"}]}], ";", " ", 
    RowBox[{"(*", " ", 
     RowBox[{"elimina", " ", "cabo", " ", "pr"}], "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{"aux", "=", 
     RowBox[{"Inverse", "[", "Zspr", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"aux01", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"Sum", "[", 
        RowBox[{
         RowBox[{"aux", "[", 
          RowBox[{"[", 
           RowBox[{"i", ",", "j"}], "]"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", 
           RowBox[{
            RowBox[{"nfeixe", "*", "m"}], " ", "-", 
            RowBox[{"(", 
             RowBox[{"nfeixe", "-", "1"}], ")"}]}], ",", 
           RowBox[{"nfeixe", "*", "m"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", 
           RowBox[{
            RowBox[{"nfeixe", "*", "n"}], " ", "-", 
            RowBox[{"(", 
             RowBox[{"nfeixe", "-", "1"}], ")"}]}], ",", 
           RowBox[{"nfeixe", "*", "n"}]}], "}"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"m", ",", "1", ",", "nfases"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "1", ",", "nfases"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Z1", "=", 
     RowBox[{"Inverse", "[", "aux01", "]"}]}], ";"}]}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"elimina", " ", "feixe"}], " ", "*)"}]}]], "Input"],

Cell["\<\
Matriz de Imped\[AHat]ncia em ohms por km\
\>", "Text"],

