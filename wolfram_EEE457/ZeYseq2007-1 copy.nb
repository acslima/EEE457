  RowBox[{"\[Rho]c", "=", 
   RowBox[{"1", "/", "\[Sigma]c"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Eta]c", "=", 
   SqrtBox[
    FractionBox[
     RowBox[{"I", " ", "\[Omega]", " ", "\[Mu]"}], "\[Rho]c"]]}], 
  ";"}]}], "Input"]
}, Open  ]],

