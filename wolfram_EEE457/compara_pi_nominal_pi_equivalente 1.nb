Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TableForm", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\"\<A (250km)\>\"", " ", ",", "\"\<B (250km)\>\"", " ", ",", 
       "\"\<C (250km)\>\""}], "  ", "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"100", " ", 
        RowBox[{"Abs", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", " ", "-", 
            RowBox[{"a", "[", "x", "]"}]}], ")"}], "/", 
          RowBox[{"a", "[", "x", "]"}]}], "]"}]}], ",", " ", 
       RowBox[{"100", " ", 
        RowBox[{"Abs", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"z1", " ", "x"}], " ", "-", 
            RowBox[{"b", "[", "x", "]"}]}], ")"}], "/", 
          RowBox[{"b", "[", "x", "]"}]}], "]"}]}], ",", 
       RowBox[{"100", " ", 
        RowBox[{"Abs", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"y1", " ", "x", " ", 
             RowBox[{"(", 
              RowBox[{"1", " ", "+", " ", 
               RowBox[{"z1", " ", "x", " ", "y1", " ", 
                RowBox[{"x", "/", "4"}]}]}], ")"}]}], "-", 
            RowBox[{"c", "[", "x", "]"}]}], ")"}], "/", 
          RowBox[{"c", "[", "x", "]"}]}], "]"}]}]}], "}"}]}], "}"}], "/.", 
   RowBox[{"x", "->", "250"}]}], "]"}]], "Input",
 CellChangeTimes->{{3.921834917986292*^9, 3.921834945016499*^9}, {
  3.921834978190652*^9, 3.921835058567652*^9}},
