Cell["\<\
a partir dos dados do circuito 138CSH1 do relat\[OAcute]rio da EPE, com o \
condutor GROSSBEAK\
\>", "Text",
 CellChangeTimes->{{3.921833607762647*^9, 3.921833623077732*^9}, {
  3.921833669687017*^9, 3.9218336778679333`*^9}, {3.921834584629157*^9, 
