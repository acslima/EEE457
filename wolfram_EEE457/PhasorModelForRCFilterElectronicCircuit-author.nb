Cell[CellGroupData[{

Cell["", "ManipulateCaptionSection"],

Cell[TextData[{
 "This Demonstration shows the phasor model for the steady-state behavior of \
a series RC circuit with a sinusoidal input. It lets you change the values of \
the resistance ",
 Cell[BoxData[
  FormBox["R", TraditionalForm]], "InlineMath"],
 " and capacitance ",
 Cell[BoxData[
  FormBox["C", TraditionalForm]], "InlineMath"],
 " in the circuit and the angular frequency ",
 Cell[BoxData[
  FormBox["\[Omega]", TraditionalForm]], "InlineMath"],
 " of the input to examine the amplitude and phase relationships for the \
system. It also shows how this behavior can be exploited as either a \
high-pass or low-pass filter."
}], "ManipulateCaption",
 CellChangeTimes->{
  3.35696210375764*^9, {3.47240822109375*^9, 3.472408227171875*^9}, {
   3.4724089814375*^9, 3.472409031484375*^9}, 3.47240911415625*^9, {
   3.472409458046875*^9, 3.472409459609375*^9}, {3.472835152388421*^9, 
   3.4728352050786896`*^9}, {3.472929151436967*^9, 3.4729291835773864`*^9}, {
   3.472930341390017*^9, 3.472930356195262*^9}, 3.4729946025878677`*^9},
 CellID->341035718]
}, Open  ]],

