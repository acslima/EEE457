Cell[CellGroupData[{

Cell["C\[AAcute]lculo da Imped\[AHat]ncia", "Subsection"],

Cell[BoxData[{
    \(\(Zfull = 
        Table[If[
            i \[NotEqual] 
              j, \(\(\[ImaginaryI]\ \[Omega]\ \[Mu]\)\/\(2\ \[Pi]\)\) \((\ \ \
Log[\((\[Sqrt]\((\((xc\_\(\(\[LeftDoubleBracket]\)\(i\)\(\[RightDoubleBracket]\
\)\) - xc\_\(\(\[LeftDoubleBracket]\)\(j\)\(\[RightDoubleBracket]\)\))\)\^2 + \
\((yc\_\(\(\[LeftDoubleBracket]\)\(i\)\(\[RightDoubleBracket]\)\) + yc\_\(\(\
\[LeftDoubleBracket]\)\(j\)\(\[RightDoubleBracket]\)\) + 2\ p)\)\^2)\))\)/\((\
\[Sqrt]\((\((xc\_\(\(\[LeftDoubleBracket]\)\(i\)\(\[RightDoubleBracket]\)\) - \
xc\_\(\(\[LeftDoubleBracket]\)\(j\)\(\[RightDoubleBracket]\)\))\)\^2 + \
\((yc\_\(\(\[LeftDoubleBracket]\)\(i\)\(\[RightDoubleBracket]\)\) - yc\_\(\(\
\[LeftDoubleBracket]\)\(j\)\(\[RightDoubleBracket]\)\))\)\^2)\))\)])\), 
            If[i \[LessEqual] 
                ncond - npr, \(\(\[Eta]c\ \[Rho]c\)\/\(2\ \[Pi]\ rf\)\) 
                  BesselI[0, \[Eta]c\ rf]\/BesselI[1, \[Eta]c\ rf] + \(\(\
\[ImaginaryI]\ \[Omega]\ \[Mu]\)\/\(2\ \[Pi]\)\) \((\ 
                    Log[\(2\ \((yc\_\(\(\[LeftDoubleBracket]\)\(i\)\(\
\[RightDoubleBracket]\)\) + \ p)\)\)\/rf])\)\ , \(\(\[Eta]pr\ \[Rho]pr\)\/\(2\
\ \[Pi]\ rpr\)\) 
                  BesselI[0, \[Eta]pr\ rpr]\/BesselI[1, \[Eta]pr\ rpr] + \(\(\
\[ImaginaryI]\ \[Omega]\ \[Mu]\)\/\(2\ \[Pi]\)\) \((Log[\(2 \((\ p + \ yc\_\(\
\(\[LeftDoubleBracket]\)\(i\)\(\[RightDoubleBracket]\)\))\)\)\/rpr])\)\ ]], \
{i, 1, ncond}, {j, 1, ncond}];\)\), "\[IndentingNewLine]", 
    \(Zspr = Inverse[Take[Inverse[Zfull], ncond - npr, ncond - npr]]; \  (*\ 
      elimina\ cabo\ pr*) \[IndentingNewLine]aux = 
      Inverse[Zspr];\), "\[IndentingNewLine]", 
    \(\(aux01 = 
        Table[Sum[
            aux[\([i, j]\)], {i, nfeixe*m\  - \((nfeixe - 1)\), 
              nfeixe*m}, {j, nfeixe*n\  - \((nfeixe - 1)\), nfeixe*n}], {m, 
            1, nfases}, {n, 1, nfases}];\)\), "\[IndentingNewLine]", 
    \(\(\(Z = Inverse[aux01]\)\(;\)\(\ \)\( (*\ 
      elimina\ feixe\ *) \)\)\)}], "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["C\[AAcute]lculo da Admit\[AHat]ncia", "Subsection"],

Cell[BoxData[{
    \(\(Pinv = 
        Inverse[Table[
            If[i \[NotEqual] j, 
              Log[\((\[Sqrt]\((\((xc[\([i]\)] - xc[\([j]\)])\)\^2 + \
\((yc[\([i]\)] + yc[\([j]\)])\)\^2)\))\)/\((\[Sqrt]\((\((xc[\([i]\)] - \
xc[\([j]\)])\)\^2 + \((yc[\([i]\)] - yc[\([j]\)])\)\^2)\))\)], \
\[IndentingNewLine]If[i \[LessEqual] ncond - npr, Log[2\ yc[\([i]\)]\/rf], 
                Log\ [2  yc[\([i]\)]\/rpr]]], {i, 1, ncond}, {j, 1, 
              ncond}]];\)\), "\[IndentingNewLine]", 
    \(Pspr = Inverse[Take[Pinv, ncond - npr, ncond - npr]]; \ \  (*\ 
      elimina\ cabo\ pr*) \[IndentingNewLine]aux02 = 
      Inverse[Pspr];\), "\[IndentingNewLine]", 
    \(\(Cfase = 
        Table[Sum[
            aux02[\([i, j]\)]\ , {i, nfeixe*m\  - \((nfeixe - 1)\), 
              nfeixe*m}, {j, nfeixe*n\  - \((nfeixe - 1)\), nfeixe*n}], {m, 
            1, nfases}, {n, 1, nfases}];\)\[IndentingNewLine] (*\ 
      elimina\ feixe\ *) \), "\[IndentingNewLine]", 
    \(\(Y = I\ \[Omega]\ 2.0\ \[Pi]\ \[Epsilon]\ Cfase;\)\)}], "Input"]
}, Open  ]]
}, Open  ]],

