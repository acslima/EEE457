Notebook[{
Cell["Imped\[AHat]ncia de Circuitos Duplos", "Title"],

Cell["\<\
Antonio Carlos Siqueira de Lima
Poli/COPPE/UFRJ\
\>", "Subtitle"],

Cell[CellGroupData[{

Cell["Introdu\[CCedilla]\[ATilde]o", "Section"],

Cell["\<\
O objetivo \[EAcute] apresentar o efeito do circuito duplo para as \
imped\[AHat]ncias de seq\[UDoubleDot]\[EHat]ncia. O sistema exemplo \[EAcute] \
um circuito duplo vertical de 500kV, apenas a t\[IAcute]tulo de exemplifica\
\[CCedilla]\[ATilde]o \[EAcute] considerado um condutor equivalente \
evitando-se assim a redu\[CCedilla]\[ATilde]o do feixe de condutores. A \
altura dos condutores \[EAcute] a m\[EAcute]dia supondo um v\[ATilde]o de \
450m, solo plano. \
\>", "Text"],

Cell[CellGroupData[{

Cell["Op\[CCedilla]\[OTilde]es de programa", "Subsection"],

Cell[BoxData[
    \(<< Graphics`Graphics`\)], "Input"],

Cell[BoxData[
    \(<< LinearAlgebra`MatrixManipulation`\)], "Input"],

Cell[BoxData[
    \(\(Off[General::"\<spell\>", General::"\<spell1\>"];\)\)], "Input"],

Cell[BoxData[
    \(\(SetOptions[{ListPlot, \ LogLinearListPlot, LogLinearListPlot}, 
        Axes \[Rule] False, Frame \[Rule] True, PlotJoined \[Rule] True, 
        ImageSize \[Rule] 450, DefaultFont \[Rule] {"\<Helvetica\>", 14}, 
        PlotStyle \[Rule] {PointSize[0.015]}];\)\)], "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Entrada de dados", "Subsection"],

Cell["Dados do sistema", "Text",
  PageWidth->WindowWidth,
  CellDingbat->None],

Cell["Configura\[CCedilla]\[ATilde]o da rede", "SmallText"],

Cell[CellGroupData[{

Cell[BoxData[{
    \(xa1 = \(-19.0\)/2; ya1 = 26.0\ ; xb1 = xa1; yb1 = ya1 + 12.7; 
    xc1 = xa1\ ;\), "\[IndentingNewLine]", 
    \(yc1 = ya1 + 2*12.7; xw1 = \(-7.5\); yw1 = ya1 + 36.5; xw2 = 7.5; 
    yw2 = yw1\ ;\), "\n", 
    \(\(xc = {xa1, xb1, xc1, \(-xa1\), \(-xb1\), \(-xc1\), xw1, 
          xw2};\)\), "\n", 
    \(\(yc = {ya1, yb1, yc1, ya1, yb1, yc1, yw1, 
          yw2};\)\), "\[IndentingNewLine]", 
    \(\(mostra = 
        Table[{Circle[{xc[\([i]\)], yc[\([i]\)]}, 0.5]}, {i, 1, 
            8}];\)\), "\n", 
    \(\(tduplo = 
        Show[Graphics[mostra], AspectRatio \[Rule] Automatic, 
          Axes \[Rule] False, Frame -> Automatic, PlotRange \[Rule] All, 
          FrameLabel \[Rule] {"\<dist\[AHat]ncia (m)\>", "\<dist\[AHat]ncia \
(m)\>"}];\)\)}], "Input"],

