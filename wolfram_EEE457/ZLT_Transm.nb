Cell["Extens\[ATilde]o das LTs por metro", "SmallText"],

Cell[BoxData[
    \(\(compr = 25\ 10^3;\)\)], "Input"],

Cell["Par\[AHat]metros dos condutores de fase por metro", "SmallText"],

Cell[BoxData[{
    \(\(rf = \(4.06908\/2\) 10\^\(-2\);\)\), "\[IndentingNewLine]", 
    \(\ \(rint = \((1\/2\  - 0.3565)\) 
          4.06908\ 10\^\(-2\);\)\), "\[IndentingNewLine]", 
    \(\(\[Rho]c = 
        0.03206\ 10^\(-3\)\ \ \[Pi]\ \((rf\^2 - rint\^2)\);\)\)}], "Input"],

Cell["Par\[AHat]metros dos cabos p\[AAcute]ra-raios por metro", "SmallText"],

Cell[BoxData[{
    \(\(rpr = \(1.10490\/2\) 10\^\(-2\);\)\), "\[IndentingNewLine]", 
    \(\(\[Rho]pr = 2.8645\ 10^\(-3\)\ \[Pi]\ rpr\^2;\)\)}], "Input"],

Cell["Par\[AHat]metros do solo por metro", "SmallText"],

Cell[BoxData[{
    \(\(\[Epsilon]s = \[Epsilon];\)\), "\[IndentingNewLine]", 
    \(\(\[Rho]solo = 100;\)\)}], "Input"],

Cell["Constantes el\[EAcute]tricas", "SmallText"],

Cell[BoxData[{
    \(\(\[Mu] = 4\ \[Pi]\ 10\^\(-7\);\)\), "\[IndentingNewLine]", 
    \(\(\[Epsilon] = 8.854\ 10^\(-12\);\)\)}], "Input"],

Cell[BoxData[{
    \(\(p = \@\(\[Rho]solo\/\(I\ \[Omega]\ \[Mu]\)\);\)\), "\
\[IndentingNewLine]", 
    \(\(\[Eta] = 1/p;\)\ \ \), "\[IndentingNewLine]", 
    \(\(\[Eta]c = \@\(\(I\ \[Omega]\ \[Mu]\)\/\[Rho]c\);\)\), "\
\[IndentingNewLine]", 
    \(\(\[Eta]pr = \@\(\(I\ \[Omega]\ \[Mu]\)\/\[Rho]pr\);\)\)}], "Input"],

Cell["Dados de simula\[CCedilla]\[ATilde]o", "Text"],

Cell["Freq\[UDoubleDot]\[EHat]ncias de interesse", "SmallText"],

Cell[CellGroupData[{

Cell[BoxData[
    \(f = 60.0\)], "Input"],

Cell[BoxData[
    \(60.`\)], "Output"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Imped\[AHat]ncia Externa + Interna", "Section"],

Cell[BoxData[{
    \(\(Zaux = 
        Table[If[
            i \[NotEqual] 
              j, \(\[ImaginaryI]\ \[Omega]\ \[Mu]\)\/\(2\ \[Pi]\)\ \
Log[\@\(\((xc\_\(\(\[LeftDoubleBracket]\)\(i\)\(\[RightDoubleBracket]\)\) - \
xc\_\(\(\[LeftDoubleBracket]\)\(j\)\(\[RightDoubleBracket]\)\))\)\^2 + \((2*p \
