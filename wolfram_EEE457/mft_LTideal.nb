Notebook[{
Cell["Resposta da LT Ideal com um indutor no terminal", "Title"],

Cell["\<\
Antonio Carlos Siqueira de Lima
Poli/COPPE/UFRJ\
\>", "Subtitle"],

Cell[CellGroupData[{

Cell["Introdu\[CCedilla]\[ATilde]o", "Section"],

Cell["\<\
O objetivo \[EAcute] calcular o comportamento da admit\[AHat]ncia \
caracter\[IAcute]stica e a fun\[CCedilla]\[ATilde]o de propaga\[CCedilla]\
\[ATilde]o em fun\[CCedilla]\[ATilde]o da freq\[UDoubleDot]\[EHat]ncia bem \
como os par\[AHat]metros a 60Hz da LT.\
\>", "Text"],

Cell[CellGroupData[{

Cell["Op\[CCedilla]\[OTilde]es de programa", "Subsection"],

Cell[BoxData[{
    \(<< Graphics`Graphics`\), "\[IndentingNewLine]", 
    \(<< LinearAlgebra`MatrixManipulation`\)}], "Input"],

Cell[BoxData[
    \(\(Off[General::"\<spell\>", General::"\<spell1\>"];\)\)], "Input"],

Cell[BoxData[
    \(Get["\<SmoothPhase.m\>"]\)], "Input"],

Cell[BoxData[
    \(\(SetOptions[{ListPlot, \ LogLinearListPlot, LogLogListPlot}, 
        Axes \[Rule] False, Frame \[Rule] True, PlotJoined \[Rule] True, 
        ImageSize \[Rule] 450, DefaultFont \[Rule] {"\<Helvetica\>", 14}, 
        PlotStyle \[Rule] {PointSize[0.015]}];\)\)], "Input"],

Cell[BoxData[{
    \(\(plstyle1 = {AbsoluteThickness[2], 
          RGBColor[1, 0, 0]};\)\), "\[IndentingNewLine]", 
    \(\(plstyle2 = {AbsoluteThickness[2], 
          RGBColor[0, 0, 1]};\)\), "\[IndentingNewLine]", 
    \(\(plstyle3 = {AbsoluteThickness[2], PointSize[ .015], 
          RGBColor[0, 1, 0]};\)\)}], "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Entrada de dados", "Subsection"],

Cell["Dados do sistema", "Text",
  PageWidth->WindowWidth,
  CellDingbat->None],

Cell["Configura\[CCedilla]\[ATilde]o da rede", "SmallText"],

Cell["Extens\[ATilde]o das LTs por metro", "SmallText"],

Cell[BoxData[
    \(\(compr = 500.0;\)\)], "Input"],

Cell["Par\[AHat]metros dos condutores de fase por metro", "SmallText"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Dados dos Condutores", "Section"],

Cell["Par\[AHat]metros dos condutores de fase por metro", "SmallText"],

Cell["Condutores de fase Hawk, cabos p\[AAcute]ra-raios de a\[CCedilla]o \
EHS", "Text"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Dados de simula\[CCedilla]\[ATilde]o", "Section"],

Cell["Freq\[UDoubleDot]\[EHat]ncias de interesse", "SmallText"],

Cell[BoxData[{
    \(\(n = 1024*4;\)\), "\n", 
    \(\(T = 15. *10^\(-3\);\)\), "\n", 
    \(\(c = \(-Log[0.001]\)/T;\)\[IndentingNewLine] (*\ \(c = 
          Log[n^2]/T;\)*) \), "\n", 
    \(\(dt = N[T/n];\)\), "\[IndentingNewLine]", 
    \(\(dw = 2. \ Pi/\((n*dt)\);\)\)}], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
    \(dt*10^6\)], "Input"],

Cell[BoxData[
    \(3.662109375`\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(dw/\((2\ Pi)\)\)], "Input"],

Cell[BoxData[
    \(66.66666666666667`\)], "Output"]
}, Open  ]],

Cell[BoxData[
    \(\(kk = Range[0, n/2];\)\)], "Input"],

Cell[CellGroupData[{

Cell[BoxData[{
    \(\(sk = c + I\ \ dw\ kk;\)\), "\[IndentingNewLine]", 
    \(sigma[j_] = Cos[\[Pi]\ j/\((n)\)]^2\)}], "Input"],

Cell[BoxData[
    \(Cos[\(j\ \[Pi]\)\/4096]\^2\)], "Output"]
}, Open  ]],

Cell[BoxData[
    \(\(\(\ \)\( (*\ 
      sigma[j_] = 
        If[j \[Equal] 0, 
          1, \[IndentingNewLine]Sin[\[Pi]*j\ /n]/\((\[Pi]*
                j/n)\)]\ *) \)\)\)], "Input"],

Cell[BoxData[
    \(\(sk = c + I\ dw\ kk;\)\)], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
    \(nf = Length[sk]\)], "Input"],

Cell[BoxData[
    \(2049\)], "Output"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Inicializa\[CCedilla]\[ATilde]o das listas ", "Section"],

Cell[BoxData[
    \(\(v1out = Table[0, {n, 1, nf}];\)\)], "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Fun\[CCedilla]\[OTilde]es de Bessel & Carson - Solo Convencional", \
"Section"],

Cell[CellGroupData[{

Cell[BoxData[
    \(\(\(\ \)\(AbsoluteTiming[\[IndentingNewLine]Do[{s = 
            sk[\([nm]\)], \[IndentingNewLine]z = 
            0.0234\  + s\ 1.4*10^\(-3\), \[IndentingNewLine]y = 
            s\ 8.886*10^\(-9\), \[IndentingNewLine]yc = 
            Sqrt[y/z], \[IndentingNewLine]\[Gamma] = 
            Sqrt[\ z\ y], \[IndentingNewLine]hm = 
            Exp[\(-\[Gamma]\)*compr], \[IndentingNewLine]Am = 
            yc*\((1.  + hm^2)\)/\((1.  - 
                    hm^2)\), \[IndentingNewLine]Bm = \(-2.0\)*yc*
              hm/\((1.  - hm^2)\), \[IndentingNewLine]A = \ 
            Am\ , \[IndentingNewLine]B = 
            Bm, \[IndentingNewLine]Ynodal = {{100.  + A, B}, {B, 
                A + 1. /\((s\ /
                        10. )\)}}, \[IndentingNewLine]v1out[\([nm]\)] = 
            Inverse[Ynodal] . {1000.0/s, 0.0}}, {nm, 1, nf}]]\)\)\)], "Input",\

  TextJustification->1,
  FontFamily->"Courier New"],

Cell[BoxData[
    \({0.25`6.849485002168007\ Second, Null}\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(Dimensions[v1out]\)], "Input"],

Cell[BoxData[
    \({2049, 2}\)], "Output"]
}, Open  ]],

Cell[BoxData[
    \(\(outlow = v1out\ \ Map[\ sigma, \ kk];\)\)], "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Aplicando a Modified Fourier Transform", "Section"],

Cell[CellGroupData[{

Cell[BoxData[{
    \(\(lowerhalf = Delete[outlow, nf];\)\), "\n", 
    \(\(upperhalf = Reverse[Conjugate[outlow]];\)\), "\n", 
    \(\(upperhalf = Delete[upperhalf, nf];\)\), "\n", 
    \(\(F = Join[lowerhalf, upperhalf];\)\), "\n", 
    \(Length[F]\)}], "Input"],

Cell[BoxData[
    \(4096\)], "Output"]
}, Open  ]],

Cell[BoxData[
    \(\(t = dt\ Range[0, n - 1]\ ;\)\)], "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Resultados no Dom\[IAcute]nio do Tempo", "Section"],

Cell[BoxData[
    \(\(\(\ \)\(\(v1 = 
        Exp[c\ t]/dt\ Re[\ 
            InverseFourier[F[\([All, 1]\)], 
              FourierParameters \[Rule] {1, \(-1\)}]];\)\[IndentingNewLine]
    \(v2 = 
        Exp[c\ t]/dt\ Re[\ 
            InverseFourier[F[\([All, 2]\)], 
              FourierParameters \[Rule] {1, \(-1\)}]];\)\)\)\)], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
    \(\(ListPlot[Transpose@{t, v1}, 
        PlotRange \[Rule] {{0, 8*10^\(-3\)}, {0, 15}}];\)\)], "Input"],

Cell[GraphicsData["PostScript", "\<\
