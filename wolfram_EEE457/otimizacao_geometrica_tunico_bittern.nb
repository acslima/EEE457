Cell[CellGroupData[{
Cell["Otimiza\[CCedilla]\[ATilde]o Geom\[EAcute]trica de Linhas de Transmiss\
\[ATilde]o", "Title",ExpressionUUID->"3d1cbd83-98de-47d3-86df-4e5197096f5a"],

Cell["Robson Dias - COPPE/UFRJ", "Subtitle",ExpressionUUID->"28b1c7b8-c8fa-40a7-bbb6-bcfe2eb4e7b3"],

Cell["\<\
Este programa faz a otimiza\[CCedilla]\[ATilde]o da configura\[CCedilla]\
\[ATilde]o geometrica dos condutores da Linha de Transmiss\[ATilde]o, ap\
\[OAcute]s realizada a otimiza\[CCedilla]\[ATilde]o dos condutores. Este \
programa est\[AAcute] dividido em duas partes a primeira s\[ATilde]o \
definidas as restri\[CCedilla]\[OTilde]es do problema e a segunda a otimiza\
\[CCedilla]\[ATilde]o propriamente dita. N\[ATilde]o comtempla os cabos PR\
\>", "Text",ExpressionUUID->"fd2a2adf-5261-45ab-9e92-629bff91fd92"],

