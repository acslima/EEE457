Cell[CellGroupData[{

Cell["Matriz de Pot\[EHat]nciais", "Subsection",ExpressionUUID->"d95107ce-0647-4f4b-8e6f-be6fbf231d18"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"pseudoPSymEval", "=", 
   RowBox[{"PSym", "[", 
    RowBox[{"pseudovarx", ",", "pseudovary"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"pseudoDPz", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"D", "[", 
      RowBox[{"pseudoPSymEval", ",", 
       RowBox[{"pseudovarsym", "[", 
        RowBox[{"[", "#", "]"}], "]"}]}], "]"}], "&"}], "/@", 
    RowBox[{"Range", "[", 
     RowBox[{"Length", "[", "pseudovarsym", "]"}], "]"}]}]}], ";"}]}], "Input",
 ExpressionUUID -> "b7e607d0-6967-4d1d-b51e-e53424887041"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Gradiente da Fun\[CCedilla]\[ATilde]o Objetivo (FuncObj = \
q1/(ns*Nqad))", "Subsection",ExpressionUUID->"1451f5cb-d2da-46f8-af74-\
9b453f71e53f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"GradFunObj", "[", 
   RowBox[{"xx6_List", "?", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       RowBox[{"Union", "[", 
        RowBox[{"Map", "[", 
         RowBox[{"NumberQ", ",", "#"}], "]"}], "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}], "&"}], ")"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "varxEval", ",", "varyEval", ",", "pts1", ",", "Pneginv", ",", "qt", ",",
       "conjMUnorm", ",", "DPzsub", ",", "prod", ",", "Dq"}], "}"}], ",", 
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"pts1", "=", 
      RowBox[{"Thread", "[", 
       RowBox[{"pseudovarsym", "->", "xx6"}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"varxEval", "=", 
      RowBox[{"pseudovarx", "/.", "pts1"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"varyEval", "=", 
      RowBox[{"pseudovary", "/.", "pts1"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Pneginv", "=", 
      RowBox[{"-", 
       RowBox[{"Inverse", "[", 
        RowBox[{"PSym", "[", 
         RowBox[{"varxEval", ",", "varyEval"}], "]"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"qt", "=", 
      RowBox[{"qtotal", "[", 
       RowBox[{"varxEval", ",", "varyEval"}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"conjMUnorm", "=", 
      RowBox[{"Conjugate", "[", 
       RowBox[{"MU", "/", 
        RowBox[{"(", 
         RowBox[{"NU1", "*", 
          RowBox[{"10", "^", "3"}]}], ")"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"DPzsub", "=", 
      RowBox[{"pseudoDPz", "/.", "pts1"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"grad", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Pneginv", ".", 
         RowBox[{"DPzsub", "[", 
          RowBox[{"[", "i", "]"}], "]"}], ".", "qt", ".", "conjMUnorm"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", 
          RowBox[{"Length", "[", "varsym", "]"}]}], "}"}]}], "]"}]}], ";", 
     RowBox[{"Return", "[", 
      RowBox[{
       RowBox[{"Re", "[", "grad", "]"}], "/", 
       RowBox[{"(", 
        RowBox[{"ns", "*", "Nqad"}], ")"}]}], "]"}]}]}], "]"}]}]], "Input",
 ExpressionUUID -> "90fa9968-31ed-4649-bf66-b66ab423f448"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Derivada das Cargas em rela\[CCedilla]\[ATilde]o as vari\[AAcute]veis de \
otimiza\[CCedilla]\[ATilde]o (abscissas e ordenadas)\
\>", "Subsection",ExpressionUUID->"15322033-4f5e-4cfb-a5e0-8c5eff3ea797"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Dqz", "[", 
   RowBox[{"posVAR_", ",", 
    RowBox[{"xx7_List", "?", 
     RowBox[{"(", 
      RowBox[{
