Cell["Campos Superficiais M\[AAcute]ximos", "Subsubsection",ExpressionUUID->"f0ef1aa4-033a-4e6b-b972-32a4cd824129"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Esupmax", "[", 
   RowBox[{
    RowBox[{"xx4_List", "?", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"Union", "[", 
         RowBox[{"Map", "[", 
          RowBox[{"NumberQ", ",", "#"}], "]"}], "]"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}], "&"}], ")"}]}], ",", 
    RowBox[{"yy4_List", "?", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"Union", "[", 
         RowBox[{"Map", "[", 
          RowBox[{"NumberQ", ",", "#"}], "]"}], "]"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}], "&"}], ")"}]}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "Nq", ",", "C00", ",", "campos", ",", "camposmax", ",", "camposmaxmax", 
      ",", "\[Gamma]", ",", "ang"}], "}"}], ",", "\[IndentingNewLine]", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"ang", "[", 
       RowBox[{"i_", ",", "j_"}], "]"}], ":=", 
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", "}"}], ",", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"j", "<=", "ncond"}], ",", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"i", "==", "j"}], ",", "0", ",", 
            RowBox[{"ArcTan", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"xx4", "[", 
                RowBox[{"[", "j", "]"}], "]"}], "-", 
               RowBox[{"xx4", "[", 
                RowBox[{"[", "i", "]"}], "]"}]}], ",", 
              RowBox[{
               RowBox[{"yy4", "[", 
                RowBox[{"[", "j", "]"}], "]"}], "-", 
               RowBox[{"yy4", "[", 
                RowBox[{"[", "i", "]"}], "]"}]}]}], "]"}]}], "]"}], ",", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"i", "==", "j"}], ",", 
            RowBox[{
             RowBox[{"-", "\[Pi]"}], "/", "2"}], ",", 
            RowBox[{"ArcTan", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"xx4", "[", 
                RowBox[{"[", 
                 RowBox[{"j", "-", "ncond"}], "]"}], "]"}], "-", 
               RowBox[{"xx4", "[", 
                RowBox[{"[", "i", "]"}], "]"}]}], ",", 
              RowBox[{
               RowBox[{"yy4", "[", 
                RowBox[{"[", 
                 RowBox[{"j", "-", "ncond"}], "]"}], "]"}], "+", 
               RowBox[{"yy4", "[", 
                RowBox[{"[", "i", "]"}], "]"}]}]}], "]"}]}], "]"}]}], "]"}]}],
        "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Nq", "=", 
      RowBox[{"qtotal", "[", 
       RowBox[{"xx4", ",", "yy4"}], "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"C00", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Nq", "[", 
           RowBox[{"[", "i", "]"}], "]"}], "/", 
          RowBox[{"(", 
           RowBox[{"2", "*", "\[Pi]", "*", "\[Epsilon]o", "*", 
            RowBox[{"r", "[", 
             RowBox[{"[", "i", "]"}], "]"}]}], ")"}]}], ")"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", 
          RowBox[{"Length", "[", "Nq", "]"}]}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"campos", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"C00", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "+", 
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{"Sum", "[", 
            RowBox[{
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"k", "==", "i"}], ",", "0", ",", 
               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{"k", "<=", "ncond"}], ",", 
                 RowBox[{
                  RowBox[{"-", "2"}], "*", 
                  RowBox[{
                   RowBox[{"Nq", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "/", 
                   RowBox[{"(", 
                    RowBox[{"2", "*", "\[Pi]", "*", "\[Epsilon]o", "*", 
                    RowBox[{"r", "[", 
                    RowBox[{"[", "i", "]"}], "]"}]}], ")"}]}], "*", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"r", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "/", 
                    RowBox[{"Sqrt", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"yy4", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "-", 
                    RowBox[{"yy4", "[", 
                    RowBox[{"[", "k", "]"}], "]"}]}], ")"}], "^", "2"}], "+", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"xx4", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "-", 
                    RowBox[{"xx4", "[", 
                    RowBox[{"[", "k", "]"}], "]"}]}], ")"}], "^", "2"}]}], 
                    "]"}]}], ")"}], "^", "h"}], "*", 
                  RowBox[{"Cos", "[", 
                   RowBox[{"\[Gamma]", "-", 
                    RowBox[{"ang", "[", 
                    RowBox[{"i", ",", "k"}], "]"}]}], "]"}]}], ",", 
                 RowBox[{"2", "*", 
                  RowBox[{
                   RowBox[{"Nq", "[", 
                    RowBox[{"[", 
                    RowBox[{"k", "-", "ncond"}], "]"}], "]"}], "/", 
                   RowBox[{"(", 
                    RowBox[{"2", "*", "\[Pi]", "*", "\[Epsilon]o", "*", 
                    RowBox[{"r", "[", 
                    RowBox[{"[", "i", "]"}], "]"}]}], ")"}]}], "*", 
                  RowBox[{
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"r", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "/", 
                    RowBox[{"Sqrt", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"yy4", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "+", 
                    RowBox[{"yy4", "[", 
                    RowBox[{"[", 
                    RowBox[{"k", "-", "ncond"}], "]"}], "]"}]}], ")"}], "^", 
                    "2"}], "+", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"xx4", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "-", 
                    RowBox[{"xx4", "[", 
                    RowBox[{"[", 
                    RowBox[{"k", "-", "ncond"}], "]"}], "]"}]}], ")"}], "^", 
                    "2"}]}], "]"}]}], ")"}], "^", "h"}], "*", 
                  RowBox[{"Cos", "[", 
                   RowBox[{"\[Gamma]", "-", 
                    RowBox[{"ang", "[", 
                    RowBox[{"i", ",", "k"}], "]"}]}], "]"}]}]}], "]"}]}], 
              "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"k", ",", "1", ",", 
               RowBox[{"2", "*", "ncond"}]}], "}"}]}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"h", ",", "1", ",", "2"}], "}"}]}], "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "ncond"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", " ", 
     RowBox[{"camposmax", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"FindMinimum", "[", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{"Abs", "[", 
            RowBox[{"campos", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"\[Gamma]", ",", "0", ",", 
            RowBox[{"2", "*", "\[Pi]"}]}], "}"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", 
          RowBox[{"Length", "[", "campos", "]"}]}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"camposmaxmax", "=", 
      RowBox[{
       RowBox[{"Max", "[", 
        RowBox[{"-", 
         RowBox[{"camposmax", "[", 
          RowBox[{"[", 
           RowBox[{"All", ",", "1"}], "]"}], "]"}]}], "]"}], "*", 
       RowBox[{"10", "^", 
        RowBox[{"-", "5"}]}]}]}], ";", 
     RowBox[{"Return", "[", 
      RowBox[{
       RowBox[{"-", 
        RowBox[{"camposmax", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "1"}], "]"}], "]"}]}], "*", 
       RowBox[{"10", "^", 
        RowBox[{"-", "5"}]}]}], "]"}]}]}], "]"}]}]], "Input",ExpressionUUID->\
"a6aa8b3b-da5a-4874-aca4-263007f3f328"],

Cell[BoxData[
 RowBox[{
  RowBox[{"EsupmaxInd", "[", 
   RowBox[{"posi_", ",", 
    RowBox[{"xx5_List", "?", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"Union", "[", 
         RowBox[{"Map", "[", 
          RowBox[{"NumberQ", ",", "#"}], "]"}], "]"}], "[", 
        RowBox[{"[", "1", "]"}], "]"}], "&"}], ")"}]}]}], "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "xEmax", ",", "yEmax", ",", "ytemp", ",", "pts", ",", "Nq", ",", "C00", 
      ",", "campos", ",", "camposmax", ",", "camposmaxmax", ",", "\[Gamma]", 
      ",", "ang"}], "}"}], ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"pts", "=", 
      RowBox[{"Thread", "[", 
       RowBox[{"varsym", "->", "xx5"}], "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"xEmax", "=", 
      RowBox[{"varx", "/.", "pts"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
