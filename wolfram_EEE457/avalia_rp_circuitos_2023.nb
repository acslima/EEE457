Cell[BoxData[
 RowBox[{
  RowBox[{"qll", "[", 
   RowBox[{"z_", ",", "y_", ",", "\[ScriptL]_"}], "]"}], ":=", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"\[Gamma]", "=", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"z", " ", "y"}], "]"}]}], ",", " ", 
      RowBox[{"Zc", "=", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"z", "/", "y"}], "]"}]}]}], "}"}], ",", " ", 
    "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Cosh", "[", 
         RowBox[{"\[Gamma]", " ", "\[ScriptL]"}], "]"}], ",", " ", 
        RowBox[{"Zc", " ", 
         RowBox[{"Sinh", "[", 
          RowBox[{"\[Gamma]", " ", "\[ScriptL]"}], "]"}]}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"1", "/", "Zc"}], " ", 
         RowBox[{"Sinh", "[", 
          RowBox[{"\[Gamma]", " ", "\[ScriptL]"}], "]"}]}], ",", 
        RowBox[{"Cosh", "[", 
         RowBox[{"\[Gamma]", " ", "\[ScriptL]"}], "]"}]}], "}"}]}], "}"}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.892491028355771*^9, 3.892491132121416*^9}, 
