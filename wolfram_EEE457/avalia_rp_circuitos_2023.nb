Cell[BoxData[
 RowBox[{
  RowBox[{"qlm", "[", 
   RowBox[{"z_", ",", "y_", ",", "\[ScriptL]_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
