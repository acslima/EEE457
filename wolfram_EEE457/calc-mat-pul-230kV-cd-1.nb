   "*)"}], "        ", "\n", 
  RowBox[{
   RowBox[{"eliprc", " ", "=", " ", 
    RowBox[{"Compile", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"m", ",", "_Complex", ",", "2"}], "}"}], ",", 
