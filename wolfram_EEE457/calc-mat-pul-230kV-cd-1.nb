Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"case", "  ", "2"}], ":", " ", 
    RowBox[{
    "ground", " ", "wires", " ", "and", " ", "unbundled", " ", 
     "conductors"}]}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"cZYlt", "[", 
      RowBox[{"omega_", ",", 
       RowBox[{
        RowBox[{"(", "x_", ")"}], "?", "VectorQ"}], ",", " ", 
       RowBox[{
        RowBox[{"(", "y_", ")"}], "?", "VectorQ"}], ",", " ", "sigmas_", ",", 
       " ", "rdc_", ",", "rf_", ",", "rint_", ",", " ", "npr_", ",", " ", 
       "rdcpr_", ",", " ", "rpr_"}], "]"}], ":=", "\n", "    ", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"mu", "=", 
