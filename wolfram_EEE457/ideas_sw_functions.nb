Cell[BoxData[
 RowBox[{" ", 
  RowBox[{
   RowBox[{"f", "[", "s_", "]"}], ":=", 
   RowBox[{
    FractionBox[
     RowBox[{"5.`*^-7", " ", 
      RowBox[{"Gamma", "[", 
       RowBox[{"0.`", "\[VeryThinSpace]", "+", 
        RowBox[{"5.`*^-7", " ", "s"}]}], "]"}], " ", 
