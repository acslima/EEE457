Cell[BoxData[
 FractionBox[
  RowBox[{
   RowBox[{
    RowBox[{"-", "2"}], " ", "k", " ", "\[Delta]"}], "+", 
   RowBox[{"s", " ", 
    RowBox[{"PolyGamma", "[", 
     RowBox[{"0", ",", 
      RowBox[{
       FractionBox["1", "4"], " ", 
       RowBox[{"(", 
        RowBox[{"2", "+", 
         FractionBox["s", 
          RowBox[{"k", " ", "\[Delta]"}]]}], ")"}]}]}], "]"}]}], "-", 
   RowBox[{"s", " ", 
    RowBox[{"PolyGamma", "[", 
     RowBox[{"0", ",", 
      FractionBox["s", 
       RowBox[{"4", " ", "k", " ", "\[Delta]"}]]}], "]"}]}]}], 
  RowBox[{"2", " ", "k", " ", "s", " ", "\[Delta]"}]]], "Output",
