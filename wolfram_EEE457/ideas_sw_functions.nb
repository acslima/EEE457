Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{
   RowBox[{"LaplaceTransform", "[", 
    RowBox[{
     RowBox[{"Tanh", "[", 
      RowBox[{"k", " ", "\[Delta]", " ", "t"}], "]"}], ",", "t", ",", "s"}], 
    "]"}], ",", " ", 
   RowBox[{"Assumptions", "->", 
    RowBox[{"{", 
