        RowBox[{"1.`", "\[VeryThinSpace]", "+", 
         RowBox[{"5.`*^-7", " ", "s"}]}], ",", 
        RowBox[{"-", "1"}]}], "]"}]}], 
     RowBox[{"Gamma", "[", 
