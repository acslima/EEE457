Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"LaplaceTransform", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"Tanh", "[", 
     RowBox[{"10", " ", "t"}], "]"}], "-", " ", 
    RowBox[{
     RowBox[{"HeavisideTheta", "[", 
      RowBox[{"t", "-", "5"}], "]"}], " ", 
     RowBox[{"Tanh", "[", 
      RowBox[{"10", " ", "t"}], "]"}]}]}], ",", "t", ",", "s"}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.893265583108624*^9, 3.8932655980896893`*^9}, {
  3.893265630717705*^9, 3.893265638169298*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"828fc874-f512-4440-b164-de7dd63f7ee5"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", 
   FractionBox[
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{
      RowBox[{"-", "5"}], " ", "s"}]], "s"]}], "+", 
  RowBox[{
   FractionBox["1", "10"], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{
      RowBox[{"-", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"-", "1"}], ")"}], 
        RowBox[{"s", "/", "20"}]]}], " ", 
      RowBox[{"Beta", "[", 
       RowBox[{
        RowBox[{"-", 
         SuperscriptBox["\[ExponentialE]", "100"]}], ",", 
        RowBox[{"-", 
         FractionBox["s", "20"]}], ",", "0"}], "]"}]}], "-", 
     RowBox[{"\[Pi]", " ", 
      RowBox[{"Csc", "[", 
       FractionBox[
        RowBox[{"\[Pi]", " ", "s"}], "20"], "]"}]}]}], ")"}]}], "+", 
  RowBox[{
   FractionBox["1", "20"], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", 
      FractionBox["20", "s"]}], "-", 
     RowBox[{"PolyGamma", "[", 
      RowBox[{"0", ",", 
       FractionBox["s", "40"]}], "]"}], "+", 
     RowBox[{"PolyGamma", "[", 
      RowBox[{"0", ",", 
       FractionBox[
        RowBox[{"20", "+", "s"}], "40"]}], "]"}]}], ")"}]}]}]], "Output",
 CellChangeTimes->{3.8932656000861673`*^9, 3.893265642243786*^9},
 CellLabel->"Out[7]=",ExpressionUUID->"7df05226-3aca-4825-a764-c4a97e0b71cb"]
}, Open  ]],

