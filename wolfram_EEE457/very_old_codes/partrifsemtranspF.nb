Cell[CellGroupData[{

Cell["\<\
Print[Date[]]
comptot=400000.0;
tabtransp={3,1,2,6,4,5};

mattransfdeua1=Table[0,{i,1,3161}];
Do[{
f=matf[[ifreq]],
z=matzst[[ifreq]],
y=2 Pi I f*cc,
If[f<100000.1,dx=comptot/6/1024,dx=comptot/6/8192,dx=comptot/6/8192],
Clear[un1,un2,un3,in1,in2,in3],
zdx=z*dx,
ydx=y*dx,
transf=Table[0,{i,1,6}],
Do[{If[jvar==1,{un={1,0,0},in={0,0,0}},aux=0],
If[jvar==2,{un={0,1,0},in={0,0,0}},aux=0],
If[jvar==3,{un={0,0,1},in={0,0,0}},aux=0],
If[jvar==4,{un={0,0,0},in={1,0,0}},aux=0],
If[jvar==5,{un={0,0,0},in={0,1,0}},aux=0],
If[jvar==6,{un={0,0,0},in={0,0,1}},aux=0],
dua={0,0,0},
dia={0,0,0},
Do[{
du=Simplify[-zdx.(in+1*dia/2)],
di=Simplify[-ydx.(un+1*dua/2)],
dua=du,
dia=di
},
{k,1,5}],
transf[[jvar]]=Simplify[Join[un+du,in+di]]
},
{jvar,1,6}],
transf=Transpose[transf],
transf2=transf.transf,
transf4=transf2.transf2,
transf8=transf4.transf4,
transf16=transf8.transf8,
transf32=transf16.transf16,
transf64=transf32.transf32,
transf128=transf64.transf64,
transf256=transf128.transf128,
transf512=transf256.transf256,
transf1024=transf512.transf512,
transf2048=transf1024.transf1024,
transf4096=transf2048.transf2048,
transf8192=transf4096.transf4096,
transf16394=transf8192.transf8192,
If[f<100000.1,{transfbasesex=transf1024,transfbaseter=transf2048},{\
transfbasesex=transf8192,transfbaseter=transf16394},{transfbasesex=transf8192,\
transfbaseter=transf16394}],
transfB=transfbaseter,
transfC=transfB,
transfconj=transfbasesex.transfB.transfC.transfbasesex,
Clear[ua1,ua2,ua3,ia1,ia2,ia3,ub1,ub2,ub3,ib1,ib2,ib3],
ua1=1,
ia2=0,
ia3=0,
ib1=0,
ib2=0,
ib3=0,
sol={{ub1,ub2,ub3,ia1,ua2,ua3}}/.Solve[transfconj.{ua1,ua2,ua3,ia1,ia2,ia3}=={\
ub1,ub2,ub3,ib1,ib2,ib3},{ub1,ub2,ub3,ia1,ua2,ua3}],
sol=sol[[1]][[1]],
mattransfdeua1[[ifreq]]={f,sol}},
{ifreq,1,3161}]

Print[Date[]]
\
\>", "Input"],

Cell[BoxData[
    \({2006, 7, 29, 21, 2, 5.684495`7.507266876616776}\)], "Print"],

