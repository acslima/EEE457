Cell[BoxData[
    \(\(\(\[IndentingNewLine]\)\( (*\ 
      linha\ para\ exemplo\ *) \)\(\n\)\(\n\)\(Print[Date[]]\n
    \(xcond = {\(-8\) - 0.25, \(-8\) + 0.25, \(-8\) - 0.25, \(-8\) + 
            0.25, \(-0.25\), \(+0.25\), \(-0.25\), \(+0.25\), 8 - 0.25, 
          8 + 0.25, 8 - 0.25, 8 + 0.25, \(-7\), 7};\)\n
    \(\(ycond = {13.5275, 13.5275, 13.5275 - 1.5, 13.5275 - 1.5, 13.5275, 
          13.5275, 13.5275 - 0.5, 13.5275 - 0.5, 13.5275, 13.5275, 
          13.5275 - 1.5, 13.5275 - 1.5, 23.9779, 23.9779};\)\(\n\)
    \)\n
    \(\(rcond = {0.0182370, 0.0182370, 0.0182370, 0.0182370, 0.0182370, 
          0.0182370, 0.0182370, 0.0182370, 0.0182370, 0.0182370, 0.0182370, 
          0.0182370, 0.004755, 0.004755};\)\(\n\)
    \)\n
    \(rint = 0.00608078;\)\n
    \(tempfase = 60.0;\)\n
    \(nfeixe = 4;\)\n
    \(npraios = 2;\)\n
    \(epsi0 = 8.94*10^\((\(-12\))\);\)\n
    \(epsiar = 8.96*10^\((\(-12\))\);\)\n
    \(\(miu0 = 4.0*Pi*10^\((\(-7\))\);\)\(\n\)
    \)\n
    \(fencaco = 0.778767;\)\n
    \(ro0 = \[InvisibleSpace]26.4574*10^\(-9\);\)\n
    \(alfatemp = \[InvisibleSpace]0.00454562;\)\n
    \(fencalum = 0.750223;\)\n
    \(\(fencalum = 0.810237;\)\(\n\)
    \)\n
    \(\(miucondp = miu0;\)\(\n\)
    \)\n
    \(sigmacondp = fencalum/\((ro0*\((1 + alfatemp*tempfase)\))\);\)\n
    \(miupr = 100*miu0;\)\n
    \(sigmapr = fencaco*\((0.18*10^\((\(-6\))\))\)^\((\(-1\))\);\)\n
    \(ddd = 
        Table[0, {i, 1, 3*nfeixe + npraios}, {j, 1, 3*nfeixe + npraios}];\)\n
    \(\(zzz = ddd;\)\(\n\)
    \)\n
    \(cc = Table[0, {i, 1, 3}, {j, 1, 3}];\)\n
    \(yy = cc;\)\n
    Print[ddd[\([1, 1]\)]]\n
    Dimensions[ddd]\n
    Do[If[i == j, ddd[\([i, j]\)] = Log[2.0*ycond[\([i]\)]/rcond[\([i]\)]], 
        ddd[\([i, j]\)] = 
          0.5*Log[\((\((xcond[\([i]\)] - 
                          xcond[\([j]\)])\)^2 + \((ycond[\([i]\)] + 
                          ycond[\([j]\)])\)^2)\)/\((\((xcond[\([i]\)] - 
                          xcond[\([j]\)])\)^2 + \((ycond[\([i]\)] - 
                          ycond[\([j]\)])\)^2)\)]], {i, 1, 
        3*nfeixe + npraios}, {j, 1, 3*nfeixe + npraios}]\n
    \(ddd = ddd/\((2*Pi*epsiar)\);\)\n
    \(ccc = Inverse[ddd];\)\n
    Print[ccc[\([1, 1]\)]]\n
    Do[cc[\([m, n]\)] = 
        Sum[ccc[\([i, j]\)], {i, nfeixe*m - \((nfeixe - 1)\), nfeixe*m}, {j, 
            nfeixe*n - \((nfeixe - 1)\), nfeixe*n}], {m, 1, 3}, {n, 1, 3}]\n
    \(\(Print[{"\<Matriz C sem transp. , em F/m \>", cc}]\)\(\ \)\(\n\)
    \)\n
    Print[{"\<Matriz C com transp. ideal , em F/m \>", cc}]\n
    \(cd = cpmed - cmmed;\)\n
    \(ch = cpmed + 2\ cmmed;\)\n
    \(\(Print["\<cd = \>", cd, "\<   ch = \>", ch]\)\(\n\)
    \)\n
    \(f = 60.0;\)\n
    Print[{"\<Freq\[UDoubleDot]\[EHat]ncia, em Hz = \>", f}]\ \n
    \(w = 2*Pi*f;\)\n
    \({yd, yh} = I*w*{cd, ch};\)\n
    \(\(Print["\<yd = \>", yd, "\<   yh = \>", yh]\)\(\n\)\(\n\)
    \)\n
    \(delta = \((\((0.5*10^\((\(-3\))\) + 
                  0.205/10^6*\((1/Tan[Pi/2*0.7] + I)\)*w^0.7)\)*I*w*
              miu0)\)^\((\(-0.5\))\);\)\n
    Do[If[i == j, 
        zzz[\([i, j]\)] = 
          Log[\((2.0*ycond[\([i]\)] + 2*delta)\)/rcond[\([i]\)]], 
        zzz[\([i, j]\)] = 
          0.5*Log[\((\((xcond[\([i]\)] - 
                          xcond[\([j]\)])\)^2 + \((ycond[\([i]\)] + 
                          ycond[\([j]\)] + 
                          2*delta)\)^2)\)/\((\((xcond[\([i]\)] - 
                          xcond[\([j]\)])\)^2 + \((ycond[\([i]\)] - 
                          ycond[\([j]\)])\)^2)\)]], {i, 1, 
        3*nfeixe + npraios}, {j, 1, 3*nfeixe + npraios}]\n
    \(zzzextprel = zzz;\)\n
    \(\(zzz = I*miu0*w/\((2\ Pi)\)*zzz;\)\(\n\)
    \)\n
    \(ro0polo = rint*\((I*w*miucondp*sigmacondp)\)^0.5;\)\n
    \(ro1polo = rcond[\([1]\)]*\((I*w*miucondp*sigmacondp)\)^0.5;\)\n
    \(\(zintpolo = \((I*w*miucondp/sigmacondp)\)^0.5/\((2*Pi*
                rcond[\([1]\)])\)*\((BesselI[0, ro1polo]*
                  BesselK[1, ro0polo] + 
                BesselK[0, ro1polo]*
                  BesselI[1, ro0polo])\)/\((BesselI[1, ro1polo]*
                  BesselK[1, ro0polo] - 
                BesselK[1, ro1polo]*BesselI[1, ro0polo])\);\)\(\n\)
    \)\n
    \(\(Print[{"\<zintpolo = \>", zintpolo}]\)\(\ \)\(\n\)
    \)\n
    \(ro1pr = rcond[\([3*nfeixe + 1]\)]*\((I*w*miupr*sigmapr)\)^0.5;\)\n
    \(\(zintpr = \((I*w*miupr/sigmapr)\)^0.5/\((2*Pi*
                rcond[\([13]\)])\)*\((BesselI[0, ro1pr])\)/\((BesselI[1, 
                ro1pr])\);\)\(\n\)
    \)\n
    Do[zzz[\([i, i]\)] = zzz[\([i, i]\)] + zintpolo, {i, 1, 3*nfeixe}]\t\n
    \(\(Do[
      zzz[\([i, i]\)] = zzz[\([i, i]\)] + zintpr, {i, 3*nfeixe + 1, 
        3*nfeixe + npraios}]\)\(\t\)\(\n\)
    \)\n
    \(yyy = Inverse[zzz];\)\n
    zzz[\([1, 1]\)]\n
    Do[yy[\([m, n]\)] = 
        Sum[yyy[\([i, j]\)], {i, nfeixe*m - \((nfeixe - 1)\), nfeixe*m}, {j, 
            nfeixe*n - \((nfeixe - 1)\), nfeixe*n}], {m, 1, 3}, {n, 1, 3}]\n
    \(zz = Inverse[yy];\)\n
    Print[{"\<Matriz Z , em Ohm/m = \>", zz}]\n
    \(zpmed = \((zz[\([1, 1]\)] + zz[\([2, 2]\)] + zz[\([3, 3]\)])\)/3;\)\n
    \(\(zmmed = \((zz[\([1, 2]\)] + zz[\([1, 3]\)] + zz[\([2, 1]\)] + 
              zz[\([2, 3]\)] + zz[\([3, 1]\)] + zz[\([3, 2]\)])\)/6;\)\(\n\)
    \)\n
    \(zd = zpmed - zmmed;\)\n
    \(zh = zpmed + 2\ zmmed;\)\n
    \(\(Print["\<zd = \>", zd, "\<   zh = \>", zh]\)\(\n\)
    \)\n
    \(matfAA = Table[1*\((10^0.0625)\)^\((ifreq - 1)\), {ifreq, 17}];\)\n
    \(matfBB = 10*Table[1*\((10^0.015625)\)^\((ifreq)\), {ifreq, 64}];\)\n
    \(matfCC = Table[100.0 + ifreq*5, {ifreq, 180}];\)\n
    \(matfDD = Table[1000.0 + ifreq*10, {ifreq, 2900}];\)\n
    \(matf = Join[matfAA, matfBB, matfCC, matfDD];\)\n
    \(\(nfreq = \(Dimensions[matf]\)[\([1]\)];\)\(\n\)
    \)\n
    \(matzd = Table[0, {ifreq, nfreq}];\)\n
    \(matzh = Table[0, {ifreq, nfreq}];\)\n
    \(matzst = Table[0, {ifreq, nfreq}];\)\n
    \(\(Do[{\n
        Clear[f, zzzaff, zzzaffparte, \ deltaff, ro0poloff, ro1poloff, 
          zintpoloff, ro1prff, zintprff, i, j, m, n, yyyff, yyffparte, yyff, 
          zzff, zpmedff, zmmedff, zdff, zhff], \nf = matf[\([ifreq]\)], \n
        deltaff = \((\((0.5*10^\((\(-3\))\) + 
                    0.205/10^6*\((1/Tan[Pi/2*0.7] + 
                          I)\)*\((2\ Pi\ f)\)^0.7)\)*I*\((2\ Pi\ f)\)*
                miu0)\)^\((\(-0.5\))\); \n
        ro0poloff = rint*\((I*2*Pi*f*miucondp*sigmacondp)\)^0.5, \n
        ro1poloff = rcond[\([1]\)]*\((I*2*Pi*f*miucondp*sigmacondp)\)^0.5, \n
        zintpoloff = \((I*2*Pi*f*miucondp/sigmacondp)\)^0.5/\((2*Pi*
                  rcond[\([1]\)])\)*\((BesselI[0, ro1poloff]*
                    BesselK[1, ro0poloff] + 
                  BesselK[0, ro1poloff]*
                    BesselI[1, ro0poloff])\)/\((BesselI[1, ro1poloff]*
                    BesselK[1, ro0poloff] - 
                  BesselK[1, ro1poloff]*BesselI[1, ro0poloff])\), \n
        ro1prff = 
          rcond[\([3*nfeixe + 1]\)]*\((I*2*Pi*f*miupr*sigmapr)\)^0.5, \n
        zintprff = \((I*2*Pi*f*miupr/sigmapr)\)^0.5/\((2*Pi*
                  rcond[\([3*nfeixe + 1]\)])\)*\((BesselI[0, 
                  ro1prff])\)/\((BesselI[1, ro1prff])\), \n
        zzzaffparte[i_, j_] := 
          If[i == j, 
            If[i <= 3*nfeixe, 
              I*miu0*f*
                  Log[\((2.0*ycond[\([i]\)] + 2*deltaff)\)/rcond[\([i]\)]] + 
                zintpoloff, 
              I*miu0*f*
                  Log[\((2.0*ycond[\([i]\)] + 2*deltaff)\)/rcond[\([i]\)]] + 
                zintprff], 
            I*miu0*f*0.5*
              Log[\((\((xcond[\([i]\)] - 
                            xcond[\([j]\)])\)^2 + \((ycond[\([i]\)] + 
                            ycond[\([j]\)] + 
                            2*deltaff)\)^2)\)/\((\((xcond[\([i]\)] - 
                            xcond[\([j]\)])\)^2 + \((ycond[\([i]\)] - 
                            ycond[\([j]\)])\)^2)\)]], \n
        zzzaff = 
          Table[zzzaffparte[i, j], {i, 1, 3*nfeixe + npraios}, {j, 1, 
              3*nfeixe + npraios}], \nyyyff = Inverse[zzzaff], \n
        yyffparte[m_, n_] := 
          Sum[yyyff[\([i, j]\)], {i, nfeixe*m - \((nfeixe - 1)\), 
              nfeixe*m}, {j, nfeixe*n - \((nfeixe - 1)\), nfeixe*n}], \n
        yyff = Table[yyffparte[m, n], {m, 1, 3}, {n, 1, 3}], \n
        zzff = Inverse[yyff], \nmatzst[\([ifreq]\)] = zzff}, \n\t{ifreq, 1, 
        nfreq}]\)\(\t\)\(\n\)
    \)\n
    Print[Date[]]\)\)\)], "Input"],

