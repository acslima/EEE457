Notebook[{
Cell["Simplest example (Add Two numbers)", "Title"],

Cell[" Code Generation using MathCode", "Subtitle"],

Cell["Copyright \[Copyright] MathCore AB 1998-2004", "Copyright"],

Cell[CellGroupData[{

Cell["Simplest example", "Section"],

Cell[CellGroupData[{

Cell[TextData[{
  "Load the MathCode system into ",
  StyleBox["Mathematica",
    FontSlant->"Italic"]
}], "Subsection"],

Cell[TextData[{
  "Needs[\"",
  StyleBox["MathCode`",
    FontColor->RGBColor[0, 0, 1]],
  "\"]"
}], "Input"],

Cell["This is needed if many notebooks run in a sequence", "Text"],

Cell[BoxData[
    \(\(\(SetCurrentPackage["\<Global\>"]\)\(\ \)\)\)], "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Set Working Directory", "Subsection"],

Cell["SetDirectory[$MCRoot<>\"/Demos/SimplestExample\"];", "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Define a simple function", "Subsection"],

Cell["Typed definition", "Text"],

Cell["addtwo[Real a_,Real b_] -> Real := Module[{},a+b]", "Input"],

Cell[TextData[{
  "Evaluation in ",
  StyleBox["Mathematica",
    FontSlant->"Italic"]
}], "Text"],

Cell["addtwo[2.,2.]", "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Generate C++ and Build Executables", "Subsection"],

Cell["BuildCode[]", "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Install the Mathlink Executable", "Subsection"],

Cell["InstallCode[];", "Input"],

Cell["Run some examples", "Text"],

Cell["addtwo[2.,2.]", "Input"],

Cell["Uninstall the code", "Text"],

Cell[BoxData[
    \(\(UninstallCode[];\)\)], "Input"],

Cell[TextData[{
  "which will clean up things and terminate the ",
  StyleBox["MathLink",
    FontSlant->"Italic"],
  " process."
}], "Text"]
}, Open  ]],

Cell[CellGroupData[{

Cell["A glance at the Generated Code", "Subsection"],

Cell[BoxData[
    \(\(!! Global.cc\)\)], "Input"],

Cell["CleanMathCodeFiles[Confirm -> False, CleanAllBut -> {}];", "Input"]
}, Open  ]]
}, Open  ]]
},
