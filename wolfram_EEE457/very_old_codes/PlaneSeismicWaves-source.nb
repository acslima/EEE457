Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"step", "=", 
       FractionBox["1", "20"]}], "}"}], ",", 
     RowBox[{"Show", "[", 
      RowBox[{"Sequence", "[", 
       RowBox[{"Table", "[", "\[IndentingNewLine]", 
