              RowBox[{"{", 
               RowBox[{"0", ",", "5"}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"-", ".5"}], ",", ".5"}], "}"}]}], "}"}]}], ",", 
           RowBox[{"ImageSize", "\[Rule]", 
            RowBox[{"{", 
             RowBox[{"550", ",", "150"}], "}"}]}]}], "]"}], ",", 
