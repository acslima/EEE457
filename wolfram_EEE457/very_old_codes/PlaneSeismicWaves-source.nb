                  RowBox[{"tt", "-", 
                   RowBox[{"(", 
                    RowBox[{"t", "-", 
                    RowBox[{
                    RowBox[{"Max", "[", 
                    RowBox[{"1", ",", "n"}], "]"}], " ", "step"}]}], ")"}]}], 
                  ")"}]}], 
                RowBox[{
                 RowBox[{"Max", "[", 
                  RowBox[{"1", ",", "n"}], "]"}], " ", "step"}]], "]"}], ",", 
              
              RowBox[{"Darker", "[", "Blue", "]"}], ",", 
              RowBox[{"Opacity", "[", ".6", "]"}]}], "]"}]}], ",", 
