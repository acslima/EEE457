           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{
               RowBox[{"x", "+", 
                RowBox[{"pa", " ", 
                 RowBox[{"ff", "[", 
                  RowBox[{
                   FractionBox[
                    RowBox[{"2", " ", "\[Pi]", " ", "x"}], "pl"], ",", 
                   RowBox[{"2", " ", "\[Pi]", " ", "tt"}]}], "]"}]}]}], ",", 
               RowBox[{"sa", " ", 
                RowBox[{"gg", "[", 
                 RowBox[{
                  FractionBox[
                   RowBox[{"2", " ", "\[Pi]", " ", "x"}], "sl"], ",", 
                  RowBox[{"2", " ", "\[Pi]", " ", "tt"}]}], "]"}]}]}], "}"}], 
             ",", 
             RowBox[{"{", 
              RowBox[{"x", ",", "0", ",", "5", ",", 
               FractionBox["5", "np"]}], "}"}]}], "]"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"Filling", "\[Rule]", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"tt", "\[Equal]", "t"}], ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"1", "\[Rule]", "1"}], ",", 
                RowBox[{"1", "\[Rule]", 
                 RowBox[{"-", "1"}]}]}], "}"}], ",", "False"}], "]"}]}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"PlotStyle", "\[Rule]", 
            RowBox[{"Directive", "[", 
             RowBox[{
              RowBox[{"AbsolutePointSize", "[", 
               FractionBox[
                RowBox[{"4", " ", 
