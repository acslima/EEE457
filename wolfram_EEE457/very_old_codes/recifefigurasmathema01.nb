\)*retanglarg, \(vertc[\([5]\)]\)[\([3]\)] - retangh}, {\(-retangx\), 
            0.5*retanglarg, \(vertc[\([5]\)]\)[\([3]\)] - 
              retangh}, {\(-retangx\), 
            0.5*retanglarg, \(vertc[\([5]\)]\)[\([3]\)]}};\)\n\n\n\), "\n", 
    \(\(alfa = 
        N[ArcTan[\((vertb[\([5, 1]\)] - 
                  verta[\([5, 1]\)])\)/\((vertb[\([5, 3]\)] - 
                  verta[\([5, 3]\)])\)]];\)\), "\n", 
    \(\(hpir = 5;\)\), "\n", 
    \(\(cquada = {verta[\([5, 1]\)] + hpir*Sin[alfa], 0, 
          verta[\([5, 3]\)] + hpir*Cos[alfa]};\)\), "\n", 
    \(\(cquadb = {vertb[\([5, 1]\)] - hpir*Sin[alfa], 0, 
          vertb[\([5, 3]\)] - hpir*Cos[alfa]};\)\), "\n", 
    \(\(tquad1 = Transpose[tquad0];\)\), "\n", 
    \(\(tquad2 = 
