    \(\(retangx = 25.0;\)\n\), "\n", 
    \(\(quad = 1.2;\)\), "\[IndentingNewLine]", 
    \(\(quad = 1.8;\)\), "\n", 
    \(\(tquad0 = {{\(-1\), \(-1\), 0}, {1, \(-1\), 0}, {1, 1, 0}, {\(-1\), 1, 
              0}}*quad/2.0;\)\), "\n", 
    \(\(vert = Table[0, {k, 1, 5}];\)\), "\n", 
    \(\(verta = vert;\)\), "\n", 
    \(\(vertb = vert;\)\), "\n", 
    \(\(vertc = vert;\)\), "\n", 
    \(\(vertd = vert;\)\), "\n", 
    \(\(alfaaux = N[ArcTan[11/40]];\)\), "\[IndentingNewLine]", 
    \(\(alfaaux = N[ArcTan[18/40]];\)\), "\n", 
    \(\(hmont = 32.3;\)\), "\[IndentingNewLine]", 
    \(\(hmont = 55.4;\)\), "\n", 
    \(\(verta[\([5]\)] = {10, 0, 0};\)\), "\[IndentingNewLine]", 
    \(\(vertb[\([5]\)] = {10 + 11*hmont/40, 0, 
          hmont};\)\), "\[IndentingNewLine]", 
    \(\(verta[\([5]\)] = {19, 0, 0};\)\), "\[IndentingNewLine]", 
    \(\(vertb[\([5]\)] = {19 + 11*hmont/40, 0, 
          hmont};\)\), "\[IndentingNewLine]", 
    \(\(vertc[\([5]\)] = vertb[\([5]\)];\)\), "\n", 
    \(\(vertd[\([5]\)] = {\(-\(vertc[\([5]\)]\)[\([1]\)]\), \
\(vertc[\([5]\)]\)[\([2]\)], \(vertc[\([5]\)]\)[\([3]\)]};\)\), "\n", 
    \(\({vertc[\([1]\)], vertc[\([2]\)], vertc[\([3]\)], 
          vertc[\([4]\)]} = {{retangx, \(-0.5\)*
              retanglarg, \(vertc[\([5]\)]\)[\([3]\)]}, {retangx, \(-0.5\)*
              retanglarg, \(vertc[\([5]\)]\)[\([3]\)] - retangh}, {retangx, 
            0.5*retanglarg, \(vertc[\([5]\)]\)[\([3]\)] - retangh}, {retangx, 
            0.5*retanglarg, \(vertc[\([5]\)]\)[\([3]\)]}};\)\), "\n", 
    \(\({vertd[\([1]\)], vertd[\([2]\)], vertd[\([3]\)], 
