Cell["MATRIX DE IMPED\[CapitalAHat]NCIA INTERNA DOS CABOS (Zi) ", "Subsection",
  FontSize->14],

Cell[CellGroupData[{

Cell["IMPED\[CapitalAHat]NCIA INTERNA DO CABO COAXIAL", "Subsubsection",
  FontColor->RGBColor[0, 0, 1]],

Cell["ARGUMENTOS DAS FUN\[CapitalCCedilla]\[CapitalOTilde]ES MODIFICADAS DE \
BESSEL;", "Text",
  FontSize->10,
  FontWeight->"Bold"],

Cell[BoxData[{
    \(\(mc = \@\(\(s\ \[Mu]\ \[Mu]c\)\/\[Rho]c\);\)\), "\[IndentingNewLine]", \

    \(\(ms = \@\(\(s\ \[Mu]\ \[Mu]s\)\/\[Rho]s\);\)\), "\[IndentingNewLine]", \

    \(\(x1 = mc\ r0;\)\), "\[IndentingNewLine]", 
    \(\(x2 = mc\ r1;\)\), "\[IndentingNewLine]", 
    \(\(x3 = ms\ r2;\)\), "\[IndentingNewLine]", 
    \(\(x4 = ms\ r3;\)\)}], "Input"],

Cell["IMPED\[CapitalAHat]NCIAS COMPONENTES;", "Text",
  FontSize->10,
  FontWeight->"Bold"],

Cell[BoxData[{
    \(\(z1 = \(\(\(\ \)\(s\ \[Mu]\ \[Mu]c\)\)\/\(2  \[Pi]\ x2\)\) 
          BesselI[0, x2]\/BesselI[1, x2];\)\), "\[IndentingNewLine]", 
    \(\(z2 = \(\(\(\ \)\(s\ \[Mu]\)\)\/\(2  \[Pi]\)\) 
          Log[r2/r1];\)\), "\[IndentingNewLine]", 
    \(\(z3 = \(\(\(\ \)\(s\ \[Mu]\ \[Mu]s\)\)\/\(2  \[Pi]\ x3\)\) \
\(BesselI[0, x3] BesselK[1, x4] + BesselK[0, x3] BesselI[1, \
x4]\)\/\(BesselI[1, x4] BesselK[1, x3] - BesselI[1, x3] BesselK[1, \
x4]\);\)\), "\[IndentingNewLine]", 
    \(\(z4 = \(\(\(\[Rho]s\)\(\ \)\)\/\(2  \[Pi]\ r2\ r3\)\) 
          1\/\(BesselI[1, x4] BesselK[1, x3] - BesselI[1, x3] BesselK[1, \
x4]\);\)\), "\[IndentingNewLine]", 
    \(\(z5 = \(\(\(\ \)\(s\ \[Mu]\ \[Mu]s\)\)\/\(2  \[Pi]\ x4\)\) \
\(BesselI[0, x4] BesselK[1, x3] + BesselK[0, x4] BesselI[1, \
x3]\)\/\(BesselI[1, x4] BesselK[1, x3] - BesselI[1, x3] BesselK[1, \
x4]\);\)\), "\[IndentingNewLine]", 
    \(\(z6 = \(\(\(\ \)\(s\ \[Mu]\)\)\/\(2  \[Pi]\)\) 
          Log[r4/r3];\)\), "\[IndentingNewLine]", 
    \(\(zcc = z1 + z2 + z3 + z5 + z6 - 2\ z4;\)\), "\[IndentingNewLine]", 
    \(\(zcs = z5 + z6 - z4;\)\), "\[IndentingNewLine]", 
    \(\(zsc = zcs;\)\), "\[IndentingNewLine]", 
    \(\(zss = z5 + z6;\)\)}], "Input"]
}, Open  ]],

