Cell[BoxData[{\(e1 = 
        LogLinearListPlot[Transpose[{f, Abs[Af1[\([Range[nf], col, 1]\)]]}], 
          DisplayFunction \[Rule] Identity, 
          PlotStyle \[Rule] plstyle1];\), "\n", \(e2 = 
        LogLinearListPlot[Transpose[{f, Abs[Af1[\([Range[nf], col, 2]\)]]}], 
          DisplayFunction \[Rule] Identity, 
          PlotStyle \[Rule] plstyle2];\), "\n", \(e3 = 
        LogLinearListPlot[Transpose[{f, Abs[Af1[\([Range[nf], col, 3]\)]]}], 
          DisplayFunction \[Rule] Identity, 
          PlotStyle \[Rule] plstyle3];\), "\n", \(e4 = 
        LogLinearListPlot[Transpose[{f, Abs[Af1[\([Range[nf], col, 4]\)]]}], 
          DisplayFunction \[Rule] Identity, 
          PlotStyle \[Rule] plstyle4];\), "\n", \(e5 = 
        LogLinearListPlot[Transpose[{f, Abs[Af1[\([Range[nf], col, 5]\)]]}], 
          DisplayFunction \[Rule] Identity, 
          PlotStyle \[Rule] plstyle1];\), "\n", \(e6 = 
        LogLinearListPlot[Transpose[{f, Abs[Af1[\([Range[nf], col, 6]\)]]}], 
          DisplayFunction \[Rule] Identity, 
          PlotStyle \[Rule] plstyle2];\), "\n", \(e7 = 
        LogLinearListPlot[Transpose[{f, Abs[Af1[\([Range[nf], col, 7]\)]]}], 
          DisplayFunction \[Rule] Identity, 
          PlotStyle \[Rule] plstyle3];\), "\[IndentingNewLine]", 
    RowBox[{
      RowBox[{"Ple1", "=", 
        RowBox[{"Show", "[", 
          
          RowBox[{\({e1, e2, e3, e4, e5, e6, e7}\), 
            ",", \(PlotLabel \[Rule] 
              FontForm["\<Fator de Propaga\[CCedilla]\[ATilde]o\>", \
{"\<Arial-Bold\>", \ 13}]\), ",", 
            RowBox[{
              StyleBox["FrameLabel",
                FormatType->StandardForm,
                FontFamily->"Courier-Bold",
                FontSize->11], 
              StyleBox[" ",
                FormatType->StandardForm,
