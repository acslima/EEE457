Cell[BoxData[{
    \(\(y2 = 
        rp2\ \@\(\(s\ \[Mu]\ \[Mu]p\)\/\[Rho]p\);\)\), "\[IndentingNewLine]", \

    \(\(Dp1 = 
        BesselI[1, y2] BesselK[1, y1] - 
