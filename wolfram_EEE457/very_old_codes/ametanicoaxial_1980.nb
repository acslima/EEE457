Notebook[{
Cell[TextData[{
  "Modelos Matem\[AAcute]ticos de Linhas de Transmiss\[ATilde]o\n",
  StyleBox["Petrobr\[AAcute]s Roncador Power Cable TCT",
    FontSize->18,
    FontWeight->"Bold"]
}], "Title",
  TextAlignment->Center,
  TextJustification->0],

Cell["\<\
Aluno: Paulo Eduardo Darski Rocha
Profs.: Dr. Antonio Carlos Siqueira de Lima / PhD Sandoval Carneiro Jr.
Poli/COPPE/UFRJ\
\>", "Subtitle"],

Cell[CellGroupData[{

Cell["Op\[CCedilla]\[OTilde]es de programa", "Section"],

Cell[BoxData[{
    \(<< LinearAlgebra`MatrixManipulation`\), "\[IndentingNewLine]", 
    \(<< Graphics`Graphics`\), "\[IndentingNewLine]", 
    \(\(Off[General::"\<spell\>", General::"\<spell1\>"];\)\)}], "Input"],

Cell[BoxData[
    \(\(SetOptions[{ListPlot, \ LogLinearListPlot, LogLogListPlot}, 
        Axes \[Rule] False, Frame \[Rule] True, PlotJoined \[Rule] True, 
        ImageSize \[Rule] 450, DefaultFont \[Rule] {"\<Helvetica\>", 14}, 
        PlotStyle \[Rule] {PointSize[0.015]}];\)\)], "Input"],

Cell[BoxData[{
    \(\(plstyle1 = {AbsoluteThickness[2], 
          RGBColor[1, 0, 0]};\)\), "\[IndentingNewLine]", 
    \(\(plstyle2 = {AbsoluteThickness[2], 
          RGBColor[0, 0, 1]};\)\), "\[IndentingNewLine]", 
    \(\(plstyle3 = {AbsoluteThickness[2], PointSize[ .015], 
          RGBColor[0, 1, 0]};\)\), "\[IndentingNewLine]", 
    \(\(plstyle4 = {AbsoluteThickness[2], PointSize[ .025], 
          RGBColor[1, 0.5, 0]};\)\)}], "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Dados de Entrada", "Section"],

Cell[CellGroupData[{

Cell[TextData[StyleBox["DIMENS\[CapitalOTilde]ES DO SISTEMA",
  FontSize->14,
  FontVariations->{"CompatibilityType"->0}]], "Subsection"],

Cell[CellGroupData[{

Cell["CIRCUITO", "Subsubsection",
  FontColor->RGBColor[0, 0, 1]],

Cell["RAIOS DOS CABOS COAXIAIS DO CIRCUITO DE FOR\[CapitalCCedilla]A;", "Text",
  FontSize->10,
  FontWeight->"Bold"],

Cell[BoxData[{
    \(\(r0 = 0;\)\), "\[IndentingNewLine]", 
    \(\(r1 = 19.50\ 10\^\(-3\);\)\), "\n", 
    \(\(r2 = 37.75\ 10\^\(-3\);\)\), "\[IndentingNewLine]", 
    \(\(r3 = 37.97\ 10\^\(-3\);\)\), "\[IndentingNewLine]", 
    \(\(r4 = 42.50\ 10\^\(-3\);\)\)}], "Input"],

Cell["ANGULO ENTRE OS ELEMENTOS CONDUTORES;", "Text",
  FontSize->10,
  FontWeight->"Bold"],

Cell[BoxData[
    \(\(\(\(\[Theta]jk = \(2\ \[Pi]\)\/3\) \)\(;\)\(\ \)\( (*entre\ os\ cabos\
\ coaxias*) \)\)\)], "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["TUBO", "Subsubsection",
  FontColor->RGBColor[0, 0, 1]],

Cell["RAIOS DOS TUBO;", "Text",
  FontSize->10,
  FontWeight->"Bold"],

Cell[BoxData[
    \(\(\(\(rp1 = 106.1\ 10\^\(-3\);\)\[IndentingNewLine]
    \(rp2 = 126.1\ 10\^\(-3\);\)\[IndentingNewLine]
    \(rp3 = 146.1\ 10\^\(-3\);\)\[IndentingNewLine]
    \(Dj = 
        60.6\ 10\^\(-3\);\)\  (*distancia\ do\ cabo\ ao\ centro\ do\ PT\
*) \[IndentingNewLine]
    \(\(Dk = 
        60.6\ 10\^\(-3\)\) \); \)\(\ \)\( (*distancia\ do\ cabo\ ao\ centro\ \
do\ PT*) \)\)\)], "Input"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["DIMENS\[CapitalOTilde]ES DA REDE E CARACTER\[CapitalIAcute]STICAS DOS \
MATERIAIS", "Subsection",
  FontSize->14],

Cell[CellGroupData[{

Cell["COMPRIMENTO E PROFUNDIDADE DA LINHA DE TRANSMISS\[CapitalATilde]O", \
"Subsubsection",
  FontColor->RGBColor[0, 0, 1]],

Cell[BoxData[{
    \(\(compr = 10*10\^3;\)\), "\[IndentingNewLine]", 
    \(\(h = 1;\)\)}], "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["CONSTANTES EL\[CapitalEAcute]TRICAS", "Subsubsection",
  FontColor->RGBColor[0, 0, 1]],

Cell[BoxData[{
    \(\(\[Mu] = 4.0\ \[Pi]\ 10\^\(-7\);\)\), "\[IndentingNewLine]", 
    \(\(\[Epsilon] = 8.854*10^\(-12\);\)\), "\[IndentingNewLine]", 
    \(\(\[Rho]s = 3.365\ 10^\(-8\);\)\), "\[IndentingNewLine]", 
    \(\(\[Rho]c = 1.718\ 10^\(-8\);\)\), "\[IndentingNewLine]", 
    \(\(\[Rho]p = 7.54\ 10^\(-8\);\)\), "\[IndentingNewLine]", 
    \(\(\[Rho]g = 100;\)\), "\[IndentingNewLine]", 
    \(\(\[Mu]c = 1;\)\), "\[IndentingNewLine]", 
    \(\(\[Mu]s = 1;\)\), "\[IndentingNewLine]", 
    \(\(\[Mu]p = 200;\)\), "\[IndentingNewLine]", 
    \(\(\[Mu]g = 1;\)\), "\[IndentingNewLine]", 
    \(\(\[Epsilon]c = 3.5;\)\), "\[IndentingNewLine]", 
    \(\(\[Epsilon]s = 3.5;\)\), "\[IndentingNewLine]", 
    \(\(\[Epsilon]p1 = 3.5;\)\), "\[IndentingNewLine]", 
    \(\(\[Epsilon]p3 = 3.5;\)\)}], "Input"]
}, Open  ]]
}, Open  ]]
}, Closed]],

Cell[CellGroupData[{

Cell["Configura\[CCedilla]\[ATilde]o da Rede", "Section",
  FontColor->RGBColor[0.443137, 0.156863, 0.572549]],

Cell[CellGroupData[{

Cell["LOCALIZA\[CapitalCCedilla]\[CapitalATilde]O DOS CONDUTORES NO CIRCUITO \
DE FOR\[CapitalCCedilla]A", "Subsection",
  FontSize->14],

Cell[CellGroupData[{

Cell["CABOS COAXIAIS", "Subsubsection",
  FontColor->RGBColor[0, 0, 1]],

Cell[BoxData[{
    \(xc1 = 0; yc1 = Dj\ ;\), "\[IndentingNewLine]", 
    \(xc2 = Dk\ Sin[Pi/3]; 
    yc2 = \(-Dk\)\ Sin[Pi/6];\), "\[IndentingNewLine]", 
    \(xc3 = \(-Dk\)\ \ Sin[Pi/3]; yc3 = \(-Dk\)\ Sin[Pi/6];\)}], "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["TUBO", "Subsubsection",
  FontColor->RGBColor[0, 0, 1]],

Cell[BoxData[{
    \(\(xpt = 0;\)\), "\[IndentingNewLine]", 
    \(\(ypt = 0;\)\)}], "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["LAYOUT", "Subsubsection",
  FontColor->RGBColor[0, 0, 1]],

Cell[BoxData[{
    \(\(xc = {xc1, xc1, xc1, xc1, xc2, xc2, xc2, xc2, xc3, xc3, xc3, xc3, 
          xpt, xpt, xpt};\)\), "\[IndentingNewLine]", 
    \(\(yc = {yc1, yc1, yc1, yc1, yc2, yc2, yc2, yc2, yc3, yc3, yc3, yc3, 
          ypt, ypt, ypt};\)\), "\n", 
    \(\(r = {r1, r2, r3, r4, r1, r2, r3, r4, r1, r2, r3, r4, rp1, rp2, 
          rp3};\)\)}], "Input"],

Cell[BoxData[
    \(\(umbilical = 
        Table[{Circle[{xc[\([i]\)], yc[\([i]\)]}, r[\([i]\)]]}, {i, 1, 
            15}];\)\)], "Input"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["CABO PIPE-TYPE", "Subsection",
