Cell["Matriz de Transforma\[CCedilla]\[ATilde]o (T)", "Subsubsection",
  FontSize->14,
  FontWeight->"Bold"],

Cell["Magnitude da Matrix de Transforma\[CCedilla]\[ATilde]o", "SmallText",
  FontWeight->"Bold"],

Cell[BoxData[{\(c1 = 
        LogLinearListPlot[Transpose[{f, Abs[T[\([Range[nf], 1, col]\)]]}], 
          PlotStyle \[Rule] plstyle1, \ 
          DisplayFunction \[Rule] Identity];\), "\[IndentingNewLine]", \(c2 = 
        LogLinearListPlot[Transpose[{f, Abs[T[\([Range[nf], 2, col]\)]]}], 
          PlotStyle \[Rule] plstyle2, \ 
          DisplayFunction \[Rule] Identity];\), "\[IndentingNewLine]", \(c3 = 
        LogLinearListPlot[Transpose[{f, Abs[T[\([Range[nf], 3, col]\)]]}], 
          PlotStyle \[Rule] plstyle3, \ 
          DisplayFunction \[Rule] Identity];\), "\[IndentingNewLine]", \(c4 = 
        LogLinearListPlot[Transpose[{f, Abs[T[\([Range[nf], 4, col]\)]]}], 
          PlotStyle \[Rule] plstyle4, \ 
          DisplayFunction \[Rule] Identity];\), "\[IndentingNewLine]", \(c5 = 
        LogLinearListPlot[Transpose[{f, Abs[T[\([Range[nf], 5, col]\)]]}], 
          PlotStyle \[Rule] plstyle1, \ 
          DisplayFunction \[Rule] Identity];\), "\[IndentingNewLine]", \(c6 = 
        LogLinearListPlot[Transpose[{f, Abs[T[\([Range[nf], 6, col]\)]]}], 
          PlotStyle \[Rule] plstyle2, \ 
          DisplayFunction \[Rule] Identity];\), "\[IndentingNewLine]", 
    RowBox[{\(c7 = 
          LogLinearListPlot[Transpose[{f, Abs[T[\([Range[nf], 7, col]\)]]}], 
            PlotStyle \[Rule] plstyle3, \ 
            DisplayFunction \[Rule] Identity];\), 
      "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
    RowBox[{
      RowBox[{"Plc1", "=", 
        RowBox[{"Show", "[", 
          
          RowBox[{\({c1, c2, c3, c4, c5, c6, c7}\), 
            ",", \(PlotLabel \[Rule] 
              FontForm["\<M\[OAcute]dulo de T\>", {"\<Arial-Bold\>", \ 13}]\),
             ",", 
            RowBox[{
              StyleBox["FrameLabel",
                FormatType->StandardForm,
                FontFamily->"Courier-Bold",
                FontSize->11], 
              StyleBox[" ",
                FormatType->StandardForm,
                FontFamily->"Courier-Bold",
                FontSize->11], "\[Rule]", 
              RowBox[{"{", 
                RowBox[{
                  RowBox[{"FontForm", "[", 
                    RowBox[{
                      StyleBox["\"\<Frequ\[EHat]ncia\>\"",
                        FormatType->StandardForm,
                        FontFamily->"Courier-Bold",
                        FontSize->11], ",", \({"\<Arial-Bold\>", \ 10}\)}], 
                    "]"}], ",", 
                  RowBox[{"FontForm", "[", 
                    RowBox[{
                      StyleBox["\"\<Amplitude\>\"",
                        FormatType->StandardForm,
                        FontFamily->"Courier-Bold",
                        FontSize->11], ",", \({"\<Arial-Bold\>", \ 10}\)}], 
                    "]"}]}], "}"}]}], 
            StyleBox[",",
              FormatType->StandardForm,
              FontFamily->"Courier-Bold",
              FontSize->11], \(PlotRange \[Rule] \ All\)}], "]"}]}], 
      ";"}]}], "Input"],

