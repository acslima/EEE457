Cell[CellGroupData[{

Cell["Avalia\[CCedilla]\[ATilde]o do comportamento com a frequ\[EHat]ncia", \
"Section",
  TextAlignment->Left,
  TextJustification->1],

Cell[CellGroupData[{

Cell[BoxData[
    \(AbsoluteTiming[
      Do[{s = I\ 2\ \[Pi]\ f[\([nm]\)], \[IndentingNewLine]mg = \@\(\(s\ \
\[Mu]\ \[Mu]g\)\/\[Rho]g\), \[IndentingNewLine]polchk = 
            NIntegrate[\(Exp[\(-2\)\ h\ \@\(\[Alpha]^2 + mg^2\)]\/\(Abs[\
\[Alpha]] + \@\(\[Alpha]^2 + mg^2\)\)\) 
                Exp[I\ rp3\ \[Alpha]], {\[Alpha], \(-\[Infinity]\), \
\[Infinity]}, MaxRecursion \[Rule] 50], \[IndentingNewLine]\ 
          Zo = \(\(s\ \[Mu]\)\/\(\(2\)\(\ \)\(\[Pi]\)\(\ \)\)\) \((BesselK[0, 
                    mg*rp3] - BesselK[0, mg\ \ \@\(rp3^2 + \((2\ h)\)^2\)] + 
                  polchk)\), \[IndentingNewLine]Z = 
            Zi + Zp + Zc + Zo, \[IndentingNewLine]Y = 
            s\ Inverse[Ptt], \[IndentingNewLine]S[\([nm]\)] = 
            Z . Y, \[IndentingNewLine]\[Gamma] = 
            MatrixPower[N[Z . Y], 
              0.5], \[IndentingNewLine]Yc1\_\(\(\[LeftDoubleBracket]\)\(nm\)\(\
\[RightDoubleBracket]\)\) = 
            N[Inverse[
                  Z]] . \[Gamma], \[IndentingNewLine]{\[Lambda]\_\([\([nm]\)]\
\), T\_\([\([nm]\)]\)} = 
            Eigensystem[
              S[\([nm]\)]], \[IndentingNewLine]\[CapitalGamma]1[\([nm]\)] = 
            Sqrt[\[Lambda]\_\([\([nm]\)]\)], \[IndentingNewLine]Af1\_\(\(\
\[LeftDoubleBracket]\)\(nm\)\(\[RightDoubleBracket]\)\) = \ 
            Transpose[T[\([nm]\)]] . 
              DiagonalMatrix[
                Exp[\((\(-compr\))\)\ \[CapitalGamma]1[\([nm]\)]]] . 
              Inverse[Transpose[
                  T[\([nm]\)]]], \[IndentingNewLine]Am1[\([nm]\)] = 
            Exp[\((\(-compr\))\)*\[CapitalGamma]1[\([nm]\)]], \
\[IndentingNewLine]Zall[\([nm]\)] = Z, \[IndentingNewLine]Rall[\([nm]\)] = 
            Re[Z], \[IndentingNewLine]Lall[\([nm]\)] = 
            Im[Z]/\((2\ Pi\ f[\([nm]\)])\)}, {nm, 1, nf}]]\)], "Input"],

Cell[BoxData[
    \({141.338449`8.601805314701098\ Second, Null}\)], "Output"]
}, Open  ]]
}, Open  ]],

