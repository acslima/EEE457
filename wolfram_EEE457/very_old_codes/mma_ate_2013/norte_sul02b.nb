        RowBox[{"np", "-", "1"}]}], "}"}]}], "]"}]}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Calculo", " ", "da", " ", "matriz", " ", "de", " ", "admitancia", " ", 
     "nodal", " ", "a", " ", "partir", " ", "de", " ", "parametros", " ", 
     "unitarios", " ", "e", " ", "comprimento", " ", "do", " ", "circuito"}], 
    "*)"}], 
   RowBox[{
    RowBox[{"Ynodal", "[", 
     RowBox[{"Z_", ",", "Y_", ",", "length_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Z1", "=", "Z"}], ",", 
