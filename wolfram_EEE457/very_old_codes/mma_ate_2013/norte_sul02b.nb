        "y12", ",", "Yy"}], "}"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"{", 
         RowBox[{"eval", ",", "evect"}], "}"}], "=", 
        RowBox[{"Eigensystem", "[", 
         RowBox[{"N", "[", 
          RowBox[{"Z1", ".", "Y1"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"d", "=", 
        RowBox[{"Sqrt", "[", "eval", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Tv", "=", 
        RowBox[{"Transpose", "[", "evect", "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Tvi", "=", 
        RowBox[{"Inverse", "[", 
         RowBox[{"Transpose", "[", "evect", "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"hm", "=", 
