Cell[CellGroupData[{

Cell["Rutinas Auxiliares (Segmentador, RPT, etc)", "Section",
 CellChangeTimes->{{3.480195392848486*^9, 3.4801953952081337`*^9}, {
  3.49282916486075*^9, 3.49282918623575*^9}, {3.492832266470125*^9, 
  3.492832270345125*^9}, {3.492832376376375*^9, 3.492832379267*^9}, {
  3.49285265667325*^9, 3.492852672126375*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"segs", "[", 
    RowBox[{"SP1_List", ",", "SP2_List", ",", "NS_Real", ",", "r_Real"}], 
    "]"}], ":=", 
   RowBox[{"Module", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "LSPH1M", ",", "LSGM", ",", "LTotal", ",", "RP12C", ",", "SP1NS", ",", 
       "SP2NS", ",", "SP12C", ",", "SP1XI", ",", "SP2XI", ",", "vectorr", ",",
        "SP12XI", ",", "radius", ",", "LSmatriz"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"LSPH1M", "=", 
       RowBox[{"Length", "[", "SP1", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"LSGM", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"Norm", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"SP2", "-", "SP1"}], ")"}], "[", 
           RowBox[{"[", 
            RowBox[{"#", ",", "All"}], "]"}], "]"}], "]"}], "&"}], "/@", 
        RowBox[{"Range", "[", 
         RowBox[{"1", ",", "LSPH1M"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"LTotal", "=", 
       RowBox[{"Total", "[", "LSGM", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"SP1NS", "=", 
       RowBox[{"Flatten", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"SP1", "[", 
               RowBox[{"[", 
                RowBox[{"i", ",", "All"}], "]"}], "]"}], "+", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"#", "/", "NS"}], ")"}], "*", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"SP2", "[", 
                  RowBox[{"[", 
                   RowBox[{"i", ",", "All"}], "]"}], "]"}], "-", 
                 RowBox[{"SP1", "[", 
                  RowBox[{"[", 
                   RowBox[{"i", ",", "All"}], "]"}], "]"}]}], ")"}]}]}], 
             "&"}], "/@", 
            RowBox[{"Range", "[", 
             RowBox[{"0", ",", 
              RowBox[{"NS", "-", "1"}]}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", "LSPH1M"}], "}"}]}], "]"}], ",", 
         "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"SP2NS", "=", 
       RowBox[{"Flatten", "[", 
        RowBox[{
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"SP1", "[", 
               RowBox[{"[", 
                RowBox[{"i", ",", "All"}], "]"}], "]"}], "+", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"#", "+", "1"}], ")"}], "/", "NS"}], ")"}], "*", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{"SP2", "[", 
                  RowBox[{"[", 
                   RowBox[{"i", ",", "All"}], "]"}], "]"}], "-", 
                 RowBox[{"SP1", "[", 
                  RowBox[{"[", 
                   RowBox[{"i", ",", "All"}], "]"}], "]"}]}], ")"}]}]}], 
             "&"}], "/@", 
            RowBox[{"Range", "[", 
             RowBox[{"0", ",", 
              RowBox[{"NS", "-", "1"}]}], "]"}]}], ",", 
           RowBox[{"{", 
            RowBox[{"i", ",", "1", ",", "LSPH1M"}], "}"}]}], "]"}], ",", 
         "1"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"SP12C", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"SP1NS", "+", "SP2NS"}], ")"}], "/", "2"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"vectorr", "=", 
       RowBox[{
        RowBox[{
         RowBox[{"Cross", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"1", ",", "0", ",", "0"}], "}"}], ",", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"SP2NS", "-", "SP1NS"}], ")"}], "[", 
            RowBox[{"[", "#", "]"}], "]"}]}], "]"}], "&"}], "/@", 
        RowBox[{"Range", "[", 
         RowBox[{"1", ",", 
          RowBox[{"NS", "*", "LSPH1M"}]}], "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Norm", "[", 
            RowBox[{"vectorr", "[", 
             RowBox[{"[", "#", "]"}], "]"}], "]"}], "\[Equal]", "0"}], ",", 
          RowBox[{
           RowBox[{"vectorr", "[", 
            RowBox[{"[", "#", "]"}], "]"}], "=", 
           RowBox[{"Cross", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"0", ",", "1", ",", "0"}], "}"}], ",", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"SP2NS", "-", "SP1NS"}], ")"}], "[", 
              RowBox[{"[", "#", "]"}], "]"}]}], "]"}]}], ",", 
          RowBox[{"vectorr", "[", 
