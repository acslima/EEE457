Notebook[{

Cell[CellGroupData[{
Cell["Ikeda Delay Differential Equation", "Section",
 CellFrameColor->RGBColor[
  0.6449835965514611, 0.758632791638056, 0.2516823071641108],
 FontColor->RGBColor[
  0.6449835965514611, 0.758632791638056, 0.2516823071641108]],

Cell[BoxData[
 RowBox[{"Manipulate", "[", 
  RowBox[{
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"sol", ",", "  ", "t", ",", "x"}], "}"}], ",", 
     RowBox[{
      RowBox[{"sol", "=", " ", 
       RowBox[{"First", "[", 
        RowBox[{"NDSolve", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"x", "'"}], "[", "t", "]"}], "\[Equal]", 
             RowBox[{"Sin", "[", 
              RowBox[{"x", "[", 
               RowBox[{"t", "-", "\[Tau]"}], "]"}], "]"}]}], ",", " ", 
            RowBox[{
             RowBox[{"x", "[", 
              RowBox[{"t", "/;", 
               RowBox[{"t", "\[LessEqual]", " ", "0"}]}], "]"}], "\[Equal]", 
             "xh"}]}], "}"}], ",", "x", ",", 
          RowBox[{"{", 
           RowBox[{"t", ",", "0", ",", "500"}], "}"}], ",", " ", 
          RowBox[{"Method", "\[Rule]", "\"\<Extrapolation\>\""}]}], "]"}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"TrueQ", "[", "pp", "]"}], ",", "\[IndentingNewLine]", 
        RowBox[{"ParametricPlot", "[", 
         RowBox[{
          RowBox[{"Evaluate", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"x", "[", 
               RowBox[{"t", "-", "\[Tau]"}], "]"}], ",", 
              RowBox[{"x", "[", "t", "]"}]}], "}"}], " ", "/.", " ", "sol"}], 
           "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"t", ",", "\[Tau]", ",", "500"}], "}"}], ",", " ", 
          "\[IndentingNewLine]", 
          RowBox[{"PlotRange", "\[Rule]", "All"}], ",", "\[IndentingNewLine]", 
          RowBox[{"Epilog", "\[Rule]", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"PointSize", "[", "0.025", "]"}], ",", 
             RowBox[{"Point", "[", 
              RowBox[{"{", 
               RowBox[{"xh", ",", 
                RowBox[{
                 RowBox[{"x", "[", "\[Tau]", "]"}], " ", "/.", " ", "sol"}]}],
                "}"}], "]"}]}], "}"}]}], ",", 
          RowBox[{"ColorFunction", "\[Rule]", 
           RowBox[{"Function", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"x", ",", "y", ",", "t"}], "}"}], ",", 
             RowBox[{
              RowBox[{"ColorData", "[", "\"\<DarkRainbow\>\"", "]"}], "[", 
              "t", "]"}]}], "]"}]}], ",", 
          RowBox[{"ImageSize", "\[Rule]", 
           RowBox[{"{", 
            RowBox[{"500", ",", "350"}], "}"}]}]}], "]"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"Plot", "[", 
         RowBox[{
          RowBox[{"Evaluate", "[", 
           RowBox[{
            RowBox[{"x", "[", "t", "]"}], " ", "/.", " ", "sol"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"t", ",", "\[Tau]", ",", "500"}], "}"}], ",", " ", 
          "\[IndentingNewLine]", 
          RowBox[{"PlotRange", "\[Rule]", "All"}], ",", "\[IndentingNewLine]", 
          RowBox[{"ColorFunction", "\[Rule]", 
           RowBox[{"Function", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"t", ",", "x"}], "}"}], ",", 
             RowBox[{
              RowBox[{"ColorData", "[", "\"\<DarkRainbow\>\"", "]"}], "[", 
              "t", "]"}]}], "]"}]}], ",", 
          RowBox[{"ImageSize", "\[Rule]", 
           RowBox[{"{", 
            RowBox[{"500", ",", "350"}], "}"}]}]}], "]"}]}], "]"}]}]}], "]"}],
    ",", "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\[Tau]", ",", " ", "3.894", ",", "\"\<delay \[Tau]\>\""}], 
      "}"}], ",", ".25", ",", "6", ",", 
     RowBox[{"Appearance", "\[Rule]", "\"\<Labeled\>\""}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"xh", ",", " ", 
       RowBox[{"\[Pi]", "/", "2"}], ",", " ", 
       RowBox[{"\"\<initial history \>\"", "<>", 
        RowBox[{"ToString", "[", 
         RowBox[{
          RowBox[{"x", "[", "t", "]"}], ",", " ", "TraditionalForm"}], "]"}], 
        "<>", "\"\< for \>\"", "<>", 
        RowBox[{"ToString", "[", 
         RowBox[{
          RowBox[{"t", "\[LessEqual]", " ", "0"}], ",", " ", 
          "TraditionalForm"}], "]"}]}]}], "}"}], ",", "0", ",", "\[Pi]", ",", 
     
     RowBox[{"Appearance", "\[Rule]", "\"\<Labeled\>\""}]}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "pp", ",", "False", ",", " ", "\"\<plot in delay phase plane\>\""}], 
      "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"False", ",", " ", "True"}], "}"}]}], "}"}], ",", 
   RowBox[{"SynchronousUpdating", "\[Rule]", "False"}]}], "]"}]], "Input",
 CellChangeTimes->{
  3.35696210375764*^9, 3.4363010313136*^9, {3.4363013892244*^9, 
   3.4363014451972*^9}, {3.436309181984375*^9, 3.436309223375*^9}, {
   3.436489409102395*^9, 3.436489432087064*^9}}]
}, Open  ]],

Cell[BoxData[
 TagBox[
  StyleBox[
   DynamicModuleBox[{$CellContext`pp$$ = False, $CellContext`xh$$ = 
    2.161415745669778, $CellContext`\[Tau]$$ = 3.894, Typeset`show$$ = True, 
    Typeset`bookmarkList$$ = {}, Typeset`bookmarkMode$$ = "Menu", 
    Typeset`animator$$, Typeset`animvar$$ = 1, Typeset`name$$ = 
    "\"untitled\"", Typeset`specs$$ = {{{
       Hold[$CellContext`\[Tau]$$], 3.894, "delay \[Tau]"}, 0.25, 6}, {{
       Hold[$CellContext`xh$$], 2.161415745669778, 
       "initial history \!\(TraditionalForm\`\(x(t)\)\) for \
\!\(TraditionalForm\`\(t \[LessEqual] 0\)\)"}, 0, Pi}, {{
       Hold[$CellContext`pp$$], False, "plot in delay phase plane"}, {
      False, True}}}, Typeset`size$$ = {500., {173., 177.}}, 
    Typeset`update$$ = 0, Typeset`initDone$$, Typeset`skipInitDone$$ = 
    True, $CellContext`\[Tau]$60257$$ = 0, $CellContext`xh$60258$$ = 
    0, $CellContext`pp$60259$$ = False}, 
    DynamicBox[Manipulate`ManipulateBoxes[
     1, StandardForm, 
      "Variables" :> {$CellContext`pp$$ = False, $CellContext`xh$$ = 
        2.161415745669778, $CellContext`\[Tau]$$ = 3.894}, 
      "ControllerVariables" :> {
        Hold[$CellContext`\[Tau]$$, $CellContext`\[Tau]$60257$$, 0], 
        Hold[$CellContext`xh$$, $CellContext`xh$60258$$, 0], 
        Hold[$CellContext`pp$$, $CellContext`pp$60259$$, False]}, 
      "OtherVariables" :> {
       Typeset`show$$, Typeset`bookmarkList$$, Typeset`bookmarkMode$$, 
        Typeset`animator$$, Typeset`animvar$$, Typeset`name$$, 
        Typeset`specs$$, Typeset`size$$, Typeset`update$$, Typeset`initDone$$,
         Typeset`skipInitDone$$}, "Body" :> 
      Block[{$CellContext`sol, $CellContext`t, $CellContext`x}, \
$CellContext`sol = First[
           NDSolve[{Derivative[1][$CellContext`x][$CellContext`t] == Sin[
               $CellContext`x[$CellContext`t - $CellContext`\[Tau]$$]], \
$CellContext`x[
               
               Condition[$CellContext`t, $CellContext`t <= 
                0]] == $CellContext`xh$$}, $CellContext`x, {$CellContext`t, 0,
              500}, Method -> "Extrapolation"]]; If[
          TrueQ[$CellContext`pp$$], 
          ParametricPlot[
           Evaluate[
            ReplaceAll[{
              $CellContext`x[$CellContext`t - $CellContext`\[Tau]$$], 
              $CellContext`x[$CellContext`t]}, $CellContext`sol]], \
{$CellContext`t, $CellContext`\[Tau]$$, 500}, PlotRange -> All, Epilog -> {
             PointSize[0.025], 
             Point[{$CellContext`xh$$, 
               ReplaceAll[
                $CellContext`x[$CellContext`\[Tau]$$], $CellContext`sol]}]}, 
           ColorFunction -> 
           Function[{$CellContext`x, $CellContext`y, $CellContext`t}, 
             ColorData["DarkRainbow"][$CellContext`t]], 
           ImageSize -> {500, 350}], 
          Plot[
           Evaluate[
            ReplaceAll[
             $CellContext`x[$CellContext`t], $CellContext`sol]], \
{$CellContext`t, $CellContext`\[Tau]$$, 500}, PlotRange -> All, ColorFunction -> 
           Function[{$CellContext`t, $CellContext`x}, 
             ColorData["DarkRainbow"][$CellContext`t]], 
           ImageSize -> {500, 350}]]], 
      "Specifications" :> {{{$CellContext`\[Tau]$$, 3.894, "delay \[Tau]"}, 
         0.25, 6, Appearance -> 
         "Labeled"}, {{$CellContext`xh$$, 2.161415745669778, 
          "initial history \!\(TraditionalForm\`\(x(t)\)\) for \
\!\(TraditionalForm\`\(t \[LessEqual] 0\)\)"}, 0, Pi, Appearance -> 
         "Labeled"}, {{$CellContext`pp$$, False, 
          "plot in delay phase plane"}, {False, True}}}, 
      "Options" :> {SynchronousUpdating -> False}, 
      "DefaultOptions" :> {ControllerLinking -> True}],
     ImageSizeCache->{545., {240., 245.}},
     SingleEvaluation->True],
    Deinitialization:>None,
    DynamicModuleValues:>{},
    SynchronousInitialization->True,
    UnsavedVariables:>{Typeset`initDone$$},
    UntrackedVariables:>{Typeset`size$$}], "Manipulate",
   Deployed->True,
