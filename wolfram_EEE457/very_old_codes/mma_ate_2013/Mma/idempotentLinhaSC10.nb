Cell[BoxData[
 RowBox[{
  RowBox[{"recompmatrizesexport", "[", 
   RowBox[{
   "polos_", ",", "residuos_", ",", "TermD_", ",", "TermE_", ",", "freq_"}], 
   "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "SERA", ",", "SERB", ",", "SERC", ",", "SERD", ",", "SERE", ",", 
      "SERRsinconv", ",", "SERpoles", ",", "s", ",", "n", ",", "npol"}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"n", "=", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Sqrt", "[", 
          RowBox[{"1", "+", 
           RowBox[{"8", "*", 
            RowBox[{"N", "[", 
             RowBox[{"Length", "[", "residuos", "]"}], "]"}]}]}], "]"}], "-", 
         "1"}], ")"}], "/", "2"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"s", "=", 
      RowBox[{"{", "freq", "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"SERA", "=", 
      RowBox[{"SparseArray", "[", 
       RowBox[{
        RowBox[{"DiagonalMatrix", "[", 
         RowBox[{"Flatten", "[", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"{", "polos", "}"}], ",", 
            RowBox[{"{", "n", "}"}]}], "]"}], "]"}], "]"}], "//", "Chop"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"npol", "=", 
      RowBox[{"Length", "[", "polos", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"SERB", "=", 
      RowBox[{"Table", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{"n", "*", "npol"}], "}"}], ",", 
        RowBox[{"{", "n", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Flatten", "[", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"SERB", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"(", 
               RowBox[{"j", "-", "1"}], ")"}], "*", "npol"}], "+", "i"}], ",",
             "j"}], "]"}], "]"}], "=", "1"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "npol"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "1", ",", "n"}], "}"}]}], "]"}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", "SERD", "}"}], "=", 
      RowBox[{"recompmatr", "[", "TermD", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", "SERE", "}"}], "=", 
      RowBox[{"recompmatr", "[", "TermE", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"SERRsinconv", "=", 
      RowBox[{"Transpose", "[", "residuos", "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"SERC", "=", 
      RowBox[{"Table", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{"Length", "[", "polos", "]"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"Length", "[", "TermD", "]"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"Length", "[", "TermD", "]"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"SERC", "[", 
         RowBox[{"[", "n", "]"}], "]"}], "=", 
        RowBox[{
         RowBox[{"recompmatr", "[", 
          RowBox[{"residuos", "[", 
           RowBox[{"[", 
            RowBox[{"All", ",", "n"}], "]"}], "]"}], "]"}], "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "1", ",", 
         RowBox[{"Length", "[", "polos", "]"}]}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"SERC", "=", 
      RowBox[{"Transpose", "[", 
       RowBox[{"Flatten", "[", 
        RowBox[{"SERC", ",", "1"}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"SERpoles", "=", "polos"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"{", 
       RowBox[{
       "SERA", ",", "SERB", ",", "SERC", ",", "SERD", ",", "SERE", ",", 
        "SERRsinconv", ",", "SERpoles", ",", "s"}], "}"}], "]"}]}]}], 
   "]"}]}]], "Input",
