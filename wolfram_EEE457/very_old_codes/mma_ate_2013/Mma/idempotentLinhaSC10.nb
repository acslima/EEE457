  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"kk", ",", "nm", ",", "Matr2"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Matr2", "=", 
      RowBox[{"Table", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{"N", "[", 
          RowBox[{"Max", "[", 
           RowBox[{"Dimensions", "[", "Matr", "]"}], "]"}], "]"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"N", "[", 
           RowBox[{"Min", "[", 
            RowBox[{"Dimensions", "[", "Matr", "]"}], "]"}], "]"}], "*", 
          RowBox[{"(", 
           RowBox[{"N", "[", 
            RowBox[{"Min", "[", 
             RowBox[{"Dimensions", "[", "Matr", "]"}], "]"}], "]"}], ")"}]}], 
         "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"nm", "=", "1"}], ",", 
       RowBox[{"nm", "\[LessEqual]", 
        RowBox[{"N", "[", 
         RowBox[{"Max", "[", 
          RowBox[{"Dimensions", "[", "Matr", "]"}], "]"}], "]"}]}], ",", 
       RowBox[{"nm", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
