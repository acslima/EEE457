            RowBox[{
             RowBox[{"resfim", "[", 
              RowBox[{"[", "nm", "]"}], "]"}], "=", 
             RowBox[{
              RowBox[{"XXff", "[", 
               RowBox[{"[", "nm", "]"}], "]"}], "+", 
              RowBox[{"\[ImaginaryI]", "*", 
               RowBox[{"XXff", "[", 
                RowBox[{"[", 
                 RowBox[{"nm", "+", "1"}], "]"}], "]"}]}]}]}], ";", 
            RowBox[{
             RowBox[{"resfim", "[", 
              RowBox[{"[", 
               RowBox[{"nm", "+", "1"}], "]"}], "]"}], "=", 
             RowBox[{
              RowBox[{"XXff", "[", 
               RowBox[{"[", "nm", "]"}], "]"}], "-", 
              RowBox[{"\[ImaginaryI]", "*", 
               RowBox[{"XXff", "[", 
                RowBox[{"[", 
                 RowBox[{"nm", "+", "1"}], "]"}], "]"}]}]}]}]}], ",", "0"}], 
          "]"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"nm", ",", "npol"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"termoD", "\[Equal]", "1"}], "\[And]", 
        RowBox[{"termoE", "\[Equal]", "1"}]}], ",", 
       RowBox[{
        RowBox[{"dd", "=", 
         RowBox[{"XXff", "[", 
          RowBox[{"[", 
           RowBox[{"-", "2"}], "]"}], "]"}]}], ";", 
        RowBox[{"ee", "=", 
         RowBox[{"XXff", "[", 
          RowBox[{"[", 
           RowBox[{"-", "1"}], "]"}], "]"}]}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"termoD", "\[Equal]", "1"}], "\[And]", 
