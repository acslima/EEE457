Cell[BoxData[
 RowBox[{
  RowBox[{"res", "[", 
   RowBox[{"polos_List", ",", "freq_List", ",", "data_List", ",", 
    RowBox[{"termoD_:", "1."}], ",", 
    RowBox[{"termoE_:", "1."}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "npol", ",", "nfreq", ",", "ss", ",", "indices", ",", "AAnum", ",", 
      "UUmS", ",", "AAf", ",", "AAff", ",", "AAffT", ",", "normas", ",", 
      "BBff", ",", "XXff", ",", "resfim", ",", "dd", ",", "ee", ",", "naux", 
      ",", "AAAaux", ",", "AAAscale", ",", "Xaux", ",", "scale"}], "}"}], ",",
     "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"npol", "=", 
      RowBox[{"Length", "[", "polos", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"nfreq", "=", 
      RowBox[{"Length", "[", "freq", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"ss", "=", 
      RowBox[{"\[ImaginaryI]", "*", 
       RowBox[{"N", "[", "freq", "]"}]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"indices", "=", 
      RowBox[{"idx", "[", "polos", "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"AAnum", "=", 
      RowBox[{"Transpose", "[", 
       RowBox[{"Aux", "[", 
        RowBox[{
         RowBox[{"ss", "[", 
          RowBox[{"[", 
           RowBox[{"Range", "[", "nfreq", "]"}], "]"}], "]"}], ",", "polos", 
         ",", "indices"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"UUmS", "=", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"termoD", "\[Equal]", "1"}], "\[And]", 
         RowBox[{"termoE", "\[Equal]", "1"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"1", ",", 
            RowBox[{"ss", "[", 
             RowBox[{"[", "#", "]"}], "]"}]}], "}"}], "&"}], "/@", 
         RowBox[{"Range", "[", "nfreq", "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"termoD", "\[Equal]", "1"}], "\[And]", 
           RowBox[{"termoE", "\[Equal]", "0"}]}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"{", "1", "}"}], "&"}], "/@", 
           RowBox[{"Range", "[", "nfreq", "]"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"termoD", "\[Equal]", "0"}], "\[And]", 
             RowBox[{"termoE", "\[Equal]", "1"}]}], ",", 
            RowBox[{
             RowBox[{
              RowBox[{"{", 
               RowBox[{"ss", "[", 
                RowBox[{"[", "#", "]"}], "]"}], "}"}], "&"}], "/@", 
             RowBox[{"Range", "[", "nfreq", "]"}]}], ",", 
            RowBox[{
             RowBox[{
              RowBox[{"{", "}"}], "&"}], "/@", 
             RowBox[{"Range", "[", "nfreq", "]"}]}]}], "]"}]}], "]"}]}], 
       "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"AAf", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"Flatten", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"AAnum", "[", 
            RowBox[{"[", "#", "]"}], "]"}], ",", 
           RowBox[{"UUmS", "[", 
            RowBox[{"[", "#", "]"}], "]"}]}], "}"}], "]"}], "&"}], "/@", 
       RowBox[{"Range", "[", "nfreq", "]"}]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"AAff", "=", 
      RowBox[{"ArrayFlatten", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"Re", "[", "AAf", "]"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"Im", "[", "AAf", "]"}], "}"}]}], "}"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"BBff", "=", 
      RowBox[{"Flatten", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Re", "[", "data", "]"}], ",", 
         RowBox[{"Im", "[", "data", "]"}]}], "}"}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"naux", "=", 
      RowBox[{"termoD", "+", "termoE"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"AAffT", "=", 
      RowBox[{"Transpose", "[", "AAff", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"normas", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"Norm", "[", 
         RowBox[{"AAffT", "[", 
          RowBox[{"[", "#", "]"}], "]"}], "]"}], "&"}], "/@", 
       RowBox[{"Range", "[", 
        RowBox[{"1", ",", 
         RowBox[{"npol", "+", "naux"}]}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"AAAaux", "=", 
      RowBox[{"AAffT", "/", "normas"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"AAAscale", "=", 
      RowBox[{"Transpose", "[", "AAAaux", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Xaux", "=", 
      RowBox[{"LeastSquares", "[", 
       RowBox[{"AAAscale", ",", "BBff"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"scale", "=", 
      RowBox[{"1", "/", "normas"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"XXff", "=", 
      RowBox[{"Xaux", "*", "scale"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"resfim", "=", 
      RowBox[{"0", "*", 
       RowBox[{"Range", "[", 
        RowBox[{"1", ",", "npol"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"indices", "[", 
           RowBox[{"[", "nm", "]"}], "]"}], "\[Equal]", "0"}], ",", 
         RowBox[{
          RowBox[{"resfim", "[", 
           RowBox[{"[", "nm", "]"}], "]"}], "=", 
