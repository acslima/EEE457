Cell[BoxData[
 RowBox[{
  RowBox[{"recompmatrlarga", "[", "Matr_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"YsAux", ",", "Ys", ",", "k"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
