         RowBox[{
          RowBox[{"dd", "=", 
           RowBox[{"XXff", "[", 
            RowBox[{"[", 
             RowBox[{"-", "1"}], "]"}], "]"}]}], ";", 
          RowBox[{"ee", "=", "0"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"termoD", "\[Equal]", "0"}], "\[And]", 
            RowBox[{"termoE", "\[Equal]", "1"}]}], ",", 
           RowBox[{
            RowBox[{"dd", "=", "0"}], ";", 
            RowBox[{"ee", "=", 
