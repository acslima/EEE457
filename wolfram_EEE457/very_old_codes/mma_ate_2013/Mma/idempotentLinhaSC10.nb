       RowBox[{"Table", "[", 
        RowBox[{"0", ",", 
         RowBox[{"{", "Nc", "}"}], ",", 
         RowBox[{"{", "Nc", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"SB", "=", "SA"}], ";", "\[IndentingNewLine]", 
      RowBox[{"scale1", "=", 
