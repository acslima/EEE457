        RowBox[{"0", ",", 
         RowBox[{"{", "Nc", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"scale2", "=", 
       RowBox[{"scale", "=", 
        RowBox[{"ang", "=", "scale1"}]}]}], ";", "\[IndentingNewLine]", 
