                  RowBox[{"j", ",", "col"}], "]"}], "]"}], "]"}], "*", 
               RowBox[{"Im", "[", 
                RowBox[{"SA", "[", 
                 RowBox[{"[", 
                  RowBox[{"j", ",", "col"}], "]"}], "]"}], "]"}]}]}]}], ";", 
            "\[IndentingNewLine]", 
