Cell[BoxData[
 RowBox[{
  RowBox[{"calcelem", "[", 
   RowBox[{
   "polos_List", ",", "residuos_List", ",", "omega_List", ",", "yElementos_", 
    ",", "TermD_", ",", "TermE_", ",", "nres_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "funcoes", ",", "Pontos", ",", "difRMS", ",", "dif", ",", "RMSD"}], 
     "}"}], ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"funcoes", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"residuos", "[", 
              RowBox[{"[", 
               RowBox[{"i", ",", "kk"}], "]"}], "]"}], "/", 
             RowBox[{"(", 
              RowBox[{"s", "-", 
               RowBox[{"polos", "[", 
                RowBox[{"[", "kk", "]"}], "]"}]}], ")"}]}], ")"}], ",", 
           RowBox[{"{", 
            RowBox[{"kk", ",", 
             RowBox[{"Length", "[", "polos", "]"}]}], "}"}]}], "]"}], "+", 
         RowBox[{"TermD", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "+", 
         RowBox[{"s", "*", 
          RowBox[{"TermE", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}]}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "nres"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Pontos", "=", 
      RowBox[{"Transpose", "[", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Map", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"funcoes", "[", 
               RowBox[{"[", "i", "]"}], "]"}], "/.", 
              RowBox[{"s", "->", "#"}]}], ")"}], "&"}], ",", 
           RowBox[{"\[ImaginaryI]", " ", "omega"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "nres"}], "}"}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"dif", "=", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"Abs", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"Pontos", "-", "yElementos"}], ")"}], "^", "2"}], "]"}], 
        "/", 
        RowBox[{"Length", "[", "omega", "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"RMSD", "=", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"Total", "[", 
         RowBox[{
          RowBox[{"Abs", "[", 
           RowBox[{"Pontos", "-", "yElementos"}], "]"}], "^", "2"}], "]"}], 
        "/", 
        RowBox[{"Length", "[", "omega", "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"{", 
       RowBox[{"funcoes", ",", "Pontos", ",", "RMSD", ",", "dif"}], "}"}], 
      "]"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.494588523375*^9, 3.4945885249375*^9}, 
   3.494589055015625*^9}],

Cell[BoxData[
 RowBox[{
  RowBox[{"recompmatr", "[", "Matr_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"ncond2", ",", "k", ",", "Mrecomp"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"ncond2", "=", 
      RowBox[{
       RowBox[{"Solve", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"2", "*", 
             RowBox[{"Min", "[", 
              RowBox[{"Dimensions", "[", "Matr", "]"}], "]"}]}], "-", "x"}], 
           "]"}], "==", "x"}], ",", "x"}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "1", ",", "2"}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Mrecomp", "=", 
      RowBox[{"Table", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", "ncond2", "}"}], ",", 
        RowBox[{"{", "ncond2", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"k", "=", "1"}], ",", 
       RowBox[{"k", "<", 
        RowBox[{"ncond2", "+", "1"}]}], ",", 
       RowBox[{"k", "++"}], ",", 
       RowBox[{
        RowBox[{"Mrecomp", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "k"}], "]"}], "]"}], "=", 
        RowBox[{"Flatten", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Take", "[", 
            RowBox[{"Matr", ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{
                RowBox[{"k", "*", 
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{"k", "-", "1"}], ")"}], "/", "2"}]}], "+", "1"}], 
               ",", 
               RowBox[{"k", "*", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"k", "+", "1"}], ")"}], "/", "2"}]}]}], "}"}]}], 
            "]"}], ",", 
           RowBox[{"Table", "[", 
            RowBox[{"0", ",", 
             RowBox[{"{", 
              RowBox[{"ncond2", "-", "k"}], "}"}]}], "]"}]}], "}"}], 
         "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Mrecomp", "[", 
         RowBox[{"[", 
          RowBox[{"j", ",", "i"}], "]"}], "]"}], "=", 
        RowBox[{"Mrecomp", "[", 
         RowBox[{"[", 
          RowBox[{"i", ",", "j"}], "]"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "ncond2"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "1", ",", "ncond2"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"{", "Mrecomp", "}"}], "]"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.486995830171875*^9, 3.486995854625*^9}, {
   3.48699591890625*^9, 3.486995956421875*^9}, 3.486996155140625*^9, {
   3.487083806953125*^9, 3.4870838109375*^9}, 3.487084070828125*^9, 
   3.4872808628125*^9, {3.48728125428125*^9, 3.487281293328125*^9}, {
   3.48753481309375*^9, 3.48753481425*^9}, {3.4898761263125*^9, 
   3.489876126453125*^9}, {3.49064196378125*^9, 3.490641969359375*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"calctraco", "[", 
   RowBox[{
   "polos_List", ",", "residuos_List", ",", "freq_", ",", "data_", ",", 
    "termoD_", ",", "termoE_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"funcoes", ",", "Pontos", ",", "difRMS", ",", "dif"}], "}"}], 
    ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"funcoes", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Sum", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"residuos", "[", 
             RowBox[{"[", "kk", "]"}], "]"}], "/", 
            RowBox[{"(", 
             RowBox[{"s", "-", 
              RowBox[{"polos", "[", 
               RowBox[{"[", "kk", "]"}], "]"}]}], ")"}]}], ")"}], ",", 
          RowBox[{"{", 
           RowBox[{"kk", ",", 
            RowBox[{"Length", "[", "polos", "]"}]}], "}"}]}], "]"}], "+", 
        "termoD", "+", 
        RowBox[{"s", "*", "termoE"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Pontos", "=", 
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"funcoes", "/.", 
           RowBox[{"s", "->", "#"}]}], ")"}], "&"}], ",", 
        RowBox[{"\[ImaginaryI]", " ", "freq"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"difRMS", "=", 
      RowBox[{
       RowBox[{"Sqrt", "[", 
        RowBox[{"Total", "[", 
         RowBox[{"Abs", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"Pontos", "-", "data"}], ")"}], "^", "2"}], "]"}], "]"}], 
        "]"}], "/", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"Length", "[", "freq", "]"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"dif", "=", 
      RowBox[{
       RowBox[{"Sqrt", "[", 
        RowBox[{"Abs", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"Pontos", "-", "data"}], ")"}], "^", "2"}], "]"}], "]"}], 
       "/", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"Length", "[", "freq", "]"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"{", 
       RowBox[{"funcoes", ",", "Pontos", ",", "difRMS", ",", "dif"}], "}"}], 
      "]"}]}]}], "]"}]}]], "Input",
