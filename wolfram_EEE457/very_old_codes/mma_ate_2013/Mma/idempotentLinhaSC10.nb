         RowBox[{"{", "Nc", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"denominator", "=", 
       RowBox[{"numerator", "=", 
        RowBox[{"scale1", "=", "scale2"}]}]}], ";", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"col", "=", "1"}], ",", 
        RowBox[{"col", "\[LessEqual]", " ", "Nc"}], ",", 
        RowBox[{"col", "++"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"numerator", "[", 
           RowBox[{"[", "col", "]"}], "]"}], "=", "0."}], ";", 
         "\[IndentingNewLine]", 
