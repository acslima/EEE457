        RowBox[{"eval", ",", "ev"}], "}"}], "=", 
       RowBox[{"Eigensystem", "[", 
        RowBox[{"Zpipe", ".", "Ypipe"}], " ", "]"}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"evect", "=", 
       RowBox[{"rot", "[", 
        RowBox[{"Transpose", "[", "ev", "]"}], "]"}]}], ",", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"k", "=", "nm"}], ",", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"k", ">", "1"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"evect", "=", 
            RowBox[{"xchEig", "[", 
             RowBox[{"evelho", ",", "evect"}], "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"\[Lambda]0", "[", 
             RowBox[{"[", "nm", "]"}], "]"}], "=", 
            RowBox[{"Diagonal", "[", 
             RowBox[{
              RowBox[{"Inverse", "[", "R", "]"}], ".", 
              RowBox[{"DiagonalMatrix", "[", "eval", "]"}], ".", "R"}], 
             "]"}]}]}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"\[Lambda]0", "[", 
             RowBox[{"[", "nm", "]"}], "]"}], "=", "eval"}], ";"}]}], 
         "\[IndentingNewLine]", "]"}], ","}], "*)"}], "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"\[Lambda]0", "[", 
         RowBox[{"[", "nm", "]"}], "]"}], "=", 
        RowBox[{"Sort", "[", 
         RowBox[{
          RowBox[{"Sqrt", "[", "eval", "]"}], ",", " ", 
          RowBox[{
           RowBox[{
            RowBox[{"Re", "[", "#1", "]"}], "<", 
            RowBox[{"Re", "[", "#2", "]"}]}], "&"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"evelho", "=", "evect"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"Am1", "[", 
        RowBox[{"[", "nm", "]"}], "]"}], "=", 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", " ", 
          RowBox[{"\[Lambda]0", "[", 
           RowBox[{"[", "nm", "]"}], "]"}]}], " ", "compr"}], "]"}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"T", "[", 
        RowBox[{"[", "nm", "]"}], "]"}], "=", "evect"}]}], 
