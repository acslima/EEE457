Cell[BoxData[
 RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Show", "[", 
    RowBox[{"protein", ",", 
     RowBox[{"waves", "[", 
      RowBox[{"p", ",", "t"}], "]"}], ",", 
     RowBox[{"water", "[", 
      RowBox[{"p", ",", "t"}], "]"}], ",", 
     RowBox[{"PlotRange", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"0", ",", "400"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "300"}], "}"}]}], "}"}]}], ",", 
     RowBox[{"ImageSize", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"580", ",", "375"}], "}"}]}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"p", ",", "0", ",", "\"\<power level\>\""}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "1"}], "\[Rule]", "\"\<low\>\""}], ",", 
       RowBox[{"0", "\[Rule]", "\"\<medium\>\""}], ",", 
       RowBox[{"1", "\[Rule]", "\"\<high\>\""}]}], "}"}], ",", "Setter"}], 
    "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"t", ",", "0", ",", "\"\<turn on\>\""}], "}"}], ",", "0", ",", 
     "100", ",", "1", ",", "Trigger", ",", 
     RowBox[{"DisplayAllSteps", "\[Rule]", "True"}]}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"AutorunSequencing", "\[Rule]", 
    RowBox[{"{", "2", "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"TrackedSymbols", "\[RuleDelayed]", 
    RowBox[{"{", 
     RowBox[{"p", ",", "t"}], "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"Initialization", "\[RuleDelayed]", 
    RowBox[{"(", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"waves", "[", 
         RowBox[{"p_", ",", "t_"}], "]"}], ":=", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"0", "<", "t", "<", "100"}], ",", 
          RowBox[{"Show", "[", 
           RowBox[{
            RowBox[{"Plot", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"25", "-", 
                 RowBox[{"10", "p"}], "+", 
                 RowBox[{"10", " ", 
                  RowBox[{"Sin", "[", 
                   RowBox[{"\[Pi]", " ", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"x", "+", 
                    RowBox[{"20", "t"}]}], ")"}], "/", "50"}]}], "]"}]}]}], 
                ",", 
                RowBox[{"100", "+", 
                 RowBox[{"10", "p"}], "+", 
                 RowBox[{"10", " ", 
                  RowBox[{"Sin", "[", 
                   RowBox[{"\[Pi]", " ", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"x", "+", 
                    RowBox[{"20", "t"}]}], ")"}], "/", "50"}]}], "]"}]}]}]}], 
               "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"x", ",", "0", ",", "600"}], "}"}], ",", 
              RowBox[{"Axes", "\[Rule]", "None"}], ",", 
              RowBox[{"Filling", "\[Rule]", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"1", "\[Rule]", "62.5"}], ",", 
                 RowBox[{"2", "\[Rule]", "62.5"}]}], "}"}]}], ",", 
              RowBox[{"FillingStyle", "\[Rule]", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"Opacity", "[", ".5", "]"}], ",", "Gray"}], "}"}], 
                 ",", 
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"Opacity", "[", ".5", "]"}], ",", "Gray"}], 
                  "}"}]}], "}"}]}], ",", 
              RowBox[{"PlotRange", "\[Rule]", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"0", ",", "600"}], "}"}], ",", 
                 RowBox[{"{", 
                  RowBox[{"0", ",", "350"}], "}"}]}], "}"}]}]}], "]"}], ",", 
            RowBox[{"Plot", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"250", "+", 
                 RowBox[{"10", "p"}], "+", 
                 RowBox[{"10", " ", 
                  RowBox[{"Sin", "[", 
                   RowBox[{"\[Pi]", " ", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"x", "-", 
                    RowBox[{"20", "t"}]}], ")"}], "/", "50"}]}], "]"}]}]}], 
                ",", 
                RowBox[{"175", "-", 
                 RowBox[{"10", "p"}], "+", 
