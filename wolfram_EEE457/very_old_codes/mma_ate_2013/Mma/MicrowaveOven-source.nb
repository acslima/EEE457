                  RowBox[{"Sin", "[", 
                   RowBox[{"\[Pi]", " ", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"x", "-", 
                    RowBox[{"20", "t"}]}], ")"}], "/", "50"}]}], "]"}]}]}]}], 
               "}"}], ",", 
              RowBox[{"{", 
               RowBox[{"x", ",", "0", ",", "600"}], "}"}], ",", 
              RowBox[{"Axes", "\[Rule]", "None"}], ",", 
              RowBox[{"Filling", "\[Rule]", 
               RowBox[{"{", 
