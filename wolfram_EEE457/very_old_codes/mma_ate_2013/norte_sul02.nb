Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"AbsoluteTiming", "[", 
   RowBox[{"Do", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Omega]", "=", 
        RowBox[{"2", " ", "\[Pi]", " ", 
         RowBox[{"f", "[", 
          RowBox[{"[", "k", "]"}], "]"}]}]}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"aux0", "=", 
         RowBox[{"DiagonalMatrix", "[", "\[IndentingNewLine]", "      ", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{"i", "\[LessEqual]", 
               RowBox[{"(", 
                RowBox[{"ncond", "-", "2"}], ")"}]}], ",", 
              "\[IndentingNewLine]", "        ", 
              RowBox[{"Zin", "[", 
               RowBox[{"\[Omega]", ",", "\[Rho]c", ",", "rf", ",", "1.0"}], 
               "]"}], ",", "\[IndentingNewLine]", "        ", 
              RowBox[{"Zin", "[", 
               RowBox[{"\[Omega]", ",", "\[Rho]pr", ",", "rpr", ",", "80."}], 
               "]"}]}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"i", ",", "ncond"}], "}"}]}], "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"aux1", "=", 
         RowBox[{
         "\[ImaginaryJ]", " ", "\[Omega]", " ", "2.0", " ", "\[Pi]", " ", 
          "\[Epsilon]", " ", 
          RowBox[{"eliminaPR", "[", 
           RowBox[{
            RowBox[{"MPot", "[", 
             RowBox[{
             "xc", ",", "yc", ",", "ncond", ",", "2", ",", "rf", ",", "rpr"}],
              "]"}], ",", "ncond", ",", "2"}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"aux2", "=", 
         RowBox[{"aux0", "+", " ", 
          RowBox[{"Zexterno", "[", 
           RowBox[{
           "\[Omega]", ",", "\[Sigma]solo", ",", "ncond", ",", "2", ",", "xc",
             ",", "yc", ",", "rf", ",", "rpr"}], "]"}]}]}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Y1", "=", 
         RowBox[{"eliminaFeixe", "[", 
          RowBox[{"aux1", ",", "nfeixe", ",", "nfases"}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Z1", "=", 
         RowBox[{"Inverse", "[", 
          RowBox[{"eliminaFeixe", "[", 
           RowBox[{
            RowBox[{"eliminaPR", "[", 
             RowBox[{"aux2", ",", "ncond", ",", "2"}], "]"}], ",", "nfeixe", 
            ",", "nfases"}], "]"}], "]"}]}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"ylt1", "=", 
        RowBox[{"Ynodal", "[", 
         RowBox[{"Z1", ",", "Y1", ",", "\[ScriptL]"}], "]"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Qlt1", "=", 
        RowBox[{"Y2Quad", "[", "ylt1", "]"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"QLT", "=", 
        RowBox[{"Qlt1", ".", "Q\[Phi]", ".", 
         RowBox[{"MatrixPower", "[", 
          RowBox[{"Qlt1", ",", "2"}], "]"}], ".", "Q\[Phi]", ".", 
         RowBox[{"MatrixPower", "[", 
          RowBox[{"Qlt1", ",", "2"}], "]"}], ".", "Q\[Phi]", ".", "Qlt1"}]}], 
       ",", "\[IndentingNewLine]", 
       RowBox[{"yaux", "=", 
        RowBox[{"Quad2Y", "[", 
         RowBox[{
         "Qcap", ".", "Qreator", ".", "QLT", ".", "Qreator", ".", "Qcap"}], 
         "]"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"ylt", "[", 
         RowBox[{"[", "k", "]"}], "]"}], "=", 
        RowBox[{
         RowBox[{"Inverse", "[", "Aaux", "]"}], ".", "yaux", ".", 
         "Aaux"}]}]}], "\[IndentingNewLine]", "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "nf"}], "}"}]}], "]"}], "]"}], 
  "\[IndentingNewLine]"}]], "Input",
