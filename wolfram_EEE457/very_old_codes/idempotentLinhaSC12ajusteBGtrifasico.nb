Cell[BoxData[
 RowBox[{
  RowBox[{"descompmatrlarga", "[", "Matr_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"kk", ",", "nm", ",", "Matr2"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Matr2", "=", 
      RowBox[{"Table", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{"N", "[", 
          RowBox[{"Max", "[", 
           RowBox[{"Dimensions", "[", "Matr", "]"}], "]"}], "]"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"N", "[", 
           RowBox[{"Min", "[", 
            RowBox[{"Dimensions", "[", "Matr", "]"}], "]"}], "]"}], "*", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"N", "[", 
              RowBox[{"Min", "[", 
               RowBox[{"Dimensions", "[", "Matr", "]"}], "]"}], "]"}], "+", 
             "1"}], ")"}], "/", "2"}]}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"nm", "=", "1"}], ",", 
       RowBox[{"nm", "\[LessEqual]", 
        RowBox[{"N", "[", 
         RowBox[{"Max", "[", 
          RowBox[{"Dimensions", "[", "Matr", "]"}], "]"}], "]"}]}], ",", 
       RowBox[{"nm", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"kk", "=", "0"}], ";", "\[IndentingNewLine]", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"If", "[", " ", 
           RowBox[{
            RowBox[{"i", "\[GreaterEqual]", " ", "j"}], ",", 
            RowBox[{
             RowBox[{"kk", "++"}], ";", 
             RowBox[{
              RowBox[{"Matr2", "[", 
               RowBox[{"[", 
                RowBox[{"nm", ",", "kk"}], "]"}], "]"}], "=", 
              RowBox[{"Matr", "[", 
               RowBox[{"[", 
                RowBox[{"nm", ",", "i", ",", "j"}], "]"}], "]"}]}]}]}], "]"}],
           ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", 
            RowBox[{"N", "[", 
             RowBox[{"Min", "[", 
              RowBox[{"Dimensions", "[", "Matr", "]"}], "]"}], "]"}]}], "}"}],
           ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "1", ",", 
            RowBox[{"N", "[", 
             RowBox[{"Min", "[", 
              RowBox[{"Dimensions", "[", "Matr", "]"}], "]"}], "]"}]}], 
           "}"}]}], "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"{", "Matr2", "}"}], "]"}]}]}], "]"}]}]], "Input",
