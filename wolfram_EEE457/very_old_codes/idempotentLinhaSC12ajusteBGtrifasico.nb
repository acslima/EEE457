Cell[BoxData[
 RowBox[{
  RowBox[{"res", "[", 
   RowBox[{"polos_List", ",", "freq_List", ",", "data_List", ",", 
    RowBox[{"termoD_:", "1."}], ",", 
    RowBox[{"termoE_:", "1."}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "npol", ",", "nfreq", ",", "ss", ",", "indices", ",", "AAnum", ",", 
      "UUmS", ",", "AAf", ",", "AAff", ",", "AAffT", ",", "normas", ",", 
      "BBff", ",", "XXff", ",", "resfim", ",", "dd", ",", "ee", ",", "naux", 
      ",", "AAAaux", ",", "AAAscale", ",", "Xaux", ",", "scale"}], "}"}], ",",
     "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"npol", "=", 
      RowBox[{"Length", "[", "polos", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"nfreq", "=", 
      RowBox[{"Length", "[", "freq", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"ss", "=", 
      RowBox[{"\[ImaginaryI]", "*", 
       RowBox[{"N", "[", "freq", "]"}]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"indices", "=", 
      RowBox[{"idx", "[", "polos", "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"AAnum", "=", 
      RowBox[{"Transpose", "[", 
       RowBox[{"Aux", "[", 
        RowBox[{
         RowBox[{"ss", "[", 
          RowBox[{"[", 
           RowBox[{"Range", "[", "nfreq", "]"}], "]"}], "]"}], ",", "polos", 
         ",", "indices"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"UUmS", "=", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"termoD", "\[Equal]", "1"}], "\[And]", 
         RowBox[{"termoE", "\[Equal]", "1"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"1", ",", 
            RowBox[{"ss", "[", 
             RowBox[{"[", "#", "]"}], "]"}]}], "}"}], "&"}], "/@", 
         RowBox[{"Range", "[", "nfreq", "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"termoD", "\[Equal]", "1"}], "\[And]", 
           RowBox[{"termoE", "\[Equal]", "0"}]}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"{", "1", "}"}], "&"}], "/@", 
           RowBox[{"Range", "[", "nfreq", "]"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"termoD", "\[Equal]", "0"}], "\[And]", 
             RowBox[{"termoE", "\[Equal]", "1"}]}], ",", 
            RowBox[{
             RowBox[{
              RowBox[{"{", 
               RowBox[{"ss", "[", 
                RowBox[{"[", "#", "]"}], "]"}], "}"}], "&"}], "/@", 
             RowBox[{"Range", "[", "nfreq", "]"}]}], ",", 
            RowBox[{
             RowBox[{
              RowBox[{"{", "}"}], "&"}], "/@", 
             RowBox[{"Range", "[", "nfreq", "]"}]}]}], "]"}]}], "]"}]}], 
       "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"AAf", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"Flatten", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"AAnum", "[", 
            RowBox[{"[", "#", "]"}], "]"}], ",", 
           RowBox[{"UUmS", "[", 
            RowBox[{"[", "#", "]"}], "]"}]}], "}"}], "]"}], "&"}], "/@", 
       RowBox[{"Range", "[", "nfreq", "]"}]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"AAff", "=", 
      RowBox[{"ArrayFlatten", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"Re", "[", "AAf", "]"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"Im", "[", "AAf", "]"}], "}"}]}], "}"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"BBff", "=", 
      RowBox[{"Flatten", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Re", "[", "data", "]"}], ",", 
         RowBox[{"Im", "[", "data", "]"}]}], "}"}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"naux", "=", 
      RowBox[{"termoD", "+", "termoE"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"AAffT", "=", 
      RowBox[{"Transpose", "[", "AAff", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"normas", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"Norm", "[", 
         RowBox[{"AAffT", "[", 
          RowBox[{"[", "#", "]"}], "]"}], "]"}], "&"}], "/@", 
       RowBox[{"Range", "[", 
        RowBox[{"1", ",", 
         RowBox[{"npol", "+", "naux"}]}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"AAAaux", "=", 
      RowBox[{"AAffT", "/", "normas"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"AAAscale", "=", 
      RowBox[{"Transpose", "[", "AAAaux", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Xaux", "=", 
      RowBox[{"LeastSquares", "[", 
       RowBox[{"AAAscale", ",", "BBff"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"scale", "=", 
      RowBox[{"1", "/", "normas"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"XXff", "=", 
      RowBox[{"Xaux", "*", "scale"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"resfim", "=", 
      RowBox[{"0", "*", 
       RowBox[{"Range", "[", 
        RowBox[{"1", ",", "npol"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Do", "[", 
      RowBox[{
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"indices", "[", 
           RowBox[{"[", "nm", "]"}], "]"}], "\[Equal]", "0"}], ",", 
         RowBox[{
          RowBox[{"resfim", "[", 
           RowBox[{"[", "nm", "]"}], "]"}], "=", 
          RowBox[{"XXff", "[", 
           RowBox[{"[", "nm", "]"}], "]"}]}], ",", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"indices", "[", 
             RowBox[{"[", "nm", "]"}], "]"}], "\[Equal]", "1"}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"resfim", "[", 
              RowBox[{"[", "nm", "]"}], "]"}], "=", 
             RowBox[{
              RowBox[{"XXff", "[", 
               RowBox[{"[", "nm", "]"}], "]"}], "+", 
              RowBox[{"\[ImaginaryI]", "*", 
               RowBox[{"XXff", "[", 
                RowBox[{"[", 
                 RowBox[{"nm", "+", "1"}], "]"}], "]"}]}]}]}], ";", 
            RowBox[{
             RowBox[{"resfim", "[", 
              RowBox[{"[", 
               RowBox[{"nm", "+", "1"}], "]"}], "]"}], "=", 
             RowBox[{
              RowBox[{"XXff", "[", 
               RowBox[{"[", "nm", "]"}], "]"}], "-", 
              RowBox[{"\[ImaginaryI]", "*", 
               RowBox[{"XXff", "[", 
                RowBox[{"[", 
                 RowBox[{"nm", "+", "1"}], "]"}], "]"}]}]}]}]}], ",", "0"}], 
          "]"}]}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"nm", ",", "npol"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"termoD", "\[Equal]", "1"}], "\[And]", 
        RowBox[{"termoE", "\[Equal]", "1"}]}], ",", 
       RowBox[{
        RowBox[{"dd", "=", 
         RowBox[{"XXff", "[", 
          RowBox[{"[", 
           RowBox[{"-", "2"}], "]"}], "]"}]}], ";", 
        RowBox[{"ee", "=", 
         RowBox[{"XXff", "[", 
          RowBox[{"[", 
           RowBox[{"-", "1"}], "]"}], "]"}]}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"termoD", "\[Equal]", "1"}], "\[And]", 
          RowBox[{"termoE", "\[Equal]", "0"}]}], ",", 
         RowBox[{
          RowBox[{"dd", "=", 
           RowBox[{"XXff", "[", 
            RowBox[{"[", 
             RowBox[{"-", "1"}], "]"}], "]"}]}], ";", 
          RowBox[{"ee", "=", "0"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"termoD", "\[Equal]", "0"}], "\[And]", 
            RowBox[{"termoE", "\[Equal]", "1"}]}], ",", 
           RowBox[{
            RowBox[{"dd", "=", "0"}], ";", 
            RowBox[{"ee", "=", 
             RowBox[{"XXff", "[", 
              RowBox[{"[", 
               RowBox[{"-", "1"}], "]"}], "]"}]}]}], ",", 
           RowBox[{
            RowBox[{"dd", "=", "0"}], ";", 
            RowBox[{"ee", "=", "0"}]}]}], "]"}]}], "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"{", 
       RowBox[{"resfim", ",", "dd", ",", "ee"}], "}"}], "]"}]}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.451841802875*^9, 3.451841824984375*^9}, {
   3.451841934125*^9, 3.451841983375*^9}, {3.45184201684375*^9, 
   3.4518423421875*^9}, {3.451842521203125*^9, 3.451842522390625*^9}, 
   3.45184279396875*^9, 3.482770258203125*^9, 3.485506133703125*^9, {
   3.4856421396875*^9, 3.485642164796875*^9}, {3.485654145984375*^9, 
