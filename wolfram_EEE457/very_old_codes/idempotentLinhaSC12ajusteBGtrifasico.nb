Cell[BoxData[
 RowBox[{
  RowBox[{"calctraco", "[", 
   RowBox[{
   "polos_List", ",", "residuos_List", ",", "freq_", ",", "data_", ",", 
    "termoD_", ",", "termoE_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"funcoes", ",", "Pontos", ",", "difRMS", ",", "dif"}], "}"}], 
    ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"funcoes", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Sum", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"residuos", "[", 
             RowBox[{"[", "kk", "]"}], "]"}], "/", 
            RowBox[{"(", 
             RowBox[{"s", "-", 
              RowBox[{"polos", "[", 
               RowBox[{"[", "kk", "]"}], "]"}]}], ")"}]}], ")"}], ",", 
          RowBox[{"{", 
           RowBox[{"kk", ",", 
            RowBox[{"Length", "[", "polos", "]"}]}], "}"}]}], "]"}], "+", 
        "termoD", "+", 
        RowBox[{"s", "*", "termoE"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Pontos", "=", 
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"funcoes", "/.", 
           RowBox[{"s", "->", "#"}]}], ")"}], "&"}], ",", 
        RowBox[{"\[ImaginaryI]", " ", "freq"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"difRMS", "=", 
      RowBox[{
       RowBox[{"Sqrt", "[", 
        RowBox[{"Total", "[", 
         RowBox[{"Abs", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{"Pontos", "-", "data"}], ")"}], "^", "2"}], "]"}], "]"}], 
        "]"}], "/", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"Length", "[", "freq", "]"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"dif", "=", 
      RowBox[{
       RowBox[{"Sqrt", "[", 
        RowBox[{"Abs", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"Pontos", "-", "data"}], ")"}], "^", "2"}], "]"}], "]"}], 
       "/", 
       RowBox[{"Sqrt", "[", 
        RowBox[{"Length", "[", "freq", "]"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"{", 
       RowBox[{"funcoes", ",", "Pontos", ",", "difRMS", ",", "dif"}], "}"}], 
      "]"}]}]}], "]"}]}]], "Input",
