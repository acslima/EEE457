Cell[CellGroupData[{

Cell["Outros Calculos", "Title",
 CellFrame->{{0, 0}, {0, 0.5}},
 CellChangeTimes->{{3.485657530625*^9, 3.48565755228125*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"calcelem", "[", 
   RowBox[{
   "polos_List", ",", "residuos_List", ",", "omega_List", ",", "yElementos_", 
    ",", "TermD_", ",", "TermE_", ",", "nres_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "funcoes", ",", "Pontos", ",", "difRMS", ",", "dif", ",", "RMSD"}], 
     "}"}], ",", "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"funcoes", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"residuos", "[", 
              RowBox[{"[", 
               RowBox[{"i", ",", "kk"}], "]"}], "]"}], "/", 
             RowBox[{"(", 
              RowBox[{"s", "-", 
               RowBox[{"polos", "[", 
                RowBox[{"[", "kk", "]"}], "]"}]}], ")"}]}], ")"}], ",", 
           RowBox[{"{", 
            RowBox[{"kk", ",", 
             RowBox[{"Length", "[", "polos", "]"}]}], "}"}]}], "]"}], "+", 
         RowBox[{"TermD", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "+", 
         RowBox[{"s", "*", 
          RowBox[{"TermE", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}]}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "nres"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Pontos", "=", 
      RowBox[{"Transpose", "[", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Map", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"funcoes", "[", 
               RowBox[{"[", "i", "]"}], "]"}], "/.", 
              RowBox[{"s", "->", "#"}]}], ")"}], "&"}], ",", 
           RowBox[{"\[ImaginaryI]", " ", "omega"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "nres"}], "}"}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"dif", "=", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"Abs", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"Pontos", "-", "yElementos"}], ")"}], "^", "2"}], "]"}], 
        "/", 
        RowBox[{"Length", "[", "omega", "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"RMSD", "=", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"Total", "[", 
         RowBox[{
          RowBox[{"Abs", "[", 
           RowBox[{"Pontos", "-", "yElementos"}], "]"}], "^", "2"}], "]"}], 
        "/", 
        RowBox[{"Length", "[", "omega", "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"{", 
       RowBox[{"funcoes", ",", "Pontos", ",", "RMSD", ",", "dif"}], "}"}], 
      "]"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.494588523375*^9, 3.4945885249375*^9}, 
   3.494589055015625*^9}],

Cell[BoxData[
 RowBox[{
  RowBox[{"recompmatr", "[", "Matr_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"ncond2", ",", "k", ",", "Mrecomp"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"ncond2", "=", 
      RowBox[{
       RowBox[{"Solve", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"2", "*", 
             RowBox[{"Min", "[", 
              RowBox[{"Dimensions", "[", "Matr", "]"}], "]"}]}], "-", "x"}], 
           "]"}], "==", "x"}], ",", "x"}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "1", ",", "2"}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Mrecomp", "=", 
      RowBox[{"Table", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", "ncond2", "}"}], ",", 
        RowBox[{"{", "ncond2", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"k", "=", "1"}], ",", 
       RowBox[{"k", "<", 
        RowBox[{"ncond2", "+", "1"}]}], ",", 
       RowBox[{"k", "++"}], ",", 
       RowBox[{
        RowBox[{"Mrecomp", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "k"}], "]"}], "]"}], "=", 
        RowBox[{"Flatten", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Take", "[", 
            RowBox[{"Matr", ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{
                RowBox[{"k", "*", 
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{"k", "-", "1"}], ")"}], "/", "2"}]}], "+", "1"}], 
               ",", 
               RowBox[{"k", "*", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"k", "+", "1"}], ")"}], "/", "2"}]}]}], "}"}]}], 
            "]"}], ",", 
           RowBox[{"Table", "[", 
            RowBox[{"0", ",", 
             RowBox[{"{", 
              RowBox[{"ncond2", "-", "k"}], "}"}]}], "]"}]}], "}"}], 
         "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Mrecomp", "[", 
         RowBox[{"[", 
          RowBox[{"j", ",", "i"}], "]"}], "]"}], "=", 
        RowBox[{"Mrecomp", "[", 
         RowBox[{"[", 
          RowBox[{"i", ",", "j"}], "]"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "ncond2"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "1", ",", "ncond2"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"{", "Mrecomp", "}"}], "]"}]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.486995830171875*^9, 3.486995854625*^9}, {
