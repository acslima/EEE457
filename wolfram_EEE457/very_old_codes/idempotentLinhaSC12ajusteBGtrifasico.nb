   "*************)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"UnwrapPhase", "[", 
     RowBox[{
      RowBox[{"data_", "?", "VectorQ"}], ",", 
      RowBox[{"tol_:", "Pi"}], ",", 
      RowBox[{"inc_:", "2", " ", "Pi"}]}], "]"}], ":=", 
    RowBox[{"FixedPoint", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"#", "+", 
        RowBox[{"inc", "*", 
         RowBox[{"FoldList", "[", 
          RowBox[{"Plus", ",", "0.", ",", 
           RowBox[{"Sign", "[", 
            RowBox[{"Chop", "[", 
             RowBox[{
              RowBox[{"ListCorrelate", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"1", ",", 
                  RowBox[{"-", "1"}]}], "}"}], ",", "#"}], "]"}], ",", 
              "tol"}], "]"}], "   ", 
            RowBox[{"(*", 
             RowBox[{"close", " ", "Chop"}], "*)"}], "]"}]}], "    ", 
          RowBox[{"(*", 
           RowBox[{"close", " ", "Sign"}], "*)"}], "]"}]}]}], "&"}], ",", 
      RowBox[{"(*", 
       RowBox[{"close", " ", "FoldList"}], "*)"}], "data"}], "]"}]}], "   ", 
   RowBox[{"(*", 
    RowBox[{
    "close", " ", "FixedPoint", " ", "and", " ", "overall", " ", "function"}],
     "*)"}], "\[IndentingNewLine]", "\n", 
   RowBox[{
    RowBox[{"UnwrapPhase", "[", 
     RowBox[{"list", ":", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"_", ",", "_"}], "}"}], ".."}], "}"}]}], "]"}], ":=", 
    RowBox[{"Transpose", "[", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"list", "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "1"}], "]"}], "]"}], ",", 
       RowBox[{"UnwrapPhase", "[", 
        RowBox[{"list", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", 
           RowBox[{"-", "1"}]}], "]"}], "]"}], "]"}]}], "}"}], "]"}]}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"**", "**", "**", "**", "**", "UnwrapPhase"}], " ", "above"}], 
    "*************)"}]}]}]], "Input",
 CellChangeTimes->{3.493684593046875*^9}]
