  3.49427546234375*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"eigNR", "[", 
    RowBox[{
     RowBox[{"G_", "?", "MatrixQ"}], ",", "V0_", ",", "d0_", ",", 
     RowBox[{"Tol_:", 
      RowBox[{"10", "^", 
       RowBox[{"-", "10"}]}]}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
