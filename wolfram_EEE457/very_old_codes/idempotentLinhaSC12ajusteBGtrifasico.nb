       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"k", "=", "1"}], ",", 
       RowBox[{"k", "\[LessEqual]", " ", 
        RowBox[{"N", "[", 
         RowBox[{"Max", "[", 
          RowBox[{"Dimensions", "[", "Matr", "]"}], "]"}], "]"}]}], ",", 
       RowBox[{"k", "++"}], ",", 
       RowBox[{
        RowBox[{"YsAux", "[", 
         RowBox[{"[", "k", "]"}], "]"}], "=", 
        RowBox[{"recompmatr", "[", 
         RowBox[{"Matr", "[", 
