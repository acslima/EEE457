Cell["Decompor Matriz (n x n) em elementos", "Subsection",
 CellChangeTimes->{{3.492374730136524*^9, 3.492374736886057*^9}, {
  3.492378538443406*^9, 3.49237855198556*^9}, {3.493667908890625*^9, 
  3.49366793090625*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"descompmatrlargaAsimetrica", "[", "Matr_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"kk", ",", "nm", ",", "Matr2"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Matr2", "=", 
      RowBox[{"Table", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", 
         RowBox[{"N", "[", 
          RowBox[{"Max", "[", 
           RowBox[{"Dimensions", "[", "Matr", "]"}], "]"}], "]"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"N", "[", 
           RowBox[{"Min", "[", 
            RowBox[{"Dimensions", "[", "Matr", "]"}], "]"}], "]"}], "*", 
          RowBox[{"(", 
           RowBox[{"N", "[", 
            RowBox[{"Min", "[", 
             RowBox[{"Dimensions", "[", "Matr", "]"}], "]"}], "]"}], ")"}]}], 
         "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"nm", "=", "1"}], ",", 
       RowBox[{"nm", "\[LessEqual]", 
        RowBox[{"N", "[", 
         RowBox[{"Max", "[", 
          RowBox[{"Dimensions", "[", "Matr", "]"}], "]"}], "]"}]}], ",", 
       RowBox[{"nm", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"kk", "=", "0"}], ";", "\[IndentingNewLine]", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"kk", "++"}], ";", 
           RowBox[{
            RowBox[{"Matr2", "[", 
             RowBox[{"[", 
              RowBox[{"nm", ",", "kk"}], "]"}], "]"}], "=", 
            RowBox[{"Matr", "[", 
             RowBox[{"[", 
              RowBox[{"nm", ",", "i", ",", "j"}], "]"}], "]"}]}]}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", 
            RowBox[{"N", "[", 
             RowBox[{"Min", "[", 
              RowBox[{"Dimensions", "[", "Matr", "]"}], "]"}], "]"}]}], "}"}],
           ",", 
          RowBox[{"{", 
           RowBox[{"j", ",", "1", ",", 
            RowBox[{"N", "[", 
             RowBox[{"Min", "[", 
              RowBox[{"Dimensions", "[", "Matr", "]"}], "]"}], "]"}]}], 
           "}"}]}], "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Return", "[", "Matr2", "]"}]}]}], "]"}]}]], "Input",
