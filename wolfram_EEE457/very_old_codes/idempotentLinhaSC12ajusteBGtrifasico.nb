Cell[BoxData[{
 RowBox[{
  RowBox[{"yElementos", "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"Am1", "[", 
       RowBox[{"[", "#", "]"}], "]"}], " ", 
      RowBox[{"Exp", "[", 
       RowBox[{"I", " ", 
        RowBox[{"omega", "[", 
         RowBox[{"[", "#", "]"}], "]"}], " ", "tauvector"}], "]"}]}], "&"}], "/@", 
    RowBox[{"Range", "[", 
     RowBox[{"1", ",", "nf"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"ytraco", "=", 
    RowBox[{
     RowBox[{
      RowBox[{"Tr", "[", 
       RowBox[{"yElementos", "[", 
        RowBox[{"[", "#", "]"}], "]"}], "]"}], "&"}], "/@", 
     RowBox[{"Range", "[", "nf", "]"}]}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"AbsoluteTiming", "[", 
   RowBox[{"Do", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"pp", "=", 
       RowBox[{"RVFpolos", "[", 
        RowBox[{
        "ppolos", ",", "omega", ",", "ytraco", ",", "TemD", ",", "TemE"}], 
        "]"}]}], ";", 
      RowBox[{"ppolos", "=", "pp"}]}], ",", 
     RowBox[{"{", "niterElem", "}"}]}], "]"}], "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"polosRVF", "=", "ppolos"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"nres", "=", 
   RowBox[{"Min", "[", 
    RowBox[{"Dimensions", "[", "yElementos", "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"residuosRVF", "=", 
    RowBox[{"TermDRVF", "=", 
     RowBox[{"TermERVF", "=", 
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0", ",", "nres"}], "]"}]}]}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Do", "[", 
