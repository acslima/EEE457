       RowBox[{"Length", "[", "A", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"scale", "=", 
       RowBox[{"Norm", "[", "A", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"A", "=", 
       RowBox[{"A", "/", "scale"}]}], ";", "\[IndentingNewLine]", 
