Cell[BoxData[
 RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"Graphics", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Opacity", "[", "0.9", "]"}], ",", 
       RowBox[{"First", "@", "background"}], ",", 
       RowBox[{"mandelGraph", "[", 
        RowBox[{"1", ",", "n2", ",", "init"}], "]"}]}], "}"}], ",", 
     RowBox[{"PlotRange", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"-", "2"}], ",", "2"}], "}"}]}], "}"}]}], ",", 
     RowBox[{"Axes", "\[Rule]", "True"}], ",", 
     RowBox[{"ImageSize", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"390", ",", "390"}], "}"}]}]}], "]"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"n2", ",", "6", ",", "\"\<iterations\>\""}], "}"}], ",", "1", 
     ",", "20", ",", "1", ",", 
     RowBox[{"Appearance", "\[Rule]", "\"\<Labeled\>\""}]}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"init", ",", 
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{".25", ",", "0.50"}], "}"}], "}"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "2"}], ",", 
       RowBox[{"-", "2"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"2", ",", "2"}], "}"}], ",", "Locator"}], "}"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"AutorunSequencing", "\[Rule]", 
    RowBox[{"{", "2", "}"}]}], ",", "\[IndentingNewLine]", 
   RowBox[{"SynchronousInitialization", "\[Rule]", "False"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"Initialization", "\[RuleDelayed]", 
    RowBox[{"(", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"mandelbrotConv", "[", 
        RowBox[{"n_Integer", ",", "c_"}], "]"}], ":=", 
       RowBox[{"Length", "@", 
        RowBox[{"NestWhileList", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            SuperscriptBox["#", "2"], "+", "c"}], "&"}], ",", "0", ",", 
          RowBox[{
           RowBox[{
            RowBox[{"Abs", "[", "#", "]"}], "<", "2"}], "&"}], ",", "1", ",", 
          "n"}], "]"}]}]}], ";", 
      RowBox[{"grd", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"mandelbrotConv", "[", 
          RowBox[{"100", ",", 
           RowBox[{"x", "+", 
            RowBox[{"I", " ", "y"}]}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"y", ",", 
           RowBox[{"-", "2"}], ",", "2", ",", "0.01"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"x", ",", 
           RowBox[{"-", "2"}], ",", "2", ",", "0.01"}], "}"}]}], "]"}]}], ";", 
      RowBox[{"background", "=", 
       RowBox[{"ArrayPlot", "[", 
        RowBox[{"grd", ",", 
         RowBox[{"Frame", "\[Rule]", "None"}], ",", 
         RowBox[{"ColorFunction", "\[Rule]", "\"\<LightTemperatureMap\>\""}], 
         ",", 
         RowBox[{"DataRange", "\[Rule]", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "2"}], ",", "2"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "2"}], ",", "2"}], "}"}]}], "}"}]}], ",", 
         RowBox[{"DataReversed", "\[Rule]", "True"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"mandelbrot", "[", 
        RowBox[{"n_Integer", ",", "c_"}], "]"}], ":=", 
       RowBox[{"NestWhileList", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           SuperscriptBox["#", "2"], "+", "c"}], "&"}], ",", "0", ",", 
         RowBox[{
          RowBox[{
           RowBox[{"Abs", "[", "#", "]"}], "<", "2"}], "&"}], ",", "1", ",", 
         "n"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"colorFun", "=", 
       RowBox[{"ColorData", "[", "3", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"mandelGraph", "[", 
        RowBox[{"nVec_Integer", ",", "nIt_Integer", ",", "init_"}], "]"}], ":=", 
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"tmp1", "=", 
           RowBox[{
            RowBox[{
             RowBox[{"mandelbrot", "[", 
              RowBox[{"nIt", ",", "#"}], "]"}], "&"}], "/@", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"init", "[", 
               RowBox[{"[", 
                RowBox[{"1", ",", "1"}], "]"}], "]"}], "+", 
              RowBox[{"I", " ", 
               RowBox[{"init", "[", 
                RowBox[{"[", 
                 RowBox[{"1", ",", "2"}], "]"}], "]"}]}]}], "}"}]}]}], "}"}], 
         ",", 
         RowBox[{"MapIndexed", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"colorFun", "[", 
               RowBox[{"#2", "[", 
                RowBox[{"[", "2", "]"}], "]"}], "]"}], ",", 
              RowBox[{"Arrow", "[", "#1", "]"}]}], "}"}], "&"}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"Partition", "[", 
              RowBox[{
               RowBox[{
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{
                   RowBox[{"Re", "[", "#", "]"}], ",", 
                   RowBox[{"Im", "[", "#", "]"}]}], "}"}], "&"}], "/@", "#"}],
                ",", "2", ",", "1"}], "]"}], "&"}], "/@", "tmp1"}], ",", 
           RowBox[{"{", "2", "}"}]}], "]"}]}], "]"}]}], ";"}], ")"}]}]}], 
  "]"}]], "Input",
 CellChangeTimes->{
