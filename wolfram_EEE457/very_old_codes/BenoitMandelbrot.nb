Cell[BoxData[
 TagBox[
  StyleBox[
   DynamicModuleBox[{$CellContext`init$$ = {{0.25, 0.5}}, $CellContext`n2$$ = 
    6, Typeset`show$$ = True, Typeset`bookmarkList$$ = {}, 
    Typeset`bookmarkMode$$ = "Menu", Typeset`animator$$, Typeset`animvar$$ = 
    1, Typeset`name$$ = "\"untitled\"", Typeset`specs$$ = {{{
       Hold[$CellContext`n2$$], 6, "iterations"}, 1, 20, 1}, {{
       Hold[$CellContext`init$$], {{0.25, 0.5}}}, {-2, -2}, {2, 2}}}, 
    Typeset`size$$ = Automatic, Typeset`update$$ = 0, Typeset`initDone$$, 
    Typeset`skipInitDone$$ = False, $CellContext`n2$1875$$ = 
    0, $CellContext`init$1876$$ = {0, 0}}, 
    DynamicBox[Manipulate`ManipulateBoxes[
     1, StandardForm, 
      "Variables" :> {$CellContext`init$$ = {{0.25, 0.5}}, $CellContext`n2$$ = 
        6}, "ControllerVariables" :> {
        Hold[$CellContext`n2$$, $CellContext`n2$1875$$, 0], 
        Hold[$CellContext`init$$, $CellContext`init$1876$$, {0, 0}]}, 
      "OtherVariables" :> {
       Typeset`show$$, Typeset`bookmarkList$$, Typeset`bookmarkMode$$, 
        Typeset`animator$$, Typeset`animvar$$, Typeset`name$$, 
        Typeset`specs$$, Typeset`size$$, Typeset`update$$, Typeset`initDone$$,
         Typeset`skipInitDone$$}, "Body" :> Graphics[{
         Opacity[0.9], 
         First[$CellContext`background], 
         $CellContext`mandelGraph[1, $CellContext`n2$$, $CellContext`init$$]},
         PlotRange -> {{-2, 2}, {-2, 2}}, Axes -> True, 
        ImageSize -> {390, 390}], 
      "Specifications" :> {{{$CellContext`n2$$, 6, "iterations"}, 1, 20, 1, 
         Appearance -> 
         "Labeled"}, {{$CellContext`init$$, {{0.25, 0.5}}}, {-2, -2}, {2, 2}, 
         ControlType -> Locator}}, 
      "Options" :> {
       AutorunSequencing -> {2}, SynchronousInitialization -> False}, 
      "DefaultOptions" :> {}],
     ImageSizeCache->{443., {241., 246.}},
     SingleEvaluation->True],
    Deinitialization:>None,
    DynamicModuleValues:>{},
    Initialization:>(($CellContext`mandelbrotConv[
         Pattern[$CellContext`n, 
          Blank[Integer]], 
         Pattern[$CellContext`c, 
          Blank[]]] := Length[
         NestWhileList[#^2 + $CellContext`c& , 0, Abs[#] < 2& , 
          1, $CellContext`n]]; $CellContext`grd = Table[
         $CellContext`mandelbrotConv[
         100, $CellContext`x + I $CellContext`y], {$CellContext`y, -2, 2, 
          0.01}, {$CellContext`x, -2, 2, 0.01}]; $CellContext`background = 
       ArrayPlot[$CellContext`grd, Frame -> None, ColorFunction -> 
         "LightTemperatureMap", DataRange -> {{-2, 2}, {-2, 2}}, DataReversed -> 
         True]; $CellContext`mandelbrot[
         Pattern[$CellContext`n, 
          Blank[Integer]], 
         Pattern[$CellContext`c, 
          Blank[]]] := 
       NestWhileList[#^2 + $CellContext`c& , 0, Abs[#] < 2& , 
         1, $CellContext`n]; $CellContext`colorFun = 
       ColorData[3]; $CellContext`mandelGraph[
         Pattern[$CellContext`nVec, 
          Blank[Integer]], 
         Pattern[$CellContext`nIt, 
          Blank[Integer]], 
         Pattern[$CellContext`init, 
          Blank[]]] := 
       Module[{$CellContext`tmp1 = 
          Map[$CellContext`mandelbrot[$CellContext`nIt, #]& , {
            Part[$CellContext`init, 1, 1] + 
             I Part[$CellContext`init, 1, 2]}]}, 
         MapIndexed[{
           $CellContext`colorFun[
            Part[#2, 2]], 
           Arrow[#]}& , 
          Map[Partition[
            Map[{
              Re[#], 
              Im[#]}& , #], 2, 1]& , $CellContext`tmp1], {2}]]; Null); 
     Typeset`initDone$$ = True),
    SynchronousInitialization->False,
    UnsavedVariables:>{Typeset`initDone$$},
    UntrackedVariables:>{Typeset`size$$}], "Manipulate",
   Deployed->True,
   StripOnInput->False],
  Manipulate`InterpretManipulate[1]]], "Output",
