Cell[TextData[{
 "Twenty-five years ago, the ",
 ButtonBox["Mandelbrot set",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://mathworld.wolfram.com/MandelbrotSet.html"], None},
  ButtonNote->"http://mathworld.wolfram.com/MandelbrotSet.html"],
 " was published on the cover of ",
 StyleBox["Scientific American",
  FontSlant->"Italic"],
 ", in connection with an A. K. Dewdney Computer Recreations column. A few \
days ago, the original ",
 ButtonBox["Mandelbrot set column ",
  BaseStyle->"Hyperlink",
  ButtonData->{
    URL["http://www.scientificamerican.com/article.cfm?id=mandelbrot-set"], 
    None},
  ButtonNote->
   "http://www.scientificamerican.com/article.cfm?id=mandelbrot-set"],
 "was re-released."
}], "Text",
 CellChangeTimes->{{3.496419633236516*^9, 3.496419668084*^9}, {
