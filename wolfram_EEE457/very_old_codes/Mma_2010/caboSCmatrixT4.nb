Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"eigNR", "[", 
    RowBox[{
     RowBox[{"G_", "?", "MatrixQ"}], ",", "V0_", ",", "d0_", ",", 
     RowBox[{"Tol_:", " ", 
      RowBox[{"10", "^", 
       RowBox[{"-", "10"}]}]}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"A", "=", "G"}], ",", "nc", ",", "scale", ",", "v", ",", "d", 
       ",", "vec", ",", "res", ",", "jac", ",", "i"}], "}"}], ",", 
     RowBox[{
      RowBox[{"nc", "=", 
       RowBox[{"Length", "[", "A", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"scale", "=", 
       RowBox[{"Norm", "[", "A", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"A", "=", 
       RowBox[{"A", "/", "scale"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"outd", "=", 
       RowBox[{"Table", "[", 
        RowBox[{"0", ",", 
         RowBox[{"{", "nc", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"outv", "=", 
       RowBox[{"Table", "[", 
        RowBox[{"0", ",", 
         RowBox[{"{", "nc", "}"}], ",", 
         RowBox[{"{", "nc", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"itr", "=", "0"}], ";", "\[IndentingNewLine]", 
      RowBox[{"jac", "=", 
       RowBox[{"Table", "[", 
        RowBox[{"0.0", ",", 
         RowBox[{"{", 
          RowBox[{"nc", "+", "1"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"nc", "+", "1"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"v", "=", 
           RowBox[{"V0", "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{"1", ";;"}], ",", "i"}], "]"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"d", "=", 
           RowBox[{"d0", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"res", "=", 
           RowBox[{"Max", "[", 
            RowBox[{"Abs", "[", 
             RowBox[{
              RowBox[{"A", ".", "v"}], "-", 
              RowBox[{"v", "*", "d"}]}], "]"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"While", "[", 
           RowBox[{
