 CellID->272833626],

Cell[BoxData[
 RowBox[{
  RowBox[{"diffusion", "[", "x0_", "]"}], " ", ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"u", ",", "t", ",", "x"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"sss", " ", "=", " ", 
        RowBox[{"Min", "[", 
         RowBox[{"0.25", ",", " ", 
          RowBox[{"x0", "/", "80"}]}], "]"}]}], "}"}], ",", " ", "\n", " ", 
      RowBox[{"Head", "[", 
       RowBox[{
        RowBox[{"NDSolve", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"D", "[", 
              RowBox[{
               RowBox[{"u", "[", 
                RowBox[{"t", ",", " ", "x"}], "]"}], ",", " ", "t"}], "]"}], 
             " ", "==", " ", "\n", " ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{"1", "/", "4"}], ")"}], "*", 
              RowBox[{"D", "[", 
               RowBox[{
                RowBox[{"u", "[", 
                 RowBox[{"t", ",", " ", "x"}], "]"}], ",", " ", "x", ",", " ",
                 "x"}], "]"}]}]}], ",", " ", 
            RowBox[{
             RowBox[{"u", "[", 
              RowBox[{"0", ",", " ", "x"}], "]"}], " ", "==", " ", 
             RowBox[{"E", "^", 
              RowBox[{"(", 
               RowBox[{"-", 
                RowBox[{"x", "^", "2"}]}], ")"}]}]}], ",", " ", "\n", " ", 
            RowBox[{
             RowBox[{"u", "[", 
              RowBox[{"t", ",", " ", 
               RowBox[{"-", "x0"}]}], "]"}], " ", "==", " ", 
             RowBox[{"u", "[", 
              RowBox[{"t", ",", " ", "x0"}], "]"}]}]}], "}"}], ",", " ", 
          RowBox[{"u", "[", 
           RowBox[{"t", ",", " ", "x"}], "]"}], ",", " ", 
          RowBox[{"{", 
           RowBox[{"t", ",", " ", "0", ",", " ", "x0"}], "}"}], ",", " ", 
          "\n", " ", 
          RowBox[{"{", 
           RowBox[{"x", ",", " ", 
            RowBox[{"-", "x0"}], ",", " ", "x0"}], "}"}], ",", " ", 
          RowBox[{"StartingStepSize", " ", "\[Rule]", " ", "sss"}], ",", " ", 
          "\n", " ", 
          RowBox[{"MaxSteps", " ", "\[Rule]", " ", "Infinity"}]}], "]"}], "[", 
        RowBox[{"[", 
         RowBox[{"1", ",", "1", ",", "2"}], "]"}], "]"}], "]"}]}], "]"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 InitializationCell->True,
 CellChangeTimes->{
  3.35696210375764*^9, {3.489256790776636*^9, 3.489256790781636*^9}, {
