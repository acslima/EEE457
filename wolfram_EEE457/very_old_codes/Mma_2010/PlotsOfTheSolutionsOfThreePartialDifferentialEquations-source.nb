 CellID->1130297684],

Cell[BoxData[
 RowBox[{
  RowBox[{"wave", "[", "time_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"x", ",", "t"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"x0", " ", "=", " ", "time"}], "}"}], ",", 
      RowBox[{"Plot3D", "[", 
       RowBox[{
        RowBox[{"Evaluate", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"1", "/", "2"}], ")"}], "*", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"E", "^", 
             RowBox[{"(", 
              RowBox[{"-", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"x", " ", "-", " ", "t"}], ")"}], "^", "2"}]}], 
              ")"}]}], " ", "+", " ", "\n", " ", 
            RowBox[{"E", "^", 
             RowBox[{"(", 
              RowBox[{"-", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"x", " ", "+", " ", "t"}], ")"}], "^", "2"}]}], 
              ")"}]}]}], ")"}]}], "]"}], ",", " ", 
        RowBox[{"{", 
         RowBox[{"x", ",", " ", 
          RowBox[{
           RowBox[{"-", "x0"}], " ", "-", " ", "2"}], ",", " ", 
          RowBox[{"x0", " ", "+", " ", "2"}]}], "}"}], ",", " ", "\n", " ", 
        RowBox[{"{", 
         RowBox[{"t", ",", " ", "0", ",", " ", "x0"}], "}"}], ",", " ", 
        RowBox[{"PlotPoints", " ", "\[Rule]", " ", "50"}], ",", " ", 
        RowBox[{"Mesh", " ", "\[Rule]", " ", "True"}], ",", " ", "\n", " ", 
        RowBox[{"PlotRange", " ", "\[Rule]", " ", "All"}], ",", " ", "\n", 
        " ", 
        RowBox[{"Axes", " ", "\[Rule]", " ", "False"}], ",", " ", 
        RowBox[{"ViewPoint", " ", "\[Rule]", " ", 
         RowBox[{"{", 
          RowBox[{"0", ",", " ", "2", ",", " ", "3"}], "}"}]}], ",", " ", 
        "\n", " ", 
        RowBox[{"BoxRatios", " ", "\[Rule]", " ", 
         RowBox[{"{", 
          RowBox[{"2", ",", " ", "1", ",", " ", "0.25"}], "}"}]}], ",", " ", 
        RowBox[{"AspectRatio", " ", "\[Rule]", " ", 
         RowBox[{"1", "/", "2"}]}], ",", 
        RowBox[{"ImageSize", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{"400", ",", "400"}], "}"}]}]}], "]"}]}], "]"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 InitializationCell->True,
