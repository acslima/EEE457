                 $CellContext`u[$CellContext`t, $CellContext`x], \
{$CellContext`t, 
                  0, $CellContext`x0}, {$CellContext`x, -$CellContext`x0, \
$CellContext`x0}, StartingStepSize -> $CellContext`sss, MaxSteps -> Infinity],
                 1, 1, 2]]]; $CellContext`res], 
         Null, $CellContext`diffusiongraphics[
           Pattern[$CellContext`steps, 
            Blank[]]] := $CellContext`dim3gr[
           $CellContext`diffusion[$CellContext`steps], $CellContext`steps], \
$CellContext`sinegordongraphics[
