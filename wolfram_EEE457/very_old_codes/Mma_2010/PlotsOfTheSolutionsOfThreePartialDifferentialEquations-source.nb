Cell[CellGroupData[{

Cell["Caption", "Section",
 CellFrameColor->RGBColor[
  0.6449835965514611, 0.758632791638056, 0.2516823071641108],
 FontColor->RGBColor[
  0.6449835965514611, 0.758632791638056, 0.2516823071641108]],

Cell["\<\
This Demonstration plots the solutions of three examples of partial \
differential equations: a diffusion equation, a wave equation, and the \
sine-Gordon soliton equation, each for up to 30 time steps. \
\>", "Text"]
}, Close]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Details", "Section",
 CellFrameColor->RGBColor[
  0.6449835965514611, 0.758632791638056, 0.2516823071641108],
 FontColor->RGBColor[
  0.6449835965514611, 0.758632791638056, 0.2516823071641108]],

Cell[TextData[{
 "A diffusion equation: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[PartialD]", "t"], 
     RowBox[{"u", "(", 
      RowBox[{"t", ",", "x"}], ")"}]}], "=", 
    RowBox[{
     FractionBox["1", "4"], 
     RowBox[{
      SubscriptBox["\[PartialD]", 
       RowBox[{"x", "\[InvisibleSpace]", "x"}]], 
      RowBox[{"u", "(", 
       RowBox[{"t", ",", "x"}], ")"}]}]}]}], TraditionalForm]], "InlineMath"]
}], "Text"],

Cell[TextData[{
 "A wave equation: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[PartialD]", 
      RowBox[{"t", "\[InvisibleSpace]", "t"}]], 
     RowBox[{"u", "(", 
      RowBox[{"t", ",", "x"}], ")"}]}], "=", 
    RowBox[{
     SubscriptBox["\[PartialD]", 
      RowBox[{"x", "\[InvisibleSpace]", "x"}]], 
     RowBox[{"u", "(", 
      RowBox[{"t", ",", "x"}], ")"}]}]}], TraditionalForm]], "InlineMath"]
}], "Text"],

Cell[TextData[{
 "The sine-Gordon soliton equation: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[PartialD]", 
      RowBox[{"t", "\[InvisibleSpace]", "t"}]], 
     RowBox[{"u", "(", 
      RowBox[{"t", ",", "x"}], ")"}]}], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[PartialD]", 
       RowBox[{"x", "\[InvisibleSpace]", "x"}]], 
      RowBox[{"u", "(", 
       RowBox[{"t", ",", "x"}], ")"}]}], "+", 
     RowBox[{"sin", "(", 
      RowBox[{"u", "(", 
       RowBox[{"t", ",", "x"}], ")"}], ")"}]}]}], TraditionalForm]], 
  "InlineMath"]
}], "Text"]
}, Close]],

