   3.489256871999885*^9, 3.489256913821558*^9}},
 CellID->637165837],

Cell[BoxData[
 RowBox[{
  RowBox[{"sinegordon", "[", "x0_", "]"}], " ", ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"t", ",", "x", ",", "u", ",", "res", ",", 
      RowBox[{"sss", " ", "=", " ", 
       RowBox[{"Min", "[", 
        RowBox[{"0.2", ",", " ", 
         RowBox[{"x0", "/", "100"}]}], "]"}]}]}], "}"}], ",", " ", "\n", " ", 
    
    RowBox[{
     RowBox[{"res", "=", 
      RowBox[{"Quiet", "[", 
       RowBox[{"Head", "[", 
        RowBox[{
         RowBox[{"NDSolve", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{"D", "[", 
               RowBox[{
                RowBox[{"u", "[", 
                 RowBox[{"t", ",", " ", "x"}], "]"}], ",", " ", "t", ",", " ",
                 "t"}], "]"}], " ", "==", " ", 
              RowBox[{
               RowBox[{"D", "[", 
                RowBox[{
                 RowBox[{"u", "[", 
                  RowBox[{"t", ",", " ", "x"}], "]"}], ",", " ", "x", ",", 
                 " ", "x"}], "]"}], " ", "+", " ", "\n", " ", 
               RowBox[{"Sin", "[", 
                RowBox[{"u", "[", 
                 RowBox[{"t", ",", " ", "x"}], "]"}], "]"}]}]}], ",", " ", 
             RowBox[{
              RowBox[{"u", "[", 
               RowBox[{"0", ",", " ", "x"}], "]"}], " ", "==", " ", 
              RowBox[{"E", "^", 
               RowBox[{"(", 
                RowBox[{"-", 
                 RowBox[{"x", "^", "2"}]}], ")"}]}]}], ",", " ", "\n", " ", 
             RowBox[{
              RowBox[{
               RowBox[{"D", "[", 
                RowBox[{
                 RowBox[{"u", "[", 
                  RowBox[{"t", ",", " ", "x"}], "]"}], ",", " ", "t"}], "]"}],
                " ", "==", " ", "0"}], " ", "/.", " ", 
              RowBox[{"t", " ", "\[Rule]", " ", "0"}]}], ",", " ", 
             RowBox[{
              RowBox[{"u", "[", 
               RowBox[{"t", ",", " ", 
                RowBox[{"-", "x0"}]}], "]"}], " ", "==", " ", "\n", " ", 
              RowBox[{"u", "[", 
               RowBox[{"t", ",", " ", "x0"}], "]"}]}]}], "}"}], ",", " ", 
           RowBox[{"u", "[", 
            RowBox[{"t", ",", " ", "x"}], "]"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"t", ",", " ", "0", ",", " ", "x0"}], "}"}], ",", " ", 
           RowBox[{"{", 
            RowBox[{"x", ",", " ", 
             RowBox[{"-", "x0"}], ",", " ", "x0"}], "}"}], ",", " ", "\n", 
           " ", 
           RowBox[{"StartingStepSize", " ", "\[Rule]", " ", "sss"}], ",", " ", 
           RowBox[{"MaxSteps", " ", "\[Rule]", " ", "Infinity"}]}], "]"}], 
         "[", 
         RowBox[{"[", 
          RowBox[{"1", ",", "\n", " ", "1", ",", "2"}], "]"}], "]"}], "]"}], 
       "]"}]}], ";", "res"}]}], "]"}]}]], "Input",
