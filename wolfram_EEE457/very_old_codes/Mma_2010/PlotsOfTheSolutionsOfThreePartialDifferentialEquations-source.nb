Cell[BoxData[
 RowBox[{
  RowBox[{"dim3gr", "[", 
   RowBox[{"fun_", ",", " ", "x0_"}], "]"}], " ", ":=", " ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"t", ",", "x"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"Plot3D", "[", 
     RowBox[{
      RowBox[{"Evaluate", "[", 
       RowBox[{"fun", "[", 
        RowBox[{"t", ",", " ", "x"}], "]"}], "]"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"x", ",", " ", 
        RowBox[{"-", "x0"}], ",", " ", "x0"}], "}"}], ",", " ", "\n", " ", 
      RowBox[{"{", 
       RowBox[{"t", ",", " ", "0", ",", " ", "x0"}], "}"}], ",", " ", 
      RowBox[{"PlotPoints", " ", "\[Rule]", " ", "40"}], ",", " ", 
      RowBox[{"Mesh", " ", "\[Rule]", " ", "True"}], ",", " ", "\n", " ", 
      RowBox[{"PlotRange", " ", "\[Rule]", " ", "All"}], ",", " ", 
      RowBox[{"Axes", " ", "\[Rule]", " ", "False"}], ",", " ", "\n", " ", 
      RowBox[{"ViewPoint", " ", "\[Rule]", " ", 
       RowBox[{"{", 
        RowBox[{"0", ",", " ", "2", ",", " ", "3"}], "}"}]}], ",", " ", 
      RowBox[{"BoxRatios", " ", "\[Rule]", " ", 
       RowBox[{"{", 
        RowBox[{"2", ",", " ", "1", ",", " ", "0.25"}], "}"}]}], ",", " ", 
      "\n", " ", 
      RowBox[{"AspectRatio", " ", "\[Rule]", " ", 
       RowBox[{"1", "/", "2"}]}], ",", 
      RowBox[{"ImageSize", "\[Rule]", 
       RowBox[{"{", 
        RowBox[{"400", ",", "400"}], "}"}]}]}], "]"}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 InitializationCell->True,
