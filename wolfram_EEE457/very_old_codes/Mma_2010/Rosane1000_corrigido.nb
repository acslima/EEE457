             SqrtBox[
              RowBox[{
               RowBox[{"(", 
                RowBox[{"\[Alpha]", "^", "2"}], ")"}], "+", 
               RowBox[{"mg", "^", "2"}]}]]}]], 
           RowBox[{"Cos", "[", 
            RowBox[{"ris3e", " ", "\[Alpha]"}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"\[Alpha]", ",", "0", ",", "\[Infinity]"}], "}"}], ",", 
          RowBox[{"MaxRecursion", "\[Rule]", "50"}]}], "]"}]}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"zs", "=", 
       RowBox[{"\[ImaginaryJ]", 
        FractionBox[
         RowBox[{" ", 
          RowBox[{"\[Omega]", " ", "\[Mu]"}]}], 
         RowBox[{"2", "\[Pi]"}]], 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"BesselK", "[", 
           RowBox[{"0", ",", 
            RowBox[{"mg", " ", "ris3e"}]}], "]"}], "-", 
          RowBox[{"BesselK", "[", 
           RowBox[{"0", ",", 
            RowBox[{"mg", "  ", "de"}]}], "]"}], "+", "polchk"}], ")"}]}]}], 
      ",", "\[IndentingNewLine]", 
      RowBox[{"Z0", "=", 
       RowBox[{"Table", "[", 
        RowBox[{"zs", ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "1", ",", "8"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", "1", ",", "8"}], "}"}]}], "]"}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"Matriz", " ", "Z"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"Zcabo", "=", 
       RowBox[{"Zi", "+", "Zp", "+", "Zc", "+", "Z0"}]}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"Ycabo", "=", "Ypipe"}], ",", "\[IndentingNewLine]", 
      RowBox[{"\[CapitalGamma]", "=", " ", 
       RowBox[{"Ycabo", ".", "Zcabo"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"nc", "=", 
        RowBox[{"Length", "[", "Zcabo", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"k", "=", "nm"}]}], ",", "\[IndentingNewLine]", 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"k", "\[Equal]", "1"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"eval", ",", "evec"}], "}"}], "=", 
          RowBox[{"Eigensystem", "[", "\[CapitalGamma]", "]"}]}], ";", 
         "\[IndentingNewLine]", " ", 
         RowBox[{"evelho", "=", 
          RowBox[{"rot", "[", 
           RowBox[{"Transpose", "[", "evec", "]"}], "]"}]}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"eigNR", "[", 
          RowBox[{"\[CapitalGamma]", ",", "evelho", ",", "eval"}], "]"}], ";",
          "\[IndentingNewLine]", 
         RowBox[{"eval", "=", "outd"}], ";", "\[IndentingNewLine]", 
         RowBox[{"evelho", "=", "outv"}], ";"}]}], "\[IndentingNewLine]", 
       "]"}], ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{
        RowBox[{"\[Lambda]0", "[", 
         RowBox[{"[", "nm", "]"}], "]"}], "=", 
        RowBox[{"Sqrt", "[", "eval", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Am1", "[", 
         RowBox[{"[", "nm", "]"}], "]"}], "=", 
        RowBox[{"Exp", "[", 
         RowBox[{
          RowBox[{"-", 
           RowBox[{"\[Lambda]0", "[", 
            RowBox[{"[", "nm", "]"}], "]"}]}], " ", "compr"}], "]"}]}]}], ",",
       "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"T", "[", 
        RowBox[{"[", "nm", "]"}], "]"}], "=", "evelho"}]}], 
