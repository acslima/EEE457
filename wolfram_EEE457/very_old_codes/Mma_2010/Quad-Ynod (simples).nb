       RowBox[{
        RowBox[{"{", 
         RowBox[{"Thick", ",", 
          RowBox[{"RGBColor", "[", 
           RowBox[{"0", ",", "0", ",", 
            RowBox[{"i", "/", "nres"}]}], "]"}], ",", "Dashed"}], "}"}], ",", 
        
        RowBox[{"{", 
         RowBox[{"i", ",", "nres"}], "}"}]}], "]"}]}]}], "]"}]}], 
