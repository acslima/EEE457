Cell[BoxData[{
 RowBox[{
  RowBox[{
   SubscriptBox["A", "1"], "=", 
   RowBox[{"1", "+", 
    FractionBox[
     RowBox[{
      SuperscriptBox["s", "2"], " ", 
      SubscriptBox["L", "1"], " ", 
      SubscriptBox["c", "1"]}], "2"]}]}], ";", " ", 
  RowBox[{
   SubscriptBox["B", "1"], "=", 
   RowBox[{"s", " ", 
    SubscriptBox["L", "1"]}]}], ";", " ", 
  RowBox[{
   SubscriptBox["C", "1"], "=", 
   RowBox[{"s", " ", 
    SubscriptBox["c", "1"], " ", 
    RowBox[{"(", 
     RowBox[{"1", "+", 
      FractionBox[
       RowBox[{
        SuperscriptBox["s", "2"], " ", 
        SubscriptBox["L", "1"], " ", 
        SubscriptBox["c", "1"]}], "4"]}], ")"}]}]}], ";", " ", 
  RowBox[{
   SubscriptBox["D", "1"], "=", 
   SubscriptBox["A", "1"]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"M", "=", 
   RowBox[{
    RowBox[{"Expand", "[", 
     RowBox[{"MatrixPower", "[", 
      RowBox[{
       RowBox[{"(", GridBox[{
          {
           SubscriptBox["A", "1"], 
           SubscriptBox["B", "1"]},
          {
           SubscriptBox["C", "1"], 
           SubscriptBox["D", "1"]}
         }], ")"}], ",", "1"}], "]"}], "]"}], "//", "Simplify"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"V11", "=", 
   RowBox[{
    RowBox[{"M", "[", 
     RowBox[{"[", 
      RowBox[{"1", ",", "1"}], "]"}], "]"}], "//", "Simplify"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"V21", "=", 
   FractionBox["1", 
    RowBox[{"s", " ", "V11"}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"v", "=", 
   RowBox[{
    RowBox[{"Chop", "[", 
     RowBox[{"InverseLaplaceTransform", "[", 
      RowBox[{"V21", ",", "s", ",", "t"}], "]"}], "]"}], "//", "Simplify"}]}],
   ";"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{"v", ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "0.0000001"}], "}"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
   RowBox[{
   "PlotLabel", "\[Rule]", 
    "\"\<Tens\[ATilde]o ap\[OAcute]s Quadripolo 1\>\""}]}], "]"}]}], "Input",
 Background->RGBColor[0.768627, 1, 1]],

