Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   SubscriptBox["A", "2"], "=", 
   RowBox[{"1", "+", 
    FractionBox[
     RowBox[{
      SuperscriptBox["s", "2"], " ", 
      SubscriptBox["L", "2"], " ", 
      SubscriptBox["c", "2"]}], "2"]}]}], ";", " ", 
  RowBox[{
   SubscriptBox["B", "2"], "=", 
   RowBox[{"s", " ", 
    SubscriptBox["L", "2"]}]}], ";", " ", 
  RowBox[{
   SubscriptBox["C", "2"], "=", 
   RowBox[{"s", " ", 
    SubscriptBox["c", "2"], " ", 
    RowBox[{"(", 
     RowBox[{"1", "+", 
      FractionBox[
       RowBox[{
        SuperscriptBox["s", "2"], " ", 
        SubscriptBox["L", "2"], " ", 
        SubscriptBox["c", "2"]}], "4"]}], ")"}]}]}], ";", " ", 
  RowBox[{
   SubscriptBox["D", "2"], "=", 
   SubscriptBox["A", "2"]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"M", "=", 
   RowBox[{
    RowBox[{"Expand", "[", 
     RowBox[{"MatrixPower", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", GridBox[{
           {
            SubscriptBox["A", "1"], 
            SubscriptBox["B", "1"]},
           {
            SubscriptBox["C", "1"], 
            SubscriptBox["D", "1"]}
          }], ")"}], ".", 
        RowBox[{"(", GridBox[{
           {
            SubscriptBox["A", "2"], 
            SubscriptBox["B", "2"]},
           {
            SubscriptBox["C", "2"], 
            SubscriptBox["D", "2"]}
          }], ")"}]}], ",", "1"}], "]"}], "]"}], "//", "Simplify"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   SubscriptBox["V", "11"], "=", 
   RowBox[{
    RowBox[{"M", "[", 
     RowBox[{"[", 
      RowBox[{"1", ",", "1"}], "]"}], "]"}], "//", "Simplify"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   SubscriptBox["V", "31"], "=", 
   FractionBox["1", 
    RowBox[{"s", " ", 
     SubscriptBox["V", "11"]}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"v", "=", 
   RowBox[{
    RowBox[{"Chop", "[", 
     RowBox[{"InverseLaplaceTransform", "[", 
      RowBox[{
       SubscriptBox["V", "31"], ",", "s", ",", "t"}], "]"}], "]"}], "//", 
    "Simplify"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Plot", "[", 
  RowBox[{"v", ",", 
   RowBox[{"{", 
    RowBox[{"t", ",", "0", ",", "0.0000001"}], "}"}], ",", 
   RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
   RowBox[{
   "PlotLabel", "\[Rule]", 
    "\"\<Tens\[ATilde]o ap\[OAcute]s Quadripolos 1 e 2\>\""}]}], 
  "]"}]}], "Input",
 Background->RGBColor[0.768627, 1, 1]],

