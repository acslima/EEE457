                Line[{{0, $CellContext`astop}, {$CellContext`fstop, \
$CellContext`astop}}]}, {Dashed, 
                
                Line[{{$CellContext`fstop, -50}, {$CellContext`fstop, \
$CellContext`astop}}]}}], 
            Graphics[
