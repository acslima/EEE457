                    Numerator[$CellContext`expr]]/ComplexExpand[
                   Denominator[$CellContext`expr]]; 
                Part[$CellContext`hz, $CellContext`i] = $CellContext`expr; 
                Null}, {$CellContext`i, 1, Length[$CellContext`hz] - 1}]; 
