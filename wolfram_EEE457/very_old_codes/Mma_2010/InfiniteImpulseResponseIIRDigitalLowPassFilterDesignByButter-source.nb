                RowBox[{
                 RowBox[{"sampling", "/", "2"}], "-", "0.1"}]}]}], "]"}], ";",
              "\[IndentingNewLine]", 
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"pass", "\[GreaterEqual]", "stop"}], ",", 
               RowBox[{"pass", "=", 
                RowBox[{"stop", "-", "0.01"}]}]}], "]"}]}], "}"}], ",", 
           RowBox[{"{", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"pass", "\[GreaterEqual]", 
                RowBox[{"sampling", "/", "2"}]}], ",", 
               RowBox[{"pass", "=", 
                RowBox[{
                 RowBox[{"sampling", "/", "2"}], "-", "0.1"}]}]}], "]"}], 
             ";"}], "}"}]}], "]"}], ";", "\[IndentingNewLine]", 
         "\[IndentingNewLine]", 
         RowBox[{"wpass", " ", "=", " ", 
          RowBox[{"N", "[", 
           RowBox[{
            RowBox[{"pass", " ", "/", "sampling"}], "*", "2", "*", "Pi"}], 
           "]"}]}], ";", "\[IndentingNewLine]", 
