                    Style["h", Italic], "(", 
                    Style["n", Italic], ") discrete unit impulse response"}], 
                  12]]}}, Filling -> Axis]; 
          GraphicsColumn[{$CellContext`p1, $CellContext`p2}, ImageSize -> 
            Full]]; $CellContext`doRampResponsePlot[
          Pattern[$CellContext`hs, 
           Blank[]], 
          Pattern[$CellContext`s, 
           Blank[]], 
          Pattern[$CellContext`hz, 
           Blank[]], 
          Pattern[$CellContext`z, 
           Blank[]], 
          Pattern[$CellContext`sampleTime, 
           Blank[]], 
          Pattern[$CellContext`nSamplesForPlotting, 
           Blank[]]] := 
        Module[{$CellContext`contResponse, $CellContext`discreteResponse = 
           
           0, $CellContext`t, $CellContext`i, $CellContext`p1, \
$CellContext`p2, $CellContext`maxTime}, $CellContext`maxTime = \
$CellContext`nSamplesForPlotting $CellContext`sampleTime; 
          Do[{$CellContext`discreteResponse = $CellContext`discreteResponse + \
$CellContext`inverseZtransform[
                Part[$CellContext`hz, $CellContext`i] \
($CellContext`sampleTime ($CellContext`z/($CellContext`z - 
                    1)^2)), $CellContext`z, $CellContext`nSamplesForPlotting]; 
             Null}, {$CellContext`i, 1, 
             Length[$CellContext`hz]}]; $CellContext`contResponse = Chop[
             
             InverseLaplaceTransform[$CellContext`hs (
               1/$CellContext`s^2), $CellContext`s, $CellContext`t]]; \
$CellContext`p1 = Plot[
             
             Chop[$CellContext`contResponse], {$CellContext`t, 
              0, $CellContext`maxTime}, ImagePadding -> {{65, 10}, {40, 30}}, 
             ImageSize -> Full, PlotRange -> All, Frame -> True, 
             FrameLabel -> {{
                Text[
                 Style["amplitude", 12]], None}, {
                Text[
                 Style["time (sec)", 12]], 
                Text[
                 Style[
                  Row[{
                    Style["h", Italic], "(", 
                    Style["t", Italic], ") analog ramp response"}], 12]]}}, 
             AxesOrigin -> {0, 0}, AspectRatio -> 0.35, TicksStyle -> 
             Directive[10]]; $CellContext`p2 = 
           ListPlot[$CellContext`discreteResponse, Frame -> True, 
             ImagePadding -> All, ImageSize -> Full, FrameLabel -> {{
                Text[
                 Style["amplitude", 12]], None}, {
                Text[
                 Style["sample number", 12]], 
                Text[
                 Style[
                  Row[{
                    Style["h", Italic], "(", 
                    Style["t", Italic], ") discrete unit ramp response"}], 
                  12]]}}, Filling -> Axis, PlotRange -> All, 
             AxesOrigin -> {0, 0}, AspectRatio -> 0.45, TicksStyle -> 
             Directive[10]]; 
          GraphicsColumn[{$CellContext`p1, $CellContext`p2}, ImageSize -> 
            Full]]; $CellContext`doplotTypeButterworth[
          Pattern[$CellContext`filterOrderFoundByDesign, 
           Blank[]], 
          Pattern[$CellContext`\[CapitalOmega]c, 
           Blank[]]] := 
        Module[{$CellContext`data, $CellContext`w, \
$CellContext`commonPlotOptions, $CellContext`maxX = 
           5 $CellContext`\[CapitalOmega]c, $CellContext`title}, \
$CellContext`commonPlotOptions = {
            ImagePadding -> {{35, 10}, {40, 90}}, ImageSize -> Full, 
             ImageMargins -> 1, AxesOrigin -> {0, 0}, Frame -> True, 
             AspectRatio -> 0.4, Frame -> True, PlotStyle -> {Thick, Red}, 
             TicksStyle -> Directive[10], Joined -> True, GridLines -> 
             Automatic}; $CellContext`title = Column[{
              Text[
               Style[
                Row[{
                  Style["H", Italic], "(\[Omega]) = ", 
                  "\!\(\*FractionBox[\(1\), SqrtBox[\(1 + \
\*SuperscriptBox[\((\*FractionBox[\(\[Omega]\), SubscriptBox[\(\[Omega]\), \
\(c\)]])\), \(2  N\)]\)]]\)"}], 16]], 
              Spacer[3], 
              Style["Butterworth gain plot (normalized)", Bold, 14]}, 
             Alignment -> Center]; $CellContext`data = 
           Table[{$CellContext`w/$CellContext`\[CapitalOmega]c, 1/Sqrt[
              1 + ($CellContext`w/$CellContext`\[CapitalOmega]c)^(
                 2 $CellContext`filterOrderFoundByDesign)]}, {$CellContext`w, 
              0, $CellContext`maxX, 0.1}]; 
          ListPlot[$CellContext`data, AxesOrigin -> {0, 0}, 
            Evaluate[$CellContext`commonPlotOptions], FrameLabel -> {{
               Text[
                Style[
                 Row[{"|", 
                   Style["H", Italic], "(\[Omega])|"}], 12]], None}, {
               Text[
                Style["\[Omega]/\[Omega]", 12]], $CellContext`title}}, 
            PlotRange -> All, Frame -> True, Joined -> 
            True]]; $CellContext`doPlotButterworthSpecs[
          Pattern[$CellContext`fpass, 
           Blank[]], 
          Pattern[$CellContext`fstop, 
           Blank[]], 
          Pattern[$CellContext`apass, 
           Blank[]], 
          Pattern[$CellContext`astop, 
           Blank[]], 
          Pattern[$CellContext`\[CapitalOmega]c, 
           Blank[]], 
          Pattern[$CellContext`filterOrderFoundByDesign, 
           Blank[]]] := 
        Module[{$CellContext`data, $CellContext`w, \
$CellContext`commonPlotOptions, $CellContext`maxX = 
           5 $CellContext`\[CapitalOmega]c, $CellContext`title}, \
$CellContext`commonPlotOptions = {
            ImagePadding -> All, ImageMargins -> 1, ImageSize -> 180, 
             AspectRatio -> 0.4, PlotStyle -> {Thick, Red}, TicksStyle -> 
             Directive[10], Ticks -> None, Joined -> 
             True}; $CellContext`title = 
           Style["design specification parameters", 12]; $CellContext`data = 
           Table[{$CellContext`w, 20 
