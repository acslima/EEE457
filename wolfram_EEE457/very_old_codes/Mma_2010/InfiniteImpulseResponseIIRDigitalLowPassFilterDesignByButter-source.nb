           ListPlot[$CellContext`discreteResponse, 
             Evaluate[$CellContext`commonPlotOptions], FrameLabel -> {{
                Text[
                 Style["amplitude", 12]], None}, {
                Text[
                 Style["sample number", 12]], 
                Text[
                 Style[
