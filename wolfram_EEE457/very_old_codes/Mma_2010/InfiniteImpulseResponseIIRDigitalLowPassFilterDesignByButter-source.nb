$CellContext`T])) + ($CellContext`z Conjugate[
                    
                    Part[$CellContext`coeff, \
$CellContext`i]])/($CellContext`z - Exp[Conjugate[
                    
                    Part[$CellContext`hspoles, $CellContext`i]] \
$CellContext`T]); $CellContext`expr = Normal[
                   Chop[
                    FullSimplify[
                    ComplexExpand[$CellContext`expr]]]]; $CellContext`expr = 
