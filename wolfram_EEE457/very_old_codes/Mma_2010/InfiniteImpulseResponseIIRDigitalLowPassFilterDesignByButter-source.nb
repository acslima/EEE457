              Style[
              "\!\(\*SubscriptBox[\(A\), \(pass\)]\)", 
               12], {-0.65, $CellContext`apass}]], 
            Graphics[
             Text[
              Style[
              "\!\(\*SubscriptBox[\(A\), \(stop\)]\)", 
               12], {-0.65, $CellContext`astop}]], 
            Graphics[
             Text[
