Cell[BoxData[
 RowBox[{"Manipulate", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"(", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"ok", "=", "True"}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", " ", "[", 
      RowBox[{
       RowBox[{"Not", "[", "normalized", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"samplingUsed", "=", "sampling"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"filterOrderType", "\[Equal]", "filterOrderMinumum"}], ",", 
           RowBox[{"{", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"If", "[", 
              RowBox[{
               RowBox[{"stop", "\[GreaterEqual]", 
                RowBox[{"sampling", "/", "2"}]}], ",", 
