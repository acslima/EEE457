                1 + ($CellContext`w/$CellContext`\[CapitalOmega]c)^(
                   2 $CellContext`filterOrderFoundByDesign)]]}, \
{$CellContext`w, 0, $CellContext`maxX, 0.1}]; Show[
            ListPlot[$CellContext`data, AxesOrigin -> {0, -50}, 
             Evaluate[$CellContext`commonPlotOptions], 
             PlotRange -> {{-1.5, 6}, {0, -66}}, AxesLabel -> {
