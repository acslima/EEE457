                Length[$CellContext`hz]}]; 
             Null}, {$CellContext`hz = 
              Table[0, {$CellContext`i, 
                 1 + (Length[$CellContext`hspoles] - 1)/2}]; 
             Do[{$CellContext`expr = $CellContext`z (
                    Part[$CellContext`coeff, $CellContext`i]/($CellContext`z - 
