Cell[CellGroupData[{

Cell["Variables and Constants", "Section",
 Evaluatable->False,
 AspectRatioFixed->True],

Cell[TextData[{
 "Variables:\n\t",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "1"], TraditionalForm]]],
 "\ttranslation of cart 1 from center of track\n\t",
 Cell[BoxData[
  FormBox[
   SubscriptBox["x", "2"], TraditionalForm]]],
 "\ttranslation of cart 2 from center of track\n\t\[Theta]\tangle of seesaw \
with vertical\n\t\[Alpha]\tangle of pendulum with normal to track\n\t",
 Cell[BoxData[
  FormBox[
   SubscriptBox["F", "1"], TraditionalForm]]],
 "\tforce applied to cart 1\n\t",
 Cell[BoxData[
  FormBox[
   SubscriptBox["F", "2"], TraditionalForm]]],
 "\tforce applied to cart 2"
}], "Text",
 Evaluatable->False,
 AspectRatioFixed->True],

Cell[TextData[{
 "Constants:\n\tJ\tinertia of seesaw with track att height h\n\t",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "s"], TraditionalForm]]],
 "\tmass of seesaw with track\n\tc\tcenter of gravity\n\th\theight of track \
from pivot point\n\t",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "1"], TraditionalForm]]],
 "\tmass of cart 1 (weight cart, on the back track)\n\t",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "2"], TraditionalForm]]],
 "\tmass of cart 2\t (pendulum cart, on the front track)\n\t",
 Cell[BoxData[
  FormBox[
   SubscriptBox["m", "p"], TraditionalForm]]],
 "\tmass of pendulum\n\t",
 Cell[BoxData[
  FormBox[
   SubscriptBox["l", "p"], TraditionalForm]]],
 "\tcenter of mass of pendulum rod (half of full length)\n\tg\tgravitational \
acceleration"
}], "Text",
 Evaluatable->False,
 AspectRatioFixed->True],

Cell[BoxData[
 RowBox[{"physicalvalues", ":=", 
  RowBox[{"{", "  ", 
   RowBox[{
    RowBox[{"J", "\[Rule]", "1.6"}], ",", 
    RowBox[{
     SubscriptBox["m", "s"], "\[Rule]", "6.6"}], ",", 
    RowBox[{"c", "\[Rule]", "0.06"}], ",", 
    RowBox[{"h", "\[Rule]", "0.115"}], ",", "\n", 
    "\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t", 
    RowBox[{
     SubscriptBox["m", "1"], "\[Rule]", 
     RowBox[{"0.48", "+", "0.38"}]}], ",", 
