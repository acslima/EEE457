       RowBox[{"PlotStyle", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"RGBColor", "[", 
            RowBox[{"0", ",", "0", ",", "0"}], "]"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"RGBColor", "[", 
            RowBox[{"1", ",", "0", ",", "0"}], "]"}], "}"}]}], "}"}]}]}], 
      "]"}], "&"}], ",", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Part", "[", 
        RowBox[{
         RowBox[{"Flatten", "[", 
          RowBox[{
           RowBox[{"x", "[", "t", "]"}], "/.", "dsolStandard"}], "]"}], ",", 
         RowBox[{"Range", "[", "4", "]"}]}], "]"}], ",", "\n", "\t\t", 
       RowBox[{"Part", "[", 
        RowBox[{
         RowBox[{"Flatten", "[", 
          RowBox[{
           RowBox[{"x", "[", "t", "]"}], "/.", "dsollin"}], "]"}], ",", 
         RowBox[{"Range", "[", "4", "]"}]}], "]"}]}], "}"}], "//", 
     "Transpose"}]}], " ", "]"}], ";"}]], "Input"],

Cell[BoxData[
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"GraphicsGrid", "[", "%", "]"}], ",", 
   RowBox[{"DisplayFunction", "\[Rule]", "$DisplayFunction"}]}], 
  "]"}]], "Input"],

Cell["\<\
We notice that the linear response (red) differs significantly from the \
nonlinear one.\
\>", "Text"]
}, Open  ]],

Cell[CellGroupData[{

Cell["External Simulation of the Nonlinear Model", "Subsection"],

Cell[CellGroupData[{

Cell["Code for External Simulation of the Nonlinear Model", "Subsubsection"],

Cell["\<\
We first make an implementation of a state equation solver using the \
Runge-Kutta method\
\>", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"RK", "[", 
    RowBox[{
     RowBox[{"Integer", " ", "n_"}], ",", 
     RowBox[{"Real", " ", "h_"}], ",", 
     RowBox[{"Real", " ", "t0_"}], ",", 
     RowBox[{
      RowBox[{"Real", "[", "_", "]"}], " ", "startv_"}], ",", 
     RowBox[{"Integer", " ", "dimen_"}], ",", 
     RowBox[{"Integer", " ", "dimPlusOne_"}]}], "]"}], "\[Rule]", 
   RowBox[{"Real", "[", 
    RowBox[{"n", ",", "dimPlusOne"}], "]"}]}], ":=", "\n", "\t\t\t", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "\n", "\t\t\t\t\t", 
     RowBox[{
      RowBox[{
       RowBox[{"Real", "[", "dimen", "]"}], " ", 
       RowBox[{"{", 
        RowBox[{"x", ",", "k1", ",", "k2", ",", "k3", ",", "k4"}], "}"}]}], 
      ",", "\n", "\t\t\t\t\t", 
      RowBox[{"Integer", " ", "i"}], ",", "\n", "\t\t\t\t\t", 
      RowBox[{"Real", " ", "t"}], ",", "\n", "\t\t\t\t\t", 
      RowBox[{
       RowBox[{"Real", "[", 
        RowBox[{"n", ",", "dimPlusOne"}], "]"}], " ", "res"}]}], " ", "\n", 
     "\t\t\t\t", "}"}], ",", "\n", "\t\t\t\t", 
    RowBox[{
     RowBox[{"t", "=", "t0"}], ";", "\n", "\t\t\t\t", 
     RowBox[{"x", "=", "startv"}], ";", "\n", "\t\t\t\t", 
     RowBox[{
      RowBox[{"res", "\[LeftDoubleBracket]", 
       RowBox[{"1", ",", "1"}], "\[RightDoubleBracket]"}], "=", "t"}], ";", 
     "\n", "\t\t\t\t", 
     RowBox[{
      RowBox[{"res", "\[LeftDoubleBracket]", 
       RowBox[{"1", ",", 
        RowBox[{"2", "|", "dimPlusOne"}]}], "\[RightDoubleBracket]"}], "=", 
      "x"}], ";", "\n", "\t\t\t\t", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"i", "=", "1"}], ",", " ", 
       RowBox[{"i", "\[LessEqual]", 
        RowBox[{"n", "-", "1"}]}], ",", " ", 
       RowBox[{"i", "++"}], ",", "\n", "\t\t\t\t\t", 
       RowBox[{
        RowBox[{"k1", "=", 
         RowBox[{"h", " ", 
          RowBox[{"ClosedLoopPendulumEquationsRHS", "[", 
           RowBox[{
            RowBox[{
            "x", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], ",", 
            
            RowBox[{
            "x", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], ",", 
            
            RowBox[{
            "x", "\[LeftDoubleBracket]", "3", "\[RightDoubleBracket]"}], ",", 
            
            RowBox[{
            "x", "\[LeftDoubleBracket]", "4", "\[RightDoubleBracket]"}], ",", 
            
            RowBox[{
            "x", "\[LeftDoubleBracket]", "5", "\[RightDoubleBracket]"}], ",", 
            
            RowBox[{
            "x", "\[LeftDoubleBracket]", "6", "\[RightDoubleBracket]"}], ",", 
            
            RowBox[{
            "x", "\[LeftDoubleBracket]", "7", "\[RightDoubleBracket]"}], ",", 
            
            RowBox[{
            "x", "\[LeftDoubleBracket]", "8", "\[RightDoubleBracket]"}]}], 
           "]"}]}]}], ";", "\n", "\t\t\t\t\t", 
        RowBox[{"k2", "=", 
         RowBox[{"h", " ", 
          RowBox[{"ClosedLoopPendulumEquationsRHS", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
             "x", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], "+", 
             RowBox[{
              RowBox[{
              "k1", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], 
              "/", "2"}]}], ",", 
            RowBox[{
             RowBox[{
             "x", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], "+", 
             RowBox[{
              RowBox[{
              "k1", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], 
              "/", "2"}]}], ",", 
            RowBox[{
             RowBox[{
             "x", "\[LeftDoubleBracket]", "3", "\[RightDoubleBracket]"}], "+", 
             RowBox[{
              RowBox[{
              "k1", "\[LeftDoubleBracket]", "3", "\[RightDoubleBracket]"}], 
              "/", "2"}]}], ",", 
            RowBox[{
             RowBox[{
             "x", "\[LeftDoubleBracket]", "4", "\[RightDoubleBracket]"}], "+", 
             RowBox[{
              RowBox[{
              "k1", "\[LeftDoubleBracket]", "4", "\[RightDoubleBracket]"}], 
              "/", "2"}]}], ",", 
            RowBox[{
             RowBox[{
             "x", "\[LeftDoubleBracket]", "5", "\[RightDoubleBracket]"}], "+", 
             RowBox[{
              RowBox[{
              "k1", "\[LeftDoubleBracket]", "5", "\[RightDoubleBracket]"}], 
              "/", "2"}]}], ",", 
            RowBox[{
             RowBox[{
             "x", "\[LeftDoubleBracket]", "6", "\[RightDoubleBracket]"}], "+", 
             RowBox[{
              RowBox[{
              "k1", "\[LeftDoubleBracket]", "6", "\[RightDoubleBracket]"}], 
              "/", "2"}]}], ",", 
            RowBox[{
             RowBox[{
             "x", "\[LeftDoubleBracket]", "7", "\[RightDoubleBracket]"}], "+", 
             RowBox[{
              RowBox[{
              "k1", "\[LeftDoubleBracket]", "7", "\[RightDoubleBracket]"}], 
              "/", "2"}]}], ",", 
            RowBox[{
             RowBox[{
             "x", "\[LeftDoubleBracket]", "8", "\[RightDoubleBracket]"}], "+", 
             RowBox[{
              RowBox[{
              "k1", "\[LeftDoubleBracket]", "8", "\[RightDoubleBracket]"}], 
              "/", "2"}]}]}], "]"}]}]}], ";", "\n", "\t\t\t\t\t", 
        RowBox[{"k3", "=", 
         RowBox[{"h", " ", 
          RowBox[{"ClosedLoopPendulumEquationsRHS", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
             "x", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], "+", 
             RowBox[{
              RowBox[{
              "k2", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], 
              "/", "2"}]}], ",", 
            RowBox[{
             RowBox[{
             "x", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], "+", 
             RowBox[{
              RowBox[{
              "k2", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], 
              "/", "2"}]}], ",", 
            RowBox[{
             RowBox[{
             "x", "\[LeftDoubleBracket]", "3", "\[RightDoubleBracket]"}], "+", 
             RowBox[{
              RowBox[{
              "k2", "\[LeftDoubleBracket]", "3", "\[RightDoubleBracket]"}], 
              "/", "2"}]}], ",", 
            RowBox[{
             RowBox[{
             "x", "\[LeftDoubleBracket]", "4", "\[RightDoubleBracket]"}], "+", 
             RowBox[{
              RowBox[{
              "k2", "\[LeftDoubleBracket]", "4", "\[RightDoubleBracket]"}], 
              "/", "2"}]}], ",", 
            RowBox[{
             RowBox[{
             "x", "\[LeftDoubleBracket]", "5", "\[RightDoubleBracket]"}], "+", 
             RowBox[{
              RowBox[{
              "k2", "\[LeftDoubleBracket]", "5", "\[RightDoubleBracket]"}], 
              "/", "2"}]}], ",", 
            RowBox[{
             RowBox[{
             "x", "\[LeftDoubleBracket]", "6", "\[RightDoubleBracket]"}], "+", 
             RowBox[{
              RowBox[{
              "k2", "\[LeftDoubleBracket]", "6", "\[RightDoubleBracket]"}], 
              "/", "2"}]}], ",", 
            RowBox[{
             RowBox[{
             "x", "\[LeftDoubleBracket]", "7", "\[RightDoubleBracket]"}], "+", 
             RowBox[{
              RowBox[{
              "k2", "\[LeftDoubleBracket]", "7", "\[RightDoubleBracket]"}], 
              "/", "2"}]}], ",", 
            RowBox[{
             RowBox[{
             "x", "\[LeftDoubleBracket]", "8", "\[RightDoubleBracket]"}], "+", 
             RowBox[{
              RowBox[{
              "k2", "\[LeftDoubleBracket]", "8", "\[RightDoubleBracket]"}], 
              "/", "2"}]}]}], "]"}]}]}], ";", "\n", "\t\t\t\t\t", 
        RowBox[{"k4", "=", 
         RowBox[{"h", " ", 
          RowBox[{"ClosedLoopPendulumEquationsRHS", "[", "\n", "\t\t\t\t\t\t", 
           RowBox[{
            RowBox[{
             RowBox[{
             "x", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], "+", 
             RowBox[{
             "k3", "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}]}], 
            ",", 
            RowBox[{
             RowBox[{
             "x", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}], "+", 
             RowBox[{
             "k3", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]}], 
            ",", 
            RowBox[{
             RowBox[{
             "x", "\[LeftDoubleBracket]", "3", "\[RightDoubleBracket]"}], "+", 
             RowBox[{
             "k3", "\[LeftDoubleBracket]", "3", "\[RightDoubleBracket]"}]}], 
            ",", 
            RowBox[{
             RowBox[{
             "x", "\[LeftDoubleBracket]", "4", "\[RightDoubleBracket]"}], "+", 
             RowBox[{
             "k3", "\[LeftDoubleBracket]", "4", "\[RightDoubleBracket]"}]}], 
            ",", 
            RowBox[{
             RowBox[{
             "x", "\[LeftDoubleBracket]", "5", "\[RightDoubleBracket]"}], "+", 
             RowBox[{
             "k3", "\[LeftDoubleBracket]", "5", "\[RightDoubleBracket]"}]}], 
            ",", 
            RowBox[{
             RowBox[{
             "x", "\[LeftDoubleBracket]", "6", "\[RightDoubleBracket]"}], "+", 
             RowBox[{
             "k3", "\[LeftDoubleBracket]", "6", "\[RightDoubleBracket]"}]}], 
            ",", 
            RowBox[{
             RowBox[{
             "x", "\[LeftDoubleBracket]", "7", "\[RightDoubleBracket]"}], "+", 
             RowBox[{
             "k3", "\[LeftDoubleBracket]", "7", "\[RightDoubleBracket]"}]}], 
            ",", 
            RowBox[{
             RowBox[{
             "x", "\[LeftDoubleBracket]", "8", "\[RightDoubleBracket]"}], "+", 
             RowBox[{
             "k3", "\[LeftDoubleBracket]", "8", "\[RightDoubleBracket]"}]}]}],
            "]"}]}]}], ";", "\n", "\t\t\t\t\t", 
        RowBox[{"x", "=", 
         RowBox[{"x", "+", 
          RowBox[{
           RowBox[{"1", "/", "6"}], " ", 
           RowBox[{"(", 
            RowBox[{"k1", "+", 
             RowBox[{"2", " ", "k2"}], "+", 
             RowBox[{"2", "k3"}], "+", "k4"}], ")"}]}]}]}], ";", "\n", 
        "\t\t\t\t\t", 
        RowBox[{"t", "=", 
         RowBox[{"t", "+", "h"}]}], ";", "\n", "\t\t\t\t\t", 
        RowBox[{
         RowBox[{"res", "\[LeftDoubleBracket]", 
          RowBox[{
           RowBox[{"i", "+", "1"}], ",", "1"}], "\[RightDoubleBracket]"}], 
         "=", "t"}], ";", "\n", "\t\t\t\t\t", 
        RowBox[{
         RowBox[{"res", "\[LeftDoubleBracket]", 
          RowBox[{
           RowBox[{"i", "+", "1"}], ",", 
           RowBox[{"2", "|", "dimPlusOne"}]}], "\[RightDoubleBracket]"}], "=",
          "x"}], ";"}]}], "\n", "\t\t\t\t", "]"}], ";", "\n", "\t\t\t\t", 
     "res"}]}], "\n", "\t\t\t", "]"}]}]], "Input"],

Cell["We use RK in the following ODE solver", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ndSolve", "[", 
   RowBox[{"initvalue_", ",", "maxstepsize_", ",", 
    RowBox[{"{", 
     RowBox[{"x_", ",", "xmin_", ",", "xmax_"}], "}"}]}], "]"}], ":=", "\n", 
  "\t", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"n", ",", "dimen"}], "}"}], ",", "\n", "\t\t", 
    RowBox[{
     RowBox[{"n", "=", " ", 
      RowBox[{
       RowBox[{"IntegerPart", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"xmax", "-", "xmin"}], ")"}], "/", "maxstepsize"}], "]"}], 
       "+", "1"}]}], ";", "\n", "\t\t", 
     RowBox[{"dimen", "=", 
      RowBox[{"Length", "[", "initvalue", "]"}]}], ";", "\n", "\t\t", 
     RowBox[{"res", "=", 
      RowBox[{"RK", "[", 
       RowBox[{
       "n", ",", "maxstepsize", ",", "xmin", ",", "initvalue", ",", "dimen", 
        ",", 
        RowBox[{"dimen", "+", "1"}]}], "]"}]}], ";", "\n", "\t\t", 
     RowBox[{"Array", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Interpolation", "[", 
          RowBox[{"AppendRows", "[", 
           RowBox[{
            RowBox[{"Transpose", "[", 
             RowBox[{"{", 
              RowBox[{"res", "\[LeftDoubleBracket]", 
               RowBox[{"_", ",", "1"}], "\[RightDoubleBracket]"}], "}"}], 
             "]"}], ",", "\n", "\t\t\t\t\t\t\t\t\t", 
            RowBox[{"Transpose", "[", 
             RowBox[{"{", 
              RowBox[{"res", "\[LeftDoubleBracket]", 
               RowBox[{"_", ",", 
                RowBox[{"#", "+", "1"}]}], "\[RightDoubleBracket]"}], "}"}], 
             "]"}]}], "]"}], "]"}], ")"}], "&"}], ",", " ", 
       RowBox[{"{", "8", "}"}]}], "]"}]}]}], "\n", "\t", "]"}]}]], "Input"],

Cell["\<\
To get a correct estimate of the time spent by the external code for \
simulating the system we define the folowing function which repeats the \
external simulation n times.\
\>", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"RKRepeated", "[", 
    RowBox[{
     RowBox[{"Integer", " ", "n_"}], ",", 
     RowBox[{"Real", " ", "h_"}], ",", 
     RowBox[{"Real", " ", "t0_"}], ",", 
     RowBox[{
      RowBox[{"Real", "[", "_", "]"}], " ", "startv_"}], ",", 
     RowBox[{"Integer", " ", "dimen_"}], ",", 
     RowBox[{"Integer", " ", "dimPlusOne_"}], ",", 
     RowBox[{"Integer", " ", "loops_"}]}], "]"}], "\[Rule]", 
   RowBox[{"Real", "[", 
    RowBox[{"n", ",", "dimPlusOne"}], "]"}]}], ":=", "\n", "\t ", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Real", "[", 
       RowBox[{"n", ",", "dimPlusOne"}], "]"}], " ", "res"}], "}"}], ",", " ",
     "\n", "\t\t", 
    RowBox[{
     RowBox[{"Do", "[", "\t", 
      RowBox[{
       RowBox[{"res", " ", "=", " ", 
        RowBox[{"RK", "[", 
         RowBox[{
         "n", ",", "h", ",", "t0", ",", "startv", ",", "dimen", ",", 
          "dimPlusOne"}], "]"}]}], ",", 
       RowBox[{"{", "loops", "}"}]}], "]"}], ";", "\n", "\t\t", "res"}]}], 
   "\n", "\t", "]"}]}]], "Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ndSolveRepeated", "[", "\n", "\t", 
   RowBox[{"initvalue_", ",", "maxstepsize_", ",", 
    RowBox[{"{", 
     RowBox[{"x_", ",", "xmin_", ",", "xmax_"}], "}"}], ",", "loops_"}], 
   "]"}], ":=", "\n", "\t", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"n", ",", "dimen"}], "}"}], ",", "\n", "\t\t", 
    RowBox[{
     RowBox[{"n", "=", " ", 
      RowBox[{
       RowBox[{"IntegerPart", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"xmax", "-", "xmin"}], ")"}], "/", "maxstepsize"}], "]"}], 
       "+", "1"}]}], ";", "\n", "\t\t", 
     RowBox[{"dimen", "=", 
      RowBox[{"Length", "[", "initvalue", "]"}]}], ";", "\n", "\t\t", 
     RowBox[{"res", "=", 
      RowBox[{"RKRepeated", "[", 
       RowBox[{
       "n", ",", "maxstepsize", ",", "xmin", ",", "initvalue", ",", "dimen", 
        ",", 
        RowBox[{"dimen", "+", "1"}], ",", " ", "loops"}], "]"}]}], ";", "\n", 
     "\t\t", 
     RowBox[{"Array", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Interpolation", "[", 
          RowBox[{"AppendRows", "[", 
           RowBox[{
            RowBox[{"Transpose", "[", 
             RowBox[{"{", 
              RowBox[{"res", "\[LeftDoubleBracket]", 
               RowBox[{"_", ",", "1"}], "\[RightDoubleBracket]"}], "}"}], 
             "]"}], ",", "\n", "\t\t\t\t\t\t\t\t\t", 
            RowBox[{"Transpose", "[", 
             RowBox[{"{", 
              RowBox[{"res", "\[LeftDoubleBracket]", 
               RowBox[{"_", ",", 
                RowBox[{"#", "+", "1"}]}], "\[RightDoubleBracket]"}], "}"}], 
             "]"}]}], "]"}], "]"}], ")"}], "&"}], ",", " ", 
       RowBox[{"{", "8", "}"}]}], "]"}]}]}], "\n", "\t", "]"}]}]], "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Compilation", "Subsubsection"],

Cell["\<\
We are now ready to compile the package. The rhs of the state equations are \
optimized using common subexpression elimination\
\>", "Text"],

Cell[BoxData[
 RowBox[{"CompilePackage", "[", 
  RowBox[{"EvaluateFunctions", "\[Rule]", 
   RowBox[{"{", "ClosedLoopPendulumEquationsRHS", "}"}]}], "]"}]], "Input"],

Cell["The corresponding code", "Text"],

Cell[BoxData[
 RowBox[{"!!", 
  RowBox[{"Global", ".", "cc"}]}]], "Input"],

Cell[TextData[{
 "All necessary files for building binaries are now generated. The MakeBinary \
command can build either a standalone application using the code specified by \
the option GenerateMainFileAndFunction or a ",
 StyleBox["MathLink",
  FontSlant->"Italic"],
 " version which can be easily installed into ",
 StyleBox["Mathematica",
  FontSlant->"Italic"],
 ". We build the ",
 StyleBox["MathLink",
  FontSlant->"Italic"],
 " version"
}], "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"MakeBinary", "[", "]"}], ";"}]], "Input"],

Cell["\<\
To use the generated code for the simulation we only have to install the code \
using the Install command.\
\>", "Text"]
}, Open  ]],

Cell[CellGroupData[{

Cell["External Simulation", "Subsubsection"],

Cell["\<\
This function is a fix to be able to measure the time for external processes.\
\
\>", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"SetAttributes", "[", 
   RowBox[{"AbsTime", ",", "HoldFirst"}], "]"}], ";", 
  RowBox[{
   RowBox[{"AbsTime", "[", "x_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"start", ",", "res"}], "}"}], ",", "\n", "\t\t", 
     RowBox[{
      RowBox[{"start", "=", 
       RowBox[{"AbsoluteTime", "[", "]"}]}], ";", 
      RowBox[{"res", "=", "x"}], ";", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"AbsoluteTime", "[", "]"}], "-", "start"}], ")"}], " ", 
         "Second"}], ",", "res"}], "}"}]}]}], "]"}]}], ";"}]], "Input"],

Cell[TextData[{
 StyleBox["Uncompiled code (computations within ",
  FontWeight->"Bold"],
 StyleBox["Mathematica",
  FontWeight->"Bold",
  FontSlant->"Italic"],
 StyleBox[")",
  FontWeight->"Bold"]
}], "Text"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"dsolUncompiled", "=", 
    RowBox[{"ndSolve", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "1"}], ",", "0", ",", "1", ",", "0.1", ",", "0", ",", 
        "0", ",", "0", ",", "0"}], "}"}], ",", "0.01", ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0.", ",", "10."}], "}"}]}], "]"}]}], ";"}], "//", 
  "Timing"}], "\n", 
 RowBox[{
  RowBox[{"ndSolveUncompiledTime", "=", 
   RowBox[{"First", "[", "%", "]"}]}], ";"}]}], "Input"],

Cell["We plot the result to verify the Runge-Kutta solver", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Map", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"#", "[", "t", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", "8"}], "}"}], ",", 
       RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
       RowBox[{"DisplayFunction", "\[Rule]", "Identity"}]}], "]"}], "&"}], 
    ",", 
    RowBox[{"Part", "[", 
     RowBox[{"dsolUncompiled", ",", 
      RowBox[{"Range", "[", "4", "]"}]}], "]"}]}], "]"}], ";"}]], "Input"],

Cell[BoxData[
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"GraphicsGrid", "[", "%", "]"}], ",", 
   RowBox[{"DisplayFunction", "\[Rule]", "$DisplayFunction"}]}], 
  "]"}]], "Input"],

Cell[TextData[StyleBox["Compiled code (external computations)",
 FontWeight->"Bold"]], "Text"],

Cell["We install the executable code", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"InstallCode", "[", "]"}], ";"}]], "Input"],

Cell["\<\
The external simulation is performed 600 times to get a accurate measure of \
its timing\
\>", "Text"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"dsolCompiled", "=", 
    RowBox[{"ndSolveRepeated", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"-", "1"}], ",", "0", ",", "1", ",", "0.1", ",", "0", ",", 
        "0", ",", "0", ",", "0"}], "}"}], ",", "0.01", ",", 
      RowBox[{"{", 
       RowBox[{"t", ",", "0.", ",", "10."}], "}"}], ",", "600"}], "]"}]}], 
   ";"}], "//", "AbsTime"}], "\n", 
 RowBox[{
  RowBox[{"ndSolveCompiledTime", "=", 
   RowBox[{
    RowBox[{"First", "[", "%", "]"}], "/", "600"}]}], ";"}]}], "Input"],

Cell["We plot the result to verify the compiled Runge-Kutta solver", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Map", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"#", "[", "t", "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", "8"}], "}"}], ",", 
       RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
       RowBox[{"DisplayFunction", "\[Rule]", "Identity"}]}], "]"}], "&"}], 
    ",", 
    RowBox[{"Part", "[", 
     RowBox[{"dsolCompiled", ",", 
      RowBox[{"Range", "[", "4", "]"}]}], "]"}]}], "]"}], ";"}]], "Input"],

Cell[BoxData[
 RowBox[{"Show", "[", 
  RowBox[{
   RowBox[{"GraphicsGrid", "[", "%", "]"}], ",", 
   RowBox[{"DisplayFunction", "\[Rule]", "$DisplayFunction"}]}], 
  "]"}]], "Input"],

Cell["Looks good!", "Text"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Comparing Performance", "Section"],

Cell["\<\
We present the comparision of performance in the following table\
\>", "Text"],

