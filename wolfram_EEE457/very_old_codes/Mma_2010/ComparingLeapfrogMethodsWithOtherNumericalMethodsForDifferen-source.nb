             Table[0, {$CellContext`i, 1, $CellContext`n + 1}]; 
            Part[$CellContext`y, 1] = $CellContext`y0; 
            Do[Part[$CellContext`y, $CellContext`i] = $CellContext`rkgenStep[{
                
                 Part[$CellContext`y, $CellContext`i - 1], 
                 
                 Part[$CellContext`x, $CellContext`i - 
                  1], $CellContext`h, $CellContext`f}, {
                A, $CellContext`b, $CellContext`c}], {$CellContext`i, 
               2, $CellContext`n + 
               1}]; $CellContext`lsg = $CellContext`combList[$CellContext`x, \
$CellContext`y]]], 
         HoldComplete[Null], 
         HoldComplete[$CellContext`rkheun[{
             Pattern[$CellContext`a, 
              Blank[]], 
             Pattern[$CellContext`r, 
              Blank[]]}, 
            Pattern[$CellContext`f, 
             Blank[]], 
            Pattern[$CellContext`y0, 
             Blank[]], 
            Pattern[$CellContext`n, 
             Blank[]]] := 
          Module[{A, $CellContext`b, $CellContext`c}, 
            A = {{1/2}}; $CellContext`b = {0, 1}; $CellContext`c = {
              0, 1/2}; $CellContext`rkgen[{$CellContext`a, $CellContext`r}, \
$CellContext`f, $CellContext`y0, $CellContext`n, {
              A, $CellContext`b, $CellContext`c}]]], 
         HoldComplete[Null], 
         HoldComplete[$CellContext`rk4[{
             Pattern[$CellContext`a, 
              Blank[]], 
             Pattern[$CellContext`r, 
              Blank[]]}, 
            Pattern[$CellContext`f, 
             Blank[]], 
            Pattern[$CellContext`y0, 
             Blank[]], 
            Pattern[$CellContext`n, 
             Blank[]]] := 
          Module[{A, $CellContext`b, $CellContext`c}, 
            A = {{1/2}, {0, 1/2}, {0, 0, 1}}; $CellContext`b = {
              1/6, 1/3, 1/3, 1/6}; $CellContext`c = {
              0, 1/2, 1/2, 
               1}; $CellContext`rkgen[{$CellContext`a, $CellContext`r}, \
$CellContext`f, $CellContext`y0, $CellContext`n, {
              A, $CellContext`b, $CellContext`c}]]]}}]; 
     Typeset`initDone$$ = True),
    SynchronousInitialization->True,
    UnsavedVariables:>{Typeset`initDone$$},
    UntrackedVariables:>{Typeset`size$$}], "Manipulate",
