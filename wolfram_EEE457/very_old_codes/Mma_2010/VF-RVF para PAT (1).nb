  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"A", "=", "Matr"}], ",", "ncond2", ",", "k", ",", "Mrecomp"}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"ncond2", "=", 
      RowBox[{"Floor", "[", 
       RowBox[{"0.5", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"-", "1"}], "+", 
          RowBox[{"Sqrt", "[", 
           RowBox[{"1", "+", 
            RowBox[{"8", "*", 
             RowBox[{"Length", "[", "A", "]"}]}]}], "]"}]}], ")"}]}], "]"}]}],
      ";", "\[IndentingNewLine]", 
     RowBox[{"Mrecomp", "=", 
      RowBox[{"Table", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", "ncond2", "}"}], ",", 
        RowBox[{"{", "ncond2", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"k", "=", "1"}], ",", 
       RowBox[{"k", "<", 
        RowBox[{"ncond2", "+", "1"}]}], ",", 
       RowBox[{"k", "++"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"Mrecomp", "[", 
          RowBox[{"[", 
           RowBox[{
            RowBox[{"ncond2", "-", "k", "+", "1"}], ",", 
            RowBox[{
             RowBox[{"ncond2", "-", "k", "+", "1"}], ";;", "ncond2"}]}], 
           "]"}], "]"}], "=", 
         RowBox[{"Take", "[", 
          RowBox[{"A", ",", 
           RowBox[{"-", "k"}]}], "]"}]}], ";", 
        RowBox[{"A", "=", 
         RowBox[{"Take", "[", 
          RowBox[{"A", ",", 
           RowBox[{
            RowBox[{"Length", "[", "A", "]"}], "-", "k"}]}], "]"}]}]}]}], 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Mrecomp", "[", 
         RowBox[{"[", 
          RowBox[{"j", ",", "i"}], "]"}], "]"}], "=", 
        RowBox[{"Mrecomp", "[", 
         RowBox[{"[", 
          RowBox[{"i", ",", "j"}], "]"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "ncond2"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "1", ",", "ncond2"}], "}"}]}], "]"}], ";", 
