         "], $CellContext`f[
          Pattern[$CellContext`x, 
           Blank[]], 
          Pattern[$CellContext`\[Lambda], 
           Blank[]]] := 
        Piecewise[{{
           Sign[$CellContext`x] (
             Abs[$CellContext`x] - $CellContext`\[Lambda]), 
            Abs[$CellContext`x] - $CellContext`\[Lambda] > 0}, {
           0, Abs[$CellContext`x] - $CellContext`\[Lambda] <= 
            0}}], $CellContext`fastIWT1D1[
          Pattern[$CellContext`y, 
           Blank[]], 
          Pattern[$CellContext`h, 
           Blank[]]] := 
        Module[{$CellContext`L, $CellContext`t, $CellContext`b, \
$CellContext`z1, $CellContext`z2, $CellContext`oh, $CellContext`eh, \
$CellContext`og, $CellContext`eg}, $CellContext`L = 
           Length[$CellContext`h]; {$CellContext`t, $CellContext`b} = 
           Partition[$CellContext`y, Length[$CellContext`y]/
             2]; $CellContext`z1 = Partition[
             Join[
              
              Take[$CellContext`t, -($CellContext`L/2 - 
                1)], $CellContext`t], $CellContext`L/2, 1]; $CellContext`z2 = 
           Partition[
             Join[
              
              Take[$CellContext`b, -($CellContext`L/2 - 
                1)], $CellContext`b], $CellContext`L/2, 
             1]; {$CellContext`oh, $CellContext`eh} = {
             Part[$CellContext`h, 
              Span[1, $CellContext`L, 2]], 
             Part[$CellContext`h, 
              Span[
              2, $CellContext`L, 2]]}; {$CellContext`og, $CellContext`eg} = {
             Reverse[
              Part[$CellContext`h, 
               Span[2, $CellContext`L, 2]]], -Reverse[
               Part[$CellContext`h, 
                Span[1, $CellContext`L, 2]]]}; Riffle[
             Dot[$CellContext`z1, $CellContext`eh], 
             Dot[$CellContext`z1, $CellContext`oh]] + Riffle[
             Dot[$CellContext`z2, $CellContext`eg], 
             Dot[$CellContext`z2, $CellContext`og]]], 
        Attributes[PlotRange] = {ReadProtected}}; Typeset`initDone$$ = True); 
