         Null, $CellContext`noise = RandomReal[
            NormalDistribution[0, 1], {256}]; Null, $CellContext`fastWT1D1[
           Pattern[$CellContext`x, 
            Blank[]], 
           Pattern[$CellContext`h, 
            Blank[]]] := 
         Module[{$CellContext`size, $CellContext`g, $CellContext`v, \
$CellContext`lp, $CellContext`hp}, $CellContext`size = 
            Length[$CellContext`h]; $CellContext`g = 
            Table[(-1)^$CellContext`k 
              Part[$CellContext`h, $CellContext`size - $CellContext`k], \
{$CellContext`k, 0, $CellContext`size - 1}]; $CellContext`v = 
            Partition[$CellContext`x, $CellContext`size, 2, 
              1]; $CellContext`lp = Dot[$CellContext`v, 
              Reverse[$CellContext`h]]; $CellContext`hp = 
            Dot[$CellContext`v, 
              Reverse[$CellContext`g]]; 
           Join[$CellContext`lp, $CellContext`hp]], $CellContext`fastIWT1D1[
           Pattern[$CellContext`y, 
            Blank[]], 
           Pattern[$CellContext`h, 
            Blank[]]] := 
         Module[{$CellContext`L, $CellContext`t, $CellContext`b, \
$CellContext`z1, $CellContext`z2, $CellContext`oh, $CellContext`eh, \
$CellContext`og, $CellContext`eg}, $CellContext`L = 
            Length[$CellContext`h]; {$CellContext`t, $CellContext`b} = 
            Partition[$CellContext`y, Length[$CellContext`y]/
              2]; $CellContext`z1 = Partition[
              Join[
               
               Take[$CellContext`t, -($CellContext`L/2 - 
                 1)], $CellContext`t], $CellContext`L/2, 1]; $CellContext`z2 = 
            Partition[
              Join[
               
               Take[$CellContext`b, -($CellContext`L/2 - 
                 1)], $CellContext`b], $CellContext`L/2, 
              1]; {$CellContext`oh, $CellContext`eh} = {
              Part[$CellContext`h, 
               Span[1, $CellContext`L, 2]], 
              Part[$CellContext`h, 
               Span[
               2, $CellContext`L, 2]]}; {$CellContext`og, $CellContext`eg} = {
             
              Reverse[
               Part[$CellContext`h, 
                Span[2, $CellContext`L, 2]]], -Reverse[
                Part[$CellContext`h, 
                 Span[1, $CellContext`L, 2]]]}; Riffle[
              Dot[$CellContext`z1, $CellContext`eh], 
              Dot[$CellContext`z1, $CellContext`oh]] + Riffle[
              Dot[$CellContext`z2, $CellContext`eg], 
              Dot[$CellContext`z2, $CellContext`og]]], $CellContext`h = {
           0.33267055295008263`, 0.8068915093110927, 
           0.4598775021184916, -0.1350110200102546, -0.08544127388202671, 
           0.035226291885709526`}; Null, $CellContext`f[
           Pattern[$CellContext`x, 
            Blank[]], 
           Pattern[$CellContext`\[Lambda], 
            Blank[]]] := 
         Piecewise[{{
            Sign[$CellContext`x] (
              Abs[$CellContext`x] - $CellContext`\[Lambda]), 
             Abs[$CellContext`x] - $CellContext`\[Lambda] > 0}, {
            0, Abs[$CellContext`x] - $CellContext`\[Lambda] <= 0}}]}]]; 
