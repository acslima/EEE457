Cell[CellGroupData[{

Cell["Caption", "Section",
 CellFrameColor->RGBColor[
  0.6449835965514611, 0.758632791638056, 0.2516823071641108],
 FontColor->RGBColor[
  0.6449835965514611, 0.758632791638056, 0.2516823071641108]],

Cell[TextData[{
 "If a sinusoidal signal is applied to a linear system, the output is a sine \
wave with the same frequency. Output signals at other frequencies are \
observed as well for nonlinear systems. This Demonstration considers \
nonlinear input signals of the form ",
 Cell[BoxData[
  FormBox[
   RowBox[{"y", "=", 
    RowBox[{"x", "+", 
     RowBox[{
      SubscriptBox["c", "1"], 
      SuperscriptBox["x", "2"]}], "+", 
     RowBox[{
      SubscriptBox["c", "2"], 
      SuperscriptBox["x", "3"]}]}]}], TraditionalForm]], "InlineMath"],
 ", in which ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]], "InlineMath"],
 " is a sine wave with frequency 1 kHz and amplitude 1. The figures show the \
output ",
 Cell[BoxData[
  FormBox["y", TraditionalForm]], "InlineMath"],
 " and its magnitude spectrum obtained from the DFT (discrete Fourier \
transform). Depending on the coefficients ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "1"], TraditionalForm]], "InlineMath"],
 " and ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["c", "2"], TraditionalForm]], "InlineMath"],
 " and the settings for clipping, the output has spectral components at \
either even or odd multiples of the first harmonic. "
}], "Text"]
}, Close]]
}, Open  ]],

