Cell[TextData[{
  "Remove the link to the external code (",
  StyleBox["Mathematicas",
    FontSlant->"Italic"],
  " own definition of ",
  StyleBox["SymbolicMatrix",
    FontWeight->"Bold"],
  " is used again)."
}], "Text"],

Cell[BoxData[
    \(\(UninstallCode[];\)\)], "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["A Performance Comparision", "Subsection"],

Cell[TextData[{
  "To compare performance between compiled and uncompiled code we define a \
function that uses ",
  StyleBox["SymbolicMatrix",
    FontWeight->"Bold"],
  " a specified number of times."
}], "Text"],

Cell[BoxData[
    \(RepeatComputation[Integer\ n_] \[Rule] Null := 
      Do[\(SymbolicMatrix[1.  + 1/n, 2.  + 1/n, 3.  + 1/n, 4.  + 1/n, 
            5.  + 1/n, 6.  + 1/n, 7.  + 1/n, 8.  + 1/n, 9.  + 1/n, 
            10.  + 1/n];\), {n}]\)], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
    \(BuildCode[EvaluateFunctions \[Rule] {SymbolicMatrix}]\)], "Input"],

Cell[BoxData[
    \("Successful compilation to C++: 2 function(s)"\)], "Print"]
}, Open  ]],

Cell["\<\
We do 100 iterations with the uncompiled code and compute the \
average time:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[{
    \(\(n = 100;\)\), "\n", 
    \(\(start = AbsoluteTime[];\)\), "\n", 
    \(\(RepeatComputation[n];\)\), "\n", 
    \(time1 = \((AbsoluteTime[] - start)\)/n\)}], "Input"],

Cell[BoxData[
    \(0.01`5.7196\)], "Output"]
}, Open  ]],

Cell[TextData[{
  "Install the compiled code into ",
  StyleBox["Mathematica",
    FontSlant->"Italic"]
}], "Text"],

Cell[CellGroupData[{

Cell[BoxData[
    \(\(InstallCode[];\)\)], "Input"],

Cell[BoxData[
    InterpretationBox[\("Global"\[InvisibleSpace]" is installed."\),
      SequenceForm[ "Global", " is installed."],
      Editable->False]], "Print"]
}, Open  ]],

Cell["\<\
We do 100000 iterations with the uncompiled code and compute the \
average time:\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[{
    \(\(n = 100000;\)\), "\n", 
    \(\(start = AbsoluteTime[];\)\), "\n", 
    \(\(RepeatComputation[n];\)\), "\n", 
    \(time2 = \((AbsoluteTime[] - start)\)/n\)}], "Input"],

Cell[BoxData[
    \(0.00002`6.0206\)], "Output"]
}, Open  ]],

Cell[BoxData[
    \(\(UninstallCode[];\)\)], "Input"],

Cell["Speed-up:", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
    \(time1/time2\)], "Input"],

Cell[BoxData[
    \(499.9999999999999201677`5.5435\)], "Output"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Clean Up", "Subsection"],

Cell[TextData[{
  "Remove the definition of ",
  StyleBox["SymbolicMatrix",
    FontWeight->"Bold"],
  " and all generated files."
}], "Text"],

Cell[BoxData[
    \(Remove[SymbolicMatrix, RepeatComputation]\)], "Input"],

Cell[BoxData[
    \(CleanMathCodeFiles[Confirm \[Rule] False, 
      CleanAllBut \[Rule] {}]\)], "Input"]
}, Open  ]]
}, Open  ]]
