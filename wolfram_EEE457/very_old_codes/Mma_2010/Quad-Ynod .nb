Cell[BoxData[
 RowBox[{
  RowBox[{"recompmatr", "[", "Matr_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"ncond2", ",", "k", ",", "Mrecomp"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"ncond2", "=", 
      RowBox[{
       RowBox[{"Solve", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Sqrt", "[", 
           RowBox[{
            RowBox[{"2", "*", 
             RowBox[{"Min", "[", 
              RowBox[{"Dimensions", "[", "Matr", "]"}], "]"}]}], "-", "x"}], 
           "]"}], "==", "x"}], ",", "x"}], "]"}], "[", 
       RowBox[{"[", 
        RowBox[{"1", ",", "1", ",", "2"}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Mrecomp", "=", 
      RowBox[{"Table", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", "ncond2", "}"}], ",", 
        RowBox[{"{", "ncond2", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"k", "=", "1"}], ",", 
       RowBox[{"k", "<", 
        RowBox[{"ncond2", "+", "1"}]}], ",", 
       RowBox[{"k", "++"}], ",", 
       RowBox[{
        RowBox[{"Mrecomp", "[", 
         RowBox[{"[", 
          RowBox[{"All", ",", "k"}], "]"}], "]"}], "=", 
        RowBox[{"Flatten", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Take", "[", 
            RowBox[{"Matr", ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{
                RowBox[{"k", "*", 
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{"k", "-", "1"}], ")"}], "/", "2"}]}], "+", "1"}], 
               ",", 
               RowBox[{"k", "*", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"k", "+", "1"}], ")"}], "/", "2"}]}]}], "}"}]}], 
            "]"}], ",", 
           RowBox[{"Table", "[", 
            RowBox[{"0", ",", 
             RowBox[{"{", 
              RowBox[{"ncond2", "-", "k"}], "}"}]}], "]"}]}], "}"}], 
         "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Mrecomp", "[", 
         RowBox[{"[", 
          RowBox[{"j", ",", "i"}], "]"}], "]"}], "=", 
        RowBox[{"Mrecomp", "[", 
         RowBox[{"[", 
          RowBox[{"i", ",", "j"}], "]"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"i", ",", "1", ",", "ncond2"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"j", ",", "1", ",", "ncond2"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
