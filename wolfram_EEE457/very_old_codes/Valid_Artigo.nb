Cell[BoxData[
    \(\(\( (*\ 
      C\[AAcute]lculo\ da\ imped\[AHat]ncia\ longitudinal\ pela\ formula\
\[CCedilla]\[ATilde]o\ exata, \ 
      mas\ utilizando\ \[Gamma]\ \(\(aproximado\)\(.\)\)\ *) \)\(\
\[IndentingNewLine]\)\(ZiiAm[f_, h_, r1_] := 
        Module[{\[Omega], k, kw, kg, \[Gamma], uw, \[Rho]1, Zi, Ze, 
            Zg}, \[IndentingNewLine]\[Omega] = 
            2*\[Pi]*f; \[IndentingNewLine]k = 
            Sqrt[\[Mu]*\[Epsilon]*\[Omega]\^2 - \[ImaginaryI]*\[Mu]*\[Sigma]*\
\[Omega]]; \ \[IndentingNewLine]kw = 
            Sqrt[\[Mu]w*\[Epsilon]w*\[Omega]\^2 - \[ImaginaryI]*\[Mu]w*\
\[Sigma]w*\[Omega]]; \[IndentingNewLine]kg = 
            Sqrt[\[Mu]g*\[Epsilon]g*\[Omega]\^2 - \[ImaginaryI]*\[Mu]g*\
\[Sigma]g*\[Omega]]; \[IndentingNewLine]\[Gamma] = 
            k*Sqrt[\(\(2*\[Pi]\)\/\(\[ImaginaryI]*\[Omega]*\[Mu]\)*AZi[f] + \
Log[\(2*h\)\/r1] + 2*AS1g[f, h, r1]\)\/\(Log[\(2*h\)\/r1] + 2*AS2g[f, h, \
r1]\)]; \[IndentingNewLine]uw = 
            Sqrt[kw\^2 - \[Gamma]\^2]; \[IndentingNewLine]\[Rho]1 = \
\[ImaginaryI]*uw*
              r1; \[IndentingNewLine]Zi = \(\[Omega]*\[Mu]w\)\/\(2*\[Pi]*r1\)*
              uw\/kw\^2*
              BesselI[0, \[Rho]1]\/BesselI[1, \[Rho]1]; \[IndentingNewLine]Ze \
= \[ImaginaryI]*\[Omega]*\[Mu]\/\(2*\[Pi]\)*\[CapitalLambda][f, \[Gamma], h, 
                r1]; \[IndentingNewLine]Zg = \[ImaginaryI]*\[Omega]*\[Mu]\/\(\
\[Pi]*\((k\^2 - \[Gamma]\^2)\)\)*\((k\^2*
                    S1g[f, \[Gamma], h, 
                      r1] - \[Gamma]\^2*\((S1Lg[f, \[Gamma], h, 
                          r1] - \[Gamma]\^2\/k\^2*S2g[f, \[Gamma], 0, r1] + 
                        S2Lg[f, \[Gamma], 0, r1] + S2g[f, \[Gamma], h, r1] - 
                        S2Lg[f, \[Gamma], h, r1] + S1g[f, \[Gamma], 0, r1] - 
                        S1Lg[f, \[Gamma], 0, 
                          r1])\))\); \[IndentingNewLine]Zg];\)\)\)], "Input"],

Cell[BoxData[
    \(\(\( (*\ 
      C\[AAcute]lculo\ da\ imped\[AHat]ncia\ do\ solo\ pelo\ m\[EAcute]todo\ \
de\ Carson, \ 
      utilizada\ na\ minha\ tese\ de\ \(\(mestrado\)\(.\)\)\ *) \)\(\
\[IndentingNewLine]\)\(ZiiCa[f_, h_] := 
        Module[{\[Omega], \[Tau]}, \[IndentingNewLine]\[Omega] = 
            2*\[Pi]*f; \[IndentingNewLine]\(\[Mu]*\[Omega]\)\/\[Pi]*
            NIntegrate[\((Sqrt[\[Tau]\^2 + \[ImaginaryI]] - \[Tau])\)*
                Exp[\(-2\)*Sqrt[\[Omega]*\[Mu]g*\[Sigma]g]*
                    h*\[Tau]], {\[Tau], 0, \[Infinity]}]];\)\)\)], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
    \(\(LogLinearPlot[{Re[ZiiCa[f, h]], Im[ZiiCa[f, h]]}, {f, 10\^5, 10\^8}, 
        PlotRange \[Rule] {Automatic, {\(-3\), 3}}];\)\)], "Input"],

Cell[BoxData[
    \(4.315818353074341`\)], "Output"],

Cell[BoxData[
    \(4.4693093719328925`\)], "Output"],

