Cell[BoxData[{
    \(\(Off[General::spell1];\)\), "\[IndentingNewLine]", 
    \(<< Graphics`Graphics`\)}], "Input"],

Cell[BoxData[
    \(\(\( (*\ 
      Par\[AHat]metros\ el\[EAcute]tricos\ do\ v\[AAcute]cuo\ e\ do\ ar, \ 
      em\ S/m, \ 
      F/m\ e\ H/\(\(m\)\(.\)\)\ *) \)\(\[IndentingNewLine]\)\(\[Sigma]0 = 
      0; \[Epsilon]0 = 8.85*10\^\(-12\); \ \[Mu]0 = 
      4*\[Pi]*10\^\(-7\);\[IndentingNewLine]
    \[Sigma] = 0; \[Epsilon] = \[Epsilon]0; \[Mu] = \[Mu]0;\)\)\)], "Input"],

Cell[BoxData[
    \(\(\( (*\ 
      Dados\ do\ cabo\ condutor\[IndentingNewLine]r0\ e\ r1\  \[Rule] \ 
        raios\ interno\ e\ externo\ \((m)\); \ 
      h\  \[Rule] \ 
        altura\ em\ rela\[CCedilla]\[ATilde]o\ ao\ solo\ \((m)\) . \ \
\[IndentingNewLine]\[Sigma]w, \ \[Epsilon]w\ e\ \[Mu]w\  \[Rule] \ 
        condutividade\ \((S/m)\), \ 
      permitividade\ \((F/
            m)\)\ e\ permeabilidade\ \(\((H/
              m)\)\(.\)\)\ *) \)\(\[IndentingNewLine]\)\(r0 = 4.77/2000; \ 
    r1 = 20/2000;\[IndentingNewLine]
    \(h = 10;\)\[IndentingNewLine]
    \[Sigma]w = 3*10\^7; \[Epsilon]w = 0; \[Mu]w = \[Mu]0;\)\)\)], "Input"],

Cell[BoxData[
    \(\(\( (*\ 
      Dados\ do\ solo\[IndentingNewLine]\[Sigma]0\  \[Rule] \ \(condutividade\
\ a\ corrente\ cont\[IAcute]nua \((S/m)\)\[IndentingNewLine]
        \[Mu]g\  \[Rule] \ 
          permeabilidade\ magn\[EAcute]tica\ \(\((H/
                  m)\)\(.\)\)\)\ *) \)\(\[IndentingNewLine]\)\(\[Sigma]g = 
      5*10\^\(-3\); \[Epsilon]g = 
      5*\[Epsilon]0; \[Mu]g = \[Mu]0;\)\)\)], "Input"],

Cell[BoxData[
    \(\(\( (*\ 
      Defini\[CCedilla]\[ATilde]o\ das\ fun\[CCedilla]\[OTilde]es\ \
\(aproximadas : \ 
          imped\[AHat]ncia\ interna\ e\ integrais\ de\ \
\(\(Sommerfeld\)\(.\)\)\)\ *) \)\(\[IndentingNewLine]\)\(\(AZi[f_] := 
        Module[{\[Omega], kw, \[Rho]1}, \[IndentingNewLine]\[Omega] = 
            2*\[Pi]*f; \[IndentingNewLine]kw = 
            Sqrt[\[Mu]w*\[Epsilon]w*\[Omega]\^2 - \[ImaginaryI]*\[Mu]w*\
\[Sigma]w*\[Omega]]; \[IndentingNewLine]\[Rho]1 = \[ImaginaryI]*kw*
              r1; \[IndentingNewLine]\(\[Omega]*\[Mu]w\)\/\(2*\[Pi]*r1\)*1\/\
kw*BesselI[0, \[Rho]1]\/BesselI[1, \[Rho]1]];\)\[IndentingNewLine]\
\[IndentingNewLine]
    \(AS1g[f_, y_, z_] := 
        Module[{\[Omega], k, kg, \[Alpha], r}, \[IndentingNewLine]\[Omega] = 
            2*\[Pi]*f; \[IndentingNewLine]k = 
            Sqrt[\[Mu]*\[Epsilon]*\[Omega]\^2 - \[ImaginaryI]*\[Mu]*\[Sigma]*\
\[Omega]]; \[IndentingNewLine]kg = 
            Sqrt[\[Mu]g*\[Epsilon]g*\[Omega]\^2 - \[ImaginaryI]*\[Mu]g*\
\[Sigma]g*\[Omega]]; \[IndentingNewLine]\[Alpha] = 
            2\/Sqrt[k\^2 - kg\^2]; \[IndentingNewLine]r = 
            Sqrt[\((y + h)\)\^2 + z\^2]; \[IndentingNewLine]1\/2*
            Log[1 + \[Alpha]\/r]];\)\[IndentingNewLine]\[IndentingNewLine]
    \(AS2g[f_, y_, z_] := 
        Module[{\[Omega], k, kg, \[Beta], r}, \[IndentingNewLine]\[Omega] = 
            2*\[Pi]*f; \[IndentingNewLine]k = 
            Sqrt[\[Mu]*\[Epsilon]*\[Omega]\^2 - \[ImaginaryI]*\[Mu]*\[Sigma]*\
\[Omega]]; \[IndentingNewLine]kg = 
            Sqrt[\[Mu]g*\[Epsilon]g*\[Omega]\^2 - \[ImaginaryI]*\[Mu]g*\
\[Sigma]g*\[Omega]]; \[IndentingNewLine]\[Beta] = \(k\^2 + \
kg\^2\)\/\(k\^2*Sqrt[k\^2 - kg\^2]\); \[IndentingNewLine]r = 
            Sqrt[\((y + h)\)\^2 + 
                z\^2]; \[IndentingNewLine]k\^2\/\(k\^2 + kg\^2\)*
            Log[1 + \[Beta]\/r]];\)\)\)\)], "Input"],

Cell[BoxData[
    \(\(\( (*\ 
      Defini\[CCedilla]\[ATilde]o\ da\ fun\[CCedilla]\[ATilde]o\ \
\[CapitalLambda]\ e\ das\ integrais\ de\ \(\(Sommerfeld\)\(.\)\)\ *) \)\(\
\[IndentingNewLine]\)\(\(\[CapitalLambda][f_, \[Gamma]_, y_, z_] := 
        Module[{\[Omega], k}, \[IndentingNewLine]\[Omega] = 
            2*\[Pi]*f; \[IndentingNewLine]k = 
            Sqrt[\[Mu]*\[Epsilon]*\[Omega]\^2 - \[ImaginaryI]*\[Mu]*\[Sigma]*\
\[Omega]]; \[IndentingNewLine]BesselK[
              0, \[ImaginaryI]*Sqrt[\((y - h)\)\^2 + z\^2]*
                Sqrt[k\^2 - \[Gamma]\^2]] - 
            BesselK[0, \[ImaginaryI]*Sqrt[\((y + h)\)\^2 + z\^2]*
                Sqrt[k\^2 - \[Gamma]\^2]]];\)\[IndentingNewLine]\
\[IndentingNewLine]
    \(S1g[f_, \[Gamma]_, y_, z_] := 
        Module[{\[Omega], k, kg, u, 
            ug, \[Lambda]}, \[IndentingNewLine]\[Omega] = 
            2*\[Pi]*f; \[IndentingNewLine]k = 
            Sqrt[\[Mu]*\[Epsilon]*\[Omega]\^2 - \[ImaginaryI]*\[Mu]*\[Sigma]*\
\[Omega]]; \[IndentingNewLine]kg = 
            Sqrt[\[Mu]g*\[Epsilon]g*\[Omega]\^2 - \[ImaginaryI]*\[Mu]g*\
\[Sigma]g*\[Omega]]; \[IndentingNewLine]u = 
            Sqrt[\[Lambda]\^2 + \[Gamma]\^2 - k\^2]; \[IndentingNewLine]ug = 
            Sqrt[\[Lambda]\^2 + \[Gamma]\^2 - kg\^2]; \[IndentingNewLine]1\/2*
            NIntegrate[
              Exp[\(-u\)*\((y + h)\)]\/\(u + ug\)*
                Exp[\(-\[ImaginaryI]\)*
                    z*\[Lambda]], {\[Lambda], \(-\[Infinity]\), \[Infinity]}, 
              MaxRecursion \[Rule] 
                20]];\)\[IndentingNewLine]\[IndentingNewLine]
    \(S2g[f_, \[Gamma]_, y_, z_] := 
        Module[{\[Omega], k, kg, u, 
            ug, \[Lambda]}, \[IndentingNewLine]\[Omega] = 
            2*\[Pi]*f; \[IndentingNewLine]k = 
            Sqrt[\[Mu]*\[Epsilon]*\[Omega]\^2 - \[ImaginaryI]*\[Mu]*\[Sigma]*\
\[Omega]]; \[IndentingNewLine]kg = 
            Sqrt[\[Mu]g*\[Epsilon]g*\[Omega]\^2 - \[ImaginaryI]*\[Mu]g*\
\[Sigma]g*\[Omega]]; \[IndentingNewLine]u = 
            Sqrt[\[Lambda]\^2 + \[Gamma]\^2 - k\^2]; \[IndentingNewLine]ug = 
            Sqrt[\[Lambda]\^2 + \[Gamma]\^2 - kg\^2]; \[IndentingNewLine]1\/2*
            NIntegrate[
              Exp[\(-u\)*\((y + h)\)]\/\(\(kg\^2\/k\^2\) u + ug\)*
                Exp[\(-\[ImaginaryI]\)*
                    z*\[Lambda]], {\[Lambda], \(-\[Infinity]\), \[Infinity]}, 
              MaxRecursion \[Rule] 
                20]];\)\[IndentingNewLine]\[IndentingNewLine]
    \(S1Lg[f_, \[Gamma]_, y_, z_] := 
        Module[{\[Omega], k, kg, u, 
            ug, \[Lambda]}, \[IndentingNewLine]\[Omega] = 
            2*\[Pi]*f; \[IndentingNewLine]k = 
            Sqrt[\[Mu]*\[Epsilon]*\[Omega]\^2 - \[ImaginaryI]*\[Mu]*\[Sigma]*\
\[Omega]]; \[IndentingNewLine]kg = 
            Sqrt[\[Mu]g*\[Epsilon]g*\[Omega]\^2 - \[ImaginaryI]*\[Mu]g*\
\[Sigma]g*\[Omega]]; \[IndentingNewLine]u = 
            Sqrt[\[Lambda]\^2 + \[Gamma]\^2 - k\^2]; \[IndentingNewLine]ug = 
            Sqrt[\[Lambda]\^2 + \[Gamma]\^2 - kg\^2]; \[IndentingNewLine]1\/2*
            NIntegrate[\[Lambda]\^2\/u\^2*Exp[\(-u\)*\((y + h)\)]\/\(u + ug\)*
                Exp[\(-\[ImaginaryI]\)*
                    z*\[Lambda]], {\[Lambda], \(-\[Infinity]\), \[Infinity]}, 
              MaxRecursion \[Rule] 
                20]];\)\[IndentingNewLine]\[IndentingNewLine]
    \(S2Lg[f_, \[Gamma]_, y_, z_] := 
        Module[{\[Omega], k, kg, u, 
            ug, \[Lambda]}, \[IndentingNewLine]\[Omega] = 
            2*\[Pi]*f; \[IndentingNewLine]k = 
            Sqrt[\[Mu]*\[Epsilon]*\[Omega]\^2 - \[ImaginaryI]*\[Mu]*\[Sigma]*\
\[Omega]]; \[IndentingNewLine]kg = 
            Sqrt[\[Mu]g*\[Epsilon]g*\[Omega]\^2 - \[ImaginaryI]*\[Mu]g*\
\[Sigma]g*\[Omega]]; \[IndentingNewLine]u = 
            Sqrt[\[Lambda]\^2 + \[Gamma]\^2 - k\^2]; \[IndentingNewLine]ug = 
            Sqrt[\[Lambda]\^2 + \[Gamma]\^2 - kg\^2]; \[IndentingNewLine]1\/2*
            NIntegrate[\[Lambda]\^2\/u\^2*
                Exp[\(-u\)*\((y + h)\)]\/\(\(kg\^2\/k\^2\) u + ug\)*
                Exp[\(-\[ImaginaryI]\)*
                    z*\[Lambda]], {\[Lambda], \(-\[Infinity]\), \[Infinity]}, 
              MaxRecursion \[Rule] 
                20]];\)\[IndentingNewLine]\[IndentingNewLine]
    \(S1LLg[f_, \[Gamma]_, y_, z_] := 
        Module[{\[Omega], k, kg, u, 
            ug, \[Lambda]}, \[IndentingNewLine]\[Omega] = 
            2*\[Pi]*f; \[IndentingNewLine]k = 
            Sqrt[\[Mu]*\[Epsilon]*\[Omega]\^2 - \[ImaginaryI]*\[Mu]*\[Sigma]*\
\[Omega]]; \[IndentingNewLine]kg = 
            Sqrt[\[Mu]g*\[Epsilon]g*\[Omega]\^2 - \[ImaginaryI]*\[Mu]g*\
\[Sigma]g*\[Omega]]; \[IndentingNewLine]u = 
            Sqrt[\[Lambda]\^2 + \[Gamma]\^2 - k\^2]; \[IndentingNewLine]ug = 
            Sqrt[\[Lambda]\^2 + \[Gamma]\^2 - kg\^2]; \[IndentingNewLine]1\/2*
            NIntegrate[\[Lambda]\^2\/\(u*ug\)*
                Exp[\(-u\)*\((y + h)\)]\/\(u + ug\)*
                Exp[\(-\[ImaginaryI]\)*
                    z*\[Lambda]], {\[Lambda], \(-\[Infinity]\), \[Infinity]}, 
              MaxRecursion \[Rule] 
                20]];\)\[IndentingNewLine]\[IndentingNewLine]
    \(S2LLg[f_, \[Gamma]_, y_, z_] := 
        Module[{\[Omega], k, kg, u, 
            ug, \[Lambda]}, \[IndentingNewLine]\[Omega] = 
            2*\[Pi]*f; \[IndentingNewLine]k = 
            Sqrt[\[Mu]*\[Epsilon]*\[Omega]\^2 - \[ImaginaryI]*\[Mu]*\[Sigma]*\
\[Omega]]; \[IndentingNewLine]kg = 
            Sqrt[\[Mu]g*\[Epsilon]g*\[Omega]\^2 - \[ImaginaryI]*\[Mu]g*\
\[Sigma]g*\[Omega]]; \[IndentingNewLine]u = 
            Sqrt[\[Lambda]\^2 + \[Gamma]\^2 - k\^2]; \[IndentingNewLine]ug = 
            Sqrt[\[Lambda]\^2 + \[Gamma]\^2 - kg\^2]; \[IndentingNewLine]1\/2*
            NIntegrate[\[Lambda]\^2\/\(u*ug\)*
                Exp[\(-u\)*\((y + h)\)]\/\(\(kg\^2\/k\^2\) u + ug\)*
                Exp[\(-\[ImaginaryI]\)*
                    z*\[Lambda]], {\[Lambda], \(-\[Infinity]\), \[Infinity]}, 
              MaxRecursion \[Rule] 20]];\)\)\)\)], "Input"],

Cell[BoxData[
    \(\(\( (*\ 
      Defini\[CCedilla]\[ATilde]o\ da\ fun\[CCedilla]\[ATilde]o\ \[Gamma], \ 
      isto\ \[EAcute], \ 
      constante\ de\ propaga\[CCedilla]\[ATilde]o\ da\ \(\(linha\)\(.\)\)\ \
*) \)\(\[IndentingNewLine]\)\(\[Gamma][f_, h_, r1_] := 
        Module[{\[Omega], k, Sai}, \[IndentingNewLine]\[Omega] = 
            2*\[Pi]*f; \[IndentingNewLine]k = 
            Sqrt[\[Mu]*\[Epsilon]*\[Omega]\^2 - \[ImaginaryI]*\[Mu]*\[Sigma]*\
\[Omega]]; \[IndentingNewLine]Sai = 
            k*Sqrt[\(\(2*\[Pi]\)\/\(\[ImaginaryI]*\[Omega]*\[Mu]\)*AZi[f] + \
Log[\(2*h\)\/r1] + 2*AS1g[f, h, r1]\)\/\(Log[\(2*h\)\/r1] + 2*AS2g[f, h, \
r1]\)]; \[IndentingNewLine]Return[Sai]];\)\)\)], "Input"],

Cell[CellGroupData[{

Cell[BoxData[{
    \(\(LogLinearPlot[
        Re[\[ImaginaryI]*\[Gamma][f, h, r1]]*10\^3, {f, 10\^5, 10\^8}, 
        PlotRange \[Rule] {{10\^5, 10\^8}, {0, 
              4}}];\)\), "\[IndentingNewLine]", 
    \(\(Plot[Im[\[ImaginaryI]*\[Gamma][f, h, r1]], {f, 10\^5, 10\^8}, 
        PlotRange \[Rule] {{10\^5, 10\^8}, {0, 2.5}}];\)\)}], "Input"],

