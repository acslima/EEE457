Cell[CellGroupData[{

Cell[BoxData[
    \(LogLinearPlot[{Im[YiiAr[2*\[Pi]*f, h, r1]], 
        Im[YiiAm[2*\[Pi]*f, h, r1]]}, {f, 10\^0, 2*10\^6}, 
      PlotRange \[Rule] {{10^0 - 0.000001, 2*10^6}, {0, 
            3*10^\(-5\) + 10^\(-7\)}}, 
      PlotStyle \[Rule] {GrayLevel[0], 
          AbsoluteThickness[1]}, \[IndentingNewLine]Frame -> True, 
      FrameTicks \[Rule] {Automatic, 
          Table[i, {i, 0, 3*10^\(-5\), 1.0*10^\(-5\)}], None, None}, 
      GridLines \[Rule] {{Automatic, {GrayLevel[0.6], 
              Dashing[{0.005, 0.005}]}}, 
          Table[{i, {GrayLevel[0.6], Dashing[{0.005, 0.005}]}}, {i, 0, 
              3*10^\(-5\), 10^\(-5\)}]}]\)], "Input"],

