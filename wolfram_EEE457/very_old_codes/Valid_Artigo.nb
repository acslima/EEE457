    \(\(\( (*Elimina\[CCedilla]\[ATilde]o\ do\ Cabos\ Condutores*) \)\(\
\[IndentingNewLine]\)\(\[IndentingNewLine]\)\( (*Elimina\[CCedilla]\[ATilde]o\
\ das\ Linhas*) \)\(\[IndentingNewLine]\)\(\[IndentingNewLine]\)\(\(z1 = 
        z;\)\[IndentingNewLine]
    \(For[i = nfase + npr, i < nfase*ns + npr, i = i + nfase, 
        For[aux = 1, aux \[LessEqual] nfase, \(aux++\), 
          z1[\([aux + i]\)] = 
            z1[\([aux + i]\)] - z1[\([aux]\)]]];\)\[IndentingNewLine]
    i =. ; 
    aux =. ;\[IndentingNewLine]\[IndentingNewLine] (*Elimina\[CCedilla]\
\[ATilde]o\ das\ Colunas*) \[IndentingNewLine]\[IndentingNewLine]
    \(z2 = z1;\)\[IndentingNewLine]
    \(For[j = nfase + npr, j < nfase*ns + npr, j = j + nfase, 
        For[aux = 1, aux \[LessEqual] nfase, \(aux++\), 
          z2[\([Range[1, ns*nfase + npr], aux + j]\)] = 
            z2[\([Range[1, ns*nfase + npr], aux + j]\)] - 
              z2[\([Range[1, ns*nfase + npr], aux]\)]]];\)\[IndentingNewLine]
    j =. ; 
    aux =. ;\[IndentingNewLine]\[IndentingNewLine] (*\ 
      Elimina\[CCedilla]\[ATilde]o\ de\ Kron\ *) \[IndentingNewLine]\
\[IndentingNewLine]
    \(ad = 0;\)\[IndentingNewLine]\[IndentingNewLine]
    \(zf = \((z2[\([Range[1, nfase + ad], Range[1, nfase + ad]]\)] - 
            z2[\([Range[1, nfase + ad], 
                  Range[nfase + ad + 1, ns*nfase + npr]]\)] . 
              Inverse[z2[\([Range[nfase + ad + 1, ns*nfase + npr], 
                    Range[nfase + ad + 1, ns*nfase + npr]]\)]] . 
              z2[\([Range[nfase + ad + 1, ns*nfase + npr], 
                  Range[1, nfase + ad]]\)])\);\)\)\)\)], "Input"]
},
