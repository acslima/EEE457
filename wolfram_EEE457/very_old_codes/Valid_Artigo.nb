Cell[BoxData[
    \(\(\( (*\ 
      C\[AAcute]lculo\ da\ admit\[AHat]ncia\ transversal\ pela\ formula\
\[CCedilla]\[ATilde]o\ exata, \ 
      mas\ utilizando\ \[Gamma]\ \(\(aproximado\)\(.\)\)\ *) \)\(\
\[IndentingNewLine]\)\(YiiAm[f_, h_, r1_] := 
        Module[{\[Omega], k, kw, kg, \[Gamma], Ye, 
            Yg}, \[IndentingNewLine]\[Omega] = 
            2*\[Pi]*f; \[IndentingNewLine]k = 
            Sqrt[\[Mu]*\[Epsilon]*\[Omega]\^2 - \[ImaginaryI]*\[Mu]*\[Sigma]*\
\[Omega]]; \[IndentingNewLine]kw = 
            Sqrt[\[Mu]w*\[Epsilon]w*\[Omega]\^2 - \[ImaginaryI]*\[Mu]w*\
\[Sigma]w*\[Omega]]; \[IndentingNewLine]kg = 
            Sqrt[\[Mu]g*\[Epsilon]g*\[Omega]\^2 - \[ImaginaryI]*\[Mu]g*\
\[Sigma]g*\[Omega]]; \[IndentingNewLine]\[Gamma] = 
            k*Sqrt[\(\(2*\[Pi]\)\/\(\[ImaginaryI]*\[Omega]*\[Mu]\)*AZi[f] + \
Log[\(2*h\)\/r1] + 2*AS1g[f, h, r1]\)\/\(Log[\(2*h\)\/r1] + 2*AS2g[f, h, \
r1]\)]; \[IndentingNewLine]Ye = \[ImaginaryI]*\[Omega]*\(2*\[Pi]*\[Epsilon]\)\
\/\[CapitalLambda][f, \[Gamma], h, r1]; \[IndentingNewLine]Yg = \
\[ImaginaryI]*\[Omega]*\[Pi]*\[Epsilon]*\((k\^2 - \
\[Gamma]\^2)\)*\((k\^2*\((S1g[f, \[Gamma], h, r1] - S1Lg[f, \[Gamma], h, r1] \
- S1g[f, \[Gamma], 0, r1] + S1Lg[f, \[Gamma], 0, r1] + S2Lg[f, \[Gamma], h, \
r1] - S2Lg[f, \[Gamma], 0, r1])\) - \[Gamma]\^2*\((S2g[f, \[Gamma], h, r1] - \
S2g[f, \[Gamma], 0, r1])\))\)\^\(-1\); \[IndentingNewLine]\(Ye*Yg\)\/\(Ye + \
Yg\)];\)\)\)], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
    \(\(LogLinearPlot[{Im[YiiAm[f, h, r1]]*10\^6, 
          Im[YiiAr[2*\[Pi]*f, h, r1]]*10\^6}, {f, 10\^5, 10\^8}, 
        PlotRange \[Rule] {Automatic, Automatic}];\)\)], "Input"],

Cell[GraphicsData["PostScript", "\<\
