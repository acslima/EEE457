Notebook[{
Cell["C\[AAcute]lculo de Par\[AHat]metros em Larga Faixa de Freq\[UDoubleDot]\
\[EHat]ncia", "Title"],

Cell["\<\
Antonio Carlos Siqueira de Lima
Poli/COPPE/UFRJ\
\>", "Subtitle"],

Cell[CellGroupData[{

Cell["Introdu\[CCedilla]\[ATilde]o", "Section"],

Cell["Tentando repetir os resultados do artigo de D\.b4Amore & Sarto ", "Text"],

Cell[CellGroupData[{

Cell["Entrada de dados", "Subsection"],

Cell[BoxData[
    \(Clear["\<Global`*\>"]\)], "Input"],

Cell[BoxData[{
    \(<< Graphics`Graphics`\), "\[IndentingNewLine]", 
    \(<< Graphics`MultipleListPlot`\), "\[IndentingNewLine]", 
    \(<< LinearAlgebra`MatrixManipulation`\)}], "Input"],

Cell[BoxData[
    \(\(Off[General::"\<spell\>", General::"\<spell1\>"];\)\)], "Input"],

Cell[BoxData[{
    \(\(plstyle1 = {AbsoluteThickness[2], 
          RGBColor[1, 0, 0]};\)\), "\[IndentingNewLine]", 
    \(\(plstyle2 = {AbsoluteThickness[2], 
          RGBColor[0, 0, 1]};\)\), "\[IndentingNewLine]", 
    \(\(plstyle3 = {AbsoluteThickness[2], PointSize[ .015], 
          RGBColor[0, 1, 0]};\)\)}], "Input"],

Cell[BoxData[
    \(\(SetOptions[{ListPlot, \ LogLinearListPlot, LogLogListPlot, 
          MultipleListPlot}, Axes \[Rule] False, Frame \[Rule] True, 
        PlotJoined \[Rule] True, ImageSize \[Rule] 450, 
        DefaultFont \[Rule] {"\<Helvetica\>", 14}, 
        PlotStyle \[Rule] {AbsoluteThickness[1]}];\)\)], "Input"],

Cell[BoxData[
    \(\(SetOptions[{Plot, \ LogLinearPlot, LogLogPlot}, Axes \[Rule] False, 
        Frame \[Rule] True, ImageSize \[Rule] 450, 
        DefaultFont \[Rule] {"\<Helvetica\>", 14}, 
        PlotStyle \[Rule] {AbsoluteThickness[1]}];\)\)], "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Entrada de dados", "Subsection"],

Cell["Dados do sistema", "Text",
  PageWidth->WindowWidth,
  CellDingbat->None],

Cell["Configura\[CCedilla]\[ATilde]o da rede", "SmallText"],

Cell[BoxData[{
    \(\(xc = {\(-1. \), 0. , 1. };\)\), "\n", 
    \(\(yc = {10. , 10. , 10. };\)\)}], "Input"],

Cell[BoxData[
    \(\(ncond = Length[xc];\)\)], "Input"],

Cell[CellGroupData[{

Cell[BoxData[{
    \(\(mostra = 
        Table[{Circle[{xc[\([i]\)], yc[\([i]\)]}, 0.1]}, {i, 1, 
            ncond}];\)\), "\n", 
    \(\(tduplo = 
        Show[Graphics[mostra], AspectRatio \[Rule] Automatic, 
          Axes \[Rule] False, Frame -> Automatic, 
          FrameLabel \[Rule] {"\<dist\[AHat]ncia (m)\>", "\<dist\[AHat]ncia \
(m)\>"}, PlotRange \[Rule] {8, 11}];\)\)}], "Input"],

Cell[GraphicsData["PostScript", "\<\
