Cell["Extens\[ATilde]o das LTs por metro", "SmallText"],

Cell[BoxData[
    \(\(compr = 10.0*\ 10^3;\)\)], "Input"],

Cell["Par\[AHat]metros dos condutores de fase por metro", "SmallText"],

Cell[BoxData[{
    \(\(rf = 8*10\^\(-3\);\)\), "\[IndentingNewLine]", 
    \(\(\[Rho]c = 
        0.105\ *\((10^\((\(-3\))\))\)\ *\ \ \[Pi]\ \((rf\^2)\);\)\)}], "Input"],

Cell["Constantes el\[EAcute]tricas", "SmallText"],

Cell[BoxData[{
    \(\(\[Mu] = 4.0\ \[Pi]\ 10\^\(-7\);\)\), "\[IndentingNewLine]", 
    \(\(\[Epsilon] = 8.854\ \ 10^\(-12\);\)\ \), "\[IndentingNewLine]", 
    \(\(\[Epsilon]g = 5\ \[Epsilon];\)\), "\[IndentingNewLine]", 
    \(\(\[Sigma]g = 5*\ 10^\(-3\);\)\)}], "Input"],

Cell[BoxData[{
    \(freqlog[i_, f_, n_] := 
      Table[N[10^\((i + x \((f - i)\)/\((Floor[n] - 1)\))\)], {x, 0, 
          n - 1}]\), "\[IndentingNewLine]", 
    \(freqlin[i_, f_, n_] := 
      Table[N[\((i + x \((f - i)\)/\((Floor[n] - 1)\))\)], {x, 0, 
          n - 1}]\)}], "Input"],

Cell["Freq\[UDoubleDot]\[EHat]ncias de interesse", "SmallText"],

Cell[BoxData[{
    \(\(npontos = 20;\)\), "\n", 
    \(d1 = 1; d2 = 8;\), "\[IndentingNewLine]", 
    \(\(ndecadas = d2 - d1;\)\), "\[IndentingNewLine]", 
    \(\(nfd = ndecadas*npontos;\)\), "\[IndentingNewLine]", 
    \(\(f = freqlog[d1, d2, nfd];\)\)}], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
    \(nf = Length[f]\)], "Input"],

Cell[BoxData[
    \(140\)], "Output"]
}, Open  ]],

Cell["Constantes el\[EAcute]tricas", "SmallText"],

Cell[BoxData[{
    \(\(\[Mu] = 4\ \[Pi]\ 10\^\(-7\);\)\), "\[IndentingNewLine]", 
    \(\(\[Epsilon] = 8.854*10^\(-12\);\)\), "\[IndentingNewLine]", 
    \(\(k0 = \ \[Omega]\ Sqrt[\[Mu]\ \[Epsilon]];\)\), "\[IndentingNewLine]", \

    \(\(\[Rho]solo = 10000;\)\)}], "Input"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Determina\[CCedilla]\[ATilde]o de Z, Y, Yc e A", "Section"],

Cell[CellGroupData[{

Cell["Inicializa\[CCedilla]\[ATilde]o das listas", "Subsection"],

Cell[BoxData[{
    \(\(\[Gamma]conv = Table[0, {n, 1, nf}];\)\), "\[IndentingNewLine]", 
    \(\(\[Gamma] = \[Gamma]conv;\)\), "\[IndentingNewLine]", 
    \(\(\[Alpha] = \[Gamma];\)\), "\[IndentingNewLine]", 
    \(\(\[Beta] = \[Gamma];\)\)}], "Input"],

Cell["\<\
Como o interesse neste arquivo \[EAcute] analisar o erro relativo a \
admit\[AHat]ncia caracter\[IAcute]stica e o fator de propaga\[CCedilla]\
\[ATilde]o, apenas estes recebem o valor de matrizes. Os outros s\[ATilde]o \
tratados como matrizes sem o ac\[UAcute]mulo dos valores de freq\[UDoubleDot]\
\[EHat]ncia\
\>", "Text"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Modelagem Convencional", "Section"],

Cell[CellGroupData[{

Cell[BoxData[
    \(AbsoluteTiming[
      Block[{Den, zin, Z, P, Y, \[Lambda]conv, \[CapitalGamma]conv, 
          Tc}, \[IndentingNewLine]Do[{\[Omega] = 
              2\ \[Pi]\ f[\([nm]\)], \[IndentingNewLine]\ 
            w = 5.0\ 10^\(-3\) + \[ImaginaryJ]\ \[Omega]\ 5.0\ \[Epsilon], \
\[IndentingNewLine]\[Eta] = \@\(\[ImaginaryJ]\ \ \[Omega]\ \[Mu]\ \
\((\[Sigma]g + \[ImaginaryJ]\ \[Omega]\ \[Epsilon]g)\)\), \
\[IndentingNewLine]p = 
              1/\[Eta], \[IndentingNewLine]\[Eta]c = \@\(\(I\ \[Omega]\ \[Mu]\
\)\/\[Rho]c\), \[IndentingNewLine]Den = 
              BesselI[1, \[Eta]c\ rf], \[IndentingNewLine]zin = \(\(\[Rho]c\ \
\[Eta]c\)\/\(2  \[Pi]\ rf\)\) \(1\/Den\) \((BesselI[
                    0, \[Eta]c\ rf])\), \[IndentingNewLine]Z = 
              Table[If[
                  i \[NotEqual] 
                    j, \(\[ImaginaryI]\ \[Omega]\ \[Mu]\)\/\(4.0\ \[Pi]\)\ \
Log[\(\((xc\_\(\(\[LeftDoubleBracket]\)\(i\)\(\[RightDoubleBracket]\)\) - \
xc\_\(\(\[LeftDoubleBracket]\)\(j\)\(\[RightDoubleBracket]\)\))\)\^2 + \
\((yc\_\(\(\[LeftDoubleBracket]\)\(i\)\(\[RightDoubleBracket]\)\) + yc\_\(\(\
\[LeftDoubleBracket]\)\(j\)\(\[RightDoubleBracket]\)\) + \ 2\ \
p)\)\^2\)\/\(\((xc\_\(\(\[LeftDoubleBracket]\)\(i\)\(\[RightDoubleBracket]\)\)\
 - xc\_\(\(\[LeftDoubleBracket]\)\(j\)\(\[RightDoubleBracket]\)\))\)\^2 + \
\((yc\_\(\(\[LeftDoubleBracket]\)\(i\)\(\[RightDoubleBracket]\)\) - yc\_\(\(\
\[LeftDoubleBracket]\)\(j\)\(\[RightDoubleBracket]\)\))\)\^2\)], 
                  zin + \(\[ImaginaryI]\ \[Omega]\ \[Mu]\)\/\(2.0\ \[Pi]\)\ \
Log[\(2  p + 2\ \
yc\_\(\(\[LeftDoubleBracket]\)\(i\)\(\[RightDoubleBracket]\)\)\)\/rf]]\ , \
\[IndentingNewLine]{i, 1, ncond}, {j, 1, ncond}], \[IndentingNewLine]P = 
              Table[If[i \[NotEqual] j, 
                  1.0/2*Log[\(\((xc\_\(\(\[LeftDoubleBracket]\)\(i\)\(\
\[RightDoubleBracket]\)\) - xc\_\(\(\[LeftDoubleBracket]\)\(j\)\(\
\[RightDoubleBracket]\)\))\)\^2 + \((yc\_\(\(\[LeftDoubleBracket]\)\(i\)\(\
\[RightDoubleBracket]\)\) + yc\_\(\(\[LeftDoubleBracket]\)\(j\)\(\
\[RightDoubleBracket]\)\))\)\^2\)\/\(\((xc\_\(\(\[LeftDoubleBracket]\)\(i\)\(\
\[RightDoubleBracket]\)\) - xc\_\(\(\[LeftDoubleBracket]\)\(j\)\(\
\[RightDoubleBracket]\)\))\)\^2 + \((yc\_\(\(\[LeftDoubleBracket]\)\(i\)\(\
\[RightDoubleBracket]\)\) - yc\_\(\(\[LeftDoubleBracket]\)\(j\)\(\
\[RightDoubleBracket]\)\))\)\^2\)], Log[2.0\ yc[\([i]\)]\/rf]], {i, 1, 
                  ncond}, {j, 1, 
                  ncond}], \[IndentingNewLine]Y = \[ImaginaryJ]\ \[Omega]\ \
\[Epsilon]\ 2\ \[Pi]\ Inverse[P], \[IndentingNewLine]{\[Lambda]conv, Tc} = 
              Eigensystem[Z . Y], \[IndentingNewLine]\[CapitalGamma]conv = 
              Sqrt[\[Lambda]conv], \[IndentingNewLine]\[Gamma]conv[\([nm]\)] \
= \[CapitalGamma]conv}, {nm, 1, nf}]]]\)], "Input",
  TextJustification->1,
  FontFamily->"Courier New"],

Cell[BoxData[
    \({0.343687`5.987708098705528\ Second, Null}\)], "Output"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Modelagem Com solo complexo para imped\[AHat]ncia e admit\[AHat]ncia", \
"Section"],

Cell["\<\
Incluindo todo o efeito na matriz de produto ao inv\[EAcute]s de \
coloca-la em Z e Y (eq. (41) do artigo da PWRD ) os resultados sao similares \
e colocar 
 Z=(IdentityMatrix[ncond]-F3g .Inverse[P/2 +F2g]). Ze e  Y=\[ImaginaryJ] \
\[Omega] \[Epsilon]  \[Pi] Inverse[P/2 +F2g-F3g]. Contudo, eu consigo \
reproduzir os resultados dos artigos se
 Y=\[ImaginaryJ] \[Omega] \[Epsilon]  \[Pi] Inverse[P/2 +F2g-F3g] \
Z=(IdentityMatrix[ncond]-F3g *Inverse[P/2 +F2g]). Ze, ou seja, sem a \
multiplica\[CCedilla]\[ATilde]o matricial entre a matriz inversa e \
F3g...\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
    \(AbsoluteTiming[
      Block[{Den, zin, Ze, F2g, F3g, Z, Y, P, \[Lambda], 
          T}, \[IndentingNewLine]Do[{\[Omega] = 
              2\ \[Pi]\ f[\([nm]\)], \[IndentingNewLine]\ 
            w = 1/\[Rho]solo + 
                10^\(-6\) \((0.057849 + \[ImaginaryJ]\ 0.12097)\) \
\[Omega]^0.71603, \[IndentingNewLine]\ 
            w = 5.0\ 10^\(-3\) + \[ImaginaryJ]\ \[Omega]\ 5.0\ \[Epsilon], \
\[IndentingNewLine]\[Eta] = \@\(\[ImaginaryJ]\ \ \[Omega]\ \[Mu]\ \
\((\[Sigma]g + \[ImaginaryJ]\ \[Omega]\ \[Epsilon]g)\)\), \
\[IndentingNewLine]k0 = \ \[Omega]\ \@\(\[Mu]\ \[Epsilon]\), \
\[IndentingNewLine]kg = 
              k0\ \@\(\[Epsilon]g\/\[Epsilon] + \(I\ \[Sigma]g\)\/\(\[Omega]\ \
\[Epsilon]\)\); \[IndentingNewLine]\[Eta]c = \@\(\(I\ \[Omega]\ \[Mu]\)\/\
\[Rho]c\), \[IndentingNewLine]\[Xi]1 = 
              2\/\@\(k0^2 - kg^2\), \[IndentingNewLine]\[Xi]2 = 
              k0^2\/\(k0^2 + kg^2\), \[IndentingNewLine]\[Xi]3 = \(k0^2 + \
kg^2\)\/\(k0^2 \@\( k0^2 - kg^2\)\), \[IndentingNewLine]Den = 
              BesselI[1, \[Eta]c\ rf], \[IndentingNewLine]zin = \(\(\[Rho]c\ \
\[Eta]c\)\/\(2  \[Pi]\ rf\)\) \(1\/Den\) \((BesselI[
                    0, \[Eta]c\ rf])\), \[IndentingNewLine]Zi = 
              DiagonalMatrix[
                Table[zin, {r, 1, 3}]]; \[IndentingNewLine]S2g = \[Xi]2*\ 
                Table[Log[
                    1 + \[Xi]3\/\@\(\((xc\_\(\(\[LeftDoubleBracket]\)\(i\)\(\
\[RightDoubleBracket]\)\) + rf - xc\_\(\(\[LeftDoubleBracket]\)\(j\)\(\
\[RightDoubleBracket]\)\))\)\^2 + \((yc\_\(\(\[LeftDoubleBracket]\)\(i\)\(\
\[RightDoubleBracket]\)\) + yc\_\(\(\[LeftDoubleBracket]\)\(j\)\(\
\[RightDoubleBracket]\)\))\)\^2\)], {i, 1, ncond}, {j, 1, 
                    ncond}], \[IndentingNewLine]S1g = 
              1.0/2\ Table[
                  Log[1 + \
\[Xi]1\/\@\(\((xc\_\(\(\[LeftDoubleBracket]\)\(i\)\(\[RightDoubleBracket]\)\) \
+ rf - xc\_\(\(\[LeftDoubleBracket]\)\(j\)\(\[RightDoubleBracket]\)\))\)\^2 + \
\((yc\_\(\(\[LeftDoubleBracket]\)\(i\)\(\[RightDoubleBracket]\)\) + yc\_\(\(\
\[LeftDoubleBracket]\)\(j\)\(\[RightDoubleBracket]\)\))\)\^2\)], {i, 1, 
                    ncond}, {j, 1, ncond}], \[IndentingNewLine]P = 
              Table[1.0/2*
                  Log[\(\((xc\_\(\(\[LeftDoubleBracket]\)\(i\)\(\
\[RightDoubleBracket]\)\) - xc\_\(\(\[LeftDoubleBracket]\)\(j\)\(\
\[RightDoubleBracket]\)\) + rf)\)\^2 + \((yc\_\(\(\[LeftDoubleBracket]\)\(i\)\
\(\[RightDoubleBracket]\)\) + yc\_\(\(\[LeftDoubleBracket]\)\(j\)\(\
\[RightDoubleBracket]\)\))\)\^2\)\/\(\((xc\_\(\(\[LeftDoubleBracket]\)\(i\)\(\
\[RightDoubleBracket]\)\) - xc\_\(\(\[LeftDoubleBracket]\)\(j\)\(\
\[RightDoubleBracket]\)\) + rf)\)\^2 + \((yc\_\(\(\[LeftDoubleBracket]\)\(i\)\
\(\[RightDoubleBracket]\)\) - yc\_\(\(\[LeftDoubleBracket]\)\(j\)\(\
\[RightDoubleBracket]\)\))\)\^2\)], {i, 1, ncond}, {j, 1, 
                  ncond}], \[IndentingNewLine]Prod = \(\(2.0\ \[Pi]\)\/\(I\ \
\[Omega]\ \[Mu]\)\) Zi + P + 
                2\ S1g - \(\[CapitalGamma]\^2\/k0\^2\) \((P + 
                      2\ S2g)\), \[IndentingNewLine]sol = 
              Solve[Det[Prod] \[Equal] 
                  0, \[CapitalGamma]], \
\[Alpha]\_\(\(\[LeftDoubleBracket]\)\(nm\)\(\[RightDoubleBracket]\)\) = 
              Sort[Re@Drop[I\ \[CapitalGamma] /. sol, 3], 
                Greater], \
\[IndentingNewLine]\[Beta]\_\(\(\[LeftDoubleBracket]\)\(nm\)\(\
\[RightDoubleBracket]\)\) = 
              Sort[Im@Drop[I\ \[CapitalGamma] /. sol, 3], 
                Greater], \[IndentingNewLine]\[Gamma][\([nm]\)] = \
\[Alpha][\([nm]\)] + \[ImaginaryJ]\ \[Beta][\([nm]\)]}, {nm, 1, 
            nf}]]]\)], "Input",
  TextJustification->1,
  FontFamily->"Courier New"],

Cell[BoxData[
    \({0.615725`6.240931780905264\ Second, Null}\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(\(\(\ \)\(DisplayTogether[
        LogLinearListPlot[
          Transpose[{f, 
              10^\(-6\)\ \ 2\ \[Pi]\ f/Im[\[Gamma]conv[\([All, 3]\)]]}], 
          PlotJoined \[Rule] True, PlotRange \[Rule] All, 
          PlotStyle \[Rule] plstyle1], \[IndentingNewLine]LogLinearListPlot[
          Transpose[{f, 
              10^\(-6\)\ \ 2\ \[Pi]\ f/Im[\[Gamma]conv[\([All, 2]\)]]}], 
          PlotJoined \[Rule] True, PlotRange \[Rule] All, 
          PlotStyle \[Rule] plstyle1], \[IndentingNewLine]LogLinearListPlot[
