    \(\(o1 = 
        LogLinearListPlot[Transpose[{f, Abs[Am1[\([Range[nf], 1]\)]]}], 
          PlotJoined \[Rule] True, PlotRange \[Rule] All, 
          PlotStyle \[Rule] plstyle1, \ 
          DisplayFunction \[Rule] Identity];\)\), "\[IndentingNewLine]", 
    \(\(o2 = 
        LogLinearListPlot[Transpose[{f, Abs[Am1[\([Range[nf], 2]\)]]}], 
          PlotJoined \[Rule] True, PlotRange \[Rule] All, 
          PlotStyle \[Rule] plstyle2, \ 
          DisplayFunction \[Rule] Identity];\)\), "\[IndentingNewLine]", 
    \(\(o3 = 
        LogLinearListPlot[Transpose[{f, Abs[Am1[\([Range[nf], 3]\)]]}], 
          PlotJoined \[Rule] True, PlotRange \[Rule] All, 
          PlotStyle \[Rule] plstyle3, \ 
          DisplayFunction \[Rule] Identity];\)\), "\[IndentingNewLine]", 
    \(\(o4 = 
        LogLinearListPlot[Transpose[{f, Abs[Am1[\([Range[nf], 4]\)]]}], 
          PlotJoined \[Rule] True, PlotRange \[Rule] All, 
          PlotStyle \[Rule] plstyle4, \ 
          DisplayFunction \[Rule] Identity];\)\), "\[IndentingNewLine]", 
    \(\(Show[{o1, o2, o3, o4}, 
        DisplayFunction \[Rule] $DisplayFunction];\)\)}], "Input"],

