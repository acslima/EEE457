  FontWeight->"Bold"],

Cell[BoxData[{
    \(\(x1 = 
        rp1 \@\(\( s\ \[Mu]\ \[Mu]p\)\/\[Rho]p\);\)\), "\[IndentingNewLine]", \

    \(\(Cn = \((\(rc\ rc\)\/rp1\^2)\)\^n\ Cos[
            n\ \[Theta]jk];\)\), "\[IndentingNewLine]", 
    \(\(Qjj = 
        Log[\((rp1\/r2)\)\ \((1 - \((rc\/rp1)\)\^2)\)];\)\), "\
\[IndentingNewLine]", 
    \(Qjk = 
      Log[rp1\/\@\(rc\^2 + rc\^2 - \(\(2\)\(\ \)\(rc\)\(\ \)\(rc\)\(\ \
\)\(Cos[\[Theta]jk]\)\(\ \)\)\)] - \[Sum]\+\(n = 1\)\%40 Cn\/n;  (*convergido\
\ em\ n = 10*) ;\)}], "Input"],

Cell["IMPED\[CapitalAHat]NCIAS COMPONENTES;", "Text",
  FontSize->10,
  FontWeight->"Bold"],

Cell[BoxData[{
    \(\(Zpjj = \(\(s\)\(\ \)\(\[Mu]\)\(\ \)\)\/\(2\ \[Pi]\)\ \((\(\[Mu]p\ \
BesselK[0, x1]\)\/\(x1\ BesselK[1, x1]\) + Qjj + 
              2\ \[Mu]p\ \(\[Sum]\+\(n = 1\)\%40\((rc\/rp1)\)\^\(2\ n\)\/\(n\ \
\((1 + \[Mu]p)\) + x1\ BesselK[n - 1, x1]\/BesselK[n, x1]\)\))\);\)\), "\
\[IndentingNewLine]", 
    \(\(Zpjk = \(\(s\)\(\ \)\(\[Mu]\)\(\ \)\)\/\(2\ \[Pi]\)\ \((\(\[Mu]p\ \
BesselK[0, x1]\)\/\(x1\ BesselK[1, x1]\) + Qjk + 
              2\ \[Mu]p\ \(\[Sum]\+\(n = 1\)\%40 Cn\/\(n\ \((1 + \[Mu]p)\) + \
x1\ BesselK[n - 1, x1]\/BesselK[n, x1]\)\))\);\)\)}], "Input"]
}, Open  ]],

