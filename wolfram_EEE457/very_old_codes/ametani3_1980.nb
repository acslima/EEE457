Cell[CellGroupData[{

Cell[BoxData[{
    \(\(om1 = 
        LogLogListPlot[
          Transpose[{f, \ 
              2\ \[Pi]\ f\ 10\^\(-6\)/
                  Im[\[CapitalGamma]1[\([Range[nf], 1]\)]]}], 
          PlotJoined \[Rule] True, PlotRange \[Rule] All, 
          PlotStyle \[Rule] plstyle1, \ 
          DisplayFunction \[Rule] Identity];\)\), "\n", 
    \(\(om2 = 
        LogLogListPlot[
          Transpose[{f, 
              2\ \[Pi]\ f\ 10\^\(-6\)/
                  Im[\[CapitalGamma]1[\([Range[nf], 2]\)]]}], 
          PlotJoined \[Rule] True, PlotRange \[Rule] All, 
          PlotStyle \[Rule] plstyle2, \ 
          DisplayFunction \[Rule] Identity];\)\), "\n", 
    \(\(om3 = 
        LogLogListPlot[
          Transpose[{f, 
              2\ \[Pi]\ f\ 10\^\(-6\)/
                  Im[\[CapitalGamma]1[\([Range[nf], 3]\)]]}], 
          PlotJoined \[Rule] True, PlotRange \[Rule] All, 
          PlotStyle \[Rule] plstyle3, \ 
          DisplayFunction \[Rule] Identity];\)\), "\n", 
    \(\(om4 = 
        LogLogListPlot[
          Transpose[{f, 
              2\ \[Pi]\ f\ 10\^\(-6\)/
                  Im[\[CapitalGamma]1[\([Range[nf], 4]\)]]}], 
          PlotJoined \[Rule] True, PlotRange \[Rule] All, 
          PlotStyle \[Rule] plstyle4, \ 
          DisplayFunction \[Rule] Identity];\)\), "\n", 
    \(\(Show[{om1, om2, om3, om4}, DisplayFunction \[Rule] $DisplayFunction, 
        PlotRange \[Rule] All];\)\)}], "Input"],

