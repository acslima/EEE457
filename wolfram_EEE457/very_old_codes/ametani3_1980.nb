Cell[CellGroupData[{

Cell["\<\
MATRIX DE IMPED\[CapitalAHat]NCIA M\[CapitalUAcute]TUA ENTRE AS \
SUPERF\[CapitalIAcute]CIES INTERNA E EXTERNA DO PT (Zc) \
\>", "Subsection",
  FontSize->14],

Cell[CellGroupData[{

Cell["IMPED\[CapitalAHat]NCIAS Z1, Z2 E Z3", "Subsubsection",
  FontColor->RGBColor[0, 0, 1]],

Cell["FUN\[CapitalCCedilla]\[CapitalOTilde]ES AUXILIARES;", "Text",
  FontSize->10,
  FontWeight->"Bold"],

Cell[BoxData[{
    \(\(x2 = 
        rp2\ \@\(\(s\ \[Mu]\ \[Mu]p\)\/\[Rho]p\);\)\), "\[IndentingNewLine]", \

    \(\(Dp1 = 
        BesselI[1, x2] BesselK[1, x1] - 
          BesselI[1, x1] BesselK[1, x2];\)\), "\[IndentingNewLine]", 
    \(\(Dp2 = 
        BesselI[0, x1] BesselK[1, x2] + 
          BesselK[0, x1] BesselI[1, x2];\)\), "\[IndentingNewLine]", 
    \(\(Dp3 = 
        BesselI[0, x2] BesselK[1, x1] + 
          BesselK[0, x2] BesselI[1, x1];\)\)}], "Input"],

Cell["IMPED\[CapitalAHat]NCIAS COMPONENTES;", "Text",
  FontSize->10,
  FontWeight->"Bold"],

Cell[BoxData[{
    \(\(zpm = \[Rho]p\/\(\(2\)\(\ \)\(\[Pi]\)\(\ \)\(rp1\)\(\ \)\(rp2\)\(\ \)\
\(Dp1\)\(\ \)\);\)\), "\[IndentingNewLine]", 
    \(\(zpi = \((\(\(s\)\(\ \)\(\[Mu]\)\(\ \)\(\[Mu]p\)\(\ \ \)\)\/\(\(2\)\(\ \
\)\(\[Pi]\)\(\ \)\(x1\)\(\ \)\))\)\ Dp2\/Dp1;\)\), "\[IndentingNewLine]", 
    \(\(zpe = \((\(\(s\)\(\ \)\(\[Mu]\)\(\ \)\(\[Mu]p\)\(\ \ \)\)\/\(\(2\)\(\ \
\)\(\[Pi]\)\(\ \)\(x2\)\(\ \)\))\)\ Dp3\/Dp1;\)\), "\[IndentingNewLine]", 
    \(\(zis = \(\(s\)\(\ \)\(\[Mu]\)\(\ \)\)\/\(2\ \[Pi]\)\ Log[
            rp3\/rp2];\)\)}], "Input"],

Cell[BoxData[{
    \(\(zc1 = zpi + zpe - 2\ zpm + zis;\)\), "\[IndentingNewLine]", 
    \(\(zc2 = zpe - zpm + zis;\)\), "\[IndentingNewLine]", 
    \(\(zc3 = zpe + zis;\)\)}], "Input"]
}, Open  ]],

