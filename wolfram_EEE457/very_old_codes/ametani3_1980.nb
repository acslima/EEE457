Cell[BoxData[{
    \(\(omm1 = 
        LogLogListPlot[
          Transpose[{f, Re[\[CapitalGamma]1[\([Range[nf], 1]\)]]}], 
          PlotJoined \[Rule] True, PlotRange \[Rule] All, 
          PlotStyle \[Rule] plstyle1, \ 
          DisplayFunction \[Rule] Identity];\)\), "\[IndentingNewLine]", 
    \(\(omm2 = 
        LogLogListPlot[
          Transpose[{f, Re[\[CapitalGamma]1[\([Range[nf], 2]\)]]}], 
          PlotJoined \[Rule] True, PlotRange \[Rule] All, 
          PlotStyle \[Rule] plstyle2, \ 
          DisplayFunction \[Rule] Identity];\)\), "\[IndentingNewLine]", 
    \(\(omm3 = 
        LogLogListPlot[
          Transpose[{f, Re[\[CapitalGamma]1[\([Range[nf], 3]\)]]}], 
          PlotJoined \[Rule] True, PlotRange \[Rule] All, 
          PlotStyle \[Rule] plstyle3, \ 
          DisplayFunction \[Rule] Identity];\)\), "\[IndentingNewLine]", 
    \(\(omm4 = 
        LogLogListPlot[
          Transpose[{f, Re[\[CapitalGamma]1[\([Range[nf], 4]\)]]}], 
          PlotJoined \[Rule] True, PlotRange \[Rule] All, 
          PlotStyle \[Rule] plstyle4, \ 
          DisplayFunction \[Rule] Identity];\)\), "\[IndentingNewLine]", 
    \(\(Show[{omm1, omm2, omm3, omm4}, 
        DisplayFunction \[Rule] $DisplayFunction, 
        PlotRange \[Rule] Automatic];\)\)}], "Input"],

