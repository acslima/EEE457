Notebook[{
Cell["FindMinumum and FindRoot for 1D functions.", "Title"],

Cell["\<\
 Code Generation for FindMinimum[ ] and FindRoot[ ] 
of a 1D function using MathCode\
\>", "Subtitle"],

Cell["Copyright \[Copyright] MathCore AB 1998-2006", "Copyright"],

Cell[TextData[{
  "The function ",
  StyleBox["FindMinimum[] ",
    FontWeight->"Bold"],
  " finds a local minumum of given function and given starting value. \
Function cannot be translated by MathCode directly because\n--- its argument \
is a symbolic expression \n --- numerical algorithms for minimization are not \
included in MathCode runtime library\n The solution is to write a ",
  StyleBox["Mathematica",
    FontSlant->"Italic"],
  " function which replicates ",
  StyleBox["FindMinimum[ ]",
    FontWeight->"Bold"],
  " operation using compilable subset.\n This notebook illustrates how to do \
that for finction with one argument. \n ",
  StyleBox["FindRoot[ ]",
    FontWeight->"Bold"],
  " can be implemented using ",
  StyleBox["FindMinumum[ ] ",
    FontWeight->"Bold"],
  "as well."
}], "Text"],

Cell["\<\

This is how FindMinumum works in Mathematica\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
    \(FindMinimum[Cos[x], {x, 1}]\)], "Input"],

Cell[BoxData[
    \({\(-1.`\), {x \[Rule] 3.1415926555856286`}}\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(Needs["\<MathCode`\>"]\)], "Input"],

Cell[BoxData[
    InterpretationBox[\("MathCode C++ 1.4.0"\[InvisibleSpace]" for "\
\[InvisibleSpace]"mingw32"\[InvisibleSpace]" loaded from \
"\[InvisibleSpace]"c:\\cvsroot\\omath\\MathCode"\),
      SequenceForm[ 
      "MathCode C++ 1.4.0", " for ", "mingw32", " loaded from ", 
        "c:\\cvsroot\\omath\\MathCode"],
      Editable->False]], "Print"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(SetDirectory[
      ToFileName[{$MCRoot, "\<Demos\>", "\<FindMinimum\>"}]]\)], "Input"],

Cell[BoxData[
    \("c:\\cvsroot\\omath\\MathCode\\Demos\\FindMinimum"\)], "Output"]
}, Open  ]],

Cell[TextData[{
  "\nThis function ",
  StyleBox["LookupMin[ ]",
    FontWeight->"Bold"],
  " replicates ",
  StyleBox["Mathematica",
    FontSlant->"Italic"],
  " ",
  StyleBox["FindMinimum[ ]",
    FontWeight->"Bold"],
  ". The arguments are: \n",
  StyleBox["iters",
    FontWeight->"Bold"],
  " - maximal number of iterations\n",
  StyleBox["k",
    FontWeight->"Bold"],
  " - trial step multiplier\n",
  StyleBox["alphastart",
    FontWeight->"Bold"],
  " - a small number needed for computation of approximation of derivatives\n\
",
  StyleBox["startp",
    FontWeight->"Bold"],
  " - start value for search\n",
  StyleBox["accuracy",
    FontWeight->"Bold"],
  " - algorithm stoops when steps are less than accuracy\n",
  StyleBox["debug",
    FontWeight->"Bold"],
  " - whether additional debugging is needed.\nThe minimized function name is \
not passed to ",
  StyleBox["LookupMin[ ]",
    FontWeight->"Bold"],
  ". The name is always ",
  StyleBox["Func[ ]. ",
    FontWeight->"Bold"],
  "Later we will see how to adjust this name \"on the flight\"."
}], "Text"],

Cell[BoxData[
    \(\(\(\[IndentingNewLine]\)\(LookupMin[Integer\ iters_, Real\ k_, 
          Real\ alphastart_, Real\ startp_, Real\ accuracy_, 
          Integer\ debug_] \[Rule] {Real, 
          Real} := \[IndentingNewLine]Module[{Real\ p = startp, 
          Integer\ i = 0, 
          Real\ currentAccuracy = 99999. , \[IndentingNewLine]Real\ alpha = 
            alphastart, \[IndentingNewLine]Real\ df}, \
\[IndentingNewLine]While[\((i < iters)\) && \((currentAccuracy > 
                accuracy)\), \[IndentingNewLine]df = \((Func[p + alpha] - 
                  Func[p])\)/alpha; \[IndentingNewLine]p = 
            p - k*df; \[IndentingNewLine]alpha = 
            Abs[k*df]/2; \[IndentingNewLine]i = 
            i + 1; \[IndentingNewLine]currentAccuracy = 
            Abs[k*df]; \[IndentingNewLine]If[debug > 0, 
            Print[{Func[p], p, 
                currentAccuracy}]];\[IndentingNewLine]]; \
\[IndentingNewLine]{p, 
          Func[p]}\[IndentingNewLine]\[IndentingNewLine]]\)\)\)], "Input"],

Cell["Functions to minimize", "Text"],

Cell[BoxData[
    \(\(Func1[Real\ u_] \[Rule] Real := Cos[u] + 4;\)\)], "Input"],

Cell[BoxData[
    \(\(Func2[Real\ u_] \[Rule] Real := u\ Sin[u + 1];\)\)], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
    \(Plot[Func2[u], {u, \(-2\), 2}]\)], "Input"],

