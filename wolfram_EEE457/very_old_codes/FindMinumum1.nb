Cell["\<\

Try to minimize in Mathematica\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
    \(mm = FindMinimum[Func2[v], {v, \(-1\)}]\)], "Input"],

Cell[BoxData[
    \({\(-0.24012524415530795`\), {v \[Rule] \(-0.520268992107989`\)}}\)], \
"Output"]
}, Open  ]],

Cell[TextData[{
  "Try to minimize using our ",
  StyleBox["LookupMin",
    FontWeight->"Bold"],
  " function"
}], "Text"],

Cell[BoxData[
    \(\(Func[u_] := Func2[u];\)\)], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
    \(lm = LookupMin[500, 0.1, 0.01, \(-1. \), 0.0000001, 0]\)], "Input"],

Cell[BoxData[
    \({\(-0.5202694059459493`\), \(-0.24012524415513598`\)}\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(\(\(Print[{mm\[LeftDoubleBracket]1\[RightDoubleBracket] - 
          lm\[LeftDoubleBracket]2\[RightDoubleBracket], \((v /. \ 
              mm\[LeftDoubleBracket]2\[RightDoubleBracket])\)\  - 
          lm\[LeftDoubleBracket]1\[RightDoubleBracket]}]\)\(\
\[IndentingNewLine]\)
    \)\)], "Input"],

Cell[BoxData[
    \({\(-1.7197354651443675`*^-13\), 4.1383796023364283`*^-7}\)], "Print"]
}, Open  ]],

Cell[TextData[{
  "\nCompile ",
  StyleBox["LookupMin",
    FontWeight->"Bold"],
  " to C++. Note that we use Func2 instead of Func replacing it on the \
flight."
}], "Text"],

Cell[CellGroupData[{

Cell[BoxData[
    \(BuildCode[MacroRules \[Rule] {Func \[Rule] Func2}]\)], "Input"],

Cell[BoxData[
    \("Successful compilation to C++: 3 function(s)"\)], "Print"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(\(\(InstallCode[]\)\(\[IndentingNewLine]\)
    \)\)], "Input"],

Cell[BoxData[
    InterpretationBox[\("Global"\[InvisibleSpace]" is installed."\),
      SequenceForm[ "Global", " is installed."],
      Editable->False]], "Print"],

Cell[BoxData[
    \(LinkObject[".\\Globalml.exe", 9, 2]\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(cm = LookupMin[500, 0.1, 0.01, \(-1. \), 0.0000001, 0]\)], "Input"],

Cell[BoxData[
    \({\(-0.5202694059035576`\), \(-0.240125244155136`\)}\)], "Output"]
}, Open  ]],

Cell["How accurate are C++ computations ?", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
    \(Print[{mm\[LeftDoubleBracket]1\[RightDoubleBracket] - 
          cm\[LeftDoubleBracket]2\[RightDoubleBracket], \((v /. \ 
              mm\[LeftDoubleBracket]2\[RightDoubleBracket])\)\  - 
          cm\[LeftDoubleBracket]1\[RightDoubleBracket]}]\)], "Input"],

Cell[BoxData[
    \({\(-1.7194579093882112`*^-13\), 4.1379556858789357`*^-7}\)], "Print"]
}, Open  ]],

Cell[BoxData[
    \(\(UninstallCode[];\)\)], "Input"],

Cell["\<\

Using FindRoot[ ]\
\>", "Subtitle"],

Cell[TextData[{
  "\nFinding the root in ",
  StyleBox["Mathematica",
    FontSlant->"Italic"],
  ". This function is normally used for solving non-linear equations."
}], "Text"],

Cell[CellGroupData[{

Cell[BoxData[
    \(mathroot = x /. FindRoot[Sin[x] \[Equal] Log[x], {x, 0.5}]\)], "Input"],

Cell[BoxData[
    \(2.219107148913746`\)], "Output"]
}, Open  ]],

Cell["\<\

The problem is reduced to finding minumum of the residual function.\
\>", \
"Text"],

Cell[CellGroupData[{

Cell[BoxData[
    \(FindMinimum[\((Sin[x] - Log[x])\)^2, {x, 0.5}]\)], "Input"],

Cell[BoxData[
    \({2.294993478814369`*^-19, {x \[Rule] 2.2191071493680594`}}\)], "Output"]
}, Open  ]],

Cell["\<\

Prepare the resifual function for MathCode compilation\
\>", "Text"],

Cell[BoxData[
    \(\(Func3[Real\ u_] \[Rule] Real := \((Sin[u] - Log[u])\)^2;\)\)], "Input"],

Cell["\<\

Compute the result\
\>", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
    \(\(BuildCode[MacroRules \[Rule] {Func \[Rule] Func3}];\)\)], "Input"],

Cell[BoxData[
    \("Successful compilation to C++: 4 function(s)"\)], "Print"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(\(InstallCode[];\)\)], "Input"],

Cell[BoxData[
    InterpretationBox[\("Global"\[InvisibleSpace]" is installed."\),
      SequenceForm[ "Global", " is installed."],
      Editable->False]], "Print"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(croot = \(LookupMin[500, 0.1, 0.01, 0.5, 0.0000001, 
          0]\)[\([1]\)]\)], "Input"],

Cell[BoxData[
    \(2.219106784059143`\)], "Output"]
}, Open  ]],

Cell["Check accuracy", "Text"],

Cell[CellGroupData[{

Cell[BoxData[
    \(croot - mathroot\)], "Input"],

Cell[BoxData[
    \(\(-3.648546029744182`*^-7\)\)], "Output"]
}, Open  ]],

Cell[BoxData[
    \(\(UninstallCode[];\)\)], "Input"],

Cell["CleanMathCodeFiles[Confirm -> False, CleanAllBut -> {}];", "Input"]
},
