Cell[BoxData[
 RowBox[{
  RowBox[{"statisticalVisualization", "[", 
   RowBox[{
   "events_", ",", "totals_", ",", "opb_", ",", "creditMarketHistory_", ",", 
    "br_"}], "]"}], ":=", 
  RowBox[{"With", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"so", "=", 
      RowBox[{"statOuter", "[", 
       RowBox[{"{", 
        RowBox[{"events", ",", "totals", ",", 
         FractionBox["totals", 
          RowBox[{"Mean", "[", "events", "]"}]], ",", "opb", ",", "br", ",", 
         RowBox[{"br", "-", "creditMarketHistory"}]}], "}"}], "]"}]}], "}"}], 
    ",", 
    RowBox[{"Text", "@", 
     RowBox[{"Grid", "[", 
      RowBox[{
       RowBox[{"Join", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"{", 
           RowBox[{
           "SpanFromBoth", ",", "\"\<mean\>\"", ",", 
            "\"\<standard\\ndeviation\>\"", ",", "\"\<minimum\>\"", ",", 
            "\"\<maximum\>\""}], "}"}], "}"}], ",", 
         RowBox[{"MapThread", "[", 
          RowBox[{"Prepend", ",", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"Map", "[", 
              RowBox[{
               RowBox[{
                RowBox[{"NumberForm", "[", 
                 RowBox[{
                  RowBox[{"Chop", "[", 
                   RowBox[{"#", ",", "0.000001"}], "]"}], ",", "3"}], "]"}], 
                "&"}], ",", "so", ",", 
               RowBox[{"{", "2", "}"}]}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"Tooltip", "[", 
                RowBox[{
                "\"\<loss\>\"", ",", 
                 "\"\<the total losses suffered by the members of the pool \
each year; determined by the parameters of the loss distribution you select\>\
\""}], "]"}], ",", 
               RowBox[{"Tooltip", "[", 
                RowBox[{
                "\"\<debt service\>\"", ",", 
                 "\"\<the annual payments made each year to amortize all the \
post-event bonds issued thus far\>\""}], "]"}], ",", 
               RowBox[{"Tooltip", "[", 
                RowBox[{
                "\"\<\!\(\*FractionBox[\(debt\\\ service\), \(mean\\\ loss\)]\
\)\>\"", ",", 
                 "\"\<the ratio between the annual debt service and the mean \
losses\>\""}], "]"}], ",", 
               RowBox[{"Tooltip", "[", 
                RowBox[{
                "\"\<debt load\>\"", ",", 
                 "\"\<the aggregate outstanding principal balance on all \
post-event bonds issued thus far\>\""}], "]"}], ",", 
               RowBox[{"Tooltip", "[", 
                RowBox[{
                "\"\<borrowing rate\>\"", ",", 
                 "\"\<the interest rate on post-event bonds; this figure will \
depend in part on generally prevailing interest rates in the credit markets \
at the time each bond is issued and in part on the sensitivity of the credit \
markets to the amount of the borrower's outstanding principal balance at the \
time the bond is issued\>\""}], "]"}], ",", 
               RowBox[{"Tooltip", "[", 
