             RowBox[{"Length", "[", "A", "]"}]}]}], "]"}]}], ")"}]}], "]"}]}],
      ";", "\[IndentingNewLine]", 
     RowBox[{"Mrecomp", "=", 
      RowBox[{"Table", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", "ncond2", "}"}], ",", 
        RowBox[{"{", "ncond2", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"k", "=", "1"}], ",", 
