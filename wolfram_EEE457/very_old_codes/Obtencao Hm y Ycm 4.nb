Cell[BoxData[
 RowBox[{
  RowBox[{"res", "[", 
   RowBox[{"polos_List", ",", "freq_List", ",", "data_List", ",", 
    RowBox[{"termoD_:", "1."}], ",", 
    RowBox[{"termoE_:", "1."}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "npol", ",", "nfreq", ",", "ss", ",", "indices", ",", "AAnum", ",", 
      "UUmS", ",", "AAf", ",", "AAff", ",", "AAffT", ",", "normas", ",", 
      "BBff", ",", "XXff", ",", "resfim", ",", "dd", ",", "ee", ",", "naux", 
      ",", "AAAaux", ",", "AAAscale", ",", "Xaux", ",", "scale"}], "}"}], ",",
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
    RowBox[{
