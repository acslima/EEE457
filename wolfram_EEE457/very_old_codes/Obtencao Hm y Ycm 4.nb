             RowBox[{"2", "*", "nfreq"}]}], "]"}]}], ",", "nfreq"}], "}"}], 
        "]"}], "*", "Ws"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"AAA", "=", 
      RowBox[{"Take", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"QRDecomposition", "[", "AA", "]"}], "[", 
