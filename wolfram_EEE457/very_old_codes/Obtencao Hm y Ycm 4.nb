        RowBox[{"Re", "[", "Af", "]"}], ",", 
        RowBox[{"Im", "[", "Af", "]"}], ",", 
        RowBox[{"{", "RVF", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"BB", "=", 
