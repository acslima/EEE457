Cell[CellGroupData[{

Cell["Elimina o Cruzamento de Autovetores (Newton-Raphson)", "Subsection",
 CellChangeTimes->{{3.492374730136524*^9, 3.492374736886057*^9}, {
  3.492378538443406*^9, 3.49237855198556*^9}, {3.494275450453125*^9, 
  3.49427546234375*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"eigNR", "[", 
    RowBox[{
     RowBox[{"G_", "?", "MatrixQ"}], ",", "V0_", ",", "d0_", ",", 
     RowBox[{"Tol_:", 
      RowBox[{"10", "^", 
       RowBox[{"-", "10"}]}]}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"A", "=", "G"}], ",", "nc", ",", "scale", ",", "v", ",", "d", 
       ",", "vec", ",", "res", ",", "jac", ",", "i"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"nc", "=", 
       RowBox[{"Length", "[", "A", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"scale", "=", 
       RowBox[{"Norm", "[", "A", "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"A", "=", 
       RowBox[{"A", "/", "scale"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"outd", "=", 
       RowBox[{"Table", "[", 
        RowBox[{"0", ",", 
         RowBox[{"{", "nc", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"outv", "=", 
       RowBox[{"Table", "[", 
        RowBox[{"0", ",", 
         RowBox[{"{", "nc", "}"}], ",", 
         RowBox[{"{", "nc", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"itr", "=", "0"}], ";", "\[IndentingNewLine]", 
      RowBox[{"jac", "=", 
       RowBox[{"Table", "[", 
        RowBox[{"0.0", ",", 
         RowBox[{"{", 
          RowBox[{"nc", "+", "1"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"nc", "+", "1"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Do", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"v", "=", 
           RowBox[{"V0", "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{"1", ";;"}], ",", "i"}], "]"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"d", "=", 
           RowBox[{"d0", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"res", "=", 
           RowBox[{"Max", "[", 
            RowBox[{"Abs", "[", 
             RowBox[{
              RowBox[{"A", ".", "v"}], "-", 
              RowBox[{"v", "*", "d"}]}], "]"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"While", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"res", ">", "Tol"}], ")"}], "&&", " ", 
             RowBox[{"(", 
              RowBox[{"itr", "<", "10000"}], ")"}]}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"itr", "=", 
              RowBox[{"itr", "+", "1"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"jac", "[", 
               RowBox[{"[", 
                RowBox[{
                 RowBox[{"1", ";;", "nc"}], ",", 
                 RowBox[{"1", ";;", "nc"}]}], "]"}], "]"}], "=", 
              RowBox[{"A", "-", 
               RowBox[{"d", "*", 
                RowBox[{"IdentityMatrix", "[", "nc", "]"}]}]}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"jac", "[", 
               RowBox[{"[", 
                RowBox[{
                 RowBox[{"1", ";;", "nc"}], ",", 
                 RowBox[{"nc", "+", "1"}]}], "]"}], "]"}], "=", 
              RowBox[{"-", "v"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"jac", "[", 
               RowBox[{"[", 
                RowBox[{
                 RowBox[{"nc", "+", "1"}], ",", 
                 RowBox[{"1", ";;", "nc"}]}], "]"}], "]"}], "=", 
              RowBox[{"2", "*", "v"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"res", "=", 
              RowBox[{"Join", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"A", ".", "v"}], "-", 
                 RowBox[{"v", "*", "d"}]}], ",", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"v", ".", "v"}], "-", "1"}], "}"}]}], "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"vec", "=", 
              RowBox[{"LinearSolve", "[", 
               RowBox[{"jac", ",", "res"}], "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"res", "=", 
              RowBox[{"Max", "[", 
               RowBox[{"Abs", "[", "vec", "]"}], "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"v", "=", 
              RowBox[{"v", "-", 
               RowBox[{"vec", "[", 
                RowBox[{"[", 
                 RowBox[{"1", ";;", "nc"}], "]"}], "]"}]}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"d", "=", 
              RowBox[{"d", "-", 
               RowBox[{"vec", "[", 
                RowBox[{"[", 
                 RowBox[{"nc", "+", "1"}], "]"}], "]"}]}]}], ";"}]}], 
           "\[IndentingNewLine]", "]"}], ";", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"outd", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "=", 
           RowBox[{"d", "*", "scale"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"outv", "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{"1", ";;"}], ",", "i"}], "]"}], "]"}], "=", 
           RowBox[{"Normalize", "[", "v", "]"}]}], ";"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "nc"}], "}"}]}], "]"}]}]}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.4944099286875*^9, 3.494409931296875*^9}}]
}, Open  ]],

