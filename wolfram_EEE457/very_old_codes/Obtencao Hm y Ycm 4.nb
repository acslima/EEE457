     "\[IndentingNewLine]", 
     RowBox[{"BBB", "=", 
      RowBox[{
       RowBox[{"Take", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"QRDecomposition", "[", "AA", "]"}], "[", 
          RowBox[{"[", "1", "]"}], "]"}], ",", 
         RowBox[{
          RowBox[{"-", "npol"}], "-", "1"}]}], "]"}], ".", "BB"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"AAAT", "=", 
