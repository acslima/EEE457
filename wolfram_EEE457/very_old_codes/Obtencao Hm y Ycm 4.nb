Cell[CellGroupData[{

Cell["C\[AAcute]lculos dos P\[OAcute]los com o RVF", "Title",
 CellFrame->{{0, 0}, {0, 0.5}},
 CellChangeTimes->{{3.4518327764609375`*^9, 3.4518327876845703`*^9}, {
   3.451841757*^9, 3.451841766015625*^9}, 3.485652045515625*^9}],

Cell[BoxData[
 RowBox[{
  RowBox[{"RVFpolos", "[", 
   RowBox[{"polos_List", ",", "freq_List", ",", "data_", ",", 
    RowBox[{"termoD_:", "1"}], ",", 
    RowBox[{"termoE_:", "1"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
     "npol", ",", "nfreq", ",", "ss", ",", "indices", ",", "Anum", ",", "UmS",
       ",", "Anum2", ",", "Af", ",", "AA", ",", "BB", ",", "XX", ",", 
      "Csigma", ",", "Azeros", ",", "Bzeros", ",", "Czeros", ",", "Dzeros", 
      ",", "polaux", ",", "polosN", ",", "weight", ",", "Ws", ",", "RVF", ",",
       "i", ",", "j", ",", "q", ",", "r", ",", "AAA", ",", "BBB", ",", "AAAT",
       ",", "normas", ",", "Xaux", ",", "AAAaux", ",", "AAAscale", ",", 
      "scale"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"npol", "=", 
      RowBox[{"Length", "[", "polos", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"nfreq", "=", 
      RowBox[{"Length", "[", "freq", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"ss", "=", 
      RowBox[{"\[ImaginaryI]", "*", 
       RowBox[{"N", "[", "freq", "]"}]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"indices", "=", 
      RowBox[{"idx", "[", "polos", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Anum", "=", 
      RowBox[{"Transpose", "[", 
       RowBox[{"Aux", "[", 
        RowBox[{
         RowBox[{"ss", "[", 
          RowBox[{"[", 
           RowBox[{"Range", "[", "nfreq", "]"}], "]"}], "]"}], ",", "polos", 
         ",", "indices"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"UmS", "=", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"termoD", "\[Equal]", "1"}], "\[And]", 
         RowBox[{"termoE", "\[Equal]", "1"}]}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"1", ",", 
            RowBox[{"ss", "[", 
             RowBox[{"[", "#", "]"}], "]"}]}], "}"}], "&"}], "/@", 
         RowBox[{"Range", "[", "nfreq", "]"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"termoD", "\[Equal]", "1"}], "\[And]", 
           RowBox[{"termoE", "\[Equal]", "0"}]}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"{", "1", "}"}], "&"}], "/@", 
           RowBox[{"Range", "[", "nfreq", "]"}]}], ",", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"termoD", "\[Equal]", "0"}], "\[And]", 
             RowBox[{"termoE", "\[Equal]", "1"}]}], ",", 
            RowBox[{
             RowBox[{
              RowBox[{"{", 
               RowBox[{"ss", "[", 
                RowBox[{"[", "#", "]"}], "]"}], "}"}], "&"}], "/@", 
             RowBox[{"Range", "[", "nfreq", "]"}]}], ",", 
            RowBox[{
             RowBox[{
              RowBox[{"{", "}"}], "&"}], "/@", 
             RowBox[{"Range", "[", "nfreq", "]"}]}]}], "]"}]}], "]"}]}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Anum2", "=", 
      RowBox[{
       RowBox[{"-", "data"}], "*", "Anum"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"weight", "=", 
      RowBox[{"Table", "[", 
       RowBox[{"1", ",", 
        RowBox[{"{", "nfreq", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Ws", "=", 
      RowBox[{
       RowBox[{"Norm", "[", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"weight", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "*", 
           RowBox[{"data", "[", 
            RowBox[{"[", "i", "]"}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"i", ",", "1", ",", "nfreq"}], "}"}]}], "]"}], "]"}], "/", 
       "nfreq"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"RVF", "=", 
      RowBox[{
       RowBox[{"Flatten", "[", 
        RowBox[{"{", 
