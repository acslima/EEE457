 CellFrame->{{0, 0}, {0, 0.5}},
 CellChangeTimes->{{3.498355699609375*^9, 3.498355700078125*^9}, {
  3.49835615575*^9, 3.498356172328125*^9}, {3.498360505796875*^9, 
  3.49836052015625*^9}}],

Cell[CellGroupData[{

Cell["\<\
Multiplicacao da Funcao de Propagacao pelo Exp[I \[Omega] \[Tau]] (\[Tau] = \
Vetor Time Delay)\
\>", "Section",
 CellFrame->{{0, 0}, {0, 0.5}},
 CellChangeTimes->{{3.451895209826172*^9, 3.45189521559375*^9}, 
   3.48565225015625*^9, 3.485652566734375*^9, {3.486860773484375*^9, 
   3.48686080684375*^9}, {3.48876251509375*^9, 3.488762523953125*^9}, {
   3.494604773109375*^9, 3.494604784875*^9}, {3.494606496*^9, 
   3.4946065115625*^9}, {3.49460674609375*^9, 3.494606765390625*^9}, 
   3.49460689153125*^9, {3.49835482746875*^9, 3.49835483184375*^9}, {
   3.49835563209375*^9, 3.498355662703125*^9}}],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Am2", "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"Am1", "[", 
       RowBox[{"[", "#", "]"}], "]"}], " ", 
      RowBox[{"Exp", "[", 
       RowBox[{"I", " ", 
        RowBox[{"omega", "[", 
         RowBox[{"[", "#", "]"}], "]"}], " ", "tauvector"}], "]"}]}], "&"}], "/@", 
    RowBox[{"Range", "[", 
     RowBox[{"1", ",", "nf"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Am2Tr", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"Tr", "[", 
      RowBox[{"Am2", "[", 
       RowBox[{"[", "#", "]"}], "]"}], "]"}], "&"}], "/@", 
    RowBox[{"Range", "[", "nf", "]"}]}]}], ";"}]}], "Input",
 CellChangeTimes->{3.4947668226875*^9}],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Gr1", "=", 
   RowBox[{"ListLogLogPlot", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Transpose", "@", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"omega", "/", 
          RowBox[{"(", 
           RowBox[{"2", " ", "Pi"}], ")"}]}], ",", 
         RowBox[{"Abs", "[", "HTr", "]"}]}], "}"}]}], ",", 
      RowBox[{"Transpose", "@", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"omega", "/", 
          RowBox[{"(", 
           RowBox[{"2", " ", "Pi"}], ")"}]}], ",", 
         RowBox[{"Abs", "[", "Am2Tr", "]"}]}], "}"}]}]}], "}"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Gr2", "=", 
   RowBox[{"ListLogLinearPlot", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Transpose", "@", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"omega", "/", 
          RowBox[{"(", 
           RowBox[{"2", " ", "Pi"}], ")"}]}], ",", 
         RowBox[{"UnwrapPhase", "[", 
          RowBox[{"Arg", "[", "HTr", "]"}], "]"}]}], "}"}]}], ",", 
      RowBox[{"Transpose", "@", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"omega", "/", 
          RowBox[{"(", 
           RowBox[{"2", " ", "Pi"}], ")"}]}], ",", 
         RowBox[{"UnwrapPhase", "[", 
          RowBox[{"Arg", "[", "Am2Tr", "]"}], "]"}]}], "}"}]}]}], "}"}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"{", 
  RowBox[{"Gr1", ",", "Gr2"}], "}"}]}], "Input",
