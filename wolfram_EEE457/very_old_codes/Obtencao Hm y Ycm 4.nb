Cell[CellGroupData[{

Cell["Ajuste del Argumento de Elementos das Matrizes Idempotentes", "Section",
 CellChangeTimes->{{3.4983552265625*^9, 3.49835523440625*^9}, 
   3.498355305796875*^9, 3.498355884421875*^9}],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"GrelemRVF", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"ListLogLinearPlot", "[", 
      RowBox[{
       RowBox[{"Map", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Transpose", "@", 
           RowBox[{"{", 
            RowBox[{
             RowBox[{"omega", "/", 
              RowBox[{"(", 
               RowBox[{"2", " ", "Pi"}], ")"}]}], ",", 
             RowBox[{"UnwrapPhase", "[", 
              RowBox[{"Arg", "[", 
               RowBox[{"PontosRVFElemM2", "[", 
                RowBox[{"[", 
                 RowBox[{"j", ",", "All", ",", "#"}], "]"}], "]"}], "]"}], 
              "]"}]}], "}"}]}], "&"}], ",", 
         RowBox[{"Range", "[", "nM2", "]"}]}], "]"}], ",", 
       RowBox[{"PlotStyle", "\[Rule]", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"Thick", ",", 
            RowBox[{"RGBColor", "[", 
             RowBox[{
              RowBox[{"i", "/", "nc"}], ",", "0.5", ",", "0.5"}], "]"}], ",", 
            "Dashed"}], "}"}], ",", 
          RowBox[{"{", 
