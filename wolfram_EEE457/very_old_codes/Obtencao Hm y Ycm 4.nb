          ",", 
          RowBox[{"Table", "[", 
           RowBox[{
            RowBox[{"Sum", "[", 
             RowBox[{
              RowBox[{"Re", "[", 
               RowBox[{"Anum", "[", 
                RowBox[{"[", 
