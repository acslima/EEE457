         "0"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"mm", ",", "npol"}], "}"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"polaux", "=", 
