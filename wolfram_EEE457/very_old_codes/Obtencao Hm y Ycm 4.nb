Cell["ROT", "Subsection",
 CellChangeTimes->{{3.4923523307314453`*^9, 3.492352341618164*^9}, {
  3.4923523766660156`*^9, 3.4923523776171875`*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"rot", "[", 
   RowBox[{"s_", "?", "MatrixQ"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"S", "=", "s"}], ",", "Nc", ",", "SA", ",", "SB", ",", "scale", 
      ",", "ang", ",", "scale1", ",", "col", ",", "scale2", ",", "err1", ",", 
      "err2", ",", "numerator", ",", "denominator", ",", "aaa", ",", "bbb", 
      ",", "ccc"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"Nc", "=", 
      RowBox[{"Length", "[", "S", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"SA", "=", 
      RowBox[{"Table", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", "Nc", "}"}], ",", 
        RowBox[{"{", "Nc", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"SB", "=", "SA"}], ";", "\[IndentingNewLine]", 
     RowBox[{"scale1", "=", 
      RowBox[{"Table", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", "Nc", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"scale2", "=", 
      RowBox[{"scale", "=", 
       RowBox[{"ang", "=", "scale1"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"err1", "=", "scale1"}], ";", "\[IndentingNewLine]", 
     RowBox[{"err2", "=", "scale1"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"numerator", "=", 
      RowBox[{"Table", "[", 
       RowBox[{"0", ",", 
        RowBox[{"{", "Nc", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"denominator", "=", 
      RowBox[{"numerator", "=", 
       RowBox[{"scale1", "=", "scale2"}]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"col", "=", "1"}], ",", 
       RowBox[{"col", "\[LessEqual]", " ", "Nc"}], ",", 
       RowBox[{"col", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"numerator", "[", 
          RowBox[{"[", "col", "]"}], "]"}], "=", "0."}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"denominator", "[", 
          RowBox[{"[", "col", "]"}], "]"}], "=", 
         RowBox[{
          RowBox[{"numerator", "[", 
           RowBox[{"[", "col", "]"}], "]"}], "=", "0."}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"j", "=", "1"}], ",", 
          RowBox[{"j", "\[LessEqual]", " ", "Nc"}], ",", 
          RowBox[{"j", "++"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"numerator", "[", 
             RowBox[{"[", "col", "]"}], "]"}], "=", 
            RowBox[{
             RowBox[{"numerator", "[", 
              RowBox[{"[", "col", "]"}], "]"}], "+", 
             RowBox[{
              RowBox[{"Im", "[", 
               RowBox[{"S", "[", 
                RowBox[{"[", 
                 RowBox[{"j", ",", "col"}], "]"}], "]"}], "]"}], "*", 
              RowBox[{"Re", "[", 
               RowBox[{"S", "[", 
                RowBox[{"[", 
                 RowBox[{"j", ",", "col"}], "]"}], "]"}], "]"}]}]}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"denominator", "[", 
             RowBox[{"[", "col", "]"}], "]"}], "=", 
            RowBox[{
             RowBox[{"denominator", "[", 
              RowBox[{"[", "col", "]"}], "]"}], "+", 
             RowBox[{
              RowBox[{"Re", "[", 
               RowBox[{"S", "[", 
                RowBox[{"[", 
                 RowBox[{"j", ",", "col"}], "]"}], "]"}], "]"}], "^", "2"}], 
             "-", 
             RowBox[{
              RowBox[{"Im", "[", 
               RowBox[{"S", "[", 
                RowBox[{"[", 
                 RowBox[{"j", ",", "col"}], "]"}], "]"}], "]"}], "^", 
              "2"}]}]}]}]}], "]"}], ";", "\[IndentingNewLine]", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"numerator", "[", 
          RowBox[{"[", "col", "]"}], "]"}], "=", 
         RowBox[{
          RowBox[{"-", "2"}], "*", 
          RowBox[{"numerator", "[", 
           RowBox[{"[", "col", "]"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"ang", "[", 
          RowBox[{"[", "col", "]"}], "]"}], "=", 
         RowBox[{"0.5", "*", 
          RowBox[{"ArcTan", "[", 
           RowBox[{
            RowBox[{"denominator", "[", 
             RowBox[{"[", "col", "]"}], "]"}], ",", 
            RowBox[{"numerator", "[", 
             RowBox[{"[", "col", "]"}], "]"}]}], "]"}]}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"scale1", "[", 
          RowBox[{"[", "col", "]"}], "]"}], "=", 
         RowBox[{
          RowBox[{"Cos", "[", 
           RowBox[{"ang", "[", 
            RowBox[{"[", "col", "]"}], "]"}], "]"}], "+", 
          RowBox[{"\[ImaginaryI]", "*", 
           RowBox[{"Sin", "[", 
