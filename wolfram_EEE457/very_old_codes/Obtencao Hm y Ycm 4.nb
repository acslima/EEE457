Cell[BoxData[
 RowBox[{
  RowBox[{"calcelem", "[", 
   RowBox[{
   "polos_List", ",", "residuos_List", ",", "omega_List", ",", "yElementos_", 
    ",", "TermD_", ",", "TermE_", ",", "nres_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"funcoes", ",", "Pontos", ",", "dif", ",", "RMSD"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"funcoes", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Sum", "[", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"residuos", "[", 
              RowBox[{"[", 
               RowBox[{"i", ",", "kk"}], "]"}], "]"}], "/", 
             RowBox[{"(", 
              RowBox[{"s", "-", 
               RowBox[{"polos", "[", 
                RowBox[{"[", "kk", "]"}], "]"}]}], ")"}]}], ")"}], ",", 
           RowBox[{"{", 
            RowBox[{"kk", ",", 
             RowBox[{"Length", "[", "polos", "]"}]}], "}"}]}], "]"}], "+", 
         RowBox[{"TermD", "[", 
          RowBox[{"[", "i", "]"}], "]"}], "+", 
         RowBox[{"s", "*", 
          RowBox[{"TermE", "[", 
           RowBox[{"[", "i", "]"}], "]"}]}]}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "nres"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Pontos", "=", 
      RowBox[{"Transpose", "[", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Map", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"funcoes", "[", 
               RowBox[{"[", "i", "]"}], "]"}], "/.", 
              RowBox[{"s", "->", "#"}]}], ")"}], "&"}], ",", 
           RowBox[{"\[ImaginaryI]", " ", "omega"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", "nres"}], "}"}]}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"dif", "=", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"Abs", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"Pontos", "-", "yElementos"}], ")"}], "^", "2"}], "]"}], 
        "/", 
        RowBox[{"Length", "[", "omega", "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"RMSD", "=", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"Total", "[", 
         RowBox[{
          RowBox[{"Abs", "[", 
           RowBox[{"Pontos", "-", "yElementos"}], "]"}], "^", "2"}], "]"}], 
        "/", 
        RowBox[{"Length", "[", "omega", "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Return", "[", 
      RowBox[{"{", 
       RowBox[{"funcoes", ",", "Pontos", ",", "RMSD", ",", "dif"}], "}"}], 
      "]"}]}]}], "]"}]}]], "Input",
