     "\[IndentingNewLine]", 
     RowBox[{"AAAscale", "=", 
      RowBox[{"Transpose", "[", "AAAaux", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Xaux", "=", 
      RowBox[{"LeastSquares", "[", 
