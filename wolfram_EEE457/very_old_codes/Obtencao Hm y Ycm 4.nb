              RowBox[{"{", 
               RowBox[{"i", ",", "1", ",", "nfreq"}], "}"}]}], "]"}], ",", 
            RowBox[{"{", 
             RowBox[{"j", ",", "1", ",", "npol"}], "}"}]}], "]"}], ",", 
          "nfreq"}], "}"}], "]"}], "*", "Ws"}]}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"Af", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"Flatten", "[", 
