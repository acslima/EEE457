                  Style["G", Italic], "(", 
                  Style["f", Italic], ")|"}], None}, {
                Row[{
                  Style["f", Italic], " (Hz)"}], 
                Style["magnitude of spectrum", Bold]}}, 
             ImagePadding -> {{40, 5}, {15, 2}}]; $CellContext`p3$ = 
           Plot[(180/Pi) Arg[
               $CellContext`f[$CellContext`a$, $CellContext`T$, \
$CellContext`t0$, $CellContext`w$]], {$CellContext`w$, \
(-$CellContext`nZeros$$)/$CellContext`T$, \
