              Sin[(Pi $CellContext`w) $CellContext`T]/((
               Pi $CellContext`w) $CellContext`T))) 
            Exp[((((-I) 2) Pi) $CellContext`w) $CellContext`t0], 
            True}}]; $CellContext`process[
          Pattern[$CellContext`a$, 
           Blank[]], 
          Pattern[$CellContext`T$, 
           Blank[]], 
          Pattern[$CellContext`t0$, 
           Blank[]]] := 
        Module[{$CellContext`p1$, $CellContext`p2$, $CellContext`p3$, \
$CellContext`w$}, $CellContext`p1$ = Plot[
             $CellContext`rect[$CellContext`a$, $CellContext`T$, \
$CellContext`t0$, $CellContext`t], {$CellContext`t, $CellContext`t0$ - \
$CellContext`T$, $CellContext`t0$ + $CellContext`T$}, 
             PlotRange -> {{-($CellContext`maxT$$/
                  2 + $CellContext`maxt0$$), $CellContext`maxT$$/
                 2 + $CellContext`maxt0$$}, {0, $CellContext`maxA$$ + 0.1}}, 
             Frame -> True, ImagePadding -> {{44, 2}, {33, 30}}, ImageMargins -> 
             5, ImageSize -> 300, AspectRatio -> 0.35, FrameTicksStyle -> 
             Directive[10], AxesOrigin -> {0, 0}, PlotStyle -> Red, 
             FrameLabel -> {{
                Row[{
                  Style["g", Italic], "(", 
                  Style["t", Italic], ")"}], None}, {
                Row[{
                  Style["t", Italic], " (sec)"}], 
                Style[
                "A rect(\!\(\*FractionBox[\(t - \*SubscriptBox[\(t\), \
\(0\)]\), \(T\)]\))", Bold]}}, Epilog -> {{Red, 
                
                Line[{{$CellContext`t0$ - $CellContext`T$/
                   2, $CellContext`a$}, {$CellContext`t0$ - $CellContext`T$/2,
                    0}}]}, {Red, 
                
                Line[{{$CellContext`t0$ + $CellContext`T$/
                    2, $CellContext`a$}, {$CellContext`t0$ + $CellContext`T$/
                    2, 0}}]}}]; $CellContext`p2$ = Plot[
             Abs[
              Evaluate[
               $CellContext`f[$CellContext`a$, $CellContext`T$, \
$CellContext`t0$, $CellContext`w$]]], {$CellContext`w$, \
(-$CellContext`nZeros$$)/$CellContext`T$, \
$CellContext`nZeros$$/$CellContext`T$}, Frame -> True, AxesOrigin -> {0, 0}, 
             ImagePadding -> {{44, 4}, {45, 25}}, ImageMargins -> 5, 
             ImageSize -> 252, AspectRatio -> 0.5, PlotStyle -> Red, 
             PlotRange -> {{-($CellContext`nZeros$$/$CellContext`maxT$$), \
$CellContext`nZeros$$/$CellContext`maxT$$}, {-0.1, $CellContext`maxA$$ \
$CellContext`maxT$$ + 1}}, FrameTicks -> {{Automatic, None}, {
                
                Table[$CellContext`i/$CellContext`T$, {$CellContext`i, \
-$CellContext`nZeros$$, $CellContext`nZeros$$}], None}}, FrameLabel -> {{
