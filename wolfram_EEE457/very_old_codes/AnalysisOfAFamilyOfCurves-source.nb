Cell[CellGroupData[{

Cell["Details", "Section",
 CellFrameColor->RGBColor[
  0.6449835965514611, 0.758632791638056, 0.2516823071641108],
 FontColor->RGBColor[
  0.6449835965514611, 0.758632791638056, 0.2516823071641108]],

Cell["\<\
The presented program analyzes and visualizes a one-parameter family of \
functions. You can replace the function in the program.\
\>", "Text"],

Cell[TextData[{
 "Extreme points and inflection points are highlighted in the graph on the \
left. A change of the interval limits ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]], "InlineMath"],
 " and ",
 Cell[BoxData[
  FormBox["b", TraditionalForm]], "InlineMath"],
 " will only result in a change to the area and volume calculations. "
}], "Text"],

Cell[TextData[{
 "For the calculation of the area under the curve, choose the interval ",
 Cell[BoxData[
  FormBox[
   RowBox[{"[", 
    RowBox[{"a", ",", "b"}], "]"}], TraditionalForm]], "InlineMath"],
 " so that all function values in this interval are positive or negative (in \
the latter case, the value of the integral is the negative of the area)."
}], "Text"]
}, Close]],

