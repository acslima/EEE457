Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "rotinas", " ", "para", " ", "copiar", " ", "o", " ", "linspace", " ", "e",
     " ", "o", " ", "logspace", " ", "do", " ", "matlab"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"logspac", " ", "=", " ", 
     RowBox[{"Compile", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"i", ",", "_Real"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"f", ",", "_Real"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"np", ",", "_Integer"}], "}"}]}], "}"}], ",", "\n", 
       "                 ", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"10.0", "^", 
          RowBox[{"(", 
           RowBox[{"i", " ", "+", " ", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"x", "*", 
               RowBox[{"(", 
                RowBox[{"f", " ", "-", " ", "i"}], ")"}]}], ")"}], "/", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Floor", "[", "np", "]"}], " ", "-", " ", "1"}], 
              ")"}]}]}], ")"}]}], ",", " ", 
         RowBox[{"{", 
          RowBox[{"x", ",", " ", "0", ",", " ", 
           RowBox[{"np", " ", "-", " ", "1"}]}], "}"}]}], "]"}]}], "\n", 
      "                 ", "]"}]}], ";"}], "\n", "     "}]}]], "Input",
 CellChangeTimes->{{3.798384467885241*^9, 3.7983844762506933`*^9}, 
   3.7983845068589487`*^9},
 CellLabel->"In[9]:=",ExpressionUUID->"6b6ef9f1-0078-4789-9061-72dae45ba5f3"],

Cell[BoxData[
 RowBox[{
  RowBox[{"linspac", " ", "=", " ", 
   RowBox[{"Compile", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"i", ",", "_Real"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"f", ",", "_Real"}], "}"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"np", ",", "_Integer"}], "}"}]}], "}"}], ",", " ", "\n", 
     "                 ", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"i", " ", "+", " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"x", "*", 
           RowBox[{"(", 
            RowBox[{"f", " ", "-", " ", "i"}], ")"}]}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Floor", "[", "np", "]"}], " ", "-", " ", "1"}], ")"}]}]}],
        ",", " ", 
       RowBox[{"{", 
        RowBox[{"x", ",", " ", "0", ",", " ", 
         RowBox[{"np", " ", "-", " ", "1"}]}], "}"}]}], "]"}]}], "]"}]}], 
  ";"}]], "Input",
