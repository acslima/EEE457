Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "impedancia", " ", "interna", " ", "de", " ", "condutor", " ", "sem", " ", 
    "alma", " ", "de", " ", "aco"}], " ", "*)"}], "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
   "impedancia", " ", "interna", " ", "de", " ", "condutores", " ", 
    "cilindricos"}], " ", "*)"}], " ", "\n", 
  RowBox[{"(*", 
   RowBox[{"Mur", "=", 
    RowBox[{"90", " ", "para", " ", "cables", " ", "de", " ", "aco"}]}], 
   "*)"}], "    ", "\n", 
  RowBox[{
   RowBox[{"Zin", "[", 
    RowBox[{"Omega_", ",", " ", "Rhopr_", ",", " ", "rpr_", ",", " ", 
     RowBox[{"Mur_", ":", "90"}], ",", " ", 
     RowBox[{"Mu_", ":", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"4", "*", "Pi"}], ")"}], "/", 
       RowBox[{"10", "^", "7"}]}]}]}], "]"}], " ", ":=", " ", "\n", "    ", 
   RowBox[{"With", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"Etapr", " ", "=", " ", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"I", "*", "Omega", "*", "Mu", "*", "Mur"}], ")"}], "/", 
         "Rhopr"}], "]"}]}], "}"}], ",", " ", "\n", "         ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Etapr", "*", "Rhopr"}], ")"}], "*", 
        RowBox[{"BesselI", "[", 
         RowBox[{"0", ",", " ", 
          RowBox[{"Etapr", "*", "rpr"}]}], "]"}]}], ")"}], "/", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"2", "*", "Pi", "*", "rpr"}], ")"}], "*", 
        RowBox[{"BesselI", "[", 
         RowBox[{"1", ",", 
          RowBox[{"Etapr", "*", "rpr"}]}], "]"}]}], ")"}]}]}], 
    "]"}]}]}]], "Input",
 CellLabel->"In[2]:=",ExpressionUUID->"1b9c2de6-2e4b-4727-b51c-4e720cc8d44f"],

