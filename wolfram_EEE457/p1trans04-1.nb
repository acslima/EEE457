  "\n"
}], "Text"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Quinta Quest\[ATilde]o", "Section",
  Evaluatable->False,
  AspectRatioFixed->True],

Cell["\<\
Calcule a capacit\[AHat]ncia do circuito  n\[ATilde]o transposto abaixo, \
sabendo-se que a dist\[AHat]ncia entre circuitos \[EAcute] de 19m para os \
condutores de fase,  e 15m  para o cabo p\[AAcute]ra-raios. A separa\
\[CCedilla]\[ATilde]o vertical entre condutores \[EAcute] de 12,7m e os cabos \
para-raios est\[ATilde]o a 36.5m  acima do condutor mais inferior.\
\>", "Text",
  Evaluatable->False,
  AspectRatioFixed->True],

Cell[CellGroupData[{

Cell[BoxData[{
    \(xa1 = \(-19.0\)/2; ya1 = 26.0\ ; xb1 = xa1; yb1 = ya1 + 12.7; 
    xc1 = xa1\ ;\), "\[IndentingNewLine]", 
    \(yc1 = ya1 + 2*12.7; xw1 = \(-7.5\); yw1 = ya1 + 36.5; xw2 = 7.5; 
    yw2 = yw1\ ;\), "\n", 
    \(\(xc = {xa1, xb1, xc1, \(-xa1\), \(-xb1\), \(-xc1\), xw1, 
          xw2};\)\), "\n", 
    \(\(yc = {ya1, yb1, yc1, ya1, yb1, yc1, yw1, 
          yw2};\)\), "\[IndentingNewLine]", 
    \(\(mostra = 
        Table[{Circle[{xc[\([i]\)], yc[\([i]\)]}, 0.2]}, {i, 1, 
            8}];\)\), "\n", 
    \(\(tduplo = 
