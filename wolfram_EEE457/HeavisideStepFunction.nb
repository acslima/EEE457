Cell[CellGroupData[{

Cell[BoxData[
    RowBox[{
      RowBox[{"1", "/", 
        RowBox[{"Sqrt", "[", "\[Pi]", "]"}]}], 
      RowBox[{"Limit", "[", 
        RowBox[{
          RowBox[{"Integrate", "[", 
            RowBox[{
              RowBox[{
                RowBox[{"1", "/", "t"}], " ", 
                RowBox[{"Exp", "[", 
                  RowBox[{
                    RowBox[{"-", 
                      RowBox[{"u", "^", "2"}]}], "/", 
                    RowBox[{"t", "^", "2"}]}], "]"}]}], ",", 
              RowBox[{"{", 
                RowBox[{"u", ",", 
                  RowBox[{"-", "x"}], ",", "\[Infinity]"}], "}"}]}], "]"}], 
          ",", 
          RowBox[{"t", "\[Rule]", "0"}]}], "]"}]}]], "Input"],

Cell[BoxData[
    FractionBox[
      RowBox[{"Limit", "[", 
        RowBox[{
          FractionBox[
            RowBox[{"If", "[", 
              RowBox[{
                RowBox[{
                  RowBox[{"Re", "[", 
                    SuperscriptBox["t", "2"], "]"}], ">", "0"}], ",", 
                RowBox[{
                  FractionBox["1", "2"], " ", 
                  SqrtBox["\[Pi]"], " ", 
                  RowBox[{"(", 
                    RowBox[{
                      SqrtBox[
                        SuperscriptBox["t", "2"]], "+", 
                      RowBox[{"t", " ", 
                        RowBox[{"Erf", "[", 
                          FractionBox["x", "t"], "]"}]}]}], ")"}]}], ",", 
                RowBox[{"Integrate", "[", 
                  RowBox[{
                    SuperscriptBox["\[ExponentialE]", 
                      RowBox[{"-", 
                        FractionBox[
                          SuperscriptBox["u", "2"], 
                          SuperscriptBox["t", "2"]]}]], ",", 
                    RowBox[{"{", 
                      RowBox[{"u", ",", 
                        RowBox[{"-", "x"}], ",", "\[Infinity]"}], "}"}], ",", 
                    
                    RowBox[{"Assumptions", "\[Rule]", 
                      RowBox[{
                        RowBox[{"Re", "[", 
                          SuperscriptBox["t", "2"], "]"}], "\[LessEqual]", 
                        "0"}]}]}], "]"}]}], "]"}], "t"], ",", 
          RowBox[{"t", "\[Rule]", "0"}]}], "]"}], 
      SqrtBox["\[Pi]"]]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    FractionBox[
      RowBox[{"Limit", "[", 
        RowBox[{
          RowBox[{"FullSimplify", "[", 
            FractionBox[
              RowBox[{
                FractionBox["1", "2"], " ", 
                SqrtBox["\[Pi]"], " ", 
                RowBox[{"(", 
                  RowBox[{
                    SqrtBox[
                      SuperscriptBox["t", "2"]], "+", 
