                    FractionBox[
                      SuperscriptBox["u", "2"], "t"]}]], "t"], 
              RowBox[{"\[DifferentialD]", "u"}]}]}]}], "]"}], 
      SqrtBox["\[Pi]"]]], "Output"]
}, Open  ]],

