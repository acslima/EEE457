Cell[CellGroupData[{

Cell["Plots of Limits", "Section"],

Cell[CellGroupData[{

Cell[BoxData[
    RowBox[{
      RowBox[{
        RowBox[{"Limit", "[", 
          RowBox[{"#", ",", 
            RowBox[{"t", "\[Rule]", "0"}]}], "]"}], "&"}], "/@", 
      RowBox[{"{", "\[IndentingNewLine]", 
        RowBox[{
          RowBox[{
            RowBox[{"1", "/", "2"}], "+", 
            RowBox[{
              RowBox[{"1", "/", "Pi"}], " ", 
              RowBox[{"ArcTan", "[", 
                RowBox[{"x", "/", "t"}], "]"}]}]}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{
            RowBox[{"1", "/", "2"}], " ", 
            RowBox[{"Erfc", "[", 
              RowBox[{
                RowBox[{"-", "x"}], "/", "t"}], "]"}]}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{
            RowBox[{"1", "/", "2"}], "+", 
            RowBox[{
              RowBox[{"1", "/", "Pi"}], " ", 
              RowBox[{"SinIntegral", "[", 
                RowBox[{"Pi", " ", 
                  RowBox[{"x", "/", "t"}]}], "]"}]}]}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"1", "/", 
            RowBox[{"(", 
              RowBox[{"1", "+", 
                RowBox[{"Exp", "[", 
                  RowBox[{
                    RowBox[{"-", "x"}], "/", "t"}], "]"}]}], ")"}]}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Exp", "[", 
            RowBox[{"-", 
              RowBox[{"Exp", "[", 
                RowBox[{
                  RowBox[{"-", "x"}], "/", "t"}], "]"}]}], "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{
            RowBox[{"(", 
              RowBox[{"1", "+", 
                RowBox[{"Tanh", "[", 
                  RowBox[{"x", "/", "t"}], "]"}]}], ")"}], "/", "2"}]}], 
        "\[IndentingNewLine]", "}"}]}]], "Input"],

Cell[BoxData[
    RowBox[{"{", 
      RowBox[{
        FractionBox[
          RowBox[{"x", "+", 
            SqrtBox[
              SuperscriptBox["x", "2"]]}], 
          RowBox[{"2", " ", "x"}]], ",", 
        RowBox[{"Limit", "[", 
          RowBox[{
            RowBox[{
              FractionBox["1", "2"], " ", 
              RowBox[{"Erfc", "[", 
                RowBox[{"-", 
                  FractionBox["x", "t"]}], "]"}]}], ",", 
            RowBox[{"t", "\[Rule]", "0"}]}], "]"}], ",", 
        RowBox[{"Limit", "[", 
          RowBox[{
            RowBox[{
              FractionBox["1", "2"], "+", 
              FractionBox[
                RowBox[{"SinIntegral", "[", 
                  FractionBox[
                    RowBox[{"\[Pi]", " ", "x"}], "t"], "]"}], "\[Pi]"]}], ",",
             
            RowBox[{"t", "\[Rule]", "0"}]}], "]"}], ",", 
        RowBox[{"Limit", "[", 
          RowBox[{
            FractionBox["1", 
              RowBox[{"1", "+", 
                SuperscriptBox["\[ExponentialE]", 
                  RowBox[{"-", 
                    FractionBox["x", "t"]}]]}]], ",", 
            RowBox[{"t", "\[Rule]", "0"}]}], "]"}], ",", 
        RowBox[{"Limit", "[", 
          RowBox[{
            SuperscriptBox["\[ExponentialE]", 
              RowBox[{"-", 
                SuperscriptBox["\[ExponentialE]", 
                  RowBox[{"-", 
                    FractionBox["x", "t"]}]]}]], ",", 
            RowBox[{"t", "\[Rule]", "0"}]}], "]"}], ",", 
        RowBox[{"Limit", "[", 
          RowBox[{
            RowBox[{
              FractionBox["1", "2"], " ", 
              RowBox[{"(", 
                RowBox[{"1", "+", 
                  RowBox[{"Tanh", "[", 
                    FractionBox["x", "t"], "]"}]}], ")"}]}], ",", 
            RowBox[{"t", "\[Rule]", "0"}]}], "]"}]}], "}"}]], "Output"]
}, Open  ]],

