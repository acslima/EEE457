Cell[CellGroupData[{

Cell[BoxData[
    RowBox[{"?", "UnitStep"}]], "Input"],

Cell[BoxData["\<\"UnitStep[x] is a function that is 1 for x > 0 and 0 for x < \
0.  UnitStep[x1, x2, ...] is 1 for (x1 > 0) && (x2 > 0) && ... and 0 for  (x1 \
< 0) || (x2 < 0) || ... .\"\>"], "Print"]
}, Open  ]],

