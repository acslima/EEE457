Notebook[{

Cell[CellGroupData[{
Cell["Updating Time - Domain Vector Fitting Alogrithm", "Title",
 CellChangeTimes->{{3.8977993349986973`*^9, 
  3.897799349078087*^9}},ExpressionUUID->"50af5578-a082-4220-a36c-\
00ed648778c2"],

Cell["lento demais e n\[ATilde]o parece estar funcionando", "Text",
 CellChangeTimes->{{3.897799722461135*^9, 
  3.897799736381205*^9}},ExpressionUUID->"d6146698-36e1-4ae0-8e1c-\
6ef9c0f95c8f"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Define", " ", "the", " ", "TDVF", " ", "function"}], "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"TDVF", "[", 
     RowBox[{"data_", ",", "poles_", ",", "iterations_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
       "A", ",", "B", ",", "x", ",", "y", ",", "d", ",", "P", ",", "Q", ",", 
        "E", ",", "alpha"}], "}"}], ",", 
      RowBox[{"(*", 
       RowBox[{"Initialize", " ", "variables"}], "*)"}], 
      RowBox[{
       RowBox[{"A", "=", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{"0.", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Length", "[", "data", "]"}], ",", 
            RowBox[{"Length", "[", "poles", "]"}]}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"B", "=", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{"0.", ",", 
          RowBox[{"{", 
           RowBox[{"Length", "[", "data", "]"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"P", "=", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{"0.", ",", 
          RowBox[{"{", 
           RowBox[{"Length", "[", "poles", "]"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"Q", "=", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{"0.", ",", 
          RowBox[{"{", 
           RowBox[{"Length", "[", "poles", "]"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"E", "=", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{"0.", ",", 
          RowBox[{"{", 
           RowBox[{"Length", "[", "data", "]"}], "}"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Construct", " ", "the", " ", "matrix", " ", "A", " ", "and", " ", 
         "vector", " ", "B"}], "*)"}], 
       RowBox[{"For", "[", 
        RowBox[{
         RowBox[{"i", "=", "1"}], ",", 
         RowBox[{"i", "<=", 
          RowBox[{"Length", "[", "data", "]"}]}], ",", 
         RowBox[{"i", "++"}], ",", 
         RowBox[{
          RowBox[{"x", "=", 
           RowBox[{"data", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", "1"}], "]"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"y", "=", 
           RowBox[{"data", "[", 
            RowBox[{"[", 
             RowBox[{"i", ",", "2"}], "]"}], "]"}]}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"For", "[", 
           RowBox[{
            RowBox[{"j", "=", "1"}], ",", 
            RowBox[{"j", "<=", 
             RowBox[{"Length", "[", "poles", "]"}]}], ",", 
            RowBox[{"j", "++"}], ",", 
            RowBox[{
             RowBox[{
              RowBox[{"A", "[", 
               RowBox[{"[", 
                RowBox[{"i", ",", "j"}], "]"}], "]"}], "=", 
              RowBox[{"Exp", "[", 
               RowBox[{
                RowBox[{"-", 
                 RowBox[{"poles", "[", 
                  RowBox[{"[", "j", "]"}], "]"}]}], " ", "x"}], "]"}]}], 
             ";"}]}], "]"}], ";", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"B", "[", 
            RowBox[{"[", "i", "]"}], "]"}], "=", "y"}], ";"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{"Perform", " ", "iterations"}], "*)"}], 
       RowBox[{"For", "[", 
        RowBox[{
         RowBox[{"k", "=", "1"}], ",", 
         RowBox[{"k", "<=", "iterations"}], ",", 
         RowBox[{"k", "++"}], ",", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{"Compute", " ", "the", " ", "pseudo"}], "-", 
           RowBox[{"inverse", " ", "of", " ", "A"}]}], "*)"}], 
         RowBox[{
          RowBox[{"d", "=", "1.0"}], ";", "\[IndentingNewLine]", 
          RowBox[{"alpha", "=", "1.0"}], ";", "\[IndentingNewLine]", 
          RowBox[{"While", "[", 
           RowBox[{
            RowBox[{"d", ">", 
             RowBox[{
              RowBox[{"1", "e"}], "-", "12"}]}], ",", 
            RowBox[{
             RowBox[{"Ainv", "=", 
              RowBox[{"PseudoInverse", "[", 
               RowBox[{"A", ",", 
                RowBox[{"Tolerance", "->", 
                 RowBox[{"alpha", "*", "d"}]}]}], "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"E", "=", 
              RowBox[{"B", "-", 
               RowBox[{"Ainv", ".", "B"}]}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"d", "=", 
              RowBox[{"Norm", "[", "E", "]"}]}], ";", "\[IndentingNewLine]", 
             RowBox[{"alpha", "*=", "0.1"}], ";"}]}], "]"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{"Update", " ", "poles", " ", "and", " ", "residues"}], 
           "*)"}], 
          RowBox[{"P", "=", 
           RowBox[{"Ainv", ".", "B"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"Q", "=", 
           RowBox[{"Q", "+", "P"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"(*", 
           RowBox[{
           "Compute", " ", "the", " ", "updated", " ", "B", " ", "vector"}], 
           "*)"}], 
          RowBox[{"For", "[", 
           RowBox[{
            RowBox[{"i", "=", "1"}], ",", 
            RowBox[{"i", "<=", 
             RowBox[{"Length", "[", "data", "]"}]}], ",", 
            RowBox[{"i", "++"}], ",", 
            RowBox[{
             RowBox[{"x", "=", 
              RowBox[{"data", "[", 
               RowBox[{"[", 
                RowBox[{"i", ",", "1"}], "]"}], "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"y", "=", 
              RowBox[{"data", "[", 
               RowBox[{"[", 
                RowBox[{"i", ",", "2"}], "]"}], "]"}]}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"B", "[", 
               RowBox[{"[", "i", "]"}], "]"}], "=", 
              RowBox[{"y", "-", 
               RowBox[{"Sum", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"P", "[", 
                   RowBox[{"[", "j", "]"}], "]"}], " ", 
                  RowBox[{"Exp", "[", 
                   RowBox[{
                    RowBox[{"-", 
                    RowBox[{"poles", "[", 
                    RowBox[{"[", "j", "]"}], "]"}]}], " ", "x"}], "]"}]}], 
                 ",", 
                 RowBox[{"{", 
                  RowBox[{"j", ",", "1", ",", 
                   RowBox[{"Length", "[", "poles", "]"}]}], "}"}]}], 
                "]"}]}]}], ";"}]}], "]"}], ";"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"(*", 
        RowBox[{
        "Return", " ", "the", " ", "final", " ", "poles", " ", "and", " ", 
         "residues"}], "*)"}], 
       RowBox[{"{", 
        RowBox[{"poles", ",", "Q"}], "}"}]}]}], "]"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Example", " ", "usage"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"data", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0", ",", "1"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"1", ",", "0.5"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"2", ",", "0.3"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"3", ",", "0.2"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"4", ",", "0.1"}], "}"}]}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"poles", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "0.1"}], "-", 
        RowBox[{"0.5", " ", "I"}]}], ",", 
       RowBox[{
        RowBox[{"-", "0.1"}], "+", 
        RowBox[{"0.5", " ", "I"}]}]}], "}"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"iterations", "=", "10"}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"finalPoles", ",", "residues"}], "}"}], "=", 
     RowBox[{"TDVF", "[", 
      RowBox[{"data", ",", "poles", ",", "iterations"}], "]"}]}], ";"}], "\n",
    "finalPoles", "\n", "residues", "\n"}]}]], "Input",
 CellChangeTimes->{{3.8977993518989553`*^9, 3.897799351900848*^9}, {
  3.897799741392277*^9, 
  3.897799745105616*^9}},ExpressionUUID->"88e0a7d6-6cbb-41c2-a026-\
660c2ac5eaed"]
}, Open  ]]
},
