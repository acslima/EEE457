Cell[CellGroupData[{

Cell["Imped\[AHat]ncia Externa", "Section"],

Cell["\<\
Para o caso da imped\[AHat]ncia externa considera-se apenas um condutor monof\
\[AAcute]sico situado a10m de altura do solo e com alura constante. \
\>", "Text"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"Ze", "(", 
    RowBox[{"\[Omega]_", ",", 
     RowBox[{"\[Rho]s_:", " ", "100.0"}], ",", 
     RowBox[{"\[Mu]_", ":", 
      FractionBox[
       RowBox[{"4", " ", "\[Pi]"}], 
       SuperscriptBox["10", "7"]]}]}], ")"}], ":=", 
   RowBox[{
    FractionBox[
     RowBox[{"\[ImaginaryI]", " ", "\[Omega]", " ", "\[Mu]", " "}], 
     RowBox[{"2", " ", "\[Pi]"}]], 
    RowBox[{"log", "(", 
     FractionBox[
      RowBox[{"2", " ", 
       RowBox[{"(", 
        RowBox[{
         SqrtBox[
          FractionBox["\[Rho]s", 
           RowBox[{"\[ImaginaryI]", " ", "\[Omega]", " ", "\[Mu]"}]]], "+", 
         "10"}], ")"}]}], "r1"], ")"}]}]}], TraditionalForm]], "Input"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"Zsolo", "(", 
    RowBox[{"f_", ",", 
     RowBox[{"\[Rho]s_", ":", "100.0"}], ",", 
     RowBox[{"\[Mu]_", ":", 
      FractionBox[
       RowBox[{"4", " ", "\[Pi]"}], 
       SuperscriptBox["10", "7"]]}]}], ")"}], ":=", 
   RowBox[{
    FractionBox[
     RowBox[{"9.869", " ", "f"}], 
     SuperscriptBox["10", "7"]], "+", 
    RowBox[{"\[ImaginaryI]", "  ", "f", " ", "\[Mu]", " ", 
     RowBox[{"log", "(", 
      FractionBox[
       RowBox[{"658.4", " ", 
        SqrtBox[
         FractionBox["\[Rho]s", "f"]]}], "r1"], ")"}]}], "+", 
    RowBox[{"\[ImaginaryI]", "  ", "f", " ", "\[Mu]", " ", 
     RowBox[{"log", "(", 
      FractionBox["20.0", "r1"], ")"}]}]}]}], TraditionalForm]], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"LogLogPlot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Re", "[", 
      RowBox[{"Ze", "[", 
       RowBox[{"2", " ", "\[Pi]", " ", "f"}], "]"}], "]"}], ",", 
     RowBox[{"Im", "[", 
      RowBox[{"Ze", "[", 
       RowBox[{"2", " ", "\[Pi]", " ", "f"}], "]"}], "]"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{"f", ",", "1", ",", 
     SuperscriptBox["10", "6"]}], "}"}], ",", 
   RowBox[{"PlotStyle", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Hue", "[", "0", "]"}], ",", 
        RowBox[{"Dashing", "[", 
         RowBox[{"{", "0.03`", "}"}], "]"}]}], "}"}], ",", 
      RowBox[{"Hue", "[", "0.25`", "]"}]}], "}"}]}], ",", 
   RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
   RowBox[{"PlotPoints", "\[Rule]", "500"}]}], "]"}]], "Input"],

