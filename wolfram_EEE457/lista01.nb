Notebook[{

Cell[CellGroupData[{
Cell["Efeito da transposi\[CCedilla]\[ATilde]o", "Title"],

Cell["\<\
Antonio Carlos Siqueira de Lima
Poli/COPPE/UFRJ\
\>", "Subtitle"],

Cell[CellGroupData[{

Cell["Introdu\[CCedilla]\[ATilde]o", "Section"],

Cell["\<\
Calculando a resposta da linha ao degrau, os pontos da resposta de \
A e Yc considerando os dois casos\
\>", "Text"],

Cell["", "Text"],

Cell[CellGroupData[{

Cell["Op\[CCedilla]\[OTilde]es de programa", "Subsection"],

Cell[BoxData[
    \(\(Off[General::"\<spell\>", General::"\<spell1\>"];\)\)], "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Entrada de dados", "Subsection"],

Cell["Dados do sistema", "Text",
  PageWidth->WindowWidth,
  CellDingbat->None],

Cell["Configura\[CCedilla]\[ATilde]o da rede", "SmallText"],

Cell[CellGroupData[{

Cell[BoxData[{
    \(\(xc = {\(-10\), 0, 10. , \(-7\), 7};\)\), "\n", 
    \(\(yc = {15, 15, 15, 22, 22};\)\), "\[IndentingNewLine]", 
    \(\(mostra = 
        Table[{Circle[{xc[\([i]\)], yc[\([i]\)]}, 0.5]}, {i, 1, 
            5}];\)\), "\n", 
    \(\(tduplo = 
        Show[Graphics[mostra], AspectRatio \[Rule] Automatic, 
          Axes \[Rule] False, Frame -> Automatic, 
          FrameLabel \[Rule] {"\<dist\[AHat]ncia (m)\>", "\<dist\[AHat]ncia \
(m)\>"}];\)\)}], "Input"],

