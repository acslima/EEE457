  RowBox[{"Rf", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{".458", "/", "2"}], ")"}], " ", "/", 
    RowBox[{"Cos", "[", 
     RowBox[{"45", " ", "Degree"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Rmg", "=", 
  RowBox[{
