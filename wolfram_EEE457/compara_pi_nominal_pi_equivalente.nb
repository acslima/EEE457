Cell[BoxData[{
 RowBox[{
  RowBox[{"z1", "=", " ", 
   RowBox[{"0.1020", " ", "+", " ", 
    RowBox[{"I", ".5094"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"y1", "=", 
   RowBox[{"I", " ", "3.2599", "  ", 
    RowBox[{"10", "^", 
     RowBox[{"-", "6"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Gamma]", " ", "=", " ", 
   RowBox[{"Sqrt", "[", 
    RowBox[{"z1", " ", "y1"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Zc", "=", " ", 
   RowBox[{"Sqrt", "[", 
    RowBox[{"z1", "/", "y1"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"a", "[", "x_", "]"}], ":=", 
  RowBox[{"Cosh", "[", 
   RowBox[{"\[Gamma]", " ", "x"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"b", "[", "x_", "]"}], ":=", " ", 
  RowBox[{"Zc", " ", 
   RowBox[{"Sinh", "[", 
    RowBox[{"\[Gamma]", " ", "x"}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"c", "[", "x_", "]"}], ":=", " ", 
  RowBox[{
   RowBox[{"1", "/", "Zc"}], " ", 
   RowBox[{"Sinh", "[", 
    RowBox[{"\[Gamma]", " ", "x"}], "]"}]}]}]}], "Input",
