Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"TableForm", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "\"\<A (250km)\>\"", " ", ",", "\"\<B (250km)\>\"", " ", ",", 
       "\"\<C (250km)\>\""}], "  ", "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"100", " ", 
