Cell[CellGroupData[{

Cell["Circuito de 138 kV", "Section",
 CellChangeTimes->{{3.921833598708919*^9, 
  3.921833602669827*^9}},ExpressionUUID->"bf5f75b4-021e-46ed-8f5f-\
b9f9a01df6ab"],

Cell["\<\
a partir dos dados do circuito 138CST1 do relat\[OAcute]rio da EPE, com o \
condutor DOVE\
\>", "Text",
 CellChangeTimes->{{3.9218336077626467`*^9, 3.921833623077732*^9}, {
  3.921833669687017*^9, 
  3.9218336778679323`*^9}},ExpressionUUID->"732f8605-8886-4ea9-9eb3-\
09a2dad42bc3"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"z1", "=", " ", 
   RowBox[{"0.1160", " ", "+", " ", 
    RowBox[{"I", ".4821"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"y1", "=", 
   RowBox[{"I", " ", "3.4379", "  ", 
    RowBox[{"10", "^", 
     RowBox[{"-", "6"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Gamma]", " ", "=", " ", 
   RowBox[{"Sqrt", "[", 
    RowBox[{"z1", " ", "y1"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Zc", "=", " ", 
   RowBox[{"Sqrt", "[", 
    RowBox[{"z1", "/", "y1"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"a", "[", "x_", "]"}], ":=", 
  RowBox[{"Cosh", "[", 
   RowBox[{"\[Gamma]", " ", "x"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"b", "[", "x_", "]"}], ":=", " ", 
  RowBox[{"Zc", " ", 
   RowBox[{"Sinh", "[", 
    RowBox[{"\[Gamma]", " ", "x"}], "]"}]}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"c", "[", "x_", "]"}], ":=", " ", 
  RowBox[{
   RowBox[{"1", "/", "Zc"}], " ", 
   RowBox[{"Sinh", "[", 
    RowBox[{"\[Gamma]", " ", "x"}], "]"}]}]}]}], "Input",
 CellChangeTimes->{{3.921833679902631*^9, 3.921833846798513*^9}, {
  3.9218338799909067`*^9, 3.921833919373364*^9}, {3.921834282685533*^9, 
  3.9218343407757387`*^9}},
 CellLabel->"In[30]:=",ExpressionUUID->"f1933429-3ab4-48d3-9f23-18e35c0e39c0"],

