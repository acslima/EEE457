Cell["\<\
a partir dos dados do circuito 138CSH1 do relat\[OAcute]rio da EPE, com o \
condutor GROSSBEAK\
\>", "Text",
 CellChangeTimes->{{3.9218336077626467`*^9, 3.921833623077732*^9}, {
  3.921833669687017*^9, 3.9218336778679323`*^9}, {3.921834584629157*^9, 
  3.9218346000866833`*^9}},ExpressionUUID->"010979e1-9be3-4fe4-91be-\
