               RowBox[{"z1", " ", "x", " ", "y1", " ", 
                RowBox[{"x", "/", "4"}]}]}], ")"}]}], "-", 
            RowBox[{"c", "[", "x", "]"}]}], ")"}], "/", 
          RowBox[{"c", "[", "x", "]"}]}], "]"}]}]}], "}"}]}], "}"}], "/.", 
   RowBox[{"x", "->", "250"}]}], "]"}]], "Input",
