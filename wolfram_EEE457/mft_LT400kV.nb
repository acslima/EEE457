    \(\(\[Rho]solo = 10000.0;\)\), "\[IndentingNewLine]", 
    \(\(\[Mu] = 4.0\ \[Pi]\ 10\^\(-7\);\)\), "\[IndentingNewLine]", 
    \(\(\[Epsilon] = 8.854*10^\(-12\);\)\), "\[IndentingNewLine]", 
    \(\(p = \@\(\[Rho]solo\/\(\(I\)\(\ \)\(\[Omega]\)\(\ \)\(\[Mu]\)\(\ \
\)\)\);\)\), "\[IndentingNewLine]", 
    \(\(\[Eta]c = \@\(\(I\ \[Omega]\ \[Mu]\)\/\[Rho]c\);\)\), "\
\[IndentingNewLine]", 
    \(\(\[Eta]pr = \@\(\(I\ \[Omega]\ \[Mu]\)\/\[Rho]pr\);\)\)}], "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Dados de simula\[CCedilla]\[ATilde]o", "Section"],

Cell["Freq\[UDoubleDot]\[EHat]ncias de interesse", "SmallText"],

Cell[BoxData[{
    \(\(n = 4096/4;\)\), "\n", 
    \(\(T = 20. *10^\(-3\);\)\), "\n", 
    \(\(c = \(-Log[0.001]\)/T;\)\), "\n", 
    \(\(dt = N[T/n];\)\), "\[IndentingNewLine]", 
    \(\(dw = 2. \ Pi/\((n*dt)\);\)\)}], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
    \(dt*10^6\)], "Input"],

Cell[BoxData[
    \(19.53125`\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(dw/\((2\ Pi)\)\)], "Input"],

Cell[BoxData[
    \(50.`\)], "Output"]
}, Open  ]],

Cell[BoxData[
    \(\(kk = Range[0, n/2];\)\)], "Input"],

Cell[CellGroupData[{

Cell[BoxData[{
    \(\(sk = \(-I\)\ c + \ dw\ kk;\)\), "\[IndentingNewLine]", 
    \(sigma[j_] = Cos[\[Pi]\ j/\((n)\)]^2\)}], "Input"],

Cell[BoxData[
    \(Cos[\(j\ \[Pi]\)\/1024]\^2\)], "Output"]
}, Open  ]],

Cell[BoxData[
    \( (*\ sigma[j_] = 
        If[j \[Equal] 0, 
          1, \[IndentingNewLine]Sin[\[Pi]*j\ /n]/\((\[Pi]*
                j/n)\)]\ *) \)], "Input"],

Cell[BoxData[
    \(\(sk = \(-I\)\ c + \ dw\ kk;\)\)], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
    \(nf = Length[sk]\)], "Input"],

Cell[BoxData[
    \(513\)], "Output"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Inicializa\[CCedilla]\[ATilde]o das listas ", "Section"],

Cell[BoxData[
    \(\(v1out = Table[0, {n, 1, nf}];\)\)], "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Fun\[CCedilla]\[OTilde]es de Bessel & Carson - Solo Convencional", \
"Section"],

Cell[CellGroupData[{

Cell[BoxData[
    \(AbsoluteTiming[\[IndentingNewLine]Do[{\[Omega] = 
            sk[\([nm]\)], \[IndentingNewLine]Zfull = 
            Table[If[
                i \[NotEqual] 
                  j, \(\(\[ImaginaryI]\ \[Omega]\ \[Mu]\)\/\(2\ \[Pi]\)\) \((\
\ \ Log[\((\[Sqrt]\((\((xc\_\(\(\[LeftDoubleBracket]\)\(i\)\(\
\[RightDoubleBracket]\)\) - xc\_\(\(\[LeftDoubleBracket]\)\(j\)\(\
\[RightDoubleBracket]\)\))\)\^2 + \((yc\_\(\(\[LeftDoubleBracket]\)\(i\)\(\
\[RightDoubleBracket]\)\) + yc\_\(\(\[LeftDoubleBracket]\)\(j\)\(\
\[RightDoubleBracket]\)\) + 2\ p)\)\^2)\))\)/\((\[Sqrt]\((\((xc\_\(\(\
\[LeftDoubleBracket]\)\(i\)\(\[RightDoubleBracket]\)\) - xc\_\(\(\
\[LeftDoubleBracket]\)\(j\)\(\[RightDoubleBracket]\)\))\)\^2 + \((yc\_\(\(\
\[LeftDoubleBracket]\)\(i\)\(\[RightDoubleBracket]\)\) - yc\_\(\(\
\[LeftDoubleBracket]\)\(j\)\(\[RightDoubleBracket]\)\))\)\^2)\))\)])\), 
                If[i \[LessEqual] 
                    ncond - npr, \(\(\[Eta]c\ \[Rho]c\)\/\(2\ \[Pi]\ rf\)\) 
                      BesselI[0, \[Eta]c\ rf]\/BesselI[1, \[Eta]c\ rf] + \(\(\
\[ImaginaryI]\ \[Omega]\ \[Mu]\)\/\(2\ \[Pi]\)\) \((\ 
                        Log[\(2\ \((yc\_\(\(\[LeftDoubleBracket]\)\(i\)\(\
\[RightDoubleBracket]\)\) + \ p)\)\)\/rf])\)\ , \(\(\[Eta]pr\ \[Rho]pr\)\/\(2\
\ \[Pi]\ rpr\)\) 
                      BesselI[0, \[Eta]pr\ rpr]\/BesselI[1, \[Eta]pr\ rpr] + \
\(\(\[ImaginaryI]\ \[Omega]\ \[Mu]\)\/\(2\ \[Pi]\)\) \((Log[\(2 \((\ p + \ yc\
\_\(\(\[LeftDoubleBracket]\)\(i\)\(\[RightDoubleBracket]\)\))\)\)\/rpr])\)\ \
]], {i, 1, ncond}, {j, 1, ncond}], \[IndentingNewLine]Zspr = 
            Inverse[Take[Inverse[Zfull], ncond - npr, ncond - npr]], \  (*\ 
            elimina\ cabo\ pr*) \[IndentingNewLine]aux = 
            Inverse[Zspr], \[IndentingNewLine]aux01 = 
            Table[Sum[
                aux[\([i, j]\)], {i, nfeixe*m\  - \((nfeixe - 1)\), 
                  nfeixe*m}, {j, nfeixe*n\  - \((nfeixe - 1)\), 
                  nfeixe*n}], {m, 1, nfases}, {n, 1, 
                nfases}], \[IndentingNewLine]Z = Inverse[aux01], \  (*\ 
            elimina\ feixe\ *) \[IndentingNewLine]Pinv = 
            Inverse[Table[
                If[i \[NotEqual] j, 
                  Log[\((\[Sqrt]\((\((xc[\([i]\)] - xc[\([j]\)])\)\^2 + \
\((yc[\([i]\)] + yc[\([j]\)])\)\^2)\))\)/\((\[Sqrt]\((\((xc[\([i]\)] - \
xc[\([j]\)])\)\^2 + \((yc[\([i]\)] - yc[\([j]\)])\)\^2)\))\)], \
\[IndentingNewLine]If[i \[LessEqual] ncond - npr, Log[2\ yc[\([i]\)]\/rf], 
                    Log\ [2  yc[\([i]\)]\/rpr]]], {i, 1, ncond}, {j, 1, 
                  ncond}]], \[IndentingNewLine]Pspr = 
            Inverse[Take[Pinv, ncond - npr, ncond - npr]], \ \  (*\ 
            elimina\ cabo\ pr*) \[IndentingNewLine]aux02 = 
            Inverse[Pspr], \[IndentingNewLine]Cfase = 
            Table[Sum[
                aux02[\([i, j]\)]\ , {i, nfeixe*m\  - \((nfeixe - 1)\), 
                  nfeixe*m}, {j, nfeixe*n\  - \((nfeixe - 1)\), 
                  nfeixe*n}], {m, 1, nfases}, {n, 1, 
                nfases}], \[IndentingNewLine] (*\ 
            elimina\ feixe\ *) \[IndentingNewLine]Y = 
            I\ \[Omega]\ 2.0\ \[Pi]\ \[Epsilon]\ Cfase, \
\[IndentingNewLine]{eval, evect} = 
            Eigensystem[N[Z . Y]], \[IndentingNewLine]d = 
            Sqrt[eval], \[IndentingNewLine]Tv = 
            Transpose[evect], \[IndentingNewLine]Tvi = 
            Inverse[Transpose[evect]], \[IndentingNewLine]hm = 
            Exp[\(-d\)*compr], \[IndentingNewLine]Am = 
            d*\((1 + hm^2)\)/\((1 - hm^2)\), \[IndentingNewLine]Bm = \(-2.0\)*
              d*hm/\((1 - hm^2)\), \[IndentingNewLine]A = 
            N[Inverse[Z]] . Tv . DiagonalMatrix[Am] . 
              Tvi, \[IndentingNewLine]B = 
            N[Inverse[Z]] . Tv . DiagonalMatrix[Bm] . 
              Tvi, \[IndentingNewLine]term = 
            DiagonalMatrix[{100. , 100. , 100. , 0. , 0. , 
                0. }], \[IndentingNewLine]Ynodal = 
            term + BlockMatrix[{{A, B}, {B, 
                    A}}], \[IndentingNewLine]v1out[\([nm]\)] = 
            Inverse[Ynodal] . {100.0\ \(I\ \[Omega]\)\/\(142122.30337568672`\
\[InvisibleSpace] + \((I\ \[Omega])\)\^2\), 
                100.0\ \ \ \((\(326.483885562159`\[InvisibleSpace] - \
0.5000000000000001`  I\ \[Omega]\)\/\(\(\(142122.30337568664`\)\(\
\[InvisibleSpace]\)\) + 1.` \((I\ \[Omega])\)\^2\))\), \(-100.0\) \
\((\(\(\(326.483885562159`\)\(\[InvisibleSpace]\)\) + 0.5000000000000001`  I\ \
\[Omega]\)\/\(\(\(142122.30337568664`\)\(\[InvisibleSpace]\)\) + 1.` \((I\ \
\[Omega])\)\^2\))\), 0.0\ , 0.0, 0.0}}, {nm, 1, nf}]]\)], "Input",
  TextJustification->1,
  FontFamily->"Courier New"],

Cell[BoxData[
    \({26.25`8.870674301237948\ Second, Null}\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(Dimensions[v1out]\)], "Input"],

Cell[BoxData[
    \({513, 6}\)], "Output"]
}, Open  ]],

Cell[BoxData[
    \(\(outlow = v1out\ \ Map[\ sigma, \ kk];\)\)], "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Aplicando a Modified Fourier Transform", "Section"],

Cell[CellGroupData[{

Cell[BoxData[{
    \(\(lowerhalf = Delete[outlow, nf];\)\), "\n", 
    \(\(upperhalf = Reverse[Conjugate[outlow]];\)\), "\n", 
    \(\(upperhalf = Delete[upperhalf, nf];\)\), "\n", 
    \(\(F = Join[lowerhalf, upperhalf];\)\), "\n", 
    \(Length[F]\)}], "Input"],

Cell[BoxData[
    \(1024\)], "Output"]
}, Open  ]],

Cell[BoxData[
    \(\(t = dt\ Range[0, n - 1]\ ;\)\)], "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Resultados no Dom\[IAcute]nio do Tempo", "Section"],

Cell[BoxData[{
    \(\(va = 
        Exp[c\ t]/dt\ Chop[\ 
            InverseFourier[F[\([All, 1]\)], 
              FourierParameters \[Rule] {1, \(-1\)}]];\)\), "\
\[IndentingNewLine]", 
    \(\(vb = 
        Exp[c\ t]/dt\ Chop[\ 
            InverseFourier[F[\([All, 2]\)], 
              FourierParameters \[Rule] {1, \(-1\)}]];\)\), "\
\[IndentingNewLine]", 
    \(\(vc = 
        Exp[c\ t]/dt\ Chop[\ 
            InverseFourier[F[\([All, 3]\)], 
              FourierParameters \[Rule] {1, \(-1\)}]];\)\), "\
\[IndentingNewLine]", 
    \(\(va1 = 
        Exp[c\ t]/dt\ Chop[\ 
            InverseFourier[F[\([All, 4]\)], 
              FourierParameters \[Rule] {1, \(-1\)}]];\)\), "\
\[IndentingNewLine]", 
    \(\(vb1 = 
        Exp[c\ t]/dt\ Chop[\ 
            InverseFourier[F[\([All, 5]\)], 
              FourierParameters \[Rule] {1, \(-1\)}]];\)\), "\
\[IndentingNewLine]", 
    \(\(vc1 = 
        Exp[c\ t]/dt\ Chop[\ 
            InverseFourier[F[\([All, 6]\)], 
              FourierParameters \[Rule] {1, \(-1\)}]];\)\)}], "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Ajuste da resposta DC", "Section"],

Cell[BoxData[{
    \(\(va[\([1]\)] = \ va[\([2]\)];\)\), "\[IndentingNewLine]", 
    \(\(vb[\([1]\)] = \ vb[\([2]\)];\)\), "\[IndentingNewLine]", 
    \(\(vc[\([1]\)] = vc[\([2]\)];\)\)}], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
    \(\(DisplayTogether[
        ListPlot[Transpose@{t, va}], \[IndentingNewLine]ListPlot[
          Transpose@{t, vb}], \[IndentingNewLine]ListPlot[
          Transpose@{t, vc}]];\)\)], "Input"],

