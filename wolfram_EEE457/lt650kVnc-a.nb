Cell["Coordenadas dos centros dos Feixes", "Text"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"cx", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"-", "10.5"}], ",", "0", ",", "10.5"}], "}"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"cy", "=", 
   RowBox[{"flexacond", "+", "raio", "+", 
    RowBox[{"{", 
     RowBox[{"12", ",", 
      RowBox[{"12", "+", "\[CapitalDelta]fasecentral"}], ",", "12"}], 
     "}"}]}]}], ";"}]}], "Input"]
}, Open  ]],

