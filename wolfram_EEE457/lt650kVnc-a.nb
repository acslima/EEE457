Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"rpr", "=", 
    RowBox[{"4.57", "*", 
     RowBox[{"10", "^", 
      RowBox[{"-", "3"}]}]}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
