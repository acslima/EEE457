Cell["\<\
Defini\[CCedilla]\[ATilde]o das coordenadas do condutores\
\>", "Section"],

Cell[CellGroupData[{

Cell["Cabos de fase", "Subsection"],

Cell["Dados do condutor", "Text"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"r0", "=", 
    RowBox[{"7.3914", "*", 
     RowBox[{
      RowBox[{"10", "^", 
       RowBox[{"-", "3"}]}], "/", "2"}]}]}], ";", "   ", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"\[DoubleLongRightArrow]", " ", 
      RowBox[{"[", "m", "]"}]}], " ", "\[DoubleLongLeftArrow]"}], " ", "*)"}],
    "\[IndentingNewLine]", 
   RowBox[{"r1", "=", 
    RowBox[{"29.591", "*", 
     RowBox[{
      RowBox[{"10", "^", 
       RowBox[{"-", "3"}]}], "/", "2"}]}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Rdc\[Phi]", "=", 
    RowBox[{"6.114292531162", "*", 
     RowBox[{"10", "^", 
      RowBox[{"-", "5"}]}]}]}], ";", "  ", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"\[DoubleLongRightArrow]", " ", 
       RowBox[{"[", 
        RowBox[{"\[CapitalOmega]", "/", "m"}], "]"}]}], " ", 
      "\[DoubleLongLeftArrow]", "\[DoubleLongRightArrow]", " ", 
      RowBox[{"@", " ", 
       SuperscriptBox["25", "o"]}]}], " ", "\[DoubleLongLeftArrow]"}], "*)"}],
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"\[Rho]\[Phi]", "=", 
    RowBox[{"Rdc\[Phi]", "*", "Pi", "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"r1", "^", "2"}], "-", 
       RowBox[{"r0", "^", "2"}]}], ")"}]}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Sigma]\[Phi]", "=", 
   RowBox[{"1", "/", "\[Rho]\[Phi]"}]}], ";"}]}], "Input"],

Cell["Raio do Feixe", "Text"],

Cell[BoxData[
 RowBox[{
  RowBox[{"raio", "=", "1"}], ";"}]], "Input"],

Cell["N\[UAcute]mero de Subcondutores", "Text"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"nfase", "=", "3"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ns", "=", "7"}], ";"}]}], "Input"],

Cell["Flexa e Desvio da Fase Central", "Text"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"flexacond", "=", "23.67"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalDelta]fasecentral", "=", "2.0"}], ";"}]}], "Input"],

Cell["\<\
 Distrubui\[CCedilla]\[ATilde]o dos subcondutores no FEIXE\
\>", "Text"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[CapitalDelta]x", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"raio", "*", 
      RowBox[{"Sin", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"k", "-", "1"}], ")"}], "*", "2", "*", 
        RowBox[{"Pi", "/", "ns"}]}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"k", ",", "1", ",", "ns"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalDelta]y", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "raio"}], "*", 
      RowBox[{"Cos", "[", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"k", "-", "1"}], ")"}], "*", "2", "*", 
        RowBox[{"Pi", "/", "ns"}]}], "]"}]}], ",", 
     RowBox[{"{", 
