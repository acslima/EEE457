Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"angalfad", "=", 
    RowBox[{"Table", "[", 
     RowBox[{"0", ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", 
        RowBox[{
         RowBox[{"ns", "*", "nfase"}], "+", "2"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"j", ",", "1", ",", 
        RowBox[{
         RowBox[{"ns", "*", "nfase"}], "+", "2"}]}], "}"}]}], "]"}]}], ";"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{"alfa", "=", 
   RowBox[{
    RowBox[{"angalfad", "[", 
     RowBox[{"[", 
      RowBox[{"i", ",", "j"}], "]"}], "]"}], "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"i", "==", "j"}], ",", "0", ",", 
        RowBox[{"ArcTan", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"x", "[", 
            RowBox[{"[", "j", "]"}], "]"}], "-", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"10", "^", 
              RowBox[{"(", 
               RowBox[{"-", "15"}], ")"}]}], "+", 
             RowBox[{"x", "[", 
              RowBox[{"[", "i", "]"}], "]"}]}], ")"}]}], ",", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"y", "[", 
             RowBox[{"[", "j", "]"}], "]"}], "-", 
            RowBox[{"y", "[", 
             RowBox[{"[", "i", "]"}], "]"}]}], ")"}]}], "]"}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", 
        RowBox[{
         RowBox[{"ns", "*", "nfase"}], "+", "2"}]}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"j", ",", "1", ",", 
        RowBox[{
         RowBox[{"ns", "*", "nfase"}], "+", "2"}]}], "}"}]}], "]"}]}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.416733323782296*^9, 3.416733325914549*^9}}],

Cell[BoxData[
 RowBox[{
  RowBox[{"Set", "::", "\<\"pspec\"\>"}], 
