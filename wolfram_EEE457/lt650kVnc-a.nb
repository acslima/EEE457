Cell[CellGroupData[{

Cell["\<\
Tabelas das Coordenadas e representa\[CCedilla]\[ATilde]o gr\[AAcute]fica dos \
condutores ao meio do V\[ATilde]o\
\>", "Subsection"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"xcond", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", 
       RowBox[{"nfase", "*", "ns"}]}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"contx", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{"ksub", "=", "1"}], ",", 
     RowBox[{"ksub", "\[LessEqual]", "ns"}], ",", 
     RowBox[{"ksub", "++"}], ",", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"kfase", "=", "1"}], ",", 
       RowBox[{"kfase", "<=", "nfase"}], ",", 
       RowBox[{"kfase", "++"}], ",", 
       RowBox[{
        RowBox[{
         RowBox[{"xcond", "[", 
          RowBox[{"[", "contx", "]"}], "]"}], "=", 
         RowBox[{
          RowBox[{"cx", "[", 
           RowBox[{"[", "kfase", "]"}], "]"}], "+", 
          RowBox[{"\[CapitalDelta]x", "[", 
           RowBox[{"[", "ksub", "]"}], "]"}]}]}], ";", 
        RowBox[{"contx", "=", 
         RowBox[{"contx", "+", "1"}]}]}]}], "]"}]}], "]"}], ";", 
   RowBox[{"Clear", "[", 
    RowBox[{"contx", ",", "ksub"}], "]"}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ycond", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", 
       RowBox[{"nfase", "*", "ns"}]}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"conty", "=", "1"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"For", "[", 
   RowBox[{
    RowBox[{"ksub", "=", "1"}], ",", 
    RowBox[{"ksub", "\[LessEqual]", "ns"}], ",", 
    RowBox[{"ksub", "++"}], ",", 
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"kfase", "=", "1"}], ",", 
      RowBox[{"kfase", "<=", "nfase"}], ",", 
      RowBox[{"kfase", "++"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"ycond", "[", 
         RowBox[{"[", "conty", "]"}], "]"}], "=", 
        RowBox[{
         RowBox[{"cy", "[", 
          RowBox[{"[", "kfase", "]"}], "]"}], "+", 
         RowBox[{"\[CapitalDelta]y", "[", 
          RowBox[{"[", "ksub", "]"}], "]"}]}]}], ";", 
       RowBox[{"conty", "=", 
        RowBox[{"conty", "+", "1"}]}]}]}], "]"}]}], "]"}], ";", 
  RowBox[{"Clear", "[", 
   RowBox[{"conty", ",", "ksub"}], "]"}], ";"}]}], "Input"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"x", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"i", "\[LessEqual]", "nfase"}], ",", 
       RowBox[{"xcond", "[", 
        RowBox[{"[", "i", "]"}], "]"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"i", "\[LessEqual]", 
          RowBox[{"nfase", "+", "1"}]}], ",", 
         RowBox[{"-", "xpr"}], ",", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"i", "\[LessEqual]", 
            RowBox[{"nfase", "+", "2"}]}], ",", "xpr", ",", 
           RowBox[{"xcond", "[", 
            RowBox[{"[", 
             RowBox[{"i", "-", "2"}], "]"}], "]"}]}], "]"}]}], "]"}]}], "]"}],
      ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", 
       RowBox[{
        RowBox[{"ns", "*", "nfase"}], "+", "2"}]}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"y", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"i", "\[LessEqual]", "nfase"}], ",", 
       RowBox[{
        RowBox[{"ycond", "[", 
         RowBox[{"[", "i", "]"}], "]"}], "-", 
        RowBox[{
         RowBox[{"2", "/", "3"}], "*", "flexacond"}]}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"i", "\[LessEqual]", 
          RowBox[{"nfase", "+", "2"}]}], ",", 
         RowBox[{"ypr", "-", 
          RowBox[{
           RowBox[{"2", "/", "3"}], "*", "flexapr"}]}], ",", 
         RowBox[{
          RowBox[{"ycond", "[", 
           RowBox[{"[", 
            RowBox[{"i", "-", "2"}], "]"}], "]"}], "-", 
          RowBox[{
           RowBox[{"2", "/", "3"}], "*", "flexacond"}]}]}], "]"}]}], "]"}], 
     ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", 
       RowBox[{
        RowBox[{"ns", "*", "nfase"}], "+", "2"}]}], "}"}]}], "]"}]}], 
  ";"}]}], "Input"],

Cell[BoxData[
 RowBox[{
  RowBox[{"xy2", "=", 
   RowBox[{"Thread", "[", 
    RowBox[{"{", 
     RowBox[{"x", ",", "y"}], "}"}], "]"}]}], ";"}]], "Input",
