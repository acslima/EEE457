}, Open  ]],

Cell[BoxData[{
 RowBox[{
  RowBox[{"alfah", "=", 
   RowBox[{"Table", "[", 
    RowBox[{"0", ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", 
       RowBox[{
        RowBox[{"ns", "*", "nfase"}], "+", "2"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"j", ",", "1", ",", 
       RowBox[{
        RowBox[{"ns", "*", "nfase"}], "+", "2"}]}], "}"}]}], "]"}]}], 
