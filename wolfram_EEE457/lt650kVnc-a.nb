 RowBox[{
  RowBox[{"alfa2", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"i", "==", "j"}], ",", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"-", "1"}], ")"}], "*", 
        RowBox[{"N", "[", 
         RowBox[{"Pi", "/", "2"}], "]"}]}], ",", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"-", "1"}], ")"}], "*", 
        RowBox[{"ArcTan", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"x", "[", 
            RowBox[{"[", "j", "]"}], "]"}], "-", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"10", "^", 
              RowBox[{"(", 
               RowBox[{"-", "15"}], ")"}]}], "+", 
             RowBox[{"x", "[", 
              RowBox[{"[", "i", "]"}], "]"}]}], ")"}]}], ",", 
          RowBox[{"(", 
           RowBox[{"2", "*", 
            RowBox[{"y", "[", 
             RowBox[{"[", "j", "]"}], "]"}]}], ")"}]}], "]"}]}]}], "]"}], ",",
      
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", 
       RowBox[{
        RowBox[{"ns", "*", "nfase"}], "+", "2"}]}], "}"}], ",", 
     RowBox[{"{", 
