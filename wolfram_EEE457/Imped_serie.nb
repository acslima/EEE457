Notebook[{
Cell["Imped\[AHat]ncia S\[EAcute]rie de Linhas de Transmiss\[ATilde]o", \
"Title"],

Cell["Prof. Antonio Carlos Siqueira de Lima", "Subtitle"],

Cell[CellGroupData[{

Cell["Op\[CCedilla]\[OTilde]es de programa", "Subsection"],

Cell[BoxData[{
    \(<< LinearAlgebra`MatrixManipulation`\), "\[IndentingNewLine]", 
    \(<< Graphics`Graphics`\)}], "Input"],

Cell[BoxData[
    \(\(Off[General::"\<spell\>", General::"\<spell1\>"];\)\)], "Input"],

Cell[BoxData[{
    \(\(SetOptions[{ListPlot, \ LogLinearListPlot, LogLogListPlot}, 
        Axes \[Rule] False, Frame \[Rule] True, PlotJoined \[Rule] True, 
        ImageSize \[Rule] 450, DefaultFont \[Rule] {"\<Helvetica\>", 14}, 
        PlotStyle \[Rule] {AbsoluteThickness[2]}];\)\), "\n", 
    \(\(SetOptions[{Plot, \ LogLinearPlot, LogLogPlot}, Axes \[Rule] False, 
        Frame \[Rule] True, ImageSize \[Rule] 450, 
        DefaultFont \[Rule] {"\<Helvetica\>", 14}, 
        PlotStyle \[Rule] {AbsoluteThickness[2]}];\)\)}], "Input"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Imped\[AHat]ncia Interna", "Section"],

Cell["\<\
A imped\[AHat]ncia interna da linha de transmiss\[ATilde]o \
apresenta o comportamento variante com a freq\[UDoubleDot]\[EHat]ncia devido \
ao efeito pelicular. \
\>", "Text"],

Cell[CellGroupData[{

Cell["Condutores s\[OAcute]lidos", "Subsection"],

Cell[BoxData[
    \(\(\(\ \)\(\(r1 = \(2.5951\/2\) 10\^\(-2\);\)\(\[IndentingNewLine]\)
    \(\ \)\(r0 = \((1\/2\  - 0.3565)\) 
          2.5951\ 10\^\(-2\);\)\(\[IndentingNewLine]\)
    \(\ \)\(r1pr = \(1.10490\/2\) 10\^\(-2\);\)\(\[IndentingNewLine]\)
    \(\ \)\)\)\)], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
    \(\[Rho]0c = 
      0.03206*\((10^\((\(-3\))\))\)\ *\ \[Pi]*\ \((r1\^2 - 
            r0\^2)\)\)], "Input"],

Cell[BoxData[
    \(1.5560719406069573`*^-8\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[{
    \(\(T = 75;\)\), "\n", 
    \(\(\[Kappa] =  .750223;\)\), "\n", 
    \(\(\[Alpha] = 0.00454562;\)\), "\n", 
    \(\[Rho]c = \[Rho]0c\ \(1 + \[Alpha]\ T\)\/\[Kappa]\)}], "Input"],

Cell[BoxData[
    \(2.781266797614299`*^-8\)], "Output"]
}, Open  ]],

Cell["Par\[AHat]metros dos cabos p\[AAcute]ra-raios por metro", "SmallText"],

Cell[CellGroupData[{

Cell[BoxData[{
    \(\(\[Rho]0pr = \ \[Pi]\ \ *2.8645*\ \((10^\(-3\))\)*
          r1pr\^2;\)\), "\[IndentingNewLine]", 
    \(\(Tpr = 25;\)\), "\[IndentingNewLine]", 
    \(\(\[Kappa]pr = 0.778767;\)\), "\[IndentingNewLine]", 
    \(\[Rho]pr = \(\(\[Rho]0pr\)\(\ \ \)\(\(1 + \[Alpha]\ Tpr\)\/\[Kappa]pr\)\
\(\ \)\)\)}], "Input"],

Cell[BoxData[
    \(3.927553698940929`*^-7\)], "Output"]
}, Open  ]],

Cell[BoxData[
    \(TraditionalForm\`z1in(\[Omega]_, \[Mu]_ : \(4\ \[Pi]\)\/10\^7) := \
\(\(\@\(\(\[ImaginaryI]\ \[Omega]\ \[Mu]\)\/\[Rho]c\)\ \[Rho]c\)\/\(2\ \[Pi]\ \
r1\)\) \(\(I\_0\)(\@\(\(\[ImaginaryI]\ \[Omega]\ \[Mu]\)\/\[Rho]c\)\ \
r1)\)\/\(\(\ \)\(\(I\_1\)(\@\(\(\[ImaginaryI]\ \[Omega]\ \[Mu]\)\/\[Rho]c\)\ \
r1)\)\)\)], "Input"],

Cell[BoxData[
    \(TraditionalForm\`z2in(\[Omega]_, \[Mu]_ : \(4\ \[Pi]\)\/10\^7) := \
\(\(\(\@\(\(\[ImaginaryI]\ \[Omega]\ \[Mu]\)\/\[Rho]c\)\)\(\ \)\(\[Rho]c\)\(\ \
\)\)\/\(2\ \[Pi]\ r1\)\) \((\(\(I\_0\)(\@\(\(\[ImaginaryI]\ \[Omega]\ \[Mu]\)\
\/\[Rho]c\)\ r1)\)\ \(\(K\_1\)(\@\(\(\[ImaginaryI]\ \[Omega]\ \
\[Mu]\)\/\[Rho]c\)\ r0)\) + \(\(I\_1\)(\@\(\(\[ImaginaryI]\ \[Omega]\ \[Mu]\)\
\/\[Rho]c\)\ r0)\)\ \(\(K\_1\)(\@\(\(\[ImaginaryI]\ \[Omega]\ \
\[Mu]\)\/\[Rho]c\)\ r1)\))\)\/\(\(\ \)\((\(\(I\_1\)(\@\(\(\[ImaginaryI]\ \
\[Omega]\ \[Mu]\)\/\[Rho]c\)\ r1)\)\ \(\(K\_1\)(\@\(\(\[ImaginaryI]\ \[Omega]\
\ \[Mu]\)\/\[Rho]c\)\ r0)\) - \(\(I\_1\)(\@\(\(\[ImaginaryI]\ \[Omega]\ \[Mu]\
\)\/\[Rho]c\)\ r0)\)\ \(\(K\_1\)(\@\(\(\[ImaginaryI]\ \[Omega]\ \[Mu]\)\/\
\[Rho]c\)\ r1)\))\)\)\)], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
    \(\(Plot[{Re[z1in[2  \[Pi]\ f]], Re[z2in[2\ \[Pi]\ f]]}, {f, \ 1, \ 
          1000}, PlotStyle \[Rule] {{Hue[0], Dashing[{ .03}]}, Hue[ .25]}, 
        FrameLabel \[Rule] {"\<Freq\[UDoubleDot]\[EHat]ncia [Hz]\>", \ \
"\<Imped\[AHat]ncia unit\[AAcute]ria [\[CapitalOmega]/m]\>"}, 
        PlotRange \[Rule] All];\)\)], "Input"],

Cell[GraphicsData["PostScript", "\<\
