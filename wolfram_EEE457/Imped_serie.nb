Cell[CellGroupData[{

Cell["Imped\[AHat]ncia Externa", "Section"],

Cell["\<\
Para o caso da imped\[AHat]ncia externa considera-se apenas um \
condutor monof\[AAcute]sico situado a10m de altura do solo e com alura \
constante. \
\>", "Text"],

Cell[BoxData[
    \(TraditionalForm\`Ze(\[Omega]_, \[Rho]s_:\ 100.0, \[Mu]_ : \(4\ \
\[Pi]\)\/10\^7) := \(\(\(\[ImaginaryI]\)\(\ \)\(\[Omega]\)\(\ \)\(\[Mu]\)\(\ \
\)\)\/\(2\ \[Pi]\)\) \(log(\(2\ \((\@\(\[Rho]s\/\(\[ImaginaryI]\ \[Omega]\ \
\[Mu]\)\) + 10)\)\)\/r1)\)\)], "Input"],

Cell[BoxData[
    \(TraditionalForm\`Zsolo(
        f_, \[Rho]s_ : 
          100.0, \[Mu]_ : \(4\ \[Pi]\)\/10\^7) := \(9.869\ f\)\/10\^7 + \
\[ImaginaryI]\ \ f\ \[Mu]\ \(log(\(658.4\ \@\(\[Rho]s\/f\)\)\/r1)\) + \
\[ImaginaryI]\ \ f\ \[Mu]\ \(log(20.0\/r1)\)\)], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
    \(\(LogLogPlot[{Re[Ze[2  \[Pi]\ f]], Im[Ze[2  \[Pi]\ f]]}, {f, \ 1, \ 
          10^6}, PlotStyle \[Rule] {{Hue[0], Dashing[{ .03}]}, Hue[ .25]}, 
        PlotRange \[Rule] All, PlotPoints \[Rule] 500];\)\)], "Input"],

Cell[GraphicsData["PostScript", "\<\
