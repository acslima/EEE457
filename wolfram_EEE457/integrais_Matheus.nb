     RowBox[{"{", 
      RowBox[{
      "\"\<h\>\"", ",", " ", 
       "\"\<\[Theta](h) \!\(\*SuperscriptBox[\(10\), \(10\)]\) \>\""}], 
      "}"}]}]}], "]"}]}]], "Input",
