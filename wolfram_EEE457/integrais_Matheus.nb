Cell[BoxData[
 RowBox[{
  RowBox[{"u", "[", "h_", "]"}], ":=", 
  RowBox[{"NIntegrate", "[", 
   RowBox[{
    RowBox[{"1", "/", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Sin", "[", "h", "]"}], "^", "2"}], ")"}], 
          RowBox[{
           RowBox[{"Sin", "[", "x", "]"}], "^", "2"}]}]}], ")"}], 
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"2", "*", "9.81", "*", 
            RowBox[{"100000", "/", 
             RowBox[{"300000000", "^", "2"}]}]}], ")"}], 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Sin", "[", "h", "]"}], "^", "2"}], ")"}], 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Cos", "[", "x", "]"}], "^", "2"}], ")"}]}], "-", 
         RowBox[{
          RowBox[{"2", "/", "3"}], 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"2", "*", "9.81", "*", 
              RowBox[{"100000", "/", 
               RowBox[{"300000000", "^", "2"}]}]}], ")"}], "^", "2"}], ")"}], 
          
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Sin", "[", "h", "]"}], "^", "4"}], ")"}], 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Cos", "[", "x", "]"}], "^", "4"}], ")"}]}], "-", 
         RowBox[{
          RowBox[{"1", "/", "3"}], 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"2", "*", "9.81", "*", 
              RowBox[{"100000", "/", 
               RowBox[{"300000000", "^", "2"}]}]}], ")"}], "^", "3"}], ")"}], 
          
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Sin", "[", "h", "]"}], "^", "6"}], ")"}], 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"Cos", "[", "x", "]"}], "^", "6"}], ")"}]}]}], ")"}]}], 
      "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0", ",", 
      RowBox[{"\[Pi]", "/", "2"}]}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.893360199997649*^9, 3.893360263230551*^9}},
 CellLabel->"In[15]:=",ExpressionUUID->"219cda15-1cf9-4547-9ccc-8a39d5add35b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"v", "[", "h_", "]"}], ":=", 
  RowBox[{"NIntegrate", "[", 
   RowBox[{
    RowBox[{"1", "/", 
     RowBox[{"Sqrt", "[", 
      RowBox[{"1", "-", 
       RowBox[{
        RowBox[{
         RowBox[{"Sin", "[", "h", "]"}], "^", "2"}], 
        RowBox[{
         RowBox[{"Sin", "[", "x", "]"}], "^", "2"}]}]}], "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0", ",", 
      RowBox[{"\[Pi]", "/", "2"}]}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.893360285845109*^9, 3.893360313159457*^9}},
 CellLabel->"In[16]:=",ExpressionUUID->"392139d8-a66f-43de-b4b0-34300243fdfc"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"obj", "=", 
  RowBox[{"Plot", "[", 
   RowBox[{
    RowBox[{"4", " ", 
     RowBox[{"10", "^", "10"}], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"u", "[", "h", "]"}], "-", 
       RowBox[{"v", "[", "h", "]"}]}], ")"}]}], ",", 
    RowBox[{"{", 
